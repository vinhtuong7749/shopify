{%- comment -%}
	Mega Menu Collection
	- SHOP: Gender + Clothing + product cards
	- COLLECTION: Featured + Independence Day + Hunting + Fishing
{%- endcomment -%}

<div
	id="headerDesktopMenu:{{- first_level_link.title | handleize -}}-{{- first_level_index -}}"
	class="header-mega-desktop js-header-dropdown-menu"
>
	{%- if is_shop_menu -%}
		{%- assign shop_men_url = '/collections/all' -%}
		{%- assign shop_tshirt_url = '/collections/all?filter.p.product_type=Type1&filter.p.product_type=3D+Tshirt&filter.p.product_type=T-Shirt' -%}
		{%- assign shop_longsleeve_url = '/collections/all?filter.p.product_type=Long-sleeve' -%}
		{%- assign shop_hat_url = '/collections/all?filter.p.product_type=Hat' -%}
		<div class="header-mega-desktop__inner mega-shop">
			<div class="mega-block mega-block--gender">
				<ul class="mega-block__list mega-gender-list">
					<li>
						<a href="{{ shop_men_url }}" class="mega-block__link mega-gender-link">
							For Men
						</a>
					</li>
					<li>
						{%- assign shop_womens_col = collections['independence-day-womens'] -%}
						{%- if shop_womens_col == blank -%}
							{%- assign shop_womens_col = collections['independence-day-women-s'] -%}
						{%- endif -%}
						{%- assign shop_womens_url = '/collections/independence-day-womens' -%}
						{%- if shop_womens_col != blank -%}
							{%- assign shop_womens_url = shop_womens_col.url -%}
						{%- endif -%}
						<a href="{{ shop_womens_url }}" class="mega-block__link mega-gender-link">
							For Women
						</a>
					</li>
				</ul>

				{%- assign shop_gender_product_logic = section.settings.shop_mega_product_logic | default: 'manual_fallback' -%}
				{%- assign shop_gender_show_products = true -%}
				{%- if section.settings.shop_mega_show_products == false -%}
					{%- assign shop_gender_show_products = false -%}
				{%- endif -%}

				{%- assign shop_men_product = blank -%}
				{%- assign shop_women_product = blank -%}

				{%- if shop_gender_product_logic != 'auto' -%}
					{%- assign shop_men_product = section.settings.shop_mega_for_men_product -%}
					{%- if shop_men_product == blank -%}
						{%- assign shop_men_product = section.settings.shop_mega_men_product -%}
					{%- endif -%}
					{%- assign shop_women_product = section.settings.shop_mega_for_women_product -%}
					{%- if shop_women_product == blank -%}
						{%- assign shop_women_product = section.settings.shop_mega_women_product -%}
					{%- endif -%}
				{%- endif -%}

				{%- assign shop_gender_should_auto_fill = false -%}
				{%- if shop_gender_product_logic == 'auto' -%}
					{%- assign shop_gender_should_auto_fill = true -%}
				{%- elsif shop_gender_product_logic == 'manual_fallback' -%}
					{%- if shop_men_product == blank or shop_women_product == blank -%}
						{%- assign shop_gender_should_auto_fill = true -%}
					{%- endif -%}
				{%- endif -%}

				{%- if shop_gender_should_auto_fill -%}
					{%- if shop_men_product == blank -%}
						{%- for product in collections['all'].products -%}
							{%- assign shop_men_product = product -%}
							{%- break -%}
						{%- endfor -%}
					{%- endif -%}

					{%- if shop_women_product == blank and shop_womens_col != blank -%}
						{%- for product in shop_womens_col.products -%}
							{%- assign shop_women_product = product -%}
							{%- break -%}
						{%- endfor -%}
					{%- endif -%}
				{%- endif -%}

				{%- assign shop_has_gender_products = false -%}
				{%- if shop_men_product != blank or shop_women_product != blank -%}
					{%- assign shop_has_gender_products = true -%}
				{%- endif -%}

				{%- if shop_gender_show_products and shop_has_gender_products -%}
					<div class="mega-shop-products mega-gender-products">
						{%- if shop_men_product != blank -%}
							<div class="mega-shop-product product-card">
								<a href="{{ shop_men_product.url }}" class="mega-shop-product__image-link" aria-label="{{ shop_men_product.title | escape }}">
									<span class="mega-shop-product__media">
										{%- if shop_men_product.featured_image != blank -%}
											<img src="{{ shop_men_product.featured_image | image_url: width: 800 }}" alt="{{ shop_men_product.featured_image.alt | default: shop_men_product.title | escape }}" class="mega-shop-product__image" width="800" height="1000" loading="lazy">
										{%- endif -%}
									</span>
								</a>
								<div class="mega-shop-product__footer">
									<a href="{{ shop_men_product.url }}" class="mega-shop-product__title">{{ shop_men_product.title | escape }}</a>
									<a href="{{ shop_men_url }}" class="mega-shop-product__meta mega-shop-product__meta-link" aria-label="View all For Men">
										<span>For Men</span>
										<span class="mega-shop-product__view-all">View All <span aria-hidden="true">→</span></span>
									</a>
								</div>
							</div>
						{%- endif -%}

						{%- if shop_women_product != blank -%}
							<div class="mega-shop-product product-card">
								<a href="{{ shop_women_product.url }}" class="mega-shop-product__image-link" aria-label="{{ shop_women_product.title | escape }}">
									<span class="mega-shop-product__media">
										{%- if shop_women_product.featured_image != blank -%}
											<img src="{{ shop_women_product.featured_image | image_url: width: 800 }}" alt="{{ shop_women_product.featured_image.alt | default: shop_women_product.title | escape }}" class="mega-shop-product__image" width="800" height="1000" loading="lazy">
										{%- endif -%}
									</span>
								</a>
								<div class="mega-shop-product__footer">
									<a href="{{ shop_women_product.url }}" class="mega-shop-product__title">{{ shop_women_product.title | escape }}</a>
									<a href="{{ shop_womens_url }}" class="mega-shop-product__meta mega-shop-product__meta-link" aria-label="View all For Women">
										<span>For Women</span>
										<span class="mega-shop-product__view-all">View All <span aria-hidden="true">→</span></span>
									</a>
								</div>
							</div>
						{%- endif -%}
					</div>
				{%- endif -%}
			</div>

			<div class="mega-block mega-block--clothing">
				<ul class="mega-block__list mega-shop-clothing-nav">
					<li><a href="{{ shop_tshirt_url }}" class="mega-block__link">T-Shirts</a></li>
					<li><a href="{{ shop_longsleeve_url }}" class="mega-block__link">Long-Sleeve</a></li>
					<li><a href="{{ shop_hat_url }}" class="mega-block__link">Hats</a></li>
				</ul>

				{%- assign shop_product_logic = section.settings.shop_mega_product_logic | default: 'manual_fallback' -%}
				{%- assign shop_show_products = true -%}
				{%- if section.settings.shop_mega_show_products == false -%}
					{%- assign shop_show_products = false -%}
				{%- endif -%}

				{%- assign shop_tshirt_product = blank -%}
				{%- assign shop_longsleeve_product = blank -%}
				{%- assign shop_hat_product = blank -%}

				{%- if shop_product_logic != 'auto' -%}
					{%- assign shop_hat_product = section.settings.shop_mega_hat_product -%}
					{%- assign shop_tshirt_product = section.settings.shop_mega_tshirt_product -%}
					{%- assign shop_longsleeve_product = section.settings.shop_mega_longsleeve_product -%}
				{%- endif -%}

				{%- assign shop_should_auto_fill = false -%}
				{%- if shop_product_logic == 'auto' -%}
					{%- assign shop_should_auto_fill = true -%}
				{%- elsif shop_product_logic == 'manual_fallback' -%}
					{%- if shop_tshirt_product == blank or shop_longsleeve_product == blank or shop_hat_product == blank -%}
						{%- assign shop_should_auto_fill = true -%}
					{%- endif -%}
				{%- endif -%}

				{%- if shop_should_auto_fill -%}
					{%- for product in collections['all'].products -%}
						{%- assign shop_product_type = product.type | downcase | strip -%}
						{%- if shop_hat_product == blank -%}
							{%- if shop_product_type == 'hat' or shop_product_type contains 'hat' -%}
								{%- assign shop_hat_product = product -%}
							{%- endif -%}
						{%- endif -%}
						{%- if shop_tshirt_product == blank -%}
							{%- if shop_product_type == 'type1' or shop_product_type contains 't-shirt' or shop_product_type contains 'tshirt' -%}
								{%- assign shop_tshirt_product = product -%}
							{%- endif -%}
						{%- endif -%}
						{%- if shop_longsleeve_product == blank -%}
							{%- if shop_product_type contains 'long' and shop_product_type contains 'sleeve' -%}
								{%- assign shop_longsleeve_product = product -%}
							{%- endif -%}
						{%- endif -%}
						{%- if shop_tshirt_product != blank and shop_longsleeve_product != blank and shop_hat_product != blank -%}
							{%- break -%}
						{%- endif -%}
					{%- endfor -%}
				{%- endif -%}

				{%- assign shop_has_products = false -%}
				{%- if shop_tshirt_product != blank or shop_longsleeve_product != blank or shop_hat_product != blank -%}
					{%- assign shop_has_products = true -%}
				{%- endif -%}

				{%- if shop_show_products and shop_has_products -%}
					<div class="mega-shop-products">
						{%- if shop_tshirt_product != blank -%}
							<div class="mega-shop-product product-card">
								<a href="{{ shop_tshirt_product.url }}" class="mega-shop-product__image-link" aria-label="{{ shop_tshirt_product.title | escape }}">
									<span class="mega-shop-product__media">
										{%- if shop_tshirt_product.featured_image != blank -%}
											<img src="{{ shop_tshirt_product.featured_image | image_url: width: 800 }}" alt="{{ shop_tshirt_product.featured_image.alt | default: shop_tshirt_product.title | escape }}" class="mega-shop-product__image" width="800" height="1000" loading="lazy">
										{%- endif -%}
									</span>
								</a>
								<div class="mega-shop-product__footer">
									<a href="{{ shop_tshirt_product.url }}" class="mega-shop-product__title">{{ shop_tshirt_product.title | escape }}</a>
									<a href="{{ shop_tshirt_url }}" class="mega-shop-product__meta mega-shop-product__meta-link" aria-label="View all T-Shirts">
										<span>T-Shirt</span>
										<span class="mega-shop-product__view-all">View All <span aria-hidden="true">→</span></span>
									</a>
								</div>
							</div>
						{%- endif -%}

						{%- if shop_longsleeve_product != blank -%}
							<div class="mega-shop-product product-card">
								<a href="{{ shop_longsleeve_product.url }}" class="mega-shop-product__image-link" aria-label="{{ shop_longsleeve_product.title | escape }}">
									<span class="mega-shop-product__media">
										{%- if shop_longsleeve_product.featured_image != blank -%}
											<img src="{{ shop_longsleeve_product.featured_image | image_url: width: 800 }}" alt="{{ shop_longsleeve_product.featured_image.alt | default: shop_longsleeve_product.title | escape }}" class="mega-shop-product__image" width="800" height="1000" loading="lazy">
										{%- endif -%}
									</span>
								</a>
								<div class="mega-shop-product__footer">
									<a href="{{ shop_longsleeve_product.url }}" class="mega-shop-product__title">{{ shop_longsleeve_product.title | escape }}</a>
									<a href="{{ shop_longsleeve_url }}" class="mega-shop-product__meta mega-shop-product__meta-link" aria-label="View all Long-Sleeve">
										<span>Long-Sleeve</span>
										<span class="mega-shop-product__view-all">View All <span aria-hidden="true">→</span></span>
									</a>
								</div>
							</div>
						{%- endif -%}

						{%- if shop_hat_product != blank -%}
							<div class="mega-shop-product product-card">
								<a href="{{ shop_hat_product.url }}" class="mega-shop-product__image-link" aria-label="{{ shop_hat_product.title | escape }}">
									<span class="mega-shop-product__media">
										{%- if shop_hat_product.featured_image != blank -%}
											<img src="{{ shop_hat_product.featured_image | image_url: width: 800 }}" alt="{{ shop_hat_product.featured_image.alt | default: shop_hat_product.title | escape }}" class="mega-shop-product__image" width="800" height="1000" loading="lazy">
										{%- endif -%}
									</span>
								</a>
								<div class="mega-shop-product__footer">
									<a href="{{ shop_hat_product.url }}" class="mega-shop-product__title">{{ shop_hat_product.title | escape }}</a>
									<a href="{{ shop_hat_url }}" class="mega-shop-product__meta mega-shop-product__meta-link" aria-label="View all Hats">
										<span>Hat</span>
										<span class="mega-shop-product__view-all">View All <span aria-hidden="true">→</span></span>
									</a>
								</div>
							</div>
						{%- endif -%}
					</div>
				{%- endif -%}
			</div>
		</div>
	{%- else -%}
		<div class="header-mega-desktop__inner mega-4block">
			<div class="mega-block mega-block--featured">
				<h3 class="mega-block__heading">Featured</h3>
				<ul class="mega-block__list mega-featured-list">
					{%- assign new_col = collections['new-arrivals'] -%}
					{%- assign new_url = '/collections/new-arrivals' -%}
					{%- if new_col != blank -%}
						{%- assign new_url = new_col.url -%}
					{%- endif -%}

					{%- assign nation_park_col = collections['nation-park'] -%}
					{%- if nation_park_col == blank -%}
						{%- assign nation_park_col = collections['national-park'] -%}
					{%- endif -%}
					{%- assign nation_park_url = '/collections/nation-park' -%}
					{%- if nation_park_col != blank -%}
						{%- assign nation_park_url = nation_park_col.url -%}
					{%- endif -%}

					{%- assign world_turkey_slam_col = collections['world-turkey-slam'] -%}
					{%- assign world_turkey_slam_url = '/collections/world-turkey-slam' -%}
					{%- if world_turkey_slam_col != blank -%}
						{%- assign world_turkey_slam_url = world_turkey_slam_col.url -%}
					{%- endif -%}

					{%- assign grand_slam_col = collections['grand-slam-subspecies'] -%}
					{%- assign grand_slam_url = '/collections/grand-slam-subspecies' -%}
					{%- if grand_slam_col != blank -%}
						{%- assign grand_slam_url = grand_slam_col.url -%}
					{%- endif -%}

					<li><a href="{{ nation_park_url }}" class="mega-block__link">National Park</a></li>
					<li><a href="{{ world_turkey_slam_url }}" class="mega-block__link">World Turkey Slam</a></li>
					<li><a href="{{ grand_slam_url }}" class="mega-block__link">Grand Slam Subspecies</a></li>
					<li><a href="{{ new_url }}" class="mega-block__link">New Arrivals</a></li>
					<li><a href="/collections/turkey" class="mega-block__link">Turkey</a></li>
				</ul>
			</div>

			<div class="mega-block mega-block--hunting">
				<h3 class="mega-block__heading">Hunting</h3>
				<div class="mega-hunting-list">
					{%- assign hunting_handles = "turkey,deer,waterfowl" | split: "," -%}
					{%- assign hunting_labels = "Turkey,Deer,Waterfowl" | split: "," -%}
					{%- for handle in hunting_handles -%}
						{%- assign h_col = collections[handle] -%}
						{%- assign h_label = hunting_labels[forloop.index0] -%}
						{%- assign h_has_products = false -%}
						{%- if h_col != blank and h_col.products_count > 0 -%}
							{%- assign h_has_products = true -%}
						{%- endif -%}
						<a href="{%- if h_col != blank -%}{{ h_col.url }}{%- else -%}/collections/{{ handle }}{%- endif -%}" class="mega-hunting-item{% unless h_has_products %} mega-hunting-item--disabled{% endunless %}"{% unless h_has_products %} tabindex="-1"{% endunless %}>
							<span class="mega-hunting-icon-wrap">
								{%- if h_col.image != blank -%}
									<img src="{{ h_col.image | image_url: width: 120, height: 120, crop: 'center' }}" alt="{{ h_label }}" class="mega-hunting-icon mega-hunting-icon--{{ handle | handleize }}" width="120" height="120" loading="lazy">
								{%- else -%}
									<span class="mega-hunting-placeholder">{{ h_label | slice: 0 }}</span>
								{%- endif -%}
							</span>
							<span class="mega-hunting-label">{{ h_label | upcase }}{%- unless h_has_products -%}<em class="mega-block__coming-soon"> - Coming Soon</em>{%- endunless -%}</span>
						</a>
					{%- endfor -%}
				</div>
			</div>

			<div class="mega-block mega-block--independence">
				<h3 class="mega-block__heading">Independence Day</h3>
				<div class="mega-terrain-list mega-independence-list">
					{%- assign dog_250_col = collections['dog-250'] -%}
					{%- assign dog_250_url = '/collections/dog-250' -%}
					{%- assign dog_250_title = 'Dog 250' -%}
					{%- if dog_250_col != blank -%}
						{%- assign dog_250_url = dog_250_col.url -%}
						{%- assign dog_250_title = dog_250_col.title -%}
					{%- endif -%}

					{%- assign deer_250_col = collections['deer-250'] -%}
					{%- assign deer_250_url = '/collections/deer-250' -%}
					{%- assign deer_250_title = 'Deer 250' -%}
					{%- if deer_250_col != blank -%}
						{%- assign deer_250_url = deer_250_col.url -%}
						{%- assign deer_250_title = deer_250_col.title -%}
					{%- endif -%}

					{%- assign eagle_250_col = collections['eagle-250'] -%}
					{%- assign eagle_250_url = '/collections/eagle-250' -%}
					{%- assign eagle_250_title = 'Eagle 250' -%}
					{%- if eagle_250_col != blank -%}
						{%- assign eagle_250_url = eagle_250_col.url -%}
						{%- assign eagle_250_title = eagle_250_col.title -%}
					{%- endif -%}

					{%- assign liberty_250_col = collections['liberty-250'] -%}
					{%- assign liberty_250_url = '/collections/liberty-250' -%}
					{%- assign liberty_250_title = 'Liberty 250' -%}
					{%- if liberty_250_col != blank -%}
						{%- assign liberty_250_url = liberty_250_col.url -%}
						{%- assign liberty_250_title = liberty_250_col.title -%}
					{%- endif -%}

					{%- assign womens_col = collections['independence-day-womens'] -%}
					{%- if womens_col == blank -%}
						{%- assign womens_col = collections['independence-day-women-s'] -%}
					{%- endif -%}
					{%- assign womens_url = '/collections/independence-day-womens' -%}
					{%- assign womens_title = "Women's" -%}
					{%- if womens_col != blank -%}
						{%- assign womens_url = womens_col.url -%}
						{%- assign womens_title = womens_col.title -%}
					{%- endif -%}

					<a href="{{ dog_250_url }}" class="mega-block__link">{{ dog_250_title | escape }}</a>
					<a href="{{ deer_250_url }}" class="mega-block__link">{{ deer_250_title | escape }}</a>
					<a href="{{ eagle_250_url }}" class="mega-block__link">{{ eagle_250_title | escape }}</a>
					<a href="{{ liberty_250_url }}" class="mega-block__link">{{ liberty_250_title | escape }}</a>
					<a href="{{ womens_url }}" class="mega-block__link">{{ womens_title | escape }}</a>
				</div>
			</div>

			<div class="mega-block mega-block--fishing">
				<h3 class="mega-block__heading">Fishing</h3>
				<div class="mega-hunting-list mega-fishing-list">
					{%- assign fishing_handles = "fishing-t-shirt,saltwater-fishing-t-shirt" | split: "," -%}
					{%- assign fishing_labels = "Freshwater Fishing T-shirt,Saltwater Fishing T-shirt" | split: "," -%}
					{%- assign fishing_icon_fallbacks = "https://cdn.shopify.com/s/files/1/0741/7987/0911/collections/icon_bass.jpg?v=1780569828,https://cdn.shopify.com/s/files/1/0741/7987/0911/collections/icon_swordfish.jpg?v=1780569816" | split: "," -%}
					{%- for handle in fishing_handles -%}
						{%- assign f_col = collections[handle] -%}
						{%- assign f_label = fishing_labels[forloop.index0] -%}
						{%- assign f_fallback_icon = fishing_icon_fallbacks[forloop.index0] -%}
						<a href="{%- if f_col != blank -%}{{ f_col.url }}{%- else -%}/collections/{{ handle }}{%- endif -%}" class="mega-hunting-item mega-fishing-item">
							<span class="mega-hunting-icon-wrap">
								{%- if f_col.image != blank -%}
									<img src="{{ f_col.image | image_url: width: 120, height: 120, crop: 'center' }}" alt="{{ f_label }}" class="mega-hunting-icon mega-hunting-icon--{{ handle | handleize }}" width="120" height="120" loading="lazy">
								{%- elsif f_fallback_icon != blank -%}
									<img src="{{ f_fallback_icon }}" alt="{{ f_label }}" class="mega-hunting-icon mega-hunting-icon--{{ handle | handleize }}" width="120" height="120" loading="lazy">
								{%- else -%}
									<span class="mega-hunting-placeholder">{{ f_label | slice: 0 }}</span>
								{%- endif -%}
							</span>
							<span class="mega-hunting-label">{{ f_label | upcase }}</span>
						</a>
					{%- endfor -%}
				</div>
			</div>
		</div>
	{%- endif -%}
</div>

<style>
.header-menu__item-wrapper:has(.header-mega-desktop) {
	position: static !important;
}

.header-menu__list-nested-wrapper:has(.header-mega-desktop) {
	position: static !important;
}

.header-mega-desktop {
	position: fixed;
	top: var(--header-offset-bottom, var(--header-height-static, 86px));
	left: 0;
	width: 100vw;
	background: #fff;
	box-shadow: 0 15px 40px rgba(0, 0, 0, 0.10);
	padding: 36px 40px;
	opacity: 0;
	visibility: hidden;
	z-index: 100;
	transform: translateY(-8px);
	transition: top 0.18s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.35s cubic-bezier(0.4, 0, 0.2, 1), visibility 0.35s cubic-bezier(0.4, 0, 0.2, 1), transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
	will-change: top, opacity, transform;
	pointer-events: none;
}

.header-mega-desktop.is-active {
	opacity: 1;
	visibility: visible;
	transform: translateY(0);
	pointer-events: auto;
}

.mega-shop {
	display: grid !important;
	grid-template-columns: minmax(0, 444px) minmax(0, 676px);
	gap: 40px;
	max-width: 1230px;
	margin: 0 auto;
	align-items: start;
