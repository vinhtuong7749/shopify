			{%- render 'product-accordion',
				title: size_guide_button_text,
				content: sg_content,
				accordion_id: sg_id,
				open: false
			-%}
		{%- endif -%}
	</div>

	{%- if product_details_content != blank -%}
		{%- capture description_overlay_html -%}
			{%- comment -%} DESCRIPTION OVERLAY MOVED TO BOTTOM TO PREVENT HTML INJECTION BREAKAGE {%- endcomment -%}
			<div id="description-overlay" class="size-chart-overlay">
				<div class="size-chart-overlay__backdrop" onclick="document.getElementById('description-overlay').classList.remove('is-active'); document.body.style.overflow='';"></div>
				<div class="size-chart-overlay__panel">
					<div class="size-chart-overlay__header">
						<h2 class="size-chart-overlay__title">PRODUCT DETAILS</h2>
						<button class="size-chart-overlay__close" type="button" onclick="document.getElementById('description-overlay').classList.remove('is-active'); document.body.style.overflow='';" aria-label="Close">
							<svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
								<line x1="2" y1="2" x2="18" y2="18" stroke="currentColor" stroke-width="2"/>
								<line x1="18" y1="2" x2="2" y2="18" stroke="currentColor" stroke-width="2"/>
							</svg>
						</button>
					</div>
					<div class="size-chart-overlay__content" style="display:block;">
						<div class="product-desc-overlay__body rte">
							{{ desc_content }}
						</div>
					</div>
				</div>
			</div>

			<script>
				document.addEventListener('keydown', function(e) {
					if (e.key === 'Escape') {
						var overlay = document.getElementById('description-overlay');
						if (overlay && overlay.classList.contains('is-active')) {
							overlay.classList.remove('is-active');
							document.body.style.overflow = '';
						}
					}
				});
			</script>
		{%- endcapture -%}
		{{- description_overlay_html -}}
	{%- endif -%}

	<script>
		/* Product Accordion Toggle Logic */
		(function() {
			document.addEventListener('DOMContentLoaded', function() {
				initProductAccordions();
			});

			/* Re-init on Shopify section events */
			document.addEventListener('shopify:section:load', function() {
				initProductAccordions();
			});

			function initProductAccordions() {
				var containers = document.querySelectorAll('[data-product-accordion]');
				containers.forEach(function(container) {
					var triggers = container.querySelectorAll('[data-accordion-trigger]');
					triggers.forEach(function(trigger) {
						/* Remove old listeners by cloning */
						var newTrigger = trigger.cloneNode(true);
						trigger.parentNode.replaceChild(newTrigger, trigger);

						newTrigger.addEventListener('click', function() {
							var expanded = this.getAttribute('aria-expanded') === 'true';
							var contentId = this.getAttribute('aria-controls');
							var content = document.getElementById(contentId);

							if (expanded) {
								/* Close */
								this.setAttribute('aria-expanded', 'false');
								content.classList.remove('is-open');
								content.setAttribute('hidden', '');
							} else {
								/* Open */
								this.setAttribute('aria-expanded', 'true');
								content.classList.add('is-open');
								content.removeAttribute('hidden');
							}
						});
					});
				});
			}
		})();
	</script>
{%- endif -%}
