		<script>
			function switchSizeTab(btn, tab) {
				/* Deactivate all tabs & hide all content */
				var allTabs = btn.parentElement.querySelectorAll('.size-chart-overlay__tab');
				allTabs.forEach(function(t) { t.classList.remove('is-active'); });
				btn.classList.add('is-active');

				var overlay = document.getElementById('size-chart-overlay');
				var allContent = overlay.querySelectorAll('.size-chart-overlay__content');
				allContent.forEach(function(c) { c.style.display = 'none'; });

				document.getElementById('size-tab-' + tab).style.display = 'block';
			}

			function switchSizeUnit(btn, unit) {
				var content = btn.closest('.size-chart-overlay__content');
				if (!content) return;

				var allUnitTabs = content.querySelectorAll('.size-chart-overlay__unit-tab');
				allUnitTabs.forEach(function(tab) { tab.classList.remove('is-active'); });
				btn.classList.add('is-active');

				var panels = content.querySelectorAll('.size-chart-overlay__unit-panel');
				panels.forEach(function(panel) {
					panel.classList.toggle('is-active', panel.getAttribute('data-unit-panel') === unit);
				});
			}

			(function() {
				var overlayIds = ['size-chart-overlay', 'care-instructions-overlay', 'shipping-overlay', 'description-overlay'];
				var bodyClass = 'is-product-info-overlay-open';

				function getInfoOverlays() {
					return overlayIds.map(function(overlayId) {
						return document.getElementById(overlayId);
					}).filter(Boolean);
				}

				function syncInfoOverlayState() {
					var isOpen = getInfoOverlays().some(function(overlay) {
						return overlay.classList.contains('is-active');
					});

					document.body.classList.toggle(bodyClass, isOpen);
				}

				function queueInfoOverlaySync() {
					window.setTimeout(function() {
						initInfoOverlays();
						syncInfoOverlayState();
					}, 0);
				}

				function closeInfoOverlay(overlay) {
					if (!overlay) return;

					overlay.classList.remove('is-active');
					document.body.style.overflow = '';
					syncInfoOverlayState();
				}

				function initInfoOverlays() {
					getInfoOverlays().forEach(function(overlay) {
						if (overlay.parentNode !== document.body) {
							document.body.appendChild(overlay);
						}

						if (overlay.dataset.productInfoOverlayObserved === 'true') {
							return;
						}

						overlay.dataset.productInfoOverlayObserved = 'true';
						new MutationObserver(syncInfoOverlayState).observe(overlay, {
							attributes: true,
							attributeFilter: ['class']
						});
					});

					syncInfoOverlayState();
				}

				window.CamoProductInfoOverlays = {
					init: initInfoOverlays,
					sync: syncInfoOverlayState,
					close: function(overlayId) {
						closeInfoOverlay(document.getElementById(overlayId));
					}
				};

				/* Close on ESC key */
				document.addEventListener('keydown', function(e) {
					if (e.key === 'Escape') {
						getInfoOverlays().forEach(function(overlay) {
							if (overlay.classList.contains('is-active')) {
								overlay.classList.remove('is-active');
								document.body.style.overflow = '';
							}
						});
						syncInfoOverlayState();
					}
				});

				document.addEventListener('click', function(event) {
					var target = event.target;
					if (!target || !target.closest) return;

					var closeControl = target.closest('.size-chart-overlay__close, .size-chart-overlay__close-btn');
					var backdrop = target.classList && target.classList.contains('size-chart-overlay__backdrop') ? target : null;

					if (closeControl || backdrop) {
						var overlay = target.closest('.size-chart-overlay') || (backdrop && backdrop.closest('.size-chart-overlay'));
						event.preventDefault();
						event.stopPropagation();
						closeInfoOverlay(overlay);
						return;
					}

					if (target.closest('.size-chart-overlay') || target.closest('[onclick*="overlay"]')) {
						queueInfoOverlaySync();
					}
				}, true);

				if (document.readyState === 'loading') {
					document.addEventListener('DOMContentLoaded', initInfoOverlays);
				} else {
					initInfoOverlays();
				}

				document.addEventListener('shopify:section:load', initInfoOverlays);
			})();
		</script>

