{%- comment -%}
------------------------------------------------------------------------------
  Snippet: Product Drawers → Now renders as Inline Accordions
  Accordion items expand/collapse in-place (no side drawer)
------------------------------------------------------------------------------
{%- endcomment -%}

{%- comment -%}
	Description variables
{%- endcomment -%}
{%- assign description_show         = block.settings.show_description -%}
{%- assign description_toggle_text  = block.settings.description_toggle_text -%}
{%- assign description_drawer_title = block.settings.description_drawer_title -%}
{%- assign show_description         = false -%}

{%- if description_show and description_toggle_text != blank and product.description != blank and description_drawer_title != blank -%}
	{%- assign show_description = true -%}
{%- endif -%}

{%- comment -%}
	Drawer 1 variables
{%- endcomment -%}
{%- assign drawer_page_1 		= block.settings.drawer_page_1 -%}
{%- assign drawer_toggle_text_1 	= block.settings.drawer_toggle_text_1 -%}
{%- assign drawer_title_1 		= block.settings.drawer_title_1 | default: drawer_page_1.title -%}
{%- assign show_drawer_1 		= false -%}

{%- if drawer_page_1 != blank and drawer_page_1.content != blank and drawer_toggle_text_1 != blank -%}
	{%- assign show_drawer_1 = true -%}
{%- endif -%}

{%- comment -%}
	Drawer 2 variables
{%- endcomment -%}
{%- assign drawer_page_2 		= block.settings.drawer_page_2 -%}
{%- assign drawer_toggle_text_2 	= block.settings.drawer_toggle_text_2 -%}
{%- assign drawer_title_2 		= block.settings.drawer_title_2 | default: drawer_page_2.title -%}
{%- assign show_drawer_2 		= false -%}

{%- if drawer_page_2 != blank and drawer_page_2.content != blank and drawer_toggle_text_2 != blank -%}
	{%- assign show_drawer_2 = true -%}
{%- endif -%}

{%- comment -%}
	Drawer 3 variables
{%- endcomment -%}
{%- assign drawer_page_3 	   = block.settings.drawer_page_3 -%}
{%- assign drawer_toggle_text_3 = block.settings.drawer_toggle_text_3 -%}
{%- assign drawer_title_3 	   = block.settings.drawer_title_3 | default: drawer_page_3.title -%}
{%- assign show_drawer_3 	   = false -%}

{%- if drawer_page_3 != blank and drawer_page_3.content != blank and drawer_toggle_text_3 != blank -%}
	{%- assign show_drawer_3 = true -%}
{%- endif -%}

{%- comment -%}
	Size guide variables
{%- endcomment -%}
{%- assign show_size_guide 				  = false -%}
{%- assign size_guide_page 				  = section.settings.size_guide_page -%}
{%- assign size_guide_button_placement 		  = section.settings.size_guide_button_placement -%}
{%- assign size_guide_button_text_translation = "products.drawers.size_guide" | t -%}
{%- assign size_guide_button_text			  = section.settings.size_guide_button_text | default: size_guide_button_text_translation -%}

{%- if section.settings.show_size_guide
	and size_guide_page != blank
	and size_guide_page.content != blank
	and size_guide_button_placement == 'drawer'
-%}
	{%- assign show_size_guide = true -%}
{%- endif -%}

{%- assign has_any_accordion = false -%}
{%- if show_description or show_drawer_1 or show_drawer_2 or show_drawer_3 or show_size_guide -%}
	{%- assign has_any_accordion = true -%}
{%- endif -%}

{%- comment -%} Always show Description accordion using product.description even if drawer description is off {%- endcomment -%}
{%- if has_any_accordion or product.description != blank -%}
	{%- capture styles -%}
		--offset-top-desktop: {{ block.settings.offset_top_desktop }}px; {{-  -}}
		--offset-bottom-desktop: {{ block.settings.offset_bottom_desktop }}px; {{-  -}}
		--offset-top-mobile: {{ block.settings.offset_top_mobile }}px; {{-  -}}
		--offset-bottom-mobile: {{ block.settings.offset_bottom_mobile }}px;
	{%- endcapture -%}

	<style>
		/* ============================================
		   Product Accordion Styles
		   ============================================ */
		.product-accordion {
			padding-top: var(--offset-top-mobile);
			padding-bottom: var(--offset-bottom-mobile);
			width: 100%;
		}
		@media (min-width: 1200px) {
			.product-accordion {
				padding-top: var(--offset-top-desktop);
				padding-bottom: var(--offset-bottom-desktop);
			}
		}
		.product-accordion__item {
			border-top: 1px solid var(--color-border-thirdly, #e5e5e5);
		}
		.product-accordion__item:last-child {
			border-bottom: 1px solid var(--color-border-thirdly, #e5e5e5);
		}
		.product-accordion__trigger {
			display: flex;
			align-items: center;
			justify-content: space-between;
			width: 100%;
			padding: 16px 0;
			background: none;
			border: none;
			cursor: pointer;
			color: var(--color-text-primary, #000);
			font-size: calc(var(--body-font-size, 14px) * 0.875);
			font-weight: 600;
			letter-spacing: 0.08em;
			text-transform: uppercase;
			text-align: left;
			line-height: 1.4;
			transition: opacity var(--timing-short, 0.2s);
			font-family: 'Oswald', sans-serif !important;
		}
		.product-accordion__trigger:hover {
			opacity: 0.7;
		}
		.product-accordion__trigger:focus-visible {
			outline: 2px solid var(--color-text-primary, #000);
			outline-offset: 2px;
		}
		.product-accordion__trigger-icon {
			display: flex;
			align-items: center;
			justify-content: center;
			width: 24px;
			height: 24px;
			flex-shrink: 0;
			transition: transform var(--timing-base, 0.4s) ease;
		}
		.product-accordion__trigger[aria-expanded="true"] .product-accordion__icon-vertical {
			opacity: 0;
			transition: opacity var(--timing-short, 0.2s);
		}
		.product-accordion__trigger[aria-expanded="false"] .product-accordion__icon-vertical,
		.product-accordion__trigger:not([aria-expanded]) .product-accordion__icon-vertical {
			opacity: 1;
			transition: opacity var(--timing-short, 0.2s);
		}
		.product-accordion__content {
			overflow: hidden;
			max-height: 0;
			opacity: 0;
			transition: max-height var(--timing-base, 0.4s) ease, opacity var(--timing-short, 0.2s) ease, padding var(--timing-short, 0.2s) ease;
			padding: 0;
		}
		.product-accordion__content.is-open {
			max-height: 2000px;
			opacity: 1;
			padding-bottom: 20px;
		}
		.product-accordion__content[hidden] {
			display: block !important;
			max-height: 0;
			opacity: 0;
			padding: 0;
			overflow: hidden;
		}
		.product-accordion__content-inner {
			font-size: calc(var(--body-font-size, 14px) * 0.875);
			line-height: 1.7;
			color: var(--color-text-secondary, #666);
			font-family: 'Oswald', sans-serif !important;
		}
		.product-accordion__content-inner p {
			margin-bottom: 10px;
		}
		.product-accordion__content-inner p:last-child {
			margin-bottom: 0;
		}
		.product-accordion__table-wrapper {
			width: 100%;
			overflow-x: auto;
			-webkit-overflow-scrolling: touch;
			margin: 16px auto;
		}
		.product-accordion__table {
			width: 100% !important;
			max-width: 600px !important;
			margin: 0 auto !important;
			border-collapse: collapse;
			text-align: center;
			font-size: 14px;
		}
		.product-accordion__table th,
		.product-accordion__table td {
			padding: 14px 16px;
			border: 1px solid var(--color-border-thirdly, #e5e5e5);
			white-space: nowrap !important;
			text-align: center !important;
			color: var(--color-text-primary, #203224) !important;
		}
		.product-accordion__table th {
			background-color: var(--color-text-primary, #203224) !important;
			color: #faf6ee !important;
			font-weight: 600 !important;
			text-transform: uppercase !important;
		}
		.product-accordion__content-inner img {
			max-width: 100%;
			height: auto;
		}

		/* Mobile optimizations */
		@media (max-width: 767.98px) {
			.product-accordion__trigger {
				padding: 14px 0;
				font-size: calc(var(--body-font-size, 14px) * 0.85);
			}
			.product-accordion__content-inner {
				font-size: calc(var(--body-font-size, 14px) * 0.9);
			}
			.product-accordion__table th,
			.product-accordion__table td {
				padding: 12px 10px;
				font-size: 14px; /* Fix "too small text" */
			}
		}
	</style>

	<div class="product-accordion" style="{{ styles }}" data-product-accordion>
		{%- comment -%} DESCRIPTION - Full Page Overlay Trigger {%- endcomment -%}
		{%- if product.description != blank -%}
			{%- assign desc_content = product.description | replace: '<img', '<img loading="lazy"' -%}

			{%- comment -%} Remove product title from description {%- endcomment -%}
			{%- assign title_strong = '<strong>' | append: product.title | append: '</strong>' -%}
			{%- assign title_b = '<b>' | append: product.title | append: '</b>' -%}
			{%- assign title_em = '<em>' | append: product.title | append: '</em>' -%}
			{%- assign desc_content = desc_content | replace: title_strong, '' -%}
			{%- assign desc_content = desc_content | replace: title_b, '' -%}
			{%- assign desc_content = desc_content | replace: title_em, '' -%}
			{%- assign desc_content = desc_content | replace: product.title, '' -%}

			{%- comment -%} Remove the first meaningful paragraph (already shown as short description) {%- endcomment -%}
			{%- if desc_content contains '</p>' -%}
				{%- assign desc_paragraphs = desc_content | split: '</p>' -%}
				{%- assign first_real_para_index = -1 -%}
				{%- for para in desc_paragraphs -%}
					{%- assign para_check = para | strip_html | strip -%}
					{%- assign para_check_size = para_check | size -%}
					{%- if first_real_para_index == -1 and para_check_size > 10 -%}
						{%- assign first_real_para_index = forloop.index0 -%}
					{%- endif -%}
				{%- endfor -%}

				{%- capture desc_without_intro -%}
					{%- for para in desc_paragraphs -%}
						{%- if forloop.index0 != first_real_para_index -%}
							{%- assign para_text = para | strip_html | strip -%}
							{%- assign para_text_size = para_text | size -%}
							{%- if para_text_size > 0 -%}
								{{ para | append: '</p>' }}
							{%- endif -%}
						{%- endif -%}
					{%- endfor -%}
				{%- endcapture -%}
				{%- assign desc_content = desc_without_intro | strip -%}
			{%- endif -%}

			{%- comment -%} Clean up empty tags {%- endcomment -%}
			{%- assign desc_content = desc_content | replace: '<p></p>', '' | replace: '<p> </p>', '' | strip -%}

			<div class="product-accordion__item">
				<button
					class="product-accordion__trigger"
					type="button"
					aria-expanded="false"
					onclick="document.getElementById('description-overlay').classList.add('is-active'); document.body.style.overflow='hidden';"
				>
					<span>DESCRIPTION</span>
					<span class="product-accordion__trigger-icon">
						<svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
							<line x1="0" y1="6" x2="12" y2="6" stroke="currentColor" stroke-width="1.5"/>
							<line class="product-accordion__icon-vertical" x1="6" y1="0" x2="6" y2="12" stroke="currentColor" stroke-width="1.5"/>
						</svg>
					</span>
				</button>
			</div>

			{%- comment -%} DESCRIPTION OVERLAY {%- endcomment -%}
			<div id="description-overlay" class="size-chart-overlay">
				<div class="size-chart-overlay__backdrop" onclick="document.getElementById('description-overlay').classList.remove('is-active'); document.body.style.overflow='';"></div>
				<div class="size-chart-overlay__panel">
					<div class="size-chart-overlay__header">
						<h2 class="size-chart-overlay__title">DESCRIPTION</h2>
						<button class="size-chart-overlay__close" type="button" onclick="document.getElementById('description-overlay').classList.remove('is-active'); document.body.style.overflow='';" aria-label="Close">
							<svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
								<line x1="2" y1="2" x2="18" y2="18" stroke="currentColor" stroke-width="2"/>
								<line x1="18" y1="2" x2="2" y2="18" stroke="currentColor" stroke-width="2"/>
							</svg>
						</button>
					</div>
					<div class="size-chart-overlay__content" style="display:block;">
						<div class="product-desc-overlay__body rte">
							{{ desc_content }}
						</div>
					</div>
				</div>
			</div>

			<script>
				document.addEventListener('keydown', function(e) {
					if (e.key === 'Escape') {
						var overlay = document.getElementById('description-overlay');
						if (overlay && overlay.classList.contains('is-active')) {
							overlay.classList.remove('is-active');
							document.body.style.overflow = '';
						}
					}
				});
			</script>
		{%- endif -%}

		{%- comment -%} SIZE GUIDE - Full Page Overlay Trigger {%- endcomment -%}
		<div class="product-accordion__item">
			<button
				class="product-accordion__trigger"
				type="button"
				aria-expanded="false"
				onclick="document.getElementById('size-chart-overlay').classList.add('is-active'); document.body.style.overflow='hidden';"
			>
				<span>SIZE GUIDE</span>
				<span class="product-accordion__trigger-icon">
					<svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
						<line x1="0" y1="6" x2="12" y2="6" stroke="currentColor" stroke-width="1.5"/>
						<line class="product-accordion__icon-vertical" x1="6" y1="0" x2="6" y2="12" stroke="currentColor" stroke-width="1.5"/>
					</svg>
				</span>
			</button>
		</div>

		{%- comment -%} SIZE CHART OVERLAY {%- endcomment -%}
		<div id="size-chart-overlay" class="size-chart-overlay">
			<div class="size-chart-overlay__backdrop" onclick="document.getElementById('size-chart-overlay').classList.remove('is-active'); document.body.style.overflow='';"></div>
				<button
					class="size-chart-overlay__close-btn"
					type="button"
					onclick="document.getElementById('size-chart-overlay').classList.remove('is-active'); document.body.style.overflow='';"
					aria-label="Close"
				>&#10005;</button>
			<div class="size-chart-overlay__panel">
				{%- comment -%} Tabs {%- endcomment -%}
				<div class="size-chart-overlay__tabs">
					<button class="size-chart-overlay__tab is-active" data-tab="tshirt" type="button" onclick="switchSizeTab(this, 'tshirt')">T-Shirt</button>
					<button class="size-chart-overlay__tab" data-tab="hoodie" type="button" onclick="switchSizeTab(this, 'hoodie')">Hoodie & Sweatshirt</button>
					<button class="size-chart-overlay__tab" data-tab="longsleeve" type="button" onclick="switchSizeTab(this, 'longsleeve')">Long Sleeve</button>
				</div>

				{%- comment -%} T-Shirt Size Chart {%- endcomment -%}
				<div class="size-chart-overlay__content" id="size-tab-tshirt">
					<h3 class="size-chart-overlay__subtitle">T-Shirt Size Chart</h3>
					<p class="size-chart-overlay__note">All measurements are in <strong>inches</strong>. Sizes may vary slightly (±0.5") due to the manufacturing process.</p>
					<div class="size-chart-overlay__table-wrap">
						<table class="size-chart-overlay__table">
							<thead>
								<tr>
									<th>Size</th>
									<th>Chest (in)</th>
									<th>Length (in)</th>
									<th>Sleeve (in)</th>
								</tr>
							</thead>
							<tbody>
								<tr><td>S</td><td>18</td><td>28</td><td>15.125</td></tr>
								<tr><td>M</td><td>20</td><td>29</td><td>16.5</td></tr>
								<tr><td>L</td><td>22</td><td>30</td><td>18</td></tr>
								<tr><td>XL</td><td>24</td><td>31</td><td>19.5</td></tr>
								<tr><td>2XL</td><td>26</td><td>32</td><td>21</td></tr>
								<tr><td>3XL</td><td>28</td><td>33</td><td>22.375</td></tr>
								<tr><td>4XL</td><td>30</td><td>34</td><td>23.675</td></tr>
								<tr><td>5XL</td><td>32</td><td>35</td><td>25</td></tr>
							</tbody>
						</table>
					</div>

					<div class="size-chart-overlay__table-wrap" style="margin-top: 24px;">
						<p class="size-chart-overlay__note">Measurements in <strong>centimeters (cm)</strong>.</p>
						<table class="size-chart-overlay__table">
							<thead>
								<tr>
									<th>Size</th>
									<th>Chest (cm)</th>
									<th>Length (cm)</th>
									<th>Sleeve (cm)</th>
								</tr>
							</thead>
							<tbody>
								<tr><td>S</td><td>45.7</td><td>71.1</td><td>38.4</td></tr>
								<tr><td>M</td><td>50.8</td><td>73.7</td><td>41.9</td></tr>
								<tr><td>L</td><td>55.9</td><td>76.2</td><td>45.7</td></tr>
								<tr><td>XL</td><td>61.0</td><td>78.7</td><td>49.5</td></tr>
								<tr><td>2XL</td><td>66.0</td><td>81.3</td><td>53.3</td></tr>
								<tr><td>3XL</td><td>71.1</td><td>83.8</td><td>56.8</td></tr>
								<tr><td>4XL</td><td>76.2</td><td>86.4</td><td>60.1</td></tr>
								<tr><td>5XL</td><td>81.3</td><td>88.9</td><td>63.5</td></tr>
							</tbody>
						</table>
					</div>
				</div>

				{%- comment -%} Hoodie & Sweatshirt Size Chart {%- endcomment -%}
				<div class="size-chart-overlay__content" id="size-tab-hoodie" style="display:none;">
					<h3 class="size-chart-overlay__subtitle">Sweatshirt & Hoodie Size Chart</h3>
					<p class="size-chart-overlay__note">All measurements are in <strong>inches</strong>. Sizes may vary slightly (±0.5") due to the manufacturing process.</p>
					<div class="size-chart-overlay__table-wrap">
						<table class="size-chart-overlay__table">
							<thead>
								<tr>
									<th>Size</th>
									<th>Chest (in)</th>
									<th>Length (in)</th>
									<th>Sleeve (in)</th>
								</tr>
							</thead>
							<tbody>
								<tr><td>S</td><td>20</td><td>27</td><td>33.5</td></tr>
								<tr><td>M</td><td>22</td><td>28</td><td>34.5</td></tr>
								<tr><td>L</td><td>24</td><td>29</td><td>35.5</td></tr>
								<tr><td>XL</td><td>26</td><td>30</td><td>36.5</td></tr>
								<tr><td>2XL</td><td>28</td><td>31</td><td>37.5</td></tr>
								<tr><td>3XL</td><td>30</td><td>32</td><td>38.5</td></tr>
								<tr><td>4XL</td><td>32</td><td>33</td><td>39.5</td></tr>
								<tr><td>5XL</td><td>34</td><td>34</td><td>40.5</td></tr>
							</tbody>
						</table>
					</div>

					<div class="size-chart-overlay__table-wrap" style="margin-top: 24px;">
						<p class="size-chart-overlay__note">Measurements in <strong>centimeters (cm)</strong>.</p>
						<table class="size-chart-overlay__table">
							<thead>
								<tr>
									<th>Size</th>
									<th>Chest (cm)</th>
									<th>Length (cm)</th>
									<th>Sleeve (cm)</th>
								</tr>
							</thead>
							<tbody>
								<tr><td>S</td><td>50.8</td><td>68.6</td><td>85.1</td></tr>
								<tr><td>M</td><td>55.9</td><td>71.1</td><td>87.6</td></tr>
								<tr><td>L</td><td>61.0</td><td>73.7</td><td>90.2</td></tr>
								<tr><td>XL</td><td>66.0</td><td>76.2</td><td>92.7</td></tr>
								<tr><td>2XL</td><td>71.1</td><td>78.7</td><td>95.3</td></tr>
								<tr><td>3XL</td><td>76.2</td><td>81.3</td><td>97.8</td></tr>
								<tr><td>4XL</td><td>81.3</td><td>83.8</td><td>100.3</td></tr>
								<tr><td>5XL</td><td>86.4</td><td>86.4</td><td>102.9</td></tr>
							</tbody>
						</table>
					</div>
				</div>

				{%- comment -%} Long Sleeve Size Chart {%- endcomment -%}
				<div class="size-chart-overlay__content" id="size-tab-longsleeve" style="display:none;">
					<h3 class="size-chart-overlay__subtitle">Long Sleeve Size Chart</h3>
					<p class="size-chart-overlay__note">All measurements are in <strong>inches</strong>. Sizes may vary slightly (±0.5") due to the manufacturing process.</p>
					<div class="size-chart-overlay__table-wrap">
						<table class="size-chart-overlay__table">
							<thead>
								<tr>
									<th>Size</th>
									<th>Length (in)</th>
									<th>Sleeve (in)</th>
									<th>Shoulder (in)</th>
									<th>Chest (in)</th>
								</tr>
							</thead>
							<tbody>
								<tr><td>XS</td><td>27 1/2</td><td>33</td><td>14 3/4</td><td>34</td></tr>
								<tr><td>S</td><td>28</td><td>34</td><td>16</td><td>37</td></tr>
								<tr><td>M</td><td>28 3/4</td><td>35</td><td>17 1/4</td><td>40</td></tr>
								<tr><td>L</td><td>29 1/2</td><td>36</td><td>18 1/2</td><td>43</td></tr>
								<tr><td>XL</td><td>30 1/4</td><td>37</td><td>19 3/4</td><td>46</td></tr>
