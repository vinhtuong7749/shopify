		<style>
			/* ============================================
			   Size Chart Overlay Styles
			   ============================================ */
			.size-chart-overlay {
				position: fixed;
				top: 0;
				left: 0;
				width: 100%;
				height: 100%;
				z-index: 999998;
				display: flex;
				align-items: center;
				justify-content: center;
				pointer-events: none;
				opacity: 0;
				transition: opacity 0.3s ease;
			}
			.size-chart-overlay.is-active {
				pointer-events: auto;
				opacity: 1;
			}
			.size-chart-overlay__backdrop {
				position: absolute;
				top: 0;
				left: 0;
				width: 100%;
				height: 100%;
				background: rgba(0, 0, 0, 0.6);
				backdrop-filter: blur(4px);
				-webkit-backdrop-filter: blur(4px);
			}
			.size-chart-overlay__panel {
				position: relative;
				z-index: 1;
				background: #ffffff;
				width: 94%;
				max-width: 560px;
				max-height: calc(100vh - 80px);
				overflow-y: auto;
				border-radius: 0;
				padding: 32px 28px;
				transform: translateY(20px);
				transition: transform 0.3s ease;
				margin-top: 70px;
				margin-bottom: 10px;
			}
			.size-chart-overlay.is-active .size-chart-overlay__panel {
				transform: translateY(0);
			}
			.size-chart-overlay__header {
				display: flex;
				align-items: center;
				justify-content: space-between;
				margin-bottom: 24px;
				padding-bottom: 16px;
				border-bottom: 2px solid var(--color-text-primary, #203224);
			}
			/* X button cho size chart overlay — fixed để luôn hiện dù scroll */
			.size-chart-overlay__close-btn {
				position: fixed;
				top: 70px;
				right: 16px;
				background: rgba(255,255,255,0.9) !important;
				border: none !important;
				border-radius: 50%;
				padding: 0 !important;
				margin: 0 !important;
				min-width: 0 !important;
				min-height: 0 !important;
				width: 36px !important;
				height: 36px !important;
				font-size: 18px;
				line-height: 1;
				color: #203224 !important;
				cursor: pointer;
				display: none;
				align-items: center;
				justify-content: center;
				z-index: 999999;
				box-shadow: 0 2px 8px rgba(0,0,0,0.15);
				transition: opacity 0.2s;
			}
			.size-chart-overlay.is-active .size-chart-overlay__close-btn {
				display: flex !important;
			}
			.size-chart-overlay__close-btn::before,
			.size-chart-overlay__close-btn::after { display: none !important; }
			.size-chart-overlay__close-btn:hover { opacity: 0.8; }
			/* Giữ lại style cũ cho description/shipping overlay vẫn dùng __close */
			.size-chart-overlay__close {
				background: none !important;
				border: none !important;
				cursor: pointer;
				padding: 8px !important;
				color: #203224 !important;
				display: flex !important;
				align-items: center;
				justify-content: center;
				min-width: 0 !important;
				min-height: 0 !important;
				width: 36px !important;
				height: 36px !important;
				opacity: 1 !important;
			}
			.size-chart-overlay__close::before,
			.size-chart-overlay__close::after { display: none !important; }
			.size-chart-overlay__close svg line { stroke: #203224 !important; }
			.size-chart-overlay__close:hover { opacity: 0.6; }

			/* Tabs */
			.size-chart-overlay__tabs {
				display: flex;
				gap: 0;
				margin-bottom: 24px;
				border-bottom: 2px solid #e5e5e5;
			}
			.size-chart-overlay__tab {
				flex: 1;
				background: none;
				border: none;
				padding: 12px 16px;
				font-family: 'Oswald', sans-serif;
				font-size: 14px;
				font-weight: 600;
				letter-spacing: 0.06em;
				text-transform: uppercase;
				color: var(--color-text-secondary, #888);
				cursor: pointer;
				position: relative;
				transition: color 0.2s;
			}
			.size-chart-overlay__tab::after {
				content: '';
				position: absolute;
				bottom: -2px;
				left: 0;
				width: 100%;
				height: 2px;
				background: transparent;
				transition: background 0.2s;
			}
			.size-chart-overlay__tab.is-active {
				color: var(--color-text-primary, #203224);
			}
			.size-chart-overlay__tab.is-active::after {
				background: var(--color-text-primary, #203224);
			}
			.size-chart-overlay__tab:hover { color: var(--color-text-primary, #203224); }

			/* Content */
			.size-chart-overlay__subtitle {
				font-family: 'Oswald', sans-serif;
				font-size: 18px;
				font-weight: 600;
				letter-spacing: 0.05em;
				color: var(--color-text-primary, #203224);
				margin: 0 0 8px;
			}
			.size-chart-overlay__note {
				font-size: 13px;
				color: var(--color-text-secondary, #666);
				margin: 0 0 16px;
				line-height: 1.5;
			}
			.size-chart-overlay__table-wrap {
				width: 100%;
				overflow-x: auto;
				-webkit-overflow-scrolling: touch;
			}
			.size-chart-overlay__table {
				width: 100%;
				border-collapse: collapse;
				font-size: 14px;
				text-align: center;
			}
			.size-chart-overlay__table th,
			.size-chart-overlay__table td {
				padding: 12px 14px;
				border: 1px solid #e0ddd5;
				white-space: nowrap;
				color: var(--color-text-primary, #203224);
			}
			.size-chart-overlay__table th {
				background: var(--color-text-primary, #203224);
				color: #faf6ee;
				font-family: 'Oswald', sans-serif;
				font-weight: 600;
				text-transform: uppercase;
				font-size: 13px;
				letter-spacing: 0.06em;
			}
			.size-chart-overlay__table tbody tr:nth-child(even) {
				background: rgba(0,0,0,0.03);
			}
			.size-chart-overlay__table tbody tr:hover {
				background: rgba(32, 50, 36, 0.07);
			}
			.size-chart-overlay__disclaimer {
				font-size: 12px;
				color: var(--color-text-secondary, #888);
				line-height: 1.6;
				margin-top: 20px;
				padding-top: 16px;
				border-top: 1px solid #e5e5e5;
			}

			/* Mobile */
			@media (max-width: 767.98px) {
				.size-chart-overlay__panel {
					width: 100%;
					max-width: 100%;
					height: 100%;
					max-height: 100%;
					padding: 20px 16px;
					overflow-y: auto;
				}
				.size-chart-overlay__title { font-size: 18px; }
				.size-chart-overlay__tab { font-size: 13px; padding: 10px 12px; }
				.size-chart-overlay__table th,
				.size-chart-overlay__table td { padding: 10px 10px; font-size: 13px; }
			}
		</style>

		<script>
			function switchSizeTab(btn, tab) {
				/* Deactivate all tabs & hide all content */
				var allTabs = btn.parentElement.querySelectorAll('.size-chart-overlay__tab');
				allTabs.forEach(function(t) { t.classList.remove('is-active'); });
				btn.classList.add('is-active');

				var overlay = document.getElementById('size-chart-overlay');
				var allContent = overlay.querySelectorAll('.size-chart-overlay__content');
				allContent.forEach(function(c) { c.style.display = 'none'; });

				document.getElementById('size-tab-' + tab).style.display = 'block';
			}

			/* Close on ESC key */
			document.addEventListener('keydown', function(e) {
				if (e.key === 'Escape') {
					var overlay = document.getElementById('size-chart-overlay');
					if (overlay && overlay.classList.contains('is-active')) {
						overlay.classList.remove('is-active');
						document.body.style.overflow = '';
					}
				}
			});

			/* Move overlay to <body> to escape stacking context from theme wrappers */
			document.addEventListener('DOMContentLoaded', function() {
				var overlay = document.getElementById('size-chart-overlay');
				if (overlay && overlay.parentNode !== document.body) {
					document.body.appendChild(overlay);
				}
			});
		</script>

