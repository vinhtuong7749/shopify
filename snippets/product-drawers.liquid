	{%- endcase -%}
{%- endcapture -%}
{%- assign product_details_content = product_details_content | strip -%}

{%- comment -%}
	Description variables
{%- endcomment -%}
{%- assign description_show         = block.settings.show_description -%}
{%- assign description_toggle_text  = block.settings.description_toggle_text -%}
{%- assign description_drawer_title = block.settings.description_drawer_title -%}
{%- assign show_description         = false -%}

{%- if description_show and description_toggle_text != blank and product_details_content != blank and description_drawer_title != blank -%}
	{%- assign show_description = true -%}
{%- endif -%}

{%- comment -%}
	Drawer 1 variables
{%- endcomment -%}
{%- assign drawer_page_1 		= block.settings.drawer_page_1 -%}
{%- assign drawer_toggle_text_1 	= block.settings.drawer_toggle_text_1 -%}
{%- assign drawer_title_1 		= block.settings.drawer_title_1 | default: drawer_page_1.title -%}
{%- assign show_drawer_1 		= false -%}

{%- if drawer_page_1 != blank and drawer_page_1.content != blank and drawer_toggle_text_1 != blank -%}
	{%- assign show_drawer_1 = true -%}
{%- endif -%}

{%- assign drawer_toggle_text_1_normalized = drawer_toggle_text_1 | downcase | strip -%}
{%- if drawer_toggle_text_1_normalized == 'size guide'
	or drawer_toggle_text_1_normalized == 'size guild'
	or drawer_toggle_text_1_normalized == 'care instructions'
-%}
	{%- assign show_drawer_1 = false -%}
{%- endif -%}

{%- comment -%}
	Drawer 2 variables
{%- endcomment -%}
{%- assign drawer_page_2 		= block.settings.drawer_page_2 -%}
{%- assign drawer_toggle_text_2 	= block.settings.drawer_toggle_text_2 -%}
{%- assign drawer_title_2 		= block.settings.drawer_title_2 | default: drawer_page_2.title -%}
{%- assign show_drawer_2 		= false -%}

{%- if drawer_page_2 != blank and drawer_page_2.content != blank and drawer_toggle_text_2 != blank -%}
	{%- assign show_drawer_2 = true -%}
{%- endif -%}

{%- comment -%}
	Drawer 3 variables
{%- endcomment -%}
{%- assign drawer_page_3 	   = block.settings.drawer_page_3 -%}
{%- assign drawer_toggle_text_3 = block.settings.drawer_toggle_text_3 -%}
{%- assign drawer_title_3 	   = block.settings.drawer_title_3 | default: drawer_page_3.title -%}
{%- assign show_drawer_3 	   = false -%}

{%- if drawer_page_3 != blank and drawer_page_3.content != blank and drawer_toggle_text_3 != blank -%}
	{%- assign show_drawer_3 = true -%}
{%- endif -%}

{%- comment -%}
	Size guide variables
{%- endcomment -%}
{%- assign show_size_guide 				  = false -%}
{%- assign size_guide_page 				  = section.settings.size_guide_page -%}
{%- assign size_guide_button_placement 		  = section.settings.size_guide_button_placement -%}
{%- assign size_guide_button_text_translation = "products.drawers.size_guide" | t -%}
{%- assign size_guide_button_text			  = section.settings.size_guide_button_text | default: size_guide_button_text_translation -%}
{%- assign size_chart_product_type = product.type | downcase | strip -%}
{%- assign size_chart_mode = 'all' -%}

{%- if size_chart_product_type == 'hat' -%}
	{%- assign size_chart_mode = 'all' -%}
{%- elsif size_chart_product_type contains 'long' and size_chart_product_type contains 'sleeve' -%}
	{%- assign size_chart_mode = 'longsleeve' -%}
{%- elsif size_chart_product_type contains 'hoodie' or size_chart_product_type contains 'sweatshirt' -%}
	{%- assign size_chart_mode = 'hoodie' -%}
{%- elsif size_chart_product_type == 'type1' or size_chart_product_type contains 't-shirt' or size_chart_product_type contains 'tshirt' -%}
	{%- assign size_chart_mode = 'tshirt' -%}
{%- endif -%}

{%- if section.settings.show_size_guide
	and size_guide_page != blank
	and size_guide_page.content != blank
	and size_guide_button_placement == 'drawer'
-%}
	{%- assign show_size_guide = true -%}
{%- endif -%}

{%- assign has_any_accordion = false -%}
{%- assign show_care_instructions = true -%}
{%- if show_description or show_care_instructions or show_drawer_1 or show_drawer_2 or show_drawer_3 or show_size_guide -%}
	{%- assign has_any_accordion = true -%}
{%- endif -%}

{%- comment -%} Always show Description accordion using generated product details even if drawer description is off {%- endcomment -%}
{%- if has_any_accordion or product_details_content != blank -%}
	{%- capture styles -%}
		--offset-top-desktop: {{ block.settings.offset_top_desktop }}px; {{-  -}}
		--offset-bottom-desktop: {{ block.settings.offset_bottom_desktop }}px; {{-  -}}
		--offset-top-mobile: {{ block.settings.offset_top_mobile }}px; {{-  -}}
		--offset-bottom-mobile: {{ block.settings.offset_bottom_mobile }}px;
	{%- endcapture -%}

	<style>
		/* ============================================
		   Product Accordion Styles
		   ============================================ */
		.product-accordion {
			padding-top: var(--offset-top-mobile);
			padding-bottom: var(--offset-bottom-mobile);
			width: 100%;
		}
		@media (min-width: 1200px) {
			.product-accordion {
				padding-top: var(--offset-top-desktop);
				padding-bottom: var(--offset-bottom-desktop);
			}
		}
		.product-accordion__item {
			border-top: 1px solid var(--color-border-thirdly, #e5e5e5);
		}
		.product-accordion__item:last-child {
			border-bottom: 1px solid var(--color-border-thirdly, #e5e5e5);
		}
		.product-accordion__trigger {
			display: flex;
			align-items: center;
			justify-content: space-between;
			width: 100%;
			padding: 16px 0;
			background: none;
			border: none;
			cursor: pointer;
			color: var(--color-text-primary, #000);
			font-size: calc(var(--body-font-size, 14px) * 0.875);
			font-weight: 600;
			letter-spacing: 0.08em;
			text-transform: uppercase;
			text-align: left;
			line-height: 1.4;
			transition: opacity var(--timing-short, 0.2s);
			font-family: 'Oswald', sans-serif !important;
		}
		.product-accordion__trigger:hover {
			opacity: 0.7;
		}
		.product-accordion__trigger:focus-visible {
			outline: 2px solid var(--color-text-primary, #000);
			outline-offset: 2px;
		}
		.product-accordion__trigger-icon {
			display: flex;
			align-items: center;
			justify-content: center;
			width: 24px;
			height: 24px;
			flex-shrink: 0;
			transition: transform var(--timing-base, 0.4s) ease;
		}
		.product-accordion__trigger[aria-expanded="true"] .product-accordion__icon-vertical {
			opacity: 0;
			transition: opacity var(--timing-short, 0.2s);
		}
		.product-accordion__trigger[aria-expanded="false"] .product-accordion__icon-vertical,
		.product-accordion__trigger:not([aria-expanded]) .product-accordion__icon-vertical {
			opacity: 1;
			transition: opacity var(--timing-short, 0.2s);
		}
		.product-accordion__content {
			overflow: hidden;
			max-height: 0;
			opacity: 0;
			transition: max-height var(--timing-base, 0.4s) ease, opacity var(--timing-short, 0.2s) ease, padding var(--timing-short, 0.2s) ease;
			padding: 0;
		}
		.product-accordion__content.is-open {
			max-height: 2000px;
			opacity: 1;
			padding-bottom: 20px;
		}
		.product-accordion__content[hidden] {
			display: block !important;
			max-height: 0;
			opacity: 0;
			padding: 0;
			overflow: hidden;
		}
		.product-accordion__content-inner {
			font-size: calc(var(--body-font-size, 14px) * 0.875);
			line-height: 1.7;
			color: var(--color-text-secondary, #666);
			font-family: 'Oswald', sans-serif !important;
		}
		.product-accordion__content-inner p {
			margin-bottom: 10px;
		}
		.product-accordion__content-inner p:last-child {
			margin-bottom: 0;
		}
		.product-accordion__table-wrapper {
			width: 100%;
			overflow-x: auto;
			-webkit-overflow-scrolling: touch;
			margin: 16px auto;
		}
		.product-accordion__table {
			width: 100% !important;
			max-width: 600px !important;
			margin: 0 auto !important;
			border-collapse: collapse;
			text-align: center;
			font-size: 14px;
		}
		.product-accordion__table th,
		.product-accordion__table td {
			padding: 14px 16px;
			border: 1px solid var(--color-border-thirdly, #e5e5e5);
			white-space: nowrap !important;
			text-align: center !important;
			color: var(--color-text-primary, #203224) !important;
		}
		.product-accordion__table th {
			background-color: var(--color-text-primary, #203224) !important;
			color: #faf6ee !important;
			font-weight: 600 !important;
			text-transform: uppercase !important;
		}
		.product-accordion__content-inner img {
			max-width: 100%;
			height: auto;
		}

		/* Mobile optimizations */
		@media (max-width: 767.98px) {
			.product-accordion__trigger {
				padding: 14px 0;
				font-size: calc(var(--body-font-size, 14px) * 0.85);
			}
			.product-accordion__content-inner {
				font-size: calc(var(--body-font-size, 14px) * 0.9);
			}
			.product-accordion__table th,
			.product-accordion__table td {
				padding: 12px 10px;
				font-size: 14px; /* Fix "too small text" */
			}
		}
	</style>

	<div class="product-accordion" style="{{ styles }}" data-product-accordion>
		{%- comment -%} DESCRIPTION - Full Page Overlay Trigger {%- endcomment -%}
		{%- if product_details_content != blank -%}
			{%- assign desc_content = product_details_content -%}

			<div class="product-accordion__item">
				<button
					class="product-accordion__trigger"
					type="button"
					aria-expanded="false"
					onclick="document.getElementById('description-overlay').classList.add('is-active'); document.body.style.overflow='hidden';"
				>
					<span>PRODUCT DETAILS</span>
					<span class="product-accordion__trigger-icon">
						<svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
							<line x1="0" y1="6" x2="12" y2="6" stroke="currentColor" stroke-width="1.5"/>
							<line class="product-accordion__icon-vertical" x1="6" y1="0" x2="6" y2="12" stroke="currentColor" stroke-width="1.5"/>
						</svg>
					</span>
