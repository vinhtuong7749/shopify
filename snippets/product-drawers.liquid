{%- comment -%}
------------------------------------------------------------------------------
  Snippet: Product Drawers → Now renders as Inline Accordions
  Accordion items expand/collapse in-place (no side drawer)
------------------------------------------------------------------------------
{%- endcomment -%}

{%- comment -%}
	Product details content
	For T-Shirt products, tag-specific details win. Other product types use type-only details.
{%- endcomment -%}
{%- assign product_details_type = product.type | downcase | strip -%}
{%- assign product_details_profile = blank -%}
{%- assign product_details_is_tshirt = false -%}
{%- assign product_details_is_tshirt_family = false -%}
{%- assign product_details_has_bella = false -%}
{%- assign product_details_has_vneck = false -%}
{%- assign product_details_has_wash = false -%}
{%- assign product_details_has_tanktop = false -%}
{%- assign product_details_has_comfort_1745 = false -%}
{%- assign product_details_has_comfort_1717 = false -%}

{%- if product_details_type == 't-shirt' or product_details_type == 'tshirt' or product_details_type == 't shirt' -%}
	{%- assign product_details_is_tshirt = true -%}
	{%- assign product_details_is_tshirt_family = true -%}
{%- elsif product_details_type == 'type1' or product_details_type contains 't-shirt' or product_details_type contains 'tshirt' -%}
	{%- assign product_details_is_tshirt_family = true -%}
{%- endif -%}

{%- if product_details_is_tshirt -%}
	{%- for tag in product.tags -%}
		{%- assign product_details_tag = tag | handleize -%}
		{%- if product_details_tag contains 'bella' -%}
			{%- assign product_details_has_bella = true -%}
		{%- endif -%}
		{%- if product_details_tag contains 'vneck' or product_details_tag contains 'v-neck' -%}
			{%- assign product_details_has_vneck = true -%}
		{%- endif -%}
		{%- if product_details_tag contains 'wash' -%}
			{%- assign product_details_has_wash = true -%}
		{%- endif -%}
		{%- if product_details_tag contains 'tanktop' or product_details_tag contains 'tank-top' -%}
			{%- assign product_details_has_tanktop = true -%}
		{%- endif -%}
		{%- if product_details_tag contains '1745' or product_details_tag contains 'colorblast' or product_details_tag contains 'color-blast' -%}
			{%- assign product_details_has_comfort_1745 = true -%}
		{%- endif -%}
		{%- if product_details_tag contains '1717' or product_details_tag contains 'comfort' -%}
			{%- assign product_details_has_comfort_1717 = true -%}
		{%- endif -%}
	{%- endfor -%}

	{%- if product_details_has_vneck -%}
		{%- assign product_details_profile = 'vneck' -%}
	{%- elsif product_details_has_wash -%}
		{%- assign product_details_profile = 'wash' -%}
	{%- elsif product_details_has_tanktop -%}
		{%- assign product_details_profile = 'tanktop' -%}
	{%- elsif product_details_has_comfort_1745 -%}
		{%- assign product_details_profile = 'comfort-1745' -%}
	{%- elsif product_details_has_comfort_1717 -%}
		{%- assign product_details_profile = 'comfort-1717' -%}
	{%- elsif product_details_has_bella -%}
		{%- assign product_details_profile = 'bella' -%}
	{%- else -%}
		{%- assign product_details_profile = 'tshirt-default' -%}
	{%- endif -%}
{%- elsif product_details_type contains 'hoodie' -%}
	{%- assign product_details_profile = 'hoodie' -%}
{%- elsif product_details_type contains 'sweatshirt' or product_details_type contains 'sweater' -%}
	{%- assign product_details_profile = 'sweatshirt' -%}
{%- elsif product_details_type contains 'long' and product_details_type contains 'sleeve' -%}
	{%- assign product_details_profile = 'long-sleeve' -%}
{%- elsif product_details_type contains 'hat' or product_details_type contains 'cap' -%}
	{%- assign product_details_profile = 'hat' -%}
{%- elsif product_details_is_tshirt_family -%}
	{%- assign product_details_profile = 'tshirt-default' -%}
{%- endif -%}

{%- capture product_details_content -%}
