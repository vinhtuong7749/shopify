{% comment %}
----------------------------------------------------------------------------
  Snippet: Pagination
  - Used on blog, collection, orders, addresses, and search.
----------------------------------------------------------------------------
{% endcomment %}

{%- if paginate.parts.size > 0 -%}
	<nav class="pagination" aria-label="{{- 'general.pagination.label' | t | escape -}}">
		<div class="pagination__list" role="list">
			<span class="pagination__item pagination__item--prev {% unless paginate.previous %} pagination__item--no-active {% endunless %}">
				{%- if paginate.previous -%}
					<a
						class="pagination__link focus-visible-outline js-pagination-link"
						href="{{- paginate.previous.url -}}{{ anchor }}"
						aria-label="{{- 'general.pagination.previous' | t | escape -}}"
					>
						&lt; PREV
					</a>
				{%- else -%}
					<span class="pagination__link pagination__link--no-active" aria-hidden="true">
						&lt; PREV
					</span>
				{%- endif -%}
			</span>

			<div class="pagination__numbers">
			{%- for part in paginate.parts -%}
				<span class="pagination__item">
					{%- if part.is_link -%}
						<a
							class="focus-visible-outline pagination__link js-pagination-link"
							href="{{- part.url -}}{{ anchor }}"
							{%- if part.title != paginate.pages -%}
								aria-label="{{- 'general.pagination.page' | t: number: part.title | escape -}}"
							{%- else -%}
								aria-label="{{- 'general.pagination.last_page' | t: number: part.title | escape -}}"
							{%- endif -%}
						>
							{{- part.title -}}
						</a>
					{%- else -%}
						{%- if part.title == paginate.current_page -%}
							<a
								class="pagination__link {% if part.title == paginate.current_page %} is-active {% endif -%}"
								role="link"
								aria-disabled="true"
								aria-current="page"
								aria-label="{{- 'general.pagination.page' | t: number: part.title | escape -}}"
							>
								{{- part.title -}}
							</a>
						{%- else -%}
							<span class="pagination__link" aria-hidden="true">
								{{- part.title -}}
							</span>
						{%- endif -%}
					{%- endif -%}
				</span>
			{%- endfor -%}
			</div>

			<span class="pagination__item pagination__item--next {% unless paginate.next %} pagination__item--no-active {%- endunless -%}">
				{%- if paginate.next -%}
					<a
						class="focus-visible-outline pagination__link js-pagination-link"
						href="{{- paginate.next.url -}}{{ anchor }}"
						aria-label="{{- 'general.pagination.next' | t | escape -}}"
					>
						NEXT &gt;
					</a>
				{%- else -%}
					<span class="pagination__link pagination__link--no-active" aria-hidden="true">
						NEXT &gt;
					</span>
				{%- endif -%}
			</span>
		</div>
	</nav>
{%- endif -%}

<style>
.pagination__list {
	display: flex;
	justify-content: center; /* Center the numbers wrapper */
	align-items: center;
	margin-top: 60px;
	position: relative;
	font-size: 10px;
	letter-spacing: 1.5px;
	font-weight: 800;
	text-transform: uppercase;
	padding: 0;
	color: #000;
}
.pagination__numbers {
	display: flex;
	align-items: center;
	gap: 20px;
}
.pagination__item--prev {
	position: absolute;
	left: 0;
	color: #999;
}
.pagination__item--prev .pagination__link:hover {
	color: #000;
}
.pagination__item--next {
	position: absolute;
	right: 0;
	color: #000;
}
.pagination__item {
	display: inline-block;
}
.pagination__link {
	text-decoration: none;
	color: inherit;
	transition: color 0.3s ease;
	cursor: pointer;
}
.pagination__link.is-active {
	border-bottom: 1.5px solid #000;
	padding-bottom: 2px;
}
.pagination__link--no-active {
	opacity: 0.3;
	pointer-events: none;
}
.pagination {
	padding-bottom: 40px;
}
</style>
