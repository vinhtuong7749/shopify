<div
	class="popup password-popup js-scroll-lock-container"
	id="password-popup"
	tabindex="-1"
	aria-modal="true"
	role="dialog"
>
	<header class="password__header">
		<button
			class="password-popup__close"
			data-target="password-popup"
			aria-label="{{ "general.password_page.close_popup" | t | escape }}"
			data-js-toggle="password-popup"
		>
			{% render 'icons', icon: 'menu-close' %}
		</button>
	</header>

	<div class="password-popup__body">
		{%- if popup_heading != blank -%}
			<h2 class="h4 password-popup__heading">
				{{- popup_heading -}}
			</h2>
		{%- endif -%}

		{%- assign id = 'ContactForm--' | append: section_id -%}

		{%- form 'storefront_password', class: 'password-popup__form', id: id -%}
			<div class="password-popup__form-content">
				<div class="password-popup__field">
					<div class="input-wrapper">
						<input
							type="password"
							name="password"
							id="PasswordForm-{{- section_id -}}"
							value="{{- form.email -}}"
							class="input password-popup__input js-password-header-form"
							{% if form.errors %}
								aria-invalid="true"
								aria-describedby="PasswordForm-error-{{- section_id -}}"
							{%- endif -%}
							placeholder="{{- popup_input_placeholder -}}"
						>

						<label class="input-label" for="PasswordForm-{{- section.id -}}">
							{{- popup_input_placeholder -}}
						</label>
					</div>
				</div>

				<button
					class="button button--secondary password-popup__button"
					type="submit"
				>
					<span data-text="{{ popup_button_text | escape }}">
						<span>{{ popup_button_text }}</span>
					</span>
				</button>
			</div>

			{%- if form.errors -%}
				<p
					id="PasswordForm-error-{{- section_id -}}"
					class="password-popup__submitted-title"
					tabindex="-1"
					role="alert"
				>
					{% render 'icons', icon: 'error' %}

					{{- "general.password_page.error_heading" | t -}}
				</p>
			{% endif %}
		{%- endform -%}
	</div>
</div>
