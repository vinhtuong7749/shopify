{%- comment -%}
------------------------------------------------------------------------------
  Snippet: Product inventory status
------------------------------------------------------------------------------
{%- endcomment -%}

{%- assign current_variant 		= product.selected_or_first_available_variant -%}
{%- assign can_sell_after_zero 	= false -%}

{%- if current_variant.inventory_policy == "continue" or current_variant.inventory_management == nil -%}
	{%- assign can_sell_after_zero = true -%}
{%- endif -%}

{%- capture styles -%}
	--offset-top-desktop: {{ block.settings.offset_top_desktop }}px; {{- -}}
	--offset-bottom-desktop: {{ block.settings.offset_bottom_desktop }}px; {{- -}}
	--offset-top-mobile: {{ block.settings.offset_top_mobile }}px; {{- -}}
	--offset-bottom-mobile: {{ block.settings.offset_bottom_mobile }}px;
{%- endcapture -%}

<div class="product-inventory-status{% if can_sell_after_zero or current_variant.inventory_quantity < 1 %} is-hidden{% endif %} js-product-inventory" style="{{- styles -}}">
	<div class="product-inventory-status__container">
		{%- assign single_product_count_label   = 'products.product.product_stock_count.one' | t: count: current_variant.inventory_quantity -%}
		{%- assign multiple_product_count_label = 'products.product.product_stock_count.other' | t: count: current_variant.inventory_quantity -%}

		{%- render 'icons', icon: 'check' -%}

		<span class="js-product-inventory-label">
			{{- current_variant.inventory_quantity | pluralize: single_product_count_label, multiple_product_count_label -}}
		</span>
	</div>
</div>
