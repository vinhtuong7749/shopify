{%- comment -%}
	------------------------------------------------------------------------------
	Snippet: Product gallery image
	This snippet will output main image on product page

	- image: image object (optional, object),
	- is_lazy: is lazy load enable (optional, default: true, boolean)
	- container
	- square_image: if media height is set to 'square' then make images size square
	- additional_class: additional class for image
	- media_layout: media layout (optional)
	- thumbnails_position: the position of thumbnails (optional)

	{%- render "product-gallery-image", image: image, is_lazy: is_lazy, container: container -%}
	------------------------------------------------------------------------------
{%- endcomment -%}

{%- if image -%}
	{%- if container == "inherit" and settings.container_width == "2048px" -%}
		{%- assign inherit_2048_container = true -%}
	{%- endif -%}

	{%- if container == "inherit" and settings.container_width == "1808px" -%}
		{%- assign inherit_1808_container = true -%}
	{%- endif -%}

	{%- if container == "inherit" and settings.container_width == "100%" -%}
		{%- assign inherit_full_container = true -%}
	{%- endif -%}

	{% if image == settings.product_default_image %}
		{%- capture img_focal -%}
			--img-desktop-pos: {{ settings.product_default_image.presentation.focal_point }};
		{%- endcapture -%}
	{% endif %}

	{%- if container == "2048px" or container == "100%" or inherit_2048_container or inherit_full_container -%}
		{%- if first_media != blank and first_media == "media-full" -%}
			{%- assign w_1920 = 1173 -%}
			{%- assign w_1600 = 958 -%}
		{%- elsif first_media != blank and first_media == "media-big" -%}
			{%- assign w_1920 = 694 -%}
			{%- assign w_1600 = 566 -%}
		{%- else %}
			{%- assign w_1920 = 471 -%}
			{%- assign w_1600 = 384 -%}
		{%- endif -%}

		{% if media_layout == "carousel" %}
			{% if thumbnails_position == "bottom" %}
				{%- assign w_1920 = 1173 -%}
				{%- assign w_1600 = 958 -%}
			{% else %}
				{%- assign w_1920 = 1006 -%}
				{%- assign w_1600 = 791 -%}
			{% endif %}
		{% elsif media_layout == "stacked" %}
			{%- assign w_1920 = 1173 -%}
			{%- assign w_1600 = 958 -%}
		{% endif %}

		{%- if square_image -%}
			{%- assign h_1920 = w_1920 -%}
			{%- assign h_1600 = w_1600 -%}
		{%- else -%}
			{%- assign h_1920 = w_1920 | divided_by: image.preview_image.aspect_ratio | round -%}
			{%- assign h_1600 = w_1600 | divided_by: image.preview_image.aspect_ratio | round -%}
		{%- endif -%}

		{%- assign w_1920_x2 = w_1920 | times: 2 -%}
		{%- assign w_1600_x2 = w_1600 | times: 2 -%}

		{%- assign h_1920_x2 = h_1920 | times: 2 -%}
		{%- assign h_1600_x2 = h_1600 | times: 2 -%}
	{%- elsif container == "1808px" or inherit_1808_container -%}
		{%- if first_media != blank and first_media == "media-full" -%}
			{%- assign w_1920 = 1097 -%}
			{%- assign w_1600 = 958 -%}
		{%- elsif first_media != blank and first_media == "media-big" -%}
			{%- assign w_1920 = 649 -%}
			{%- assign w_1600 = 566 -%}
		{%- else -%}
			{%- assign w_1920 = 441 -%}
			{%- assign w_1600 = 384 -%}
		{%- endif -%}

		{% if media_layout == "carousel" %}
			{% if thumbnails_position == "bottom" %}
				{%- assign w_1920 = 1097 -%}
				{%- assign w_1600 = 958 -%}
			{% else %}
				{%- assign w_1920 = 931 -%}
				{%- assign w_1600 = 791 -%}
			{% endif %}
		{% elsif media_layout == "stacked" %}
			{%- assign w_1920 = 1097 -%}
			{%- assign w_1600 = 958 -%}
		{% endif %}

		{%- if square_image -%}
			{%- assign h_1920 = w_1920 -%}
			{%- assign h_1600 = w_1600 -%}
		{%- else -%}
			{%- assign h_1920 = w_1920 | divided_by: image.preview_image.aspect_ratio | round -%}
			{%- assign h_1600 = w_1600 | divided_by: image.preview_image.aspect_ratio | round -%}
		{%- endif -%}

		{%- assign w_1920_x2 = w_1920 | times: 2 -%}
		{%- assign w_1600_x2 = w_1600 | times: 2 -%}

		{%- assign h_1920_x2 = h_1920 | times: 2 -%}
		{%- assign h_1600_x2 = h_1600 | times: 2 -%}
	{% endif %}

	{%- assign w_1199 = 800 -%}
	{%- assign w_1199_x2 = w_1199 | times: 2 -%}
	{%- assign w_767 = 735 -%}
	{%- assign w_767_x2 = w_767 | times: 2 -%}
	{%- assign w_480 = 448 -%}
	{%- assign w_480_x2 = w_480 | times: 2 -%}
	{%- assign w_420 = 388 -%}
	{%- assign w_420_x2 = w_420 | times: 2 -%}
	{%- assign w_380 = 348 -%}
	{%- assign w_380_x2 = w_380 | times: 2 -%}

	{%- if square_image -%}
		{%- assign h_1199 = w_1199 -%}
		{%- assign h_767  = w_767 -%}
		{%- assign h_480  = w_480 -%}
		{%- assign h_420  = w_420 -%}
		{%- assign h_380  = w_380 -%}
	{%- else -%}
		{%- assign h_1199 = w_1199 | divided_by: image.preview_image.aspect_ratio | round -%}
		{%- assign h_767  = w_767 | divided_by: image.preview_image.aspect_ratio | round -%}
		{%- assign h_480  = w_480 | divided_by: image.preview_image.aspect_ratio | round -%}
		{%- assign h_420  = w_420 | divided_by: image.preview_image.aspect_ratio | round -%}
		{%- assign h_380  = w_380 | divided_by: image.preview_image.aspect_ratio | round -%}
	{%- endif -%}

	{%- assign h_1199_x2 = h_1199 | times: 2 -%}
	{%- assign h_767_x2  = h_767 | times: 2 -%}
	{%- assign h_480_x2  = h_480 | times: 2 -%}
	{%- assign h_420_x2  = h_420 | times: 2 -%}
	{%- assign h_380_x2  = h_380 | times: 2 -%}

	{%- unless is_lazy -%}
		<link rel="preload" href="{{ image | image_url: width: w_420, height: h_420 }}" as="image" media="(min-width: 380.1px) and (max-width: 420px) and (max-resolution: 1.74dppx)">
		<link rel="preload" href="{{ image | image_url: width: w_420_x2, height: h_420_x2 }}" as="image" media="(min-width: 380.1px) and (max-width: 420px) and (min-resolution: 1.75dppx)">
	{%- endunless -%}

	<picture class="{{- additional_class -}}">
		<source
			srcset="{{ image | image_url: width: w_380, height: h_380 }} 1x, {{ image | image_url: width: w_380_x2, height: h_380_x2 }} 2x"
			media="(max-width: 380px)"
			width="{{- w_380 -}}"
			height="{{- h_380 -}}"
		>

		<source
			srcset="{{ image | image_url: width: w_420, height: h_420 }} 1x, {{ image | image_url: width: w_420_x2, height: h_420_x2 }} 2x"
			media="(max-width: 420px)"
			width="{{- w_420 -}}"
			height="{{- h_420 -}}"
		>

		<source
			srcset="{{ image | image_url: width: w_480, height: h_480 }} 1x, {{ image | image_url: width: w_480_x2, height: h_480_x2 }} 2x"
			media="(max-width: 480px)"
			width="{{- w_480 -}}"
			height="{{- h_480 -}}"
		>

		<source
			srcset="{{- image | image_url: width: w_767, height: h_767 }} 1x, {{ image | image_url: width: w_767_x2, height: h_767_x2 }} 2x"
			media="(max-width: 767px)"
			width="{{- w_767 -}}"
			height="{{- h_767 -}}"
		>

		<source
			srcset="{{- image | image_url: width: w_1199, height: h_1199 }} 1x, {{ image | image_url: width: w_1199_x2, height: h_1199_x2 }} 2x"
			media="(max-width: 1199px)"
			width="{{- w_1199 -}}"
			height="{{- h_1199 -}}"
		>

		<source
			srcset="{{- image | image_url: width: w_1600, height: h_1600 }} 1x, {{ image | image_url: width: w_1600_x2, height: h_1600_x2 }} 2x"
			media="(max-width: 1600px)"
			width="{{- w_1600 -}}"
			height="{{- h_1600 -}}"
		>

		<img
			class="product-media__image"
			srcset="{{- image | image_url: width: w_1920, height: h_1920 }} 1x, {{ image | image_url: width: w_1920_x2, height: h_1920_x2 }} 2x"
			src="{{- image | image_url: width: w_1920 -}}"
			alt="{{- image.alt | escape -}}"
			width="{{- w_1920 -}}"
			height="{{- h_1920 -}}"
			{% if img_focal != blank %}
				style="{{ img_focal }}"
			{% endif %}
			{% if is_lazy %}
				fetchpriority="low"
				loading="lazy"
			{% else %}
				fetchpriority="high"
				loading="eager"
			{% endif %}
		>
	</picture>
{% endif %}
