{%- comment -%}
	------------------------------------------------------------------------------
	Snippet: Product filters selected
	- product_list: Collection or Search object (required)
	- filter_type: filter type (sidebar/top-bar/drawer)

	Usage:

	{%- render 'product-filters-selected', product_list: collection -%}
	or
	{%- render 'product-filters-selected', product_list: search -%}
	------------------------------------------------------------------------------
{%- endcomment -%}


{%- assign active_filters_size = 0 -%}

{%- for filter in product_list.filters -%}
	{%- case filter.type -%}
		{%- when 'list' or 'boolean' -%}
			{%- assign active_filters_size = active_filters_size | plus: filter.active_values.size -%}
		{%- when 'price_range' -%}
			{%- if filter.min_value.value > 0 or filter.max_value.value < filter.range_max -%}
				{%- if filter.min_value.value != nil or filter.max_value.value != nil -%}
					{%- assign active_filters_size = active_filters_size | plus: 1 -%}
				{%- endif -%}
			{%- endif -%}
	{%- endcase -%}
{%- endfor -%}

{%- capture product_filters_selected_wrapper_classes -%}
	product-filters-selected js-selected-filters-wrapper
	{% if active_filters_size == 0 %} is-hidden {% endif %}
	{% if filter_type == 'drawer' %}product-filters-selected--drawer{% endif %}
{%- endcapture -%}

{%- if filter_type == 'top-bar' -%}
	{%- assign show_list_clear_button = true -%}
{%- endif -%}

{%- if filter_type == 'sidebar' -%}
	{%- assign show_label = true -%}
	{%- assign show_clear_button = true -%}
{%- endif -%}

{%- if product_list != blank -%}
	<div class="{{- product_filters_selected_wrapper_classes | strip_newlines -}}">
		{%- if active_filters_size > 0 -%}
			<div class="product-filters-selected__container">
				{%- if show_label -%}
					<p class="product-filters-selected__label">
						{{- 'general.filters.active_title' | t -}}
					</p>
				{%- endif -%}

				<ul class="product-filters-selected__list" aria-label="{{- 'general.filters.applied_filters' | t | escape -}}">
					{%- if show_list_clear_button -%}
						{%- if active_filters_size > 1 -%}
							<li class="product-filters-selected__item">
								<button
									class="focus-visible-outline product-filters-selected__button product-filters-selected__button--clear-all js-reset-filters"
									type="button"
									aria-label="{{- 'general.filters.clear_all' | t | escape -}}"
								>
									{{- 'general.filters.clear_all' | t -}}
									{%- render 'icons', icon: 'close' -%}
								</button>
							</li>
						{%- endif -%}
					{%- endif -%}

					{%- for filter in product_list.filters -%}
						{%- case filter.type -%}
							{%- when 'list' or 'boolean' -%}
								{%- if filter.active_values.size > 0 -%}
									{%- for filter_value in filter.values -%}
										{%- if filter_value.active -%}
											{%- assign filter_value_label = filter_value.label -%}
											{%- assign tech_tag = filter_value_label | slice: 0, 7 -%}

											{%- if tech_tag contains 'label__' -%}
												{%- assign filter_value_label = filter_value_label
													| remove_first: 'label__'
													| remove_first: ':primary'
													| remove_first: ':secondary'
												-%}
											{%- endif -%}

											<li class="product-filters-selected__item">
												<a
													class="focus-visible-outline product-filters-selected__button js-remove-filter"
													href="{{- filter_value.url_to_remove -}}"
													aria-label="{{- 'general.filters.remove_filter_button_aria' | t: type: filter.label, value: filter_value.label | escape -}}"
												>
													{% if filter.type == 'boolean' %}
														{{ filter.label }}: {{- filter_value_label -}}
													{% else %}
														{{- filter_value_label -}}
													{% endif %}

													{%- render 'icons', icon: 'close' -%}
												</a>
											</li>
										{%- endif -%}
									{%- endfor -%}
								{%- endif -%}
							{%- when 'price_range' -%}
								{%- if filter.min_value.value > 0 or filter.max_value.value < filter.range_max -%}
									{%- capture price_range_filter_value -%}
										{%- if filter.min_value.value -%}
											{{- filter.min_value.value | money -}}
										{%- else -%}
											{{- 0 | money -}}
										{%- endif -%}
										-
										{%- if filter.max_value.value -%}
											{{- filter.max_value.value | money -}}
										{%- else -%}
											{{- filter.range_max | money -}}
										{%- endif -%}
									{%- endcapture -%}

									<li class="product-filters-selected__item">
										<a
											class="focus-visible-outline product-filters-selected__button js-remove-filter"
											href="{{- filter.url_to_remove -}}"
											aria-label="{{- 'general.filters.remove_filter_button_aria' | t: type: filter.label, value: price_range_filter_value | escape -}}"
										>
											{{- price_range_filter_value | strip_newlines -}}
											{%- render 'icons', icon: 'close' -%}
										</a>
									</li>
								{%- endif -%}
						{%- endcase -%}
					{%- endfor -%}
				</ul>

				{%- if show_clear_button -%}
					{%- if active_filters_size > 1 -%}
						<button
							class="focus-visible-outline product-filters-selected__button-clear-all js-reset-filters"
							type="button"
							aria-label="{{- 'general.filters.clear_all' | t | escape -}}"
						>
							{{- 'general.filters.clear_all' | t -}}
						</button>
					{%- endif -%}
				{%- endif -%}
			</div>
		{%- endif -%}
	</div>
{%- endif -%}
