		border-radius: 8px 8px 0 0 !important;
	}

	/* ============================================
	   MOBILE: Fix uneven cards and layout breakage
	   ============================================ */
	@media screen and (max-width: 767px) {
		/* ===== FORCE UNIFORM CARD IMAGE SIZE ON MOBILE ===== */
