		.product-card__tag-badge--vneck,
		.product-card__tag-badge--tanktop,
		.product-card__tag-badge--longsleeve-tee,
		.product-card__tag-badge--wash,
		.product-card__tag-badge--sweater,
		.product-card__tag-badge--hoodie,
		.product-card__tag-badge--gildan,
		.product-card__tag-badge--trucker,
		.product-card__tag-badge--colorblast {
			left: 0;
			bottom: 5px;
			width: 50%;
			max-width: 50%;
		}

