		.product-card__image--placeholder {
			width: 100% !important;
			height: 100% !important;
		}

		/* Product card box model safeguard to prevent blowout */
		.product-card {
			width: 100% !important;
			max-width: 100% !important;
			min-width: 0 !important; /* CRITICAL for flex/grid blowout */
			box-sizing: border-box !important;
			overflow: hidden !important;
		}
		.product-card__main {
			width: 100% !important;
			margin-bottom: 0 !important;
			padding-bottom: 0 !important;
			min-width: 0 !important;
		}
		.product-card__info {
			min-width: 0 !important;
			width: 100% !important;
			overflow: hidden !important;
		}

		/* Hide Quick Add button on mobile */
		.product-card__custom-quick-add {
			display: none !important;
		}
		/* Reduce footer padding (space between image and title/price) */
		.product-card__footer {
			padding: 0 !important;
			margin-top: 5px !important;
			min-width: 0 !important;
			width: 100% !important;
			overflow: visible !important;
		}
		/* Tighten title margin and padding, force strict 1-line ellipsis */
		.product-card .product-card__title {
			margin-bottom: 2px !important;
			margin-top: 0 !important;
			padding-top: 0 !important;
			font-weight: 500 !important;
			text-transform: capitalize !important;
			font-size: 13px !important;
			white-space: nowrap !important;
			overflow: hidden !important;
