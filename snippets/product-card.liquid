	/* Regular price — dark */
	@media screen and (min-width: 768px) {
		.product-card__price .price.price--on-sale .price__sale {
			align-items: baseline !important;
			gap: 6px !important;
		}

		.product-card__price .price.price--on-sale .price__sale .price-item--sale {
			font-size: 16px !important;
