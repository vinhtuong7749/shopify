{%- comment -%}
	------------------------------------------------------------------------------
	Snippet: Header mobile - with accordion dropdowns for collections
	------------------------------------------------------------------------------
{%- endcomment -%}

{%- assign burger_menu          = section.settings.burger_menu -%}
{%- assign hide_burger_menu_on_mobile = section.settings.hide_burger_menu_on_mobile -%}
{%- assign additional_menu      = section.settings.additional_menu -%}
{%- assign show_socials         = section.settings.show_socials -%}
{%- assign phone_number         = section.settings.phone_number -%}
{%- assign schedule_information = section.settings.schedule_information -%}
{%- assign animation_delay      = 0 -%}

{%- for i in (1..3) -%}
	{%- assign image_key   = 'media_image_' | append: i -%}
	{%- assign media_image = section.settings[image_key] -%}
	{%- if media_image != blank -%}
		{%- assign mega_menu_images_count = mega_menu_images_count | plus: 1 -%}
	{%- endif -%}
{%- endfor -%}

<div
	id="headerDrawerMenu"
	class="drawer drawer--left header-mobile color-{{ color_scheme }}"
	data-menu-type="main"
	role="dialog"
	aria-labelledby="headerDrawerMenuTitle"
>
	<p class="visually-hidden" id="headerDrawerMenuTitle">
		{{- "layout.navigation.drawer_menu" | t | escape -}}
	</p>

	<div class="drawer__body header-mobile__body js-mobile-header-main-menu js-scroll-lock-container">
		{%- if menu.links != blank or burger_menu.links != blank or additional_menu.links != blank -%}
			<nav
				class="header-mobile__menu-wrapper"
				aria-label="{{ "layout.navigation.drawer_menu" | t | escape }}"
			>
				{%- if mobile_top_menu.links != blank -%}
					<ul class="header-mobile__menu-top">
						{%- for link in mobile_top_menu.links limit: 3 -%}
							<li class="header-mobile__menu-top-item">
								<a href="{{ link.url }}" class="button-link">
									<span data-text="{{ link.title }}">
										<span>{{ link.title }}</span>
									</span>
								</a>
							</li>
						{%- endfor -%}
					</ul>
				{%- endif -%}

				<ul class="header-mobile__menu">
					{%- if menu.links != blank -%}
						{%- for first_level_link in menu.links -%}
							{%- assign first_level_index = forloop.index -%}

							{%- if forloop.first -%}
								{%- assign animation_delay_start = 0.2 -%}
							{%- else -%}
								{%- assign animation_delay_start = 0 -%}
							{%- endif -%}

							{%- assign animation_delay = animation_delay | plus: animation_delay_start | plus: 0.05 -%}

							{%- comment -%} === Detect collection URLs for accordion behavior === {%- endcomment -%}
							{%- assign is_all_collections = false -%}
							{%- assign is_single_collection = false -%}
							{%- assign detected_col = null -%}
							{%- if first_level_link.url contains '/collections/' -%}
								{%- assign _col_parts = first_level_link.url | split: '/collections/' -%}
								{%- assign _col_handle = _col_parts[1] | split: '?' | first | split: '/' | first -%}
								{%- if _col_handle == 'all' -%}
									{%- assign is_all_collections = true -%}
								{%- elsif _col_handle != blank -%}
									{%- assign detected_col = collections[_col_handle] -%}
									{%- if detected_col != blank and detected_col.products_count > 0 -%}
										{%- assign is_single_collection = true -%}
									{%- endif -%}
								{%- endif -%}
							{%- endif -%}

							<li class="header-mobile__menu-item-wrapper" style="--animation-delay: {{ animation_delay }}s">

								{%- if is_all_collections -%}
									{%- comment -%} ==========================================
									   BỘ SƯU TẬP (/collections/all) → dropdown showing all collections → products
									========================================== {%- endcomment -%}
									<button
										class="button-link header-mobile__menu-item header-mobile__menu-item--main js-mobile-dropdown-toggle"
										type="button"
										aria-expanded="false"
									>
										<span data-text="{{- first_level_link.title | escape -}}">
											<span>{{- first_level_link.title | escape -}}</span>
										</span>
										<svg class="icon header-mobile__dropdown-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg>
									</button>

									<div class="header-mobile__dropdown-content">
										<ul class="header-mobile__dropdown-list">
											{%- assign collection_handles = 'camo,mens,usa' | split: ',' -%}
											{%- for col_handle in collection_handles -%}
												{%- assign sub_col = collections[col_handle] -%}
												{%- if sub_col != blank -%}
													<li class="header-mobile__dropdown-item">
														<a class="header-mobile__dropdown-link" href="{{ sub_col.url }}">
															<span>{{ sub_col.title }}</span>
														</a>
													</li>
												{%- endif -%}
											{%- endfor -%}
										</ul>
									</div>

								{%- elsif first_level_link.links != blank -%}
									{%- comment -%} ==========================================
									   Admin menu nesting (if exists) → accordion
									========================================== {%- endcomment -%}
									<button
										class="button-link header-mobile__menu-item header-mobile__menu-item--main js-mobile-dropdown-toggle"
										type="button"
										aria-expanded="false"
									>
										<span data-text="{{- first_level_link.title | escape -}}">
											<span>{{- first_level_link.title | escape -}}</span>
										</span>
										<svg class="icon header-mobile__dropdown-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg>
									</button>

									<div class="header-mobile__dropdown-content">
										<ul class="header-mobile__dropdown-list">
											{%- for second_level_link in first_level_link.links -%}
												<li class="header-mobile__dropdown-item">
													<a class="header-mobile__dropdown-link" href="{{- second_level_link.url -}}">
														<span>{{ second_level_link.title | escape }}</span>
													</a>
												</li>
											{%- endfor -%}
										</ul>
									</div>

								{%- else -%}
									{%- comment -%} ==========================================
									   Simple link (no children, not a collection)
									========================================== {%- endcomment -%}
									<a
										class="button-link header-mobile__menu-item header-mobile__menu-item--main"
										href="{{- first_level_link.url -}}"
										{% if first_level_link.current %}aria-current="page"{% endif %}
									>
										<span data-text="{{- first_level_link.title | escape -}}">
											<span>{{- first_level_link.title | escape -}}</span>
										</span>
									</a>
								{%- endif -%}
							</li>
						{%- endfor -%}
					{%- endif -%}

					{%- if additional_menu.links != blank -%}
						{%- for main_link in additional_menu.links -%}
							{%- assign animation_delay = animation_delay | plus: 0.05 -%}
							<li class="header-mobile__menu-item-wrapper" style="--animation-delay: {{ animation_delay }}s">
								<a
									class="button-link header-mobile__menu-item header-mobile__menu-item--additional"
									href="{{- main_link.url -}}"
									{% if main_link.current %}aria-current="page"{% endif %}
								>
									<span data-text="{{- main_link.title | escape -}}">
										<span>{{- main_link.title | escape -}}</span>
									</span>
								</a>
							</li>
						{%- endfor -%}
					{%- endif -%}
				</ul>
			</nav>
		{%- endif -%}

		<div class="header-mobile__info">
			{%- if phone_number != blank -%}
				{%- assign animation_delay = animation_delay | plus: 0.05 -%}
				<div class="rte header-mobile__store-info" style="--animation-delay: {{ animation_delay }}s">
					{{- phone_number -}}
				</div>
			{%- endif -%}

			{%- if schedule_information != blank -%}
				{%- assign animation_delay = animation_delay | plus: 0.05 -%}
				<div class="rte header-mobile__store-info" style="--animation-delay: {{ animation_delay }}s">
					{{- schedule_information -}}
				</div>
			{%- endif -%}

			{%- if show_socials -%}
				{%- render 'social-links', animation_delay: animation_delay -%}
			{%- endif -%}

			{%- if is_language_selector_enabled or is_country_selector_enabled -%}
				{%- assign animation_delay = animation_delay | plus: 0.05 -%}
				<div class="header-mobile__localization-wrapper" style="--animation-delay: {{ animation_delay }}s">
					{%- if is_language_selector_enabled -%}
						{%- render 'language-localization-form', class: 'header-mobile', list_class: 'js-scroll-lock-ignore', id_prefix: 'header-mobile', form_id: 'header-mobile-localization-form' -%}
					{%- endif -%}
					{%- if is_country_selector_enabled -%}
						{%- render 'country-localization-form', class: 'header-mobile', list_class: 'js-scroll-lock-ignore', id_prefix: 'header-mobile', form_id: 'header-mobile-county-form' -%}
					{%- endif -%}
				</div>
			{%- endif -%}

			{%- if shop.customer_accounts_enabled -%}
				{%- assign animation_delay = animation_delay | plus: 0.05 -%}
				<div class="header-mobile__account" style="--animation-delay: {{ animation_delay }}s">
					{%- if customer -%}
						{%- assign customer_label = 'customer.account.title' | t -%}
					{%- else -%}
						{%- assign customer_label = 'customer.login.title' | t -%}
					{%- endif -%}

					<a
						href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
						class="button button--secondary button--with-icon header-mobile__login-link"
					>
						{%- render 'icons', icon: 'account' -%}
						<span data-text="{{- customer_label -}}">
							<span>{{- customer_label -}}</span>
						</span>
					</a>

					{%- unless customer -%}
						<div class="header-mobile__signup">
							<span class="header-mobile__new-customer">
								{{- "customer.login.new_customer" | t -}}
							</span>
							<a href="{{- routes.account_register_url -}}" class="button-link header-mobile__signup-link">
								<span data-text="{{- "customer.login.signup" | t -}}">
									<span>{{- "customer.login.signup" | t -}}</span>
								</span>
							</a>
						</div>
					{%- endunless -%}
				</div>
			{%- endif -%}
		</div>
	</div>
</div>

<style>
/* Mobile menu: reduce font size and weight */
.header-mobile .header-mobile__menu-item.header-mobile__menu-item--main {
	font-size: calc(var(--body-font-size) * 1.35) !important;
	font-weight: 400 !important;
	letter-spacing: 0.04em;
}
.header-mobile .header-mobile__menu-item {
	font-size: calc(var(--body-font-size) * 1.15) !important;
	font-weight: 400 !important;
}

/* === Accordion Dropdown === */
.header-mobile__dropdown-arrow {
	width: 16px;
	height: 16px;
	flex-shrink: 0;
	transition: transform 0.3s ease;
}
.js-mobile-dropdown-toggle[aria-expanded="true"] > .header-mobile__dropdown-arrow {
	transform: rotate(180deg);
}
.header-mobile__dropdown-content {
	max-height: 0;
	overflow: hidden;
	transition: max-height 0.35s cubic-bezier(0.4, 0, 0.2, 1);
}
.header-mobile__dropdown-content.is-open {
	max-height: 2000px;
	transition: max-height 0.5s cubic-bezier(0.4, 0, 0.2, 1);
}
.header-mobile__dropdown-list {
	list-style: none;
	padding: 4px 0 8px 16px;
	margin: 0;
	display: flex;
	flex-direction: column;
	gap: 2px;
}
.header-mobile__dropdown-item {
	border-bottom: 1px solid rgba(0,0,0,0.06);
}
.header-mobile__dropdown-item:last-child {
	border-bottom: none;
}
.header-mobile__dropdown-sub-toggle {
	display: flex;
	align-items: center;
	justify-content: space-between;
	width: 100%;
	padding: 10px 0;
	background: none;
	border: none;
	cursor: pointer;
	font-family: var(--heading-font-family);
	font-size: calc(var(--body-font-size) * 1.05);
	font-weight: 400;
	color: var(--color-text-primary);
	text-align: left;
	text-transform: uppercase;
	letter-spacing: 0.03em;
}
.header-mobile__dropdown-link {
	display: block;
	padding: 10px 0;
	font-family: var(--heading-font-family);
	font-size: calc(var(--body-font-size) * 1.05);
	font-weight: 400;
	color: var(--color-text-primary);
	text-decoration: none;
	text-transform: uppercase;
	letter-spacing: 0.03em;
}
.header-mobile__dropdown-products {
	list-style: none;
	padding: 4px 0 8px 8px;
	margin: 0;
	display: flex;
	flex-direction: column;
	gap: 0;
}
.header-mobile__dropdown-product-link {
	display: flex;
	align-items: center;
	gap: 10px;
	padding: 8px 4px;
	font-family: var(--base-font-family);
	font-size: calc(var(--body-font-size) * 0.85);
	font-weight: 400;
	color: var(--color-text-primary);
	text-decoration: none;
	transition: opacity 0.2s ease;
	border-bottom: 1px solid rgba(0,0,0,0.04);
}
.header-mobile__dropdown-product-link:last-child {
	border-bottom: none;
}
.header-mobile__dropdown-product-link:active {
	opacity: 0.6;
}
.header-mobile__dropdown-product-img {
	width: 30px;
	height: 30px;
	object-fit: cover;
	border-radius: 2px;
	flex-shrink: 0;
}
.header-mobile__dropdown-view-all {
	display: block;
	padding: 10px 4px;
	font-family: var(--heading-font-family);
	font-size: calc(var(--body-font-size) * 0.85);
	font-weight: 600;
	color: var(--color-text-primary);
	text-decoration: none;
	text-transform: uppercase;
	letter-spacing: 0.05em;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
	document.addEventListener('click', function(e) {
		var btn = e.target.closest('.js-mobile-dropdown-toggle');
		if (!btn) return;
		e.preventDefault();
		e.stopPropagation();

		var content = btn.nextElementSibling;
		if (!content || !content.classList.contains('header-mobile__dropdown-content')) return;

		var isOpen = btn.getAttribute('aria-expanded') === 'true';

		if (isOpen) {
			btn.setAttribute('aria-expanded', 'false');
			content.classList.remove('is-open');
		} else {
			btn.setAttribute('aria-expanded', 'true');
			content.classList.add('is-open');
		}
	});
});
</script>
