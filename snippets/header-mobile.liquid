{%- comment -%}
	------------------------------------------------------------------------------
	Snippet: Header mobile - with accordion dropdowns for collections
	------------------------------------------------------------------------------
{%- endcomment -%}

{%- assign burger_menu          = section.settings.burger_menu -%}
{%- assign hide_burger_menu_on_mobile = section.settings.hide_burger_menu_on_mobile -%}
{%- assign additional_menu      = section.settings.additional_menu -%}
{%- assign show_socials         = section.settings.show_socials -%}
{%- assign phone_number         = section.settings.phone_number -%}
{%- assign schedule_information = section.settings.schedule_information -%}
{%- assign animation_delay      = 0 -%}

{%- for i in (1..3) -%}
	{%- assign image_key   = 'media_image_' | append: i -%}
	{%- assign media_image = section.settings[image_key] -%}
	{%- if media_image != blank -%}
		{%- assign mega_menu_images_count = mega_menu_images_count | plus: 1 -%}
	{%- endif -%}
{%- endfor -%}

<div
	id="headerDrawerMenu"
	class="drawer drawer--left header-mobile color-{{ color_scheme }}"
	data-menu-type="main"
	role="dialog"
	aria-labelledby="headerDrawerMenuTitle"
>
	<p class="visually-hidden" id="headerDrawerMenuTitle">
		{{- "layout.navigation.drawer_menu" | t | escape -}}
	</p>

	{%- comment -%} Close button for mobile nav drawer {%- endcomment -%}
	<button
		class="header-mobile__close focus-visible-outline"
		type="button"
		aria-label="Close menu"
		onclick="document.querySelector('.js-mobile-header-main-toggler').click();"
	>
		{% render 'icons', icon: 'menu-close' %}
	</button>

	<style>
		.header-mobile__close {
			position: absolute;
			top: 4px;
			right: 4px;
			z-index: 100;
			background: none;
			border: none;
			padding: 0;
			cursor: pointer;
			color: #2c3d33;
			opacity: 0.95;
			transition: opacity 0.2s ease;
			width: 44px !important;
			height: 44px !important;
			min-width: 44px !important;
			min-height: 44px !important;
			display: flex;
			align-items: center;
			justify-content: center;
		}
		.header-mobile__close:hover { opacity: 1; }
		.header-mobile__close::before { display: none !important; }
		.header-mobile__close svg {
			width: 34px !important;
			height: 34px !important;
		}
		.header-mobile__close svg path {
			stroke-width: 2 !important;
		}
	</style>

	<div class="drawer__body header-mobile__body js-mobile-header-main-menu js-scroll-lock-container">
		{%- if menu.links != blank or burger_menu.links != blank or additional_menu.links != blank -%}
			<nav
				class="header-mobile__menu-wrapper"
				aria-label="{{ "layout.navigation.drawer_menu" | t | escape }}"
			>
				{%- if mobile_top_menu.links != blank -%}
					<ul class="header-mobile__menu-top">
						{%- for link in mobile_top_menu.links limit: 3 -%}
							<li class="header-mobile__menu-top-item">
								<a href="{{ link.url }}" class="button-link">
									<span data-text="{{ link.title }}">
										<span>{{ link.title }}</span>
									</span>
								</a>
							</li>
						{%- endfor -%}
					</ul>
				{%- endif -%}

				<ul class="header-mobile__menu">
					{%- if menu.links != blank -%}
						{%- for first_level_link in menu.links -%}
							{%- assign first_level_index = forloop.index -%}

							{%- if forloop.first -%}
								{%- assign animation_delay_start = 0.2 -%}
							{%- else -%}
								{%- assign animation_delay_start = 0 -%}
							{%- endif -%}

							{%- assign animation_delay = animation_delay | plus: animation_delay_start | plus: 0.05 -%}

							<li class="header-mobile__menu-item-wrapper" style="--animation-delay: {{ animation_delay }}s">

								{%- assign link_title_down = first_level_link.title | downcase -%}
								{%- assign mobile_display_title = first_level_link.title -%}
								{%- assign dest_url = first_level_link.url -%}
								{%- if link_title_down == 'new arrivals' -%}
									{%- assign dest_url = '/collections/new-arrivals' -%}
								{%- endif -%}

								{%- assign is_shop_link = false -%}
								{%- if link_title_down == 'home' or link_title_down contains 'shop' -%}
									{%- assign is_shop_link = true -%}
									{%- assign mobile_display_title = 'SHOP' -%}
									{%- assign dest_url = '/collections/all' -%}
								{%- endif -%}

								{%- assign is_collection_link = false -%}
								{%- if link_title_down contains 'collection' or is_shop_link -%}
									{%- assign is_collection_link = true -%}
								{%- endif -%}
								{%- assign is_support_link = false -%}
								{%- if link_title_down == 'support' -%}
									{%- assign is_support_link = true -%}
								{%- endif -%}

								{%- if first_level_link.links != blank or is_collection_link or is_support_link -%}
									{%- comment -%} ==========================================
									   Menu nesting → accordion (split link and toggle)
									========================================== {%- endcomment -%}
									{%- if is_collection_link and dest_url == '/collections' -%}
										{%- assign dest_url = '/collections/all' -%}
									{%- endif -%}

									<div class="header-mobile__menu-item-row" style="display: flex; align-items: center; justify-content: flex-start; gap: 6px; width: 100%;">
										<a
											class="button-link header-mobile__menu-item header-mobile__menu-item--main{% if is_shop_link %} js-mobile-dropdown-text-toggle{% endif %}"
											href="{%- if is_shop_link -%}#{%- else -%}{{- dest_url -}}{%- endif -%}"
											style="white-space: nowrap; flex: 0 1 auto; text-align: left;"
											{% if first_level_link.current and is_shop_link == false %}aria-current="page"{% endif %}
											{% if is_shop_link %}onclick="event.preventDefault(); event.stopPropagation(); var btn = this.parentElement.querySelector('.js-mobile-dropdown-toggle'); if (btn) { btn.click(); }"{% endif %}
										>
											<span data-text="{{- mobile_display_title | escape -}}">
												<span>{{- mobile_display_title | escape -}}</span>
											</span>
										</a>
										<button
											class="button-link header-mobile__menu-item header-mobile__menu-item--main js-mobile-dropdown-toggle"
											type="button"
											aria-expanded="false"
											aria-label="Toggle dropdown"
											style="display: inline-flex; width: auto !important; min-width: 24px; flex: 0 0 auto; align-items: center; justify-content: center; padding-left: 0; padding-right: 4px;"
											onclick="event.preventDefault(); event.stopPropagation(); var content = this.parentElement.nextElementSibling; if (content &amp;&amp; content.classList.contains('header-mobile__dropdown-content')) { var isOpen = this.getAttribute('aria-expanded') === 'true'; this.setAttribute('aria-expanded', !isOpen); content.classList.toggle('is-open', !isOpen); }"
										>
											<svg class="icon header-mobile__dropdown-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg>
										</button>
									</div>

									<div class="header-mobile__dropdown-content">
										<ul class="header-mobile__dropdown-list">
											{%- if is_shop_link -%}
												<li class="header-mobile__dropdown-item">
													<a class="header-mobile__dropdown-link" href="/collections/all"><span>For Men</span></a>
												</li>
												<li class="header-mobile__dropdown-item">
													{%- assign mob_shop_womens_col = collections['independence-day-womens'] -%}
													{%- if mob_shop_womens_col == blank -%}
														{%- assign mob_shop_womens_col = collections['independence-day-women-s'] -%}
													{%- endif -%}
													{%- assign mob_shop_womens_url = '/collections/independence-day-womens' -%}
													{%- if mob_shop_womens_col != blank -%}
														{%- assign mob_shop_womens_url = mob_shop_womens_col.url -%}
													{%- endif -%}
													<a class="header-mobile__dropdown-link" href="{{ mob_shop_womens_url }}"><span>For Women</span></a>
												</li>
												<li class="header-mobile__dropdown-item">
													<a class="header-mobile__dropdown-link" href="/collections/all?filter.p.product_type=Type1&filter.p.product_type=3D+Tshirt&filter.p.product_type=T-Shirt"><span>T-Shirts</span></a>
												</li>
												<li class="header-mobile__dropdown-item">
													<a class="header-mobile__dropdown-link" href="/collections/all?filter.p.product_type=Long-sleeve"><span>Long-Sleeve</span></a>
												</li>
												<li class="header-mobile__dropdown-item">
													<a class="header-mobile__dropdown-link" href="/collections/all?filter.p.product_type=Hat"><span>Hats</span></a>
												</li>
											{%- elsif is_collection_link -%}
												{%- assign mob_nation_park_col = collections['nation-park'] -%}
												{%- if mob_nation_park_col == blank -%}
													{%- assign mob_nation_park_col = collections['national-park'] -%}
												{%- endif -%}
												{%- assign mob_nation_park_url = '/collections/nation-park' -%}
												{%- if mob_nation_park_col != blank -%}
													{%- assign mob_nation_park_url = mob_nation_park_col.url -%}
												{%- endif -%}
												{%- assign mob_world_turkey_slam_col = collections['world-turkey-slam'] -%}
												{%- assign mob_world_turkey_slam_url = '/collections/world-turkey-slam' -%}
												{%- if mob_world_turkey_slam_col != blank -%}
													{%- assign mob_world_turkey_slam_url = mob_world_turkey_slam_col.url -%}
												{%- endif -%}
												{%- assign mob_grand_slam_col = collections['grand-slam-subspecies'] -%}
												{%- assign mob_grand_slam_url = '/collections/grand-slam-subspecies' -%}
												{%- if mob_grand_slam_col != blank -%}
													{%- assign mob_grand_slam_url = mob_grand_slam_col.url -%}
												{%- endif -%}
												{%- comment -%} ── FEATURED ── {%- endcomment -%}
												<li class="header-mobile__mega-group">
													<button class="header-mobile__mega-toggle" type="button" aria-expanded="false" onclick="event.preventDefault(); event.stopPropagation(); var content = this.nextElementSibling; if (content &amp;&amp; content.classList.contains('header-mobile__mega-panel')) { var isOpen = this.getAttribute('aria-expanded') === 'true'; this.setAttribute('aria-expanded', !isOpen); content.classList.toggle('is-open', !isOpen); }">
														<span>Featured</span>
														<span class="header-mobile__mega-plus" aria-hidden="true"></span>
													</button>
													<ul class="header-mobile__mega-panel">
								{% comment %}<li class="header-mobile__dropdown-item"><a class="header-mobile__dropdown-link" href="/collections/all?filter.p.product_type=Sweatshirt"><span>Sweatshirts</span></a></li>{% endcomment %}
								{% comment %}<li class="header-mobile__dropdown-item"><a class="header-mobile__dropdown-link" href="/collections/all?filter.p.product_type=Hoodie"><span>Hoodies</span></a></li>{% endcomment %}
								<li class="header-mobile__dropdown-item"><a class="header-mobile__dropdown-link" href="{{ mob_nation_park_url }}"><span>National Park</span></a></li>
								<li class="header-mobile__dropdown-item"><a class="header-mobile__dropdown-link" href="{{ mob_world_turkey_slam_url }}"><span>World Turkey Slam</span></a></li>
								<li class="header-mobile__dropdown-item"><a class="header-mobile__dropdown-link" href="{{ mob_grand_slam_url }}"><span>Grand Slam Subspecies</span></a></li>
								<li class="header-mobile__dropdown-item"><a class="header-mobile__dropdown-link" href="/collections/new-arrivals"><span>New Arrivals</span></a></li>
								<li class="header-mobile__dropdown-item"><a class="header-mobile__dropdown-link" href="/collections/turkey"><span>Turkey</span></a></li>
													</ul>
												</li>

												{%- comment -%} ── TERRAIN (image + name, vertical) ── {%- endcomment -%}
								<li class="header-mobile__mega-group">
									<button class="header-mobile__mega-toggle" type="button" aria-expanded="false" onclick="event.preventDefault(); event.stopPropagation(); var content = this.nextElementSibling; if (content &amp;&amp; content.classList.contains('header-mobile__mega-panel')) { var isOpen = this.getAttribute('aria-expanded') === 'true'; this.setAttribute('aria-expanded', !isOpen); content.classList.toggle('is-open', !isOpen); }">
										<span>Independence Day</span>
										<span class="header-mobile__mega-plus" aria-hidden="true"></span>
									</button>
									<ul class="header-mobile__mega-panel">
								{%- assign mob_terrain_handles = "dog-250,deer-250,eagle-250,liberty-250,independence-day-womens" | split: "," -%}
								{%- assign mob_terrain_labels = "DOG 250,Deer 250,Eagle 250,Liberty 250,Women's" | split: "," -%}
								{%- for mth in mob_terrain_handles -%}
									{%- assign mt_c = collections[mth] -%}
									{%- assign mt_url = '' -%}
									{%- assign mt_image_col = mt_c -%}
									{%- assign mt_label = mob_terrain_labels[forloop.index0] -%}
									{%- assign mt_empty = false -%}
									{%- if mth == 'dog-250' -%}
										{%- assign mt_dog_250_col = collections['dog-250'] -%}
										{%- assign mt_url = '/collections/dog-250' -%}
										{%- if mt_dog_250_col != blank -%}
											{%- assign mt_c = mt_dog_250_col -%}
											{%- assign mt_image_col = mt_dog_250_col -%}
											{%- assign mt_url = mt_dog_250_col.url -%}
										{%- endif -%}
										{%- assign mt_empty = true -%}
										{%- if mt_dog_250_col != blank and mt_dog_250_col.products_count > 0 -%}
											{%- assign mt_empty = false -%}
										{%- endif -%}
									{%- elsif mth == 'independence-day-womens' -%}
										{%- assign mt_womens_col = collections['independence-day-womens'] -%}
										{%- if mt_womens_col == blank -%}
											{%- assign mt_womens_col = collections['independence-day-women-s'] -%}
										{%- endif -%}
										{%- assign mt_url = '/collections/independence-day-womens' -%}
										{%- if mt_womens_col != blank -%}
											{%- assign mt_c = mt_womens_col -%}
											{%- assign mt_image_col = mt_womens_col -%}
											{%- assign mt_url = mt_womens_col.url -%}
										{%- endif -%}
										{%- if mt_womens_col == blank or mt_womens_col.products_count == 0 -%}
											{%- assign mt_empty = true -%}
										{%- endif -%}
									{%- else -%}
										{%- if mt_c != blank -%}
											{%- assign mt_url = mt_c.url -%}
										{%- else -%}
											{%- assign mt_url = '/collections/' | append: mth -%}
										{%- endif -%}
										{%- if mt_c == blank or mt_c.products_count == 0 -%}
											{%- assign mt_empty = true -%}
										{%- endif -%}
									{%- endif -%}
									{%- if mt_c != blank -%}
										{%- assign mt_label = mt_c.title -%}
									{%- endif -%}
									<li class="header-mobile__dropdown-item">
										<a class="header-mobile__dropdown-link{% if mt_empty %} header-mobile__dropdown-link--disabled{% endif %}" href="{{ mt_url }}">
											<span>{{ mt_label }}{%- if mt_empty -%}<em class="header-mobile__coming-soon"> — Coming Soon</em>{%- endif -%}</span>
										</a>
									</li>
								{%- endfor -%}
									</ul>
								</li>

												{%- comment -%} ── HUNTING ── {%- endcomment -%}
												<li class="header-mobile__mega-group">
													<button class="header-mobile__mega-toggle" type="button" aria-expanded="false" onclick="event.preventDefault(); event.stopPropagation(); var content = this.nextElementSibling; if (content &amp;&amp; content.classList.contains('header-mobile__mega-panel')) { var isOpen = this.getAttribute('aria-expanded') === 'true'; this.setAttribute('aria-expanded', !isOpen); content.classList.toggle('is-open', !isOpen); }">
														<span>Hunting</span>
														<span class="header-mobile__mega-plus" aria-hidden="true"></span>
													</button>
													<ul class="header-mobile__mega-panel">
												{%- assign mob_hunt_handles = "turkey,deer,waterfowl" | split: "," -%}
												{%- assign mob_hunt_labels = "Turkey,Deer,Waterfowl" | split: "," -%}
												{%- for mh in mob_hunt_handles -%}
													{%- assign mh_col = collections[mh] -%}
													{%- assign mh_label = mob_hunt_labels[forloop.index0] -%}
													{%- assign mh_empty = false -%}
													{%- if mh_col == blank or mh_col.products_count == 0 -%}
														{%- assign mh_empty = true -%}
													{%- endif -%}
													<li class="header-mobile__dropdown-item">
														<a class="header-mobile__dropdown-link header-mobile__hunt-link{% if mh_empty %} header-mobile__dropdown-link--disabled{% endif %}" href="/collections/{{ mh }}">
															{%- if mh_col.image != blank -%}
												<img src="{{ mh_col.image | img_url: '80x80', crop: 'center' }}" alt="{{ mh_label }}" width="80" height="80" loading="lazy" class="header-mobile__hunt-icon header-mobile__hunt-icon--{{ mh | handleize }}">
															{%- endif -%}
															<span>{{ mh_label }}{%- if mh_empty -%}<em class="header-mobile__coming-soon"> — Coming Soon</em>{%- endif -%}</span>
														</a>
													</li>
												{%- endfor -%}
													</ul>
												</li>

								{%- comment -%} FISHING {%- endcomment -%}
								<li class="header-mobile__mega-group">
									<button class="header-mobile__mega-toggle" type="button" aria-expanded="false" onclick="event.preventDefault(); event.stopPropagation(); var content = this.nextElementSibling; if (content &amp;&amp; content.classList.contains('header-mobile__mega-panel')) { var isOpen = this.getAttribute('aria-expanded') === 'true'; this.setAttribute('aria-expanded', !isOpen); content.classList.toggle('is-open', !isOpen); }">
										<span>Fishing</span>
										<span class="header-mobile__mega-plus" aria-hidden="true"></span>
									</button>
									<ul class="header-mobile__mega-panel">
								{%- assign mob_fishing_handles = "fishing-t-shirt,saltwater-fishing-t-shirt" | split: "," -%}
								{%- assign mob_fishing_icon_fallbacks = "https://cdn.shopify.com/s/files/1/0741/7987/0911/collections/icon_bass.jpg?v=1780569828,https://cdn.shopify.com/s/files/1/0741/7987/0911/collections/icon_swordfish.jpg?v=1780569816" | split: "," -%}
								{%- for mf in mob_fishing_handles -%}
									{%- assign mf_col = collections[mf] -%}
									{%- assign mf_label = mf | replace: '-', ' ' -%}
									{%- if mf_col != blank -%}
										{%- assign mf_label = mf_col.title -%}
									{%- endif -%}
									{%- assign mf_fallback_icon = mob_fishing_icon_fallbacks[forloop.index0] -%}
									<li class="header-mobile__dropdown-item">
										<a class="header-mobile__dropdown-link header-mobile__hunt-link" href="{%- if mf_col != blank -%}{{ mf_col.url }}{%- else -%}/collections/{{ mf }}{%- endif -%}">
											{%- if mf_col.image != blank -%}
												<img src="{{ mf_col.image | img_url: '80x80', crop: 'center' }}" alt="{{ mf_label | escape }}" width="80" height="80" loading="lazy" class="header-mobile__hunt-icon header-mobile__hunt-icon--{{ mf | handleize }}">
											{%- elsif mf_fallback_icon != blank -%}
												<img src="{{ mf_fallback_icon }}" alt="{{ mf_label | escape }}" width="80" height="80" loading="lazy" class="header-mobile__hunt-icon header-mobile__hunt-icon--{{ mf | handleize }}">
											{%- endif -%}
											<span>{{ mf_label | escape }}</span>
										</a>
									</li>
								{%- endfor -%}
									</ul>
								</li>
								{%- if false -%}
								{%- assign mob_womens_col = collections['independence-day-womens'] -%}
								{%- if mob_womens_col == blank -%}
									{%- assign mob_womens_col = collections['independence-day-women-s'] -%}
								{%- endif -%}
								{%- assign mob_has_seasonal = false -%}
								{%- for link in first_level_link.links -%}
									{%- assign ms_lower = link.title | downcase -%}
									{%- if ms_lower contains 'independence' or ms_lower contains 'signature' -%}
										{%- assign mob_has_seasonal = true -%}
										{%- assign mob_seasonal_title = link.title -%}
										{%- assign mob_seasonal_url = link.url -%}
										{%- if ms_lower contains 'signature' -%}
											{%- assign mob_seasonal_title = "Independence Day Women's" -%}
											{%- if mob_womens_col != blank -%}
												{%- assign mob_seasonal_url = mob_womens_col.url -%}
											{%- else -%}
												{%- assign mob_seasonal_url = '/collections/independence-day-womens' -%}
											{%- endif -%}
										{%- endif -%}
										<li class="header-mobile__dropdown-item">
											<a class="header-mobile__dropdown-link" href="{{ mob_seasonal_url }}"><span>{{ mob_seasonal_title }}</span></a>
										</li>
									{%- endif -%}
								{%- endfor -%}
								{%- unless mob_has_seasonal -%}
									{%- assign m_ind_col = collections['usa'] -%}
									{%- if m_ind_col != blank -%}
										{%- assign m_ind_empty = false -%}
										{%- if m_ind_col.products_count == 0 -%}{%- assign m_ind_empty = true -%}{%- endif -%}
										<li class="header-mobile__dropdown-item">
											<a class="header-mobile__dropdown-link{% if m_ind_empty %} header-mobile__dropdown-link--disabled{% endif %}" href="{{ m_ind_col.url }}"><span>Independence Day{%- if m_ind_empty -%}<em class="header-mobile__coming-soon"> — Coming Soon</em>{%- endif -%}</span></a>
										</li>
									{%- endif -%}
									{%- assign m_womens_url = '/collections/independence-day-womens' -%}
									{%- assign m_womens_empty = false -%}
									{%- if mob_womens_col != blank -%}
										{%- assign m_womens_url = mob_womens_col.url -%}
										{%- if mob_womens_col.products_count == 0 -%}{%- assign m_womens_empty = true -%}{%- endif -%}
									{%- endif -%}
									<li class="header-mobile__dropdown-item">
										<a class="header-mobile__dropdown-link{% if m_womens_empty %} header-mobile__dropdown-link--disabled{% endif %}" href="{{ m_womens_url }}"><span>Independence Day Women's{%- if m_womens_empty -%}<em class="header-mobile__coming-soon"> — Coming Soon</em>{%- endif -%}</span></a>
									</li>
									{%- assign mob_has_seasonal = true -%}
								{%- endunless -%}
								{%- endif -%}

											{%- elsif is_support_link -%}
												{%- comment -%} Custom order: Contact, Shipping, Refund, Privacy, Terms {%- endcomment -%}
												{%- for policy in shop.policies -%}
													{%- if policy.url contains 'contact-information' -%}
														{%- assign m_contact = policy -%}
													{%- elsif policy.url contains 'shipping-policy' -%}
														{%- assign m_shipping = policy -%}
													{%- elsif policy.url contains 'refund-policy' -%}
														{%- assign m_refund = policy -%}
													{%- elsif policy.url contains 'privacy-policy' -%}
														{%- assign m_privacy = policy -%}
													{%- elsif policy.url contains 'terms-of-service' -%}
														{%- assign m_terms = policy -%}
													{%- endif -%}
												{%- endfor -%}
												{%- if m_contact -%}
												<li class="header-mobile__dropdown-item">
													<a class="header-mobile__dropdown-link" href="/pages/contact"><span>Contact Information</span></a>
												</li>
												{%- endif -%}
												{%- if m_shipping -%}
												<li class="header-mobile__dropdown-item">
													<a class="header-mobile__dropdown-link" href="{{ m_shipping.url }}"><span>{{ m_shipping.title | escape }}</span></a>
												</li>
												{%- endif -%}
												{%- if m_refund -%}
												<li class="header-mobile__dropdown-item">
													<a class="header-mobile__dropdown-link" href="{{ m_refund.url }}"><span>{{ m_refund.title | escape }}</span></a>
												</li>
												{%- endif -%}
												{%- if m_privacy -%}
												<li class="header-mobile__dropdown-item">
													<a class="header-mobile__dropdown-link" href="{{ m_privacy.url }}"><span>{{ m_privacy.title | escape }}</span></a>
												</li>
												{%- endif -%}
												{%- if m_terms -%}
												<li class="header-mobile__dropdown-item">
													<a class="header-mobile__dropdown-link" href="{{ m_terms.url }}"><span>{{ m_terms.title | escape }}</span></a>
												</li>
												{%- endif -%}
											{%- elsif first_level_link.links != blank -%}
												{%- for second_level_link in first_level_link.links -%}
													<li class="header-mobile__dropdown-item">
														<a class="header-mobile__dropdown-link" href="{{- second_level_link.url -}}">
															<span>{{ second_level_link.title | escape }}</span>
														</a>
													</li>
												{%- endfor -%}
											{%- endif -%}
										</ul>
									</div>
								{%- else -%}
									{%- comment -%} ==========================================
									   Simple link (no children, not a collection)
									========================================== {%- endcomment -%}
									<a
										class="button-link header-mobile__menu-item header-mobile__menu-item--main"
										href="{{- dest_url -}}"
										{% if first_level_link.current %}aria-current="page"{% endif %}
									>
										<span data-text="{{- mobile_display_title | escape -}}">
											<span>{{- mobile_display_title | escape -}}</span>
										</span>
									</a>
								{%- endif -%}
							</li>
						{%- endfor -%}
					{%- endif -%}

					{%- if additional_menu.links != blank -%}
						{%- for main_link in additional_menu.links -%}
							{%- assign animation_delay = animation_delay | plus: 0.05 -%}
							<li class="header-mobile__menu-item-wrapper" style="--animation-delay: {{ animation_delay }}s">
								<a
									class="button-link header-mobile__menu-item header-mobile__menu-item--additional"
									href="{{- main_link.url -}}"
									{% if main_link.current %}aria-current="page"{% endif %}
								>
									<span data-text="{{- main_link.title | escape -}}">
										<span>{{- main_link.title | escape -}}</span>
									</span>
								</a>
							</li>
						{%- endfor -%}
					{%- endif -%}
				</ul>
			</nav>
		{%- endif -%}

		<div class="header-mobile__info">

			{%- comment -%} Social icons hidden on mobile header per request {%- endcomment -%}

			{%- if is_language_selector_enabled or is_country_selector_enabled -%}
				{%- assign animation_delay = animation_delay | plus: 0.05 -%}
				<div class="header-mobile__localization-wrapper" style="--animation-delay: {{ animation_delay }}s">
					{%- if is_language_selector_enabled -%}
						{%- render 'language-localization-form', class: 'header-mobile', list_class: 'js-scroll-lock-ignore', id_prefix: 'header-mobile', form_id: 'header-mobile-localization-form' -%}
					{%- endif -%}
					{%- if is_country_selector_enabled -%}
						{%- render 'country-localization-form', class: 'header-mobile', list_class: 'js-scroll-lock-ignore', id_prefix: 'header-mobile', form_id: 'header-mobile-county-form' -%}
					{%- endif -%}
				</div>
			{%- endif -%}

			{%- if shop.customer_accounts_enabled -%}
				{%- assign animation_delay = animation_delay | plus: 0.05 -%}
				<div class="header-mobile__account" style="--animation-delay: {{ animation_delay }}s">
					{%- if customer -%}
						{%- assign customer_label = 'customer.account.title' | t -%}
					{%- else -%}
						{%- assign customer_label = 'customer.login.title' | t -%}
					{%- endif -%}

					<a
						href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
						class="button button--secondary button--with-icon header-mobile__login-link"
					>
						{%- render 'icons', icon: 'account' -%}
						<span data-text="{{- customer_label -}}">
							<span>{{- customer_label -}}</span>
						</span>
					</a>

					{%- unless customer -%}
						<div class="header-mobile__signup">
							<span class="header-mobile__new-customer">
								{{- "customer.login.new_customer" | t -}}
							</span>
							<a href="{{- routes.account_register_url -}}" class="button-link header-mobile__signup-link">
								<span data-text="{{- "customer.login.signup" | t -}}">
									<span>{{- "customer.login.signup" | t -}}</span>
								</span>
							</a>
						</div>
					{%- endunless -%}
				</div>
			{%- endif -%}
		</div>
	</div>
</div>

