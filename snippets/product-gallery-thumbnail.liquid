{%- comment -%}
	------------------------------------------------------------------------------
	Snippet: Product gallery image
	This snippet will output main image on product page

	- image: image object (optional, object),
	- is_lazy: is lazy load enable (optional, default: true, boolean)

	{%- render "product-gallery-image", image: image, is_lazy: is_lazy -%}
	------------------------------------------------------------------------------
{%- endcomment -%}

{%- if image -%}
	{% comment %}
		Image width map
	{% endcomment %}
	{% assign base375 		  = 63 %}
	{% assign base375_2x 	  = 126 %}
	{% assign base420 		  = 72 %}
	{% assign base420_2x 	  = 144 %}
	{% assign base575 		  = 103 %}
	{% assign base575_2x 	  = 206 %}
	{% assign base767 		  = 142 %}
	{% assign base767_2x 	  = 284 %}
	{% assign base1199 		  = 155 %}
	{% assign base1199_2x 	  = 310 %}
	{%- if thumbnails_position == 'right' -%}
		{% assign base1440 		  = 78 %}
		{% assign base1440_2x 	  = 156 %}
		{% assign base_default	  = 78 %}
		{% assign base_default_2x = 156 %}
	{%- else -%}
		{% assign base1440 		  = 128 %}
		{% assign base1440_2x 	  = 256 %}
		{% assign base_default	  = 182 %}
		{% assign base_default_2x = 364 %}
	{%- endif -%}

	<picture>
		<source
			srcset="{{- image | image_url: width: base375, height: base375, crop: 'center' }} 1x, {{ image | image_url: width: base375_2x, height: base375_2x, crop: 'center' }} 2x"
			media="(max-width: 375px)"
			width="{{ base375 }}"
			height="{{ base375 }}"
		>

		<source
			srcset="{{- image | image_url: width: base420, height: base420, crop: 'center' }} 1x, {{ image | image_url: width: base420_2x, height: base420_2x, crop: 'center' }} 2x"
			media="(max-width: 420px)"
			width="{{ base420 }}"
			height="{{ base420 }}"
		>

		<source
			srcset="{{- image | image_url: width: base575, height: base575, crop: 'center' }} 1x, {{ image | image_url: width: base575_2x, height: base575_2x, crop: 'center' }} 2x"
			media="(max-width: 575px)"
			width="{{ base575 }}"
			height="{{ base575 }}"
		>

		<source
			srcset="{{- image | image_url: width: base767, height: base767, crop: 'center' }} 1x, {{ image | image_url: width: base767_2x, height: base767_2x, crop: 'center' }} 2x"
			media="(max-width: 767px)"
			width="{{ base767 }}"
			height="{{ base767 }}"
		>

		<source
			srcset="{{- image | image_url: width: base1199, height: base1199, crop: 'center' }} 1x, {{ image | image_url: width: base1199_2x, height: base1199_2x, crop: 'center' }} 2x"
			media="(max-width: 1199px)"
			width="{{ base1199 }}"
			height="{{ base1199 }}"
		>

		<source
			srcset="{{- image | image_url: width: base1440, height: base1440, crop: 'center' }} 1x, {{ image | image_url: width: base1440_2x, height: base1440_2x, crop: 'center' }} 2x"
			media="(max-width: 1440px)"
			width="{{ base1440 }}"
			height="{{ base1440 }}"
		>

		<img
			class="product-media__image"
			srcset="{{- image | image_url: width: base_default, height: base_default, crop: 'center' }} 1x, {{ image | image_url: width: base_default_2x, height: base_default_2x, crop: 'center' }} 2x"
			src="{{- image | image_url: width: base_default, height: base_default, crop: 'center' }}"
			{% if is_lazy %}
				loading="lazy"
			{% endif %}
			alt="{{- image.alt -}}"
			width="{{ base_default }}"
			height="{{ base_default }}"
		>
	</picture>
{% endif %}
