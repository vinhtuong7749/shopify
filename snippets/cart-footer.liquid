{% comment %}
	------------------------------------------------------------------------------
	Snippet: Cart footer
	Render shopping cart footer
	- section: Section object (required)
	- cart_button_label: text for "Go to cart" link (optional)

	Usage:
	{%- render 'cart-footer' -%}
	------------------------------------------------------------------------------
{% endcomment %}

{%- assign benefits_blocks = section.blocks | where: 'type', 'benefit' -%}

{%- capture benefits -%}
{%- endcapture -%}

{%- capture tax_message -%}
{%- endcapture -%}

{%- capture cart_total -%}
	{%- if cart.cart_level_discount_applications.size > 0 -%}
		<div class="cart-footer__savings" style="display: flex; align-items: center; justify-content: space-between; font-size: 14px; margin-bottom: 8px;">
			<span style="font-family: var(--font-body-family);">Discounts</span>
			<ul class="discounts discounts--right cart-footer__discounts" role="list" aria-label="{{- 'customer.order.discount' | t | escape -}}" style="margin: 0; padding: 0; list-style: none; display: flex; align-items: center; gap: 8px;">
				{%- for discount in cart.cart_level_discount_applications -%}
					<li class="discounts__item" style="display: flex; align-items: center; gap: 6px;">
						<div style="background: #f2f2f2; padding: 4px 8px; border-radius: 4px; display: inline-flex; align-items: center; gap: 4px; font-weight: 600; font-size: 12px; color: #333;">
							{% render 'icons', icon: 'discount' %}
							{{ discount.title }}
						</div>
						<span style="color: #333;">-{{ discount.total_allocated_amount | money }}</span>
					</li>
				{%- endfor -%}
			</ul>
		</div>
	{%- endif -%}

	<p class="cart-footer__subtotal">
		<span class="cart-footer__subtotal-label">
			{{- 'cart.general.subtotal' | t | append: ':' -}}
		</span>

		<span class="cart-footer__subtotal-value">
			{{- cart.total_price | money -}}
		</span>
	</p>
{%- endcapture -%}

{%- capture checkout_buttons -%}
	{%- assign cta_class = "cart-footer__ctas" -%}

	{%- if cart_button_label == blank and cart_drawer == true -%}
		{%- assign cta_class = cta_class | append: " cart-footer__ctas--one" -%}
	{%- endif -%}

	{%- if cart_drawer == false -%}
		{%- assign cta_class = "cart-template__ctas" -%}
	{%- endif -%}

	<div class="{{ cta_class }} js-cart-footer-button" style="display: flex; flex-direction: column; width: 100%; position: sticky; bottom: 0; z-index: 200; background: #ffffff; padding: 16px 24px 12px; border-top: 1px solid #e0e0e0; margin-left: auto; margin-right: auto; max-width: 100%;">
		{%- capture default_checkout_button -%}
			Checkout &bull; <span class="js-cart-subtotal">{{ cart.total_price | money }}</span>
		{%- endcapture -%}

		{%- assign checkout_button = settings.cart_checkout_button | default: default_checkout_button -%}

		{%- if cart_button_label != blank and cart_drawer == true -%}
			<a href="{{ routes.cart_url }}" class="cart-footer__button button button--primary button--block" style="display: none;">
				{{- cart_button_label -}}
			</a>
		{%- endif -%}

		<button
			type="submit"
			class="cart-footer__button button button--secondary button--block js-checkout-button"
			name="checkout"
			form="cart-{{- section.id -}}"
			style="width: 100%; background: #0d1f6b !important; border-color: #0d1f6b !important; font-family: 'Oswald', sans-serif !important; text-transform: uppercase; font-size: 16px; font-weight: 600; padding: 14px; margin-bottom: 8px; border-radius: 6px !important;"
			onclick="
				var form = document.getElementById('cart-{{- section.id -}}');
				if (form) {
					event.preventDefault();
					var input = document.createElement('input');
					input.type = 'hidden';
					input.name = 'checkout';
					input.value = 'Checkout';
					form.appendChild(input);
					form.submit();
				}
			"
		>
			<span data-text="{{- checkout_button | strip_html -}}">
				<span>{{ default_checkout_button }}</span>
			</span>
		</button>
	</div>

	{%- if settings.show_additional_checkout_buttons and additional_checkout_buttons -%}
		<style>
			/* Force border-radius on all dynamic checkout buttons (PayPal, Shop Pay, GPay) */
			.cart-footer__ctas-additional,
			.cart-footer__ctas-additional * {
				--payment-button-border-radius: 6px;
				--buttons-border-radius: 6px;
				--border-radius: 6px;
			}
			.cart-footer__ctas-additional [role="button"],
			.cart-footer__ctas-additional .shopify-cleanslate,
			.cart-footer__ctas-additional .shopify-cleanslate > div,
			.cart-footer__ctas-additional .additional-checkout-buttons ul li button {
				border-radius: 6px !important;
			}
			/* Some buttons use iframes inside shadow DOM, wrapping them with overflow-hidden ensures border-radius applies at wrapper level */
			.cart-footer__ctas-additional .additional-checkout-buttons ul li {
				border-radius: 6px !important;
				overflow: hidden !important;
			}
			
			/* Hide dynamic checkout buttons completely */
			.cart-footer__ctas-additional {
				display: none !important;
			}
		</style>
		<div class="cart-footer__ctas-additional js-cart-footer-additional-buttons" style="width: 100%; margin-bottom: 24px; padding: 0 24px;">
			{{ content_for_additional_checkout_buttons }}
		</div>
	{%- endif -%}

	{%- if cart_drawer == true -%}
		<div class="cart-drawer__payment-icons" style="width: 100%; display: flex; justify-content: center; align-items: center; gap: 8px; flex-wrap: wrap; padding: 0 24px 24px;">
			{%- for type in shop.enabled_payment_types -%}
				{{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
			{%- endfor -%}
		</div>
	{%- endif -%}
{%- endcapture -%}

{%- if cart_drawer == false -%}
	<div class="cart-footer">
		<div class="cart-template__footer">
			{%- if settings.show_cart_note or benefits != blank or settings.show_cart_discounts -%}
				<div class="cart-template__additional-content">
					{%- if benefits != blank -%}
						<div class="cart-template__benefits">
							{{- benefits -}}
						</div>
					{%- endif -%}

					{%- if settings.show_cart_discounts -%}
						{% liquid
							assign discount_codes = cart.cart_level_discount_applications | where: 'type', 'discount_code' | map: 'title'
							for item in cart.items
								for allocation in item.line_level_discount_allocations
									if allocation.discount_application.type == 'discount_code'
										assign discount_codes = item.line_level_discount_allocations | slice: forloop.index0 | map: 'discount_application' | map: 'title' | concat: discount_codes
									endif
								endfor
							endfor

							assign discount_codes = discount_codes | uniq
						%}

						<div class="js-cart-discount-block cart-discount">
							<form class="cart-discount__discount-form js-cart-discount-form" novalidate>
								<div class="input-wrapper cart-discount__discount-form-input-wrapper">
									<label class="visually-hidden" for="cart-discount">
										{{- "cart.general.discount" | t -}}
									</label>

									<input
										class="input cart-discount__discount-form-input"
										type="text"
										id="cart-discount"
										name="discount"
										placeholder="{{- 'cart.general.discount_placeholder' | t -}}"
									/>
								</div>

								<button class="button button--secondary cart-discount__discount-form-button js-cart-discount-apply-button" style="border-radius: 6px !important; font-family: 'Oswald', sans-serif !important; text-transform: uppercase; font-weight: 600; background: #0d1f6b !important; border-color: #0d1f6b !important; color: #ffffff !important;">
									{{- "cart.general.apply_discount" | t -}}
								</button>
							</form>

							<div
								class="cart-discount__discount-form-error js-cart-discount-error is-hidden"
								role="alert"
							>
								<span class="cart-discount__discount-form-error-icon-wrapper">
									{% render 'icons', icon: 'error' %}
								</span>

								<span class="cart-discount__discount-form-error-text js-cart-discount-error-code is-hidden">
									{{ 'cart.general.discount_code_error' | t }}
								</span>

								<small class="cart-discount__discount-form-error-text js-cart-discount-error-shipping is-hidden">
									{{ 'cart.general.shipping_discount_error' | t }}
								</small>
							</div>

							{%- if discount_codes.size > 0 -%}
								<ul class="cart-discount__codes">
									{% for discount_code in discount_codes %}
										<li
											class="cart-discount__pill js-cart-discount-pill"
											aria-label="{{ 'cart.general.discount_applied' | t: code: discount_code }}"
											data-discount-code="{{ discount_code }}"
										>
											<p class="cart-discount__pill-code">
												{{ discount_code }}
											</p>

											<button
												class="cart-discount__pill-remove focus-visible-outline js-cart-discount-pill-remove"
												aria-label="{{ 'cart.general.remove_discount' | t: code: discount_code }}"
												type="button"
											>
												{% render 'icons', icon: 'close' %}
											</button>
										</li>
									{% endfor %}
								</ul>
							{%- endif -%}
						</div>
					{% endif %}

					{%- if settings.show_cart_note -%}
						<div class="textarea-wrapper">
							<textarea
								id="note-cart"
								name="note"
								form="cart-{{- section.id -}}"
								class="textarea cart-template__textarea js-cart-notes-field"
								aria-label="{{- 'cart.general.note' | t | escape -}}"
								placeholder="{{- 'cart.general.note_placeholder' | t | escape -}}"
							>
								{{- cart.note -}}
							</textarea>

							<label for="note-cart" class="textarea-label">{{- 'cart.general.note' | t -}}</label>
						</div>
					{%- endif -%}
				</div>
			{%- endif -%}

			<div class="cart-template__total">
				<div class="js-cart-subtotal">
					{{- cart_total -}}

					{%- if settings.show_tax_and_shipping -%}
						{{- tax_message -}}
					{%- endif -%}
				</div>

				{{- checkout_buttons -}}
			</div>
		</div>
	</div>
{%- else -%}
	<div class="cart-footer" style="display: contents;">
		<div class="cart-footer__summary" style="padding: 0 24px;">
			{%- render 'cart-discount' -%}
			{%- render 'cart-notes', id: section.id -%}

			{%- if benefits != blank -%}
				<div class="cart-footer__benefits">
					{{- benefits -}}
				</div>
			{%- endif -%}

			<div class="cart-footer__subtotal-block js-cart-subtotal">
				{{- cart_total -}}
			</div>
		</div>

		<div class="cart-footer__main" style="display: contents;">
			{%- if settings.show_tax_and_shipping -%}
				{{- tax_message -}}
			{%- endif -%}

			{{- checkout_buttons -}}
		</div>
	</div>
{% endif %}

