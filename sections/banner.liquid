{%- comment -%}
------------------------------------------------------------------------------
	Section: Banner
------------------------------------------------------------------------------
{%- endcomment -%}

{%- assign banner_height_desktop 		= section.settings.desktop_image_height -%}
{%- assign banner_height_mobile 		= section.settings.mobile_image_height -%}
{%- if section.settings.enable_timer -%}
	{%- assign banner_height_desktop = 'auto' -%}
	{%- assign banner_height_mobile = 'auto' -%}
{%- endif -%}
{%- assign media_type 					= section.settings.media_type -%}
{%- assign title 						= section.settings.title -%}
{%- assign text 						= section.settings.text -%}

{%- if template.suffix == "contact" -%}
	{%- assign title = section.settings.title | default: page.title -%}
	{%- assign text = section.settings.text | default: page.content -%}
{%- endif -%}

{%- assign button_label_1 				= section.settings.button_label_1 -%}
{%- assign button_link_1 				= section.settings.button_link_1 -%}
{%- assign button_aria_label_1 			= section.settings.button_aria_label_1 -%}
{%- assign button_label_2 				= section.settings.button_label_2 -%}
{%- assign button_link_2 				= section.settings.button_link_2 -%}
{%- assign button_aria_label_2 			= section.settings.button_aria_label_2 -%}
{%- assign image_desktop 				= section.settings.image_desktop -%}
{%- assign image_mobile 				= section.settings.image_mobile | default: image_desktop -%}
{%- assign html_video_desktop 			= section.settings.html_video_desktop -%}
{%- assign html_video_mobile 			= section.settings.html_video_mobile | default: html_video_desktop -%}
{%- assign external_video_url_desktop 	= section.settings.external_video_url_desktop -%}
{%- assign external_video_url_mobile 	= section.settings.external_video_url_mobile | default: external_video_url_desktop -%}
{%- assign content_alignment 			= section.settings.content_alignment -%}
{%- assign content_alignment_mobile 	= section.settings.content_alignment_mobile -%}
{%- assign block_alignment 				= section.settings.block_alignment -%}
{%- assign block_alignment_vertical 	= section.settings.block_alignment_vertical -%}
{%- assign block_alignment_vertical_mob = section.settings.block_alignment_vertical_mob -%}
{%- assign show_section_breadcrumbs 	= section.settings.show_breadcrumbs -%}
{%- assign container 					= section.settings.container_width -%}

{% comment %}
	Timer settings
{% endcomment %}
{%- assign enable_timer 				= section.settings.enable_timer -%}
{%- assign timer_year 					= section.settings.timer_year -%}
{%- assign timer_month 					= section.settings.timer_month -%}
{%- assign timer_day 					= section.settings.timer_day -%}
{%- assign timer_hour 					= section.settings.timer_hour -%}
{%- assign timer_timezone 				= section.settings.timer_timezone -%}
{%- assign evergreen_timer              = section.settings.evergreen_timer -%}
{%- assign evergreen_reset_hour         = section.settings.evergreen_reset_hour | default: 7 -%}
{%- assign timer_label_days             = section.settings.timer_label_days | default: 'DAYS' -%}
{%- assign timer_label_hours            = section.settings.timer_label_hours | default: 'HOURS' -%}
{%- assign timer_label_minutes          = section.settings.timer_label_minutes | default: 'MINUTES' -%}
{%- assign timer_label_seconds          = section.settings.timer_label_seconds | default: 'SECONDS' -%}
{%- assign timer_background 			= section.settings.timer_background -%}
{%- assign timer_color 					= section.settings.timer_color -%}
{%- assign timer_border_color 			= section.settings.timer_color | color_modify: 'alpha', 0.12 -%}

{% comment %}
	Colors
{% endcomment %}
{%- assign section_background 			= section.settings.section_background -%}
{%- assign overlay 						= section.settings.overlay -%}
{%- assign text_color 					= section.settings.text_color -%}
{%- assign button_background_1 			= section.settings.button_background_1 -%}
{%- assign button_color_1 				= section.settings.button_color_1 -%}
{%- assign button_border_1 				= section.settings.button_border_1 -%}
{%- assign button_background_hover_1 	= section.settings.button_background_hover_1 -%}
{%- assign button_color_hover_1 		= section.settings.button_color_hover_1 -%}
{%- assign button_border_hover_1 		= section.settings.button_border_hover_1 -%}
{%- assign button_background_2 			= section.settings.button_background_2 -%}
{%- assign button_color_2 				= section.settings.button_color_2 -%}
{%- assign button_border_2 				= section.settings.button_border_2 -%}
{%- assign button_background_hover_2 	= section.settings.button_background_hover_2 -%}
{%- assign button_color_hover_2 		= section.settings.button_color_hover_2 -%}
{%- assign button_border_hover_2 		= section.settings.button_border_hover_2 -%}

{%- if container == 'inherit' -%}
	{%- assign container_width = settings.container_width -%}
{%- else -%}
	{%- assign container_width = container -%}
{%- endif -%}

{%- assign enable_lazy_load = true -%}

{%- if section.index == 1 -%}
	{%- assign enable_lazy_load = false -%}
{%- endif -%}

{%- if enable_timer or media_type == 'html_video' or media_type == 'iframe_video' -%}
	{%- assign is_script_needed = true -%}
{%- endif -%}

{%- if banner_height_desktop == 'auto' and image_desktop != blank -%}
	{%- assign use_aspect_desktop_class = true -%}
{%- elsif banner_height_desktop == 'auto' and html_video_desktop != blank -%}
	{%- assign use_aspect_desktop_class = true -%}
{%- endif %}

{%- if banner_height_mobile == 'auto' and image_mobile != blank -%}
	{%- assign use_aspect_mobile_class = true -%}
{%- elsif banner_height_mobile == 'auto' and html_video_mobile != blank -%}
	{%- assign use_aspect_mobile_class = true -%}
{%- endif -%}

{%- capture section_styles -%}
	--banner-min-height-desktop: {{ banner_height_desktop }}; {{-  -}}
	--banner-min-height-mobile: {{ banner_height_mobile }}; {{-  -}}
	--banner-background-color: {{- section_background -}}; {{-  -}}
	--text-color: {{- text_color -}}; {{-  -}}
	--overlay: {{- overlay -}}; {{-  -}}
	--container-width: {{ container_width }}; {{-  -}}
	{%- if  media_type == 'image' and image_desktop != blank -%}
		--aspect-ratio-media-desktop: {{ image_desktop.aspect_ratio |  round: 2 }}; {{-  -}}
		--aspect-ratio-media-mobile: {{ image_mobile.aspect_ratio | round: 2 }}; {{-  -}}
	{%- elsif media_type == 'html_video' and image_desktop != blank -%}
		--aspect-ratio-media-desktop: {{ html_video_desktop.aspect_ratio |  round: 2 }}; {{-  -}}
		--aspect-ratio-media-mobile: {{ html_video_mobile.aspect_ratio | round: 2 }}; {{-  -}}
	{%- endif -%}
{%- endcapture -%}

{%- if show_section_breadcrumbs -%}
	{% style %}
		.breadcrumb {
			display: none;
		}
	{% endstyle %}
{%- endif -%}

{%- capture banner -%}
	{%- capture image -%}
		{%- render
			'banner-image',
			image_desktop: image_desktop,
			image_mobile: image_mobile,
			enable_lazy_load: enable_lazy_load
		-%}
	{%- endcapture -%}

	{%- capture html_video -%}
		{%- if html_video_desktop != blank -%}
			<video
				class="banner__media banner__video js-video"
				data-device="desktop"
				data-type="html"
				loop
				muted
				playsinline
				tabindex="-1"
				aria-hidden="true"
				preload="none"
			>
				{%- for source in html_video_desktop.sources -%}
					{%- if source.mime_type == 'video/mp4' -%}
						<source src="{{- source.url -}}" type="{{- source.mime_type -}}">
					{%- endif -%}
				{%- endfor -%}
			</video>

			<video
				class="banner__media banner__video banner__video--mobile js-video"
				data-device="mobile"
				data-type="html"
				loop
				muted
				playsinline
				tabindex="-1"
				aria-hidden="true"
				preload="none"
			>
				{%- for source in html_video_mobile.sources -%}
					{%- if source.mime_type == 'video/mp4' -%}
						<source src="{{- source.url -}}" type="{{- source.mime_type -}}">
					{%- endif -%}
				{%- endfor -%}
			</video>
		{%- endif -%}
	{%- endcapture -%}

	{%- if external_video_url_desktop != nil -%}
		{%- capture external_video -%}
			{%- if external_video_url_desktop != nil -%}
				{%- if external_video_url_desktop.type == 'youtube' -%}
					<div
						class="banner__media banner__video js-video"
						data-device="desktop"
						data-type="{{- external_video_url_desktop.type -}}"
					>
						<div
							class="js-video-youtube"
							data-video-id="{{- external_video_url_desktop.id -}}"
							tabindex="-1"
							aria-hidden="true"
						></div>
					</div>
				{%- else -%}
					<div
						class="banner__media banner__video js-video"
						data-device="desktop"
						data-video-id="{{- external_video_url_desktop.id -}}"
						data-type="{{- external_video_url_desktop.type -}}"
						aria-hidden="true"
					></div>
				{%- endif -%}
			{%- endif -%}

			{%- if external_video_url_mobile != nil -%}
				{%- if external_video_url_mobile.type == 'youtube' -%}
					<div
						class="banner__media banner__video banner__video--mobile js-video"
						data-device="mobile"
						data-type="{{- external_video_url_mobile.type -}}"
					>
						<div
							class="js-video-youtube"
							data-video-id="{{- external_video_url_mobile.id -}}"
							tabindex="-1"
							aria-hidden="true"
						></div>
					</div>
				{%- else -%}
					<div
						class="banner__media banner__video banner__video--mobile js-video"
						data-device="mobile"
						data-video-id="{{- external_video_url_mobile.id -}}"
						data-type="{{- external_video_url_mobile.type -}}"
						aria-hidden="true"
					></div>
				{%- endif -%}
			{%- endif -%}
		{%- endcapture -%}
	{%- endif -%}

	{%- capture banner_media -%}
		{%- case media_type -%}
			{%- when 'image' -%}
				{{- image -}}
			{%- when 'html_video' -%}
				{{- html_video -}}
			{%- when 'iframe_video' -%}
				{{- external_video -}}
		{%- endcase -%}
	{%- endcapture -%}

	{%- capture timer -%}
		{%- if enable_timer -%}
			<style>
				.custom-timer {
					display: flex;
					align-items: center;
					justify-content: center;
					gap: 24px;
					margin: 20px auto;
				}
				.custom-timer__col {
					display: flex;
					flex-direction: column;
					align-items: center;
					justify-content: center;
				}
				.custom-timer__number {
					font-family: var(--font-heading-family), 'Oswald', sans-serif;
					font-size: 32px;
					line-height: 1.2;
					font-weight: 300;
					letter-spacing: 2px;
					margin: 0;
					color: var(--timer-cell-color, #fff);
				}
				.custom-timer__label {
					font-family: var(--font-body-family), sans-serif;
					font-size: 11px;
					text-transform: uppercase;
					letter-spacing: 2px;
					margin-top: 5px;
					color: var(--timer-cell-color, #fff);
				}
				.custom-timer__divider {
					height: 35px;
					width: 1px;
					background-color: var(--timer-cell-color, #fff);
					opacity: 0.5;
				}
				@media (max-width: 767px) {
					.custom-timer { gap: 12px; margin: 15px auto; }
					.custom-timer__number { font-size: 24px; }
					.custom-timer__label { font-size: 9px; letter-spacing: 1px; margin-top: 3px; }
					.custom-timer__divider { height: 25px; }
				}
			</style>
			
			<div class="custom-timer" id="EvergreenTimer-{{ section.id }}" role="timer" aria-live="off">
				<div class="custom-timer__col">
					<p class="custom-timer__number js-d-both">0</p>
					<p class="custom-timer__label">{{- timer_label_days | escape -}}</p>
				</div>
				<div class="custom-timer__divider"></div>
				<div class="custom-timer__col">
					<p class="custom-timer__number js-h-both">00</p>
					<p class="custom-timer__label">{{- timer_label_hours | escape -}}</p>
				</div>
				<div class="custom-timer__divider"></div>
				<div class="custom-timer__col">
					<p class="custom-timer__number js-m-both">00</p>
					<p class="custom-timer__label">{{- timer_label_minutes | escape -}}</p>
				</div>
				<div class="custom-timer__divider"></div>
				<div class="custom-timer__col">
					<p class="custom-timer__number js-s-both">00</p>
					<p class="custom-timer__label">{{- timer_label_seconds | escape -}}</p>
				</div>
			</div>

			<script>
				document.addEventListener('DOMContentLoaded', function() {
					function updateEvergreenTimer() {
						var timerEl = document.getElementById('EvergreenTimer-{{ section.id }}');
						if (!timerEl) return;
						
						var now = new Date();
						var targetTime = 0;

						{% if evergreen_timer %}
							var startOfDay = new Date(now.getFullYear(), now.getMonth(), now.getDate());
							var diffSinceStartOfDay = now.getTime() - startOfDay.getTime();
							var periodMs = 4 * 60 * 60 * 1000; // 4 hours in milliseconds
				
							var nextPeriodMs = Math.ceil(diffSinceStartOfDay / periodMs) * periodMs;
							if (nextPeriodMs === diffSinceStartOfDay) {
								nextPeriodMs += periodMs;
							}
							
							targetTime = startOfDay.getTime() + nextPeriodMs;
						{% else %}
							var fixedTarget = new Date(
								{{ timer_year | default: 2024 | json }}, 
								{{ timer_month | default: 1 | json }}, 
								{{ timer_day | default: 1 | json }}, 
								{{ timer_hour | default: 0 | json }}, 
								0, 0
							);
							// Apply manual timezone offset offset
							var offsetHours = {{ timer_timezone | default: 0 | json }};
							fixedTarget.setHours(fixedTarget.getHours() - offsetHours);
							targetTime = fixedTarget.getTime();
						{% endif %}

						var diff = targetTime - now.getTime();
						
						if (diff > 0) {
							var d = Math.floor(diff / (1000 * 60 * 60 * 24));
							var h = Math.floor((diff / (1000 * 60 * 60)) % 24);
							var m = Math.floor((diff / 1000 / 60) % 60);
							var s = Math.floor((diff / 1000) % 60);

							timerEl.querySelector('.js-d-both').textContent = d.toString();
							timerEl.querySelector('.js-h-both').textContent = h.toString().padStart(2, '0');
							timerEl.querySelector('.js-m-both').textContent = m.toString().padStart(2, '0');
							timerEl.querySelector('.js-s-both').textContent = s.toString().padStart(2, '0');
						}
					}
					setInterval(updateEvergreenTimer, 1000);
					updateEvergreenTimer();
				});
			</script>
		{%- endif -%}
	{%- endcapture -%}

	{%- capture banner_content -%}
		{%- if title != blank or text != blank or button_label_1 != blank or button_label_2 != blank or timer != blank -%}
			<div class="banner__content" {% if section.settings.banner_link != blank %}style="position: relative; z-index: 2; pointer-events: none;"{% endif %}>
				{%- if show_section_breadcrumbs -%}
					{%- render 'breadcrumbs', class: 'breadcrumb--banner' -%}
				{%- endif -%}

				{%- if title != blank -%}
					<h2 class="h1 banner__heading">
						{{- title -}}
					</h2>
				{%- endif -%}

				{%- if text != blank -%}
					<div class="banner__text rte">
						{{- text -}}
					</div>
				{%- endif -%}

				{%- if timer != blank -%}
					{{- timer -}}
				{%- endif -%}

				{% if button_label_1 != blank and button_link_1 != blank %}
					{% assign show_button_1 = true %}
				{% endif %}

				{% if button_label_2 != blank and button_link_2 != blank %}
					{% assign show_button_2 = true %}
				{% endif %}

				{% if show_button_1 or show_button_2 %}
					<div class="banner__buttons" {% if section.settings.banner_link != blank %}style="position: relative; z-index: 5; pointer-events: auto;"{% endif %}>
						{%- if show_button_1 -%}
							{%- capture button_styles_1 -%}
								--banner-button-background: {{- button_background_1 -}}; {{-  -}}
								--banner-button-color: {{- button_color_1 -}}; {{-  -}}
								--banner-button-border: {{- button_border_1 -}}; {{-  -}}
								--banner-button-background-hover: {{ button_background_hover_1 }}; {{-  -}}
								--banner-button-color-hover: {{ button_color_hover_1 }}; {{-  -}}
								--banner-button-border-hover: {{ button_border_hover_1 }}; {{-  -}}
							{%- endcapture -%}

							<a
								class="button button--primary banner__button"
								href="{{- button_link_1 -}}"
								style="{{ button_styles_1 }}"
								{% if button_aria_label_1 != blank %}
									aria-label="{{- button_aria_label_1 | escape -}}"
								{% endif %}
							>
								{{- button_label_1 -}}
							</a>
						{%- endif -%}

						{%- if show_button_2 -%}
							{% capture button_styles_2 %}
								--banner-button-background: {{- button_background_2 -}}; {{-  -}}
								--banner-button-color: {{- button_color_2 -}}; {{-  -}}
								--banner-button-border: {{- button_border_2 -}}; {{-  -}}
								--banner-button-background-hover: {{ button_background_hover_2 }}; {{-  -}}
								--banner-button-color-hover: {{ button_color_hover_2 }}; {{-  -}}
								--banner-button-border-hover: {{ button_border_hover_2 }}; {{-  -}}
							{% endcapture %}

							<a
								class="button button--primary banner__button"
								href="{{- button_link_2 -}}"
								style="{{ button_styles_2 }}"
								{% if button_aria_label_1 != blank %}
									aria-label="{{- button_aria_label_2 | escape -}}"
								{% endif %}
							>
								{{- button_label_2 -}}
							</a>
						{%- endif -%}
					</div>
				{% endif %}
			</div>
		{%- endif -%}
	{%- endcapture -%}

	{%- capture banner_wrapper_styles -%}
		--banner-min-height-desktop: {{ banner_height_desktop }}; {{-  -}}
		--banner-min-height-mobile: {{ banner_height_mobile }}; {{-  -}}
		--banner-inner-content-alignment: {{- content_alignment | replace: 'left', 'start' | replace: 'right', 'end' -}}; {{-  -}}
		--banner-inner-content-alignment-mobile: {{- content_alignment_mobile | replace: 'left', 'start' | replace: 'right', 'end' -}}; {{-  -}}
		--banner-overlay-color: {{- overlay -}}; {{-  -}}
		--banner-block-alignment: {{- block_alignment -}}; {{-  -}}
		--banner-block-alignment-vertical: {{- block_alignment_vertical -}}; {{-  -}}
		--banner-block-alignment-vertical-mobile: {{- block_alignment_vertical_mob -}}; {{-  -}}
		--banner-buttons-alignment-desktop: {% if content_alignment == 'center' %}center{% elsif content_alignment == 'right' %}flex-end{% endif %}; {{-  -}}
		--banner-buttons-alignment-mobile: {% if content_alignment_mobile == 'center' %}center{% elsif content_alignment_mobile == 'right' %}flex-end{% endif %}; {{-  -}}
		{% if enable_timer %}
			--timer-cell-background-color: {{- timer_background -}}; {{-  -}}
			--timer-cell-color: {{- timer_color -}};
			--timer-border-color: {{- timer_border_color -}};
		{%- endif -%}
	{%- endcapture -%}

	{%- capture banner_wrapper_classes -%}
		{% if overlay %}banner__wrapper--overlayed {{-  -}} {%- endif -%}
		{% if enable_timer %}banner__wrapper--has-timer {{-  -}} {%- endif -%}
	{%- endcapture -%}

	{%- capture media_wrapper_classes -%}
		{% if media_type == 'html_video' or media_type == 'iframe_video' %} js-videos {%- endif -%}
	{%- endcapture -%}

	{%- capture aspect_ratio_class -%}
		{% if use_aspect_desktop_class and media_type != 'iframe_video' %} banner__inner--aspect-desktop{%- endif -%}
		{% if use_aspect_mobile_class and media_type != 'iframe_video' %} banner__inner--aspect-mobile{%- endif -%}
	{%- endcapture -%}

	<div class="banner__wrapper section-animate {{ banner_wrapper_classes | strip_newlines }}" style="{{- banner_wrapper_styles | strip_newlines -}}">
		{%- if section.settings.banner_link != blank -%}
			<a href="{{ section.settings.banner_link }}" class="banner__full-link" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 3;">
				<span class="visually-hidden">{{ title | default: "Banner" }}</span>
			</a>
		{%- endif -%}

		{%- if banner_media != blank -%}
			<div class="banner__media-wrapper {{- media_wrapper_classes | strip_newlines -}}">
				{{- banner_media -}}
			</div>
		{%- endif -%}

		{%- if banner_content != blank or aspect_ratio_class != blank -%}
			<div class="banner__inner {{ aspect_ratio_class | strip_newlines }}" {% if section.settings.banner_link != blank %}style="position: relative; z-index: 4; pointer-events: none;"{% endif %}>
				{{- banner_content -}}
			</div>
		{%- endif -%}
	</div>
{%- endcapture -%}

{%- if banner != blank -%}
	{%- render 'adastra' with '/src/styles/banner.scss' -%}

	{%- style -%}
		#shopify-section-{{- section.id -}} {
			padding-top: {{- section.settings.offset_top_mobile -}}px;
			padding-bottom: {{- section.settings.offset_bottom_mobile -}}px;
		}

		@media screen and (min-width: 768px) {
			#shopify-section-{{- section.id -}} {
				padding-top: {{- section.settings.offset_top_desktop -}}px;
				padding-bottom: {{- section.settings.offset_bottom_desktop -}}px;
			}
		}
	{%- endstyle -%}

	<section class="banner{% if container_width == '100%' %} banner--full-width{% endif %} container js-banner js-animate {% if request.visual_preview_mode or section.index == 1 %}animated{% endif %}" style="{{- section_styles | strip_newlines -}}">
		{{- banner -}}
	</section>

	<style>
		@media (min-width: 992px) {
			#shopify-section-{{ section.id }} .banner__content {
				/* Use schema alignment settings */
				padding-right: 0 !important; 
				padding-bottom: 0px !important;
				align-items: var(--banner-inner-content-alignment) !important;
				text-align: var(--banner-inner-content-alignment) !important;
				margin-right: 2%; 
				width: 37%; 
				transform: translate(15px, 20px); 
			}
			#shopify-section-{{ section.id }} .banner__text {
				font-size: {{ section.settings.custom_font_size }}px; 
				font-weight: 500;
				letter-spacing: 0.5px;
			}
			#shopify-section-{{ section.id }} .banner__buttons {
				justify-content: var(--banner-buttons-alignment-desktop, flex-start) !important;
				width: 100%;
			}
			#shopify-section-{{ section.id }} .banner__button {
				font-size: 14px; 
				padding: 16px 40px;
				margin-top: 20px;
			}
		}
		/* Mobile: 4:5 aspect ratio and alignment overrides */
		@media (max-width: 767px) {
			#shopify-section-{{ section.id }} .banner__content {
				align-items: var(--banner-inner-content-alignment-mobile) !important;
				text-align: var(--banner-inner-content-alignment-mobile) !important;
			}
			#shopify-section-{{ section.id }} .banner__buttons {
				justify-content: var(--banner-buttons-alignment-mobile, flex-start) !important;
				width: 100%;
			}
			/* Removed forced aspect ratios to allow native theme settings (e.g., adapt to image) to work */
			#shopify-section-{{ section.id }} .banner__wrapper .banner__media,
			#shopify-section-{{ section.id }} .banner__wrapper .banner__media-wrapper {
				position: absolute;
				top: 0; left: 0; width: 100%; height: 100%;
			}
			#shopify-section-{{ section.id }} .banner__wrapper {
				position: relative;
				overflow: hidden;
			}
		}
	</style>

	{%- if is_script_needed == true -%}
		{%- render 'adastra' with '/src/scripts/section-banner.js' -%}
	{%- endif -%}
{%- endif -%}

