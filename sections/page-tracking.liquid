{%- comment -%}
------------------------------------------------------------------------------
	Section: Order Tracking page
	- Customer-facing UI only
	- Calls a private backend or Shopify app proxy for multi-carrier tracking data
	- Never store tracking API credentials in Liquid or browser JavaScript
------------------------------------------------------------------------------
{%- endcomment -%}

{%- assign heading        = section.settings.heading -%}
{%- assign subheading     = section.settings.subheading -%}
{%- assign lookup_mode    = section.settings.lookup_mode | default: 'order_lookup' -%}
{%- assign email_placeholder = section.settings.email_placeholder | default: 'Email address' -%}
{%- assign order_placeholder = section.settings.order_placeholder | default: 'Order number' -%}
{%- assign placeholder    = section.settings.placeholder -%}
{%- assign button_label   = section.settings.button_label -%}
{%- assign tracking_mode  = section.settings.tracking_mode | default: 'backend' -%}
{%- assign endpoint_url   = section.settings.endpoint_url | default: 'https://camosignal-order-tracking.camosignal.workers.dev' -%}
{%- assign request_method = section.settings.request_method | default: 'POST' -%}
{%- assign bg_color       = section.settings.bg_color -%}
{%- assign text_color     = section.settings.text_color -%}
{%- assign accent_color   = section.settings.accent_color -%}
{%- assign is_split_layout = false -%}
{%- if lookup_mode == 'split_lookup' or lookup_mode == 'order_lookup' -%}
	{%- assign is_split_layout = true -%}
{%- endif -%}

<section
	id="cs-tracking-{{ section.id }}"
	class="page-tracking"
	style="
		--pt-bg: {{ bg_color }};
		--pt-text: {{ text_color }};
		--pt-accent: {{ accent_color }};
	"
	data-lookup-mode="{{ lookup_mode | escape }}"
	data-mode="{{ tracking_mode | escape }}"
	data-endpoint="{{ endpoint_url | escape }}"
	data-method="{{ request_method | escape }}"
>
	<div class="page-tracking__container">
		{%- if heading != blank -%}
			<h1 class="page-tracking__heading">{{ heading | escape }}</h1>
		{%- endif -%}

		{%- if subheading != blank -%}
			<p class="page-tracking__subheading">{{ subheading | escape }}</p>
		{%- endif -%}

		<div class="page-tracking__panel{% if is_split_layout %} page-tracking__panel--split{% endif %}">
			{%- if is_split_layout -%}
				<div class="page-tracking__split">
					<form class="page-tracking__stack-form" data-order-form novalidate>
						<label class="page-tracking__field page-tracking__field--order">
							<span class="page-tracking__field-title">Order Number</span>
							<input
								class="page-tracking__input"
								type="text"
								name="orderNumber"
								placeholder="{{ order_placeholder | escape }}"
								autocomplete="off"
								autocorrect="off"
								autocapitalize="characters"
								spellcheck="false"
								minlength="2"
								maxlength="32"
								required
								data-order-number
							/>
						</label>
						<label class="page-tracking__field page-tracking__field--email">
							<span class="page-tracking__field-title">Email</span>
							<input
								class="page-tracking__input"
								type="email"
								name="email"
								placeholder="{{ email_placeholder | escape }}"
								autocomplete="email"
								autocorrect="off"
								autocapitalize="off"
								spellcheck="false"
								maxlength="254"
								required
								data-order-email
							/>
						</label>
						<label class="page-tracking__bot-field" aria-hidden="true">
							<span>Company</span>
							<input type="text" name="company" tabindex="-1" autocomplete="off" data-track-honeypot />
						</label>
						<button class="page-tracking__button" type="submit" data-track-button>
							<span class="page-tracking__button-label">{{ button_label | escape }}</span>
							<span class="page-tracking__spinner" aria-hidden="true"></span>
						</button>
					</form>

					<div class="page-tracking__divider" aria-hidden="true">
						<span>OR</span>
					</div>

					<form class="page-tracking__stack-form" data-tracking-form novalidate>
						<label class="page-tracking__field">
							<span class="page-tracking__field-title">Tracking Number</span>
							<input
								class="page-tracking__input"
								type="text"
								name="trackingNumber"
								placeholder="{{ placeholder | escape }}"
								autocomplete="off"
								autocorrect="off"
								autocapitalize="characters"
								spellcheck="false"
								minlength="4"
								maxlength="48"
								required
								data-track-input
							/>
						</label>
						<label class="page-tracking__bot-field" aria-hidden="true">
							<span>Company</span>
							<input type="text" name="company" tabindex="-1" autocomplete="off" data-track-honeypot />
						</label>
						<button class="page-tracking__button" type="submit" data-track-button>
							<span class="page-tracking__button-label">{{ button_label | escape }}</span>
							<span class="page-tracking__spinner" aria-hidden="true"></span>
						</button>
					</form>
				</div>
			{%- else -%}
				<form class="page-tracking__form" data-track-form novalidate>
					{%- if lookup_mode == 'order_lookup' -%}
						<label class="page-tracking__field page-tracking__field--email">
							<span class="page-tracking__field-label">Email address</span>
							<input
								class="page-tracking__input"
								type="email"
								name="email"
								placeholder="{{ email_placeholder | escape }}"
								autocomplete="email"
								autocorrect="off"
								autocapitalize="off"
								spellcheck="false"
								maxlength="254"
								required
								data-order-email
							/>
						</label>
						<label class="page-tracking__field page-tracking__field--order">
							<span class="page-tracking__field-label">Order number</span>
							<input
								class="page-tracking__input"
								type="text"
								name="orderNumber"
								placeholder="{{ order_placeholder | escape }}"
								autocomplete="off"
								autocorrect="off"
								autocapitalize="characters"
								spellcheck="false"
								minlength="2"
								maxlength="32"
								required
								data-order-number
							/>
						</label>
					{%- else -%}
						<label class="page-tracking__field">
							<span class="page-tracking__field-label">Tracking number</span>
							<input
								class="page-tracking__input"
								type="text"
								name="trackingNumber"
								placeholder="{{ placeholder | escape }}"
								autocomplete="off"
								autocorrect="off"
								autocapitalize="characters"
								spellcheck="false"
								minlength="4"
								maxlength="48"
								required
								data-track-input
							/>
						</label>
					{%- endif -%}
					<label class="page-tracking__bot-field" aria-hidden="true">
						<span>Company</span>
						<input type="text" name="company" tabindex="-1" autocomplete="off" data-track-honeypot />
					</label>
					<button class="page-tracking__button" type="submit" data-track-button>
						<span class="page-tracking__button-label">{{ button_label | escape }}</span>
						<span class="page-tracking__spinner" aria-hidden="true"></span>
					</button>
				</form>
			{%- endif -%}
		</div>

		<div class="page-tracking__error" data-track-error role="alert" hidden></div>

		<div class="page-tracking__widget-shell" data-17track-shell hidden>
			<div id="YQContainer-{{ section.id }}" class="page-tracking__widget-container" data-17track-container></div>
			<div class="page-tracking__widget-mask-top" aria-hidden="true"></div>
			<div class="page-tracking__widget-mask-bottom" aria-hidden="true"></div>
		</div>

		<div class="page-tracking__result" data-track-result aria-live="polite" hidden>
			<header class="cs-result__header">
				<div class="cs-result__status">
					<span class="cs-result__status-icon" data-status="pending" aria-hidden="true"></span>
					<div class="cs-result__status-text">
						<span class="cs-result__status-label">-</span>
						<span class="cs-result__status-sub">-</span>
					</div>
				</div>

				<div class="cs-result__meta">
					<div class="cs-result__meta-row"><span>Tracking #</span><strong data-field="number">-</strong></div>
					<div class="cs-result__meta-row"><span>Carrier</span><strong data-field="carrier">-</strong></div>
					<div class="cs-result__meta-row"><span>Service</span><strong data-field="service">-</strong></div>
					<div class="cs-result__meta-row cs-result__meta-row--delivery"><span>Estimated delivery</span><strong data-field="delivery">-</strong></div>
					<div class="cs-result__meta-row"><span>Origin / Destination</span><strong data-field="route">-</strong></div>
					<a class="cs-result__link" href="#" target="_blank" rel="noopener noreferrer" data-field="official-link" hidden>Open tracking page</a>
				</div>
			</header>

			<ol class="cs-result__timeline" data-field="timeline"></ol>
		</div>
	</div>
</section>

<style>
	@import url('https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&display=swap');

	.page-tracking {
		background: var(--pt-bg, #ffffff);
		color: var(--pt-text, #2c3d33);
		padding: 72px 20px 92px;
		font-family: 'Outfit', sans-serif;
	}

	.page-tracking__container {
		max-width: 1080px;
		margin: 0 auto;
	}

	.page-tracking__heading {
		margin: 0 0 14px;
		color: var(--pt-text);
		font-family: 'Outfit', sans-serif;
		font-size: 46px;
		font-weight: 700;
		letter-spacing: 0.5px;
		line-height: 1.1;
		text-align: center;
		text-transform: uppercase;
	}

	.page-tracking__subheading {
		max-width: 640px;
		margin: 0 auto 44px;
		font-size: 18px;
		line-height: 1.6;
		text-align: center;
		opacity: 0.82;
	}

	.page-tracking__panel {
		max-width: 860px;
		margin: 0 auto;
		padding: 14px;
		border: 1px solid rgba(44, 61, 51, 0.14);
		border-radius: 8px;
		background: #ffffff;
		box-shadow: 0 16px 38px rgba(21, 32, 27, 0.06), 0 1px 2px rgba(0, 0, 0, 0.03);
	}

	.page-tracking__panel--split {
		max-width: 1040px;
		padding: 52px 70px;
		box-shadow: 0 18px 46px rgba(21, 32, 27, 0.07), 0 1px 2px rgba(0, 0, 0, 0.03);
	}

	.page-tracking__split {
		display: grid;
		grid-template-columns: minmax(0, 1fr) 76px minmax(0, 1fr);
		gap: 38px;
		align-items: start;
	}

	.page-tracking__stack-form {
		display: grid;
		gap: 20px;
		align-items: start;
		margin: 0;
	}

	.page-tracking__form {
		display: flex;
		gap: 12px;
		justify-content: center;
		align-items: stretch;
		margin: 0;
	}

	.page-tracking__field {
		position: relative;
		flex: 1 1 420px;
		min-width: 0;
		margin: 0;
	}

	.page-tracking__field--email {
		flex-basis: 320px;
	}

	.page-tracking__field--order {
		flex-basis: 220px;
	}

	.page-tracking__split .page-tracking__field {
		flex: none;
	}

	.page-tracking__field-title {
		display: block;
		margin: 0 0 8px;
		color: var(--pt-text);
		font-size: 13px;
		font-weight: 700;
		letter-spacing: 0.5px;
		line-height: 1.25;
		text-transform: uppercase;
	}

	.page-tracking__divider {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 132px;
		color: rgba(44, 61, 51, 0.76);
		font-size: 13px;
		font-weight: 700;
		letter-spacing: 0.5px;
		line-height: 1;
	}

	.page-tracking__divider::before {
		content: "";
		position: absolute;
		top: 0;
		bottom: 0;
		left: 50%;
		border-left: 1px dashed rgba(44, 61, 51, 0.24);
	}

	.page-tracking__divider span {
		position: relative;
		z-index: 1;
		padding: 10px 0;
		background: #ffffff;
	}

	.page-tracking__bot-field {
		position: absolute;
		left: -10000px;
		width: 1px;
		height: 1px;
		opacity: 0;
		overflow: hidden;
		pointer-events: none;
	}

	.page-tracking__field-label {
		position: absolute;
		width: 1px;
		height: 1px;
		margin: -1px;
		padding: 0;
		overflow: hidden;
		clip: rect(0 0 0 0);
		border: 0;
		white-space: nowrap;
	}

	.page-tracking__input {
		box-sizing: border-box;
		width: 100%;
		height: 56px;
		min-width: 0;
		padding: 0 22px;
		border: 1px solid rgba(44, 61, 51, 0.16);
		border-radius: 8px;
		background: #ffffff;
		color: var(--pt-text);
		font-family: inherit;
		font-size: 15px;
		font-weight: 700;
		letter-spacing: 0;
		outline: none;
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.7), 0 1px 2px rgba(21, 32, 27, 0.04);
		transition: border-color 0.3s, box-shadow 0.3s, background 0.3s;
	}

	.page-tracking__input::placeholder {
		color: rgba(44, 61, 51, 0.48);
		font-weight: 600;
	}

	.page-tracking__split .page-tracking__input {
		height: 48px;
		padding-inline: 22px;
		border: 1px solid rgba(44, 61, 51, 0.36);
		border-radius: 6px;
		box-shadow: none;
		font-size: 14px;
		font-weight: 600;
	}

	.page-tracking__split .page-tracking__input::placeholder {
		color: rgba(44, 61, 51, 0.52);
		font-weight: 500;
	}

	.page-tracking__input:focus {
		background: #ffffff;
		border-color: var(--pt-accent);
		box-shadow: 0 0 0 3px rgba(44, 61, 51, 0.1), 0 1px 2px rgba(21, 32, 27, 0.05);
	}

	.page-tracking__button {
		position: relative;
		flex: 0 0 auto;
		min-width: 138px;
		min-height: 56px;
		padding: 0 28px;
		border: none;
		border-radius: 8px;
		background: var(--pt-accent);
		color: #fff;
		cursor: pointer;
		font-family: 'Outfit', sans-serif;
		font-size: 16px;
		font-weight: 700;
		letter-spacing: 1px;
		line-height: 1.2;
		text-transform: uppercase;
		transition: all 0.3s ease;
		box-shadow: 0 4px 12px rgba(44, 61, 51, 0.15);
	}

	.page-tracking__split .page-tracking__button {
		width: 132px;
		min-width: 132px;
		min-height: 50px;
		height: 50px;
		padding: 0 22px;
		border-radius: 6px;
		background: var(--pt-accent);
		box-shadow: 0 8px 18px rgba(44, 61, 51, 0.14);
		font-size: 13px;
		font-weight: 700;
		letter-spacing: 0.6px;
		text-transform: uppercase;
	}

	.page-tracking__button:hover {
		transform: translateY(-2px);
		box-shadow: 0 8px 24px rgba(44, 61, 51, 0.25);
		opacity: 0.95;
	}

	.page-tracking__button:active {
		transform: translateY(1px);
	}

	.page-tracking__button[disabled] {
		cursor: wait;
		opacity: 0.72;
	}

	.page-tracking__button[data-loading="true"] .page-tracking__button-label {
		visibility: hidden;
	}

	.page-tracking__spinner {
		position: absolute;
		top: 50%;
		left: 50%;
		display: none;
		width: 18px;
		height: 18px;
		margin: -9px 0 0 -9px;
		border: 2px solid rgba(255, 255, 255, 0.4);
		border-top-color: #fff;
		border-radius: 50%;
		animation: csTrackingSpin 0.7s linear infinite;
	}

	.page-tracking__button[data-loading="true"] .page-tracking__spinner {
		display: block;
	}

	@keyframes csTrackingSpin {
		to {
			transform: rotate(360deg);
		}
	}

	.page-tracking__error {
		max-width: 860px;
		margin: 14px auto 0;
		padding: 14px 18px;
		border: 1px solid #f5c2c0;
		border-radius: 6px;
		background: #fdecec;
		color: #9f1c15;
		font-size: 14px;
		line-height: 1.45;
	}

	.page-tracking__error[hidden] {
		display: none !important;
	}

	.page-tracking__widget-shell {
		position: relative;
		max-width: 880px;
		margin: 18px auto 0;
		overflow: hidden;
		border: 1px solid rgba(44, 61, 51, 0.14);
		border-radius: 8px;
		background: #fff;
		box-shadow: 0 18px 44px rgba(21, 32, 27, 0.1);
		height: 548px;
	}

	.page-tracking__widget-shell[hidden] {
		display: none;
	}

	.page-tracking__widget-container {
		height: 760px;
		background: #fff;
		transform: translateY(-58px);
		transform-origin: top left;
	}

	.page-tracking__widget-container iframe {
		display: block;
		width: 100% !important;
		max-width: 100% !important;
		height: 760px !important;
		min-height: 760px;
		border: 0 !important;
	}

	.page-tracking__widget-mask-top,
	.page-tracking__widget-mask-bottom {
		position: absolute;
		left: 0;
		z-index: 2;
		width: 100%;
		background: #fff;
		pointer-events: none;
	}

	.page-tracking__widget-mask-top {
		top: 0;
		height: 0;
	}

	.page-tracking__widget-mask-bottom {
		bottom: 0;
		height: 0;
	}

	.page-tracking__widget-container [class*="ad" i],
	.page-tracking__widget-container [id*="ad" i],
	.page-tracking__widget-container [class*="banner" i],
	.page-tracking__widget-container [id*="banner" i],
	.page-tracking__widget-container [class*="promo" i],
	.page-tracking__widget-container [id*="promo" i],
	.page-tracking__widget-container [class*="recommend" i],
	.page-tracking__widget-container [id*="recommend" i],
	.page-tracking__widget-container [class*="download" i],
	.page-tracking__widget-container [id*="download" i],
	.page-tracking__widget-container [href*="apps.shopify.com" i],
	.page-tracking__widget-container [href*="/en/api" i],
	.page-tracking__widget-container [href*="17track.net/en/api" i] {
		display: none !important;
		visibility: hidden !important;
		height: 0 !important;
		min-height: 0 !important;
		margin: 0 !important;
		padding: 0 !important;
		overflow: hidden !important;
	}

	.page-tracking__result {
		max-width: 860px;
		margin: 32px auto 0;
		overflow: hidden;
		border: 1px solid rgba(0, 0, 0, 0.05);
		border-radius: 20px;
		background: #ffffff;
		box-shadow: 0 24px 48px rgba(0, 0, 0, 0.06), 0 4px 12px rgba(0,0,0,0.02);
		animation: csFadeInUp 0.6s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.page-tracking__result[hidden] {
		display: none !important;
	}

	@keyframes csFadeInUp {
		from { opacity: 0; transform: translateY(20px); }
		to { opacity: 1; transform: translateY(0); }
	}

	.cs-result__header {
		display: grid;
		grid-template-columns: minmax(0, 1fr);
		gap: 24px;
		padding: 32px;
		border-bottom: 1px solid rgba(0, 0, 0, 0.05);
		background: #fcfdfc;
	}

	.cs-result__status {
		display: flex;
		align-items: center;
		gap: 20px;
		min-width: 0;
	}

	.cs-result__status-icon {
		position: relative;
		display: inline-flex;
		flex: 0 0 auto;
		align-items: center;
		justify-content: center;
		width: 64px;
		height: 64px;
		border-radius: 20px;
		background: rgba(44, 61, 51, 0.05);
		transition: all 0.3s ease;
	}

	.cs-result__status-icon::before {
		display: block;
		width: 32px;
		height: 32px;
		background: currentColor;
		content: "";
		-webkit-mask: center / contain no-repeat;
		mask: center / contain no-repeat;
	}

	.cs-result__status-icon[data-status="pending"] { color: #6b7280; background: #f3f4f6; }
	.cs-result__status-icon[data-status="intransit"] { color: #b27213; background: rgba(178, 114, 19, 0.12); box-shadow: 0 0 0 5px rgba(178, 114, 19, 0.08); }
	.cs-result__status-icon[data-status="delivered"] { color: #059669; background: #d1fae5; box-shadow: 0 0 0 4px rgba(167,243,208,0.4); }
	.cs-result__status-icon[data-status="exception"] { color: #dc2626; background: #fee2e2; box-shadow: 0 0 0 4px rgba(254,202,202,0.4); }
	.cs-result__status-icon[data-status="pickup"] { color: #2563eb; background: #dbeafe; box-shadow: 0 0 0 4px rgba(191,219,254,0.4); }

	.cs-result__status-icon[data-status="pending"]::before {
		-webkit-mask-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'><path fill='%23000' d='M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20Zm1 5h-2v6l5 3 1-1.7-4-2.3V7Z'/></svg>");
	}
	.cs-result__status-icon[data-status="intransit"]::before {
		width: 27px;
		height: 27px;
		-webkit-mask-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none'><path d='M3.5 7.5h10v8h-2.1' stroke='%23000' stroke-width='1.9' stroke-linecap='round' stroke-linejoin='round'/><path d='M6.4 15.5H3.5v-5.3' stroke='%23000' stroke-width='1.9' stroke-linecap='round' stroke-linejoin='round'/><path d='M13.5 10h3.8l2.7 3.2v2.3h-2.1' stroke='%23000' stroke-width='1.9' stroke-linecap='round' stroke-linejoin='round'/><path d='M13.5 15.5h1.8' stroke='%23000' stroke-width='1.9' stroke-linecap='round'/><circle cx='8.9' cy='15.5' r='2.1' stroke='%23000' stroke-width='1.9'/><circle cx='17.4' cy='15.5' r='2.1' stroke='%23000' stroke-width='1.9'/><path d='M3.5 10.2h5.2' stroke='%23000' stroke-width='1.9' stroke-linecap='round'/></svg>");
