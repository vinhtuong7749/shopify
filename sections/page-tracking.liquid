</style>

<script>
(function () {
	var section = document.getElementById('cs-tracking-{{ section.id }}');
	if (!section) return;

	var lookupMode = (section.dataset.lookupMode || 'tracking_number').trim();
	var mode = (section.dataset.mode || 'direct_link').trim();
	var endpoint = (section.dataset.endpoint || '').trim();
	var method = (section.dataset.method || 'GET').toUpperCase();
	var form = section.querySelector('[data-track-form]');
	var orderForm = section.querySelector('[data-order-form]');
	var trackingForm = section.querySelector('[data-tracking-form]');
	var trackingInput = section.querySelector('[data-track-input]');
	var emailInput = section.querySelector('[data-order-email]');
	var orderInput = section.querySelector('[data-order-number]');
	var buttons = Array.prototype.slice.call(section.querySelectorAll('[data-track-button]'));
	var errEl = section.querySelector('[data-track-error]');
	var resEl = section.querySelector('[data-track-result]');
	var widgetShell = section.querySelector('[data-17track-shell]');
	var widgetContainer = section.querySelector('[data-17track-container]');
	var yqLoadingPromise = null;
	var formStartedAt = Date.now();

	function stripTags(value) {
		if (value === null || value === undefined) return '';
		return String(value).replace(/<[^>]*>/g, '').replace(/\s+/g, ' ').trim();
	}

	function compact(parts) {
		return parts.map(stripTags).filter(Boolean);
	}

	function joinLocation(parts) {
		return compact(parts).join(', ');
	}

	function showError(message) {
		resEl.hidden = true;
		widgetShell.hidden = true;
		errEl.hidden = false;
		errEl.textContent = message;
		scrollToTrackingOutput(errEl);
	}

	function clearStates() {
		errEl.hidden = true;
		errEl.textContent = '';
		resEl.hidden = true;
		widgetShell.hidden = true;
	}

	function scrollToTrackingOutput(target) {
		if (!target || target.hidden || !window.matchMedia || !window.matchMedia('(max-width: 700px)').matches) return;

		window.setTimeout(function () {
			var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
			var top = target.getBoundingClientRect().top + window.pageYOffset - 92;

			window.scrollTo({
				top: Math.max(top, 0),
				behavior: reduceMotion ? 'auto' : 'smooth'
			});
		}, 80);
	}

	function setLoading(isLoading, sourceForm) {
		var activeButtons = sourceForm ? Array.prototype.slice.call(sourceForm.querySelectorAll('[data-track-button]')) : buttons;
		var activeFields = sourceForm ?
			Array.prototype.slice.call(sourceForm.querySelectorAll('[data-track-input], [data-order-email], [data-order-number]')) :
			[trackingInput, emailInput, orderInput];

		activeButtons.forEach(function (button) {
			button.disabled = !!isLoading;
			if (isLoading) {
				button.setAttribute('data-loading', 'true');
			} else {
				button.removeAttribute('data-loading');
			}
		});
		activeFields.forEach(function (field) {
			if (field) field.disabled = !!isLoading;
		});
	}

	function getHoneypotValue(sourceForm) {
		var field = sourceForm ? sourceForm.querySelector('[data-track-honeypot]') : section.querySelector('[data-track-honeypot]');
		return field ? field.value : '';
	}

	function isDisplayableValue(value) {
		var text = stripTags(value);
		if (!text) return false;
		return !/^(?:-|n\/a|not available|unknown|null|undefined)$/i.test(text);
	}

	function setField(selector, value) {
		var el = resEl.querySelector(selector);
		if (!el) return;

		var text = stripTags(value);
		var row = el.closest ? el.closest('.cs-result__meta-row') : null;
		var isVisible = isDisplayableValue(text);

		el.textContent = isVisible ? text : '';
		if (row) row.hidden = !isVisible;
	}

	function setOfficialLink(carrier) {
		var link = resEl.querySelector('[data-field="official-link"]');
		if (!link) return;

		if (!carrier || !carrier.url) {
			link.hidden = true;
			link.removeAttribute('href');
			return;
		}

		link.href = carrier.url;
		link.textContent = carrier.linkLabel || ('Open ' + carrier.name + ' tracking');
		link.hidden = false;
	}

	function normalizeTrackingNumber(value) {
		return String(value || '').trim().replace(/\s+/g, '').toUpperCase();
	}

	function isValidTrackingNumber(value) {
		return /^[A-Z0-9]{4,34}$/.test(value);
	}

	function normalizeEmail(value) {
		return String(value || '').trim().toLowerCase();
	}

	function isValidEmail(value) {
		return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value) && value.length <= 254;
	}

	function normalizeOrderNumber(value) {
		return String(value || '').trim().replace(/\s+/g, '').replace(/^#+/, '').toUpperCase();
	}

	function isValidOrderNumber(value) {
		return /^[A-Z0-9-]{2,32}$/.test(value);
	}

	function detectCarrier(trackingNumber) {
		var number = normalizeTrackingNumber(trackingNumber);

		if (/^YT\d{16}$/i.test(number)) {
			return {
				name: 'YunExpress',
				service: 'Official YunTrack page',
				url: 'https://www.yuntrack.com/parcelTracking?id=' + encodeURIComponent(number)
			};
		}

		if (/^[A-Z]{2}\d{9}US$/i.test(number) || /^(92|93|94|95|96|97)\d{18,32}$/.test(number)) {
			return {
				name: 'USPS',
				service: 'Official USPS tracking page',
				url: 'https://tools.usps.com/go/TrackConfirmAction?tLabels=' + encodeURIComponent(number)
			};
		}

		if (/^1Z[0-9A-Z]{16}$/i.test(number) || /^T\d{10}$/i.test(number)) {
			return {
				name: 'UPS',
				service: 'Official UPS tracking page',
				url: 'https://www.ups.com/track?tracknum=' + encodeURIComponent(number)
			};
		}

		if (/^JD[0-9A-Z]{18,}$/i.test(number)) {
			return {
				name: 'DHL',
				service: 'Official DHL tracking page',
				url: 'https://www.dhl.com/us-en/home/tracking/tracking-express.html?submit=1&tracking-id=' + encodeURIComponent(number)
			};
		}

		if (/^[A-Z]{2}\d{9}CN$/i.test(number)) {
			return {
				name: 'China Post',
				service: 'Multi-carrier tracking page',
				url: 'https://www.17track.net/en/track?nums=' + encodeURIComponent(number),
				linkLabel: 'Open multi-carrier tracking'
			};
		}

		if (/^[A-Z]{2}\d{9}GB$/i.test(number)) {
			return {
				name: 'Royal Mail',
				service: 'Official Royal Mail tracking page',
				url: 'https://www.royalmail.com/track-your-item#/tracking-results/' + encodeURIComponent(number)
			};
		}

		if (/^\d{12}$/.test(number) || /^\d{15}$/.test(number) || /^\d{20}$/.test(number)) {
			return {
				name: 'FedEx',
				service: 'Official FedEx tracking page',
				url: 'https://www.fedex.com/fedextrack/?trknbr=' + encodeURIComponent(number)
			};
		}

		if (/^\d{10}$/.test(number)) {
			return {
				name: 'DHL',
				service: 'Official DHL tracking page',
				url: 'https://www.dhl.com/us-en/home/tracking/tracking-express.html?submit=1&tracking-id=' + encodeURIComponent(number)
			};
		}

		return {
			name: 'Carrier not detected',
			service: 'Multi-carrier tracking page',
			url: 'https://www.17track.net/en/track?nums=' + encodeURIComponent(number),
			linkLabel: 'Open multi-carrier tracking',
			fallback: true
		};
	}

	function buildEndpointUrl(inputParams, includeQueryParams) {
		if (!endpoint) return '';

		var params = typeof inputParams === 'object' && inputParams !== null ? inputParams : { trackingNumber: inputParams };
		var output = endpoint;

		if (endpoint.indexOf('{trackingNumber}') !== -1) {
			output = output.replace(/\{trackingNumber\}/g, encodeURIComponent(params.trackingNumber || ''));
		}

		if (output.indexOf('{email}') !== -1) {
			output = output.replace(/\{email\}/g, encodeURIComponent(params.email || ''));
		}

		if (output.indexOf('{orderNumber}') !== -1) {
			output = output.replace(/\{orderNumber\}/g, encodeURIComponent(params.orderNumber || ''));
		}

		if (output.indexOf('{orderName}') !== -1) {
			output = output.replace(/\{orderName\}/g, encodeURIComponent(params.orderName || ''));
		}

		if (output !== endpoint) {
			return output;
		}

		var url = new URL(output, window.location.origin);
		if (includeQueryParams === false) {
			return url.toString();
		}

		if (params.trackingNumber && !url.searchParams.has('trackingNumber') && !url.searchParams.has('tracking')) {
			url.searchParams.set('trackingNumber', params.trackingNumber);
		}

		if (params.email && !url.searchParams.has('email')) {
			url.searchParams.set('email', params.email);
		}

		if (params.orderNumber && !url.searchParams.has('orderNumber') && !url.searchParams.has('order') && !url.searchParams.has('name')) {
			url.searchParams.set('orderNumber', params.orderNumber);
		}

		return url.toString();
	}

	function messageFromPayload(payload) {
		if (!payload) return '';
		if (typeof payload === 'string') return payload;
		if (payload.message) return payload.message;
		if (payload.detail) return payload.detail;
		if (payload.title) return payload.title;
		if (payload.error) return messageFromPayload(payload.error);
		if (payload.errors && payload.errors.length) return messageFromPayload(payload.errors[0]);
		return '';
	}

	function fallbackHttpMessage(status) {
		if (status === 400) return lookupMode === 'order_lookup' ? 'Please check your email and order number, then try again.' : 'Please check the tracking number and try again.';
		if (status === 401 || status === 403) return lookupMode === 'order_lookup' ? 'Order tracking access is not authorized yet.' : 'Tracking access is not authorized for this shipment yet.';
		if (status === 404) return 'No matching order with tracking was found yet. Please check your email and order number.';
		if (status === 429) return 'Tracking lookup is busy right now. Please try again in a few minutes.';
		if (status >= 500) return 'Tracking service is temporarily unavailable. Please try again soon.';
		return 'Could not fetch tracking information. Please try again.';
	}

	function parseJsonResponse(response) {
		return response.text().then(function (text) {
			var payload = null;

			if (text) {
				try {
					payload = JSON.parse(text);
				} catch (error) {
					payload = { message: text };
				}
			}

			if (!response.ok) {
				throw new Error(stripTags(messageFromPayload(payload)) || fallbackHttpMessage(response.status));
			}

			return payload;
		});
	}

	function fetchTracking(trackingNumber, sourceForm) {
		var url = buildEndpointUrl(trackingNumber);
		if (!url) {
			return Promise.reject(new Error('Tracking endpoint is not configured yet.'));
		}

		var options = {
			method: method === 'POST' ? 'POST' : 'GET',
			headers: { Accept: 'application/json' },
			credentials: 'same-origin'
		};

		if (options.method === 'POST') {
			options.headers['Content-Type'] = 'application/json';
			options.body = JSON.stringify({
				trackingNumber: trackingNumber,
				trackingNumbers: [trackingNumber],
				website: getHoneypotValue(sourceForm),
				formElapsedMs: Date.now() - formStartedAt
			});
		}

		return fetch(url, options).then(parseJsonResponse);
	}

	function fetchOrderTracking(email, orderNumber, sourceForm) {
		var orderName = '#' + orderNumber;
		var payload = {
			email: email,
			orderNumber: orderNumber,
			orderName: orderName,
			website: getHoneypotValue(sourceForm),
			formElapsedMs: Date.now() - formStartedAt
		};
		var usePost = method === 'POST';
		var url = buildEndpointUrl(payload, !usePost);

		if (!url) {
			return Promise.reject(new Error('Order tracking endpoint is not configured yet.'));
		}

		var options = {
			method: usePost ? 'POST' : 'GET',
			headers: { Accept: 'application/json' },
			credentials: 'same-origin'
		};

		if (usePost) {
			options.headers['Content-Type'] = 'application/json';
			options.body = JSON.stringify(payload);
		}

		return fetch(url, options).then(parseJsonResponse);
	}

	function load17TrackWidget() {
		if (window.YQV5 && typeof window.YQV5.trackSingle === 'function') {
			return Promise.resolve(window.YQV5);
		}

		if (yqLoadingPromise) return yqLoadingPromise;

		yqLoadingPromise = new Promise(function (resolve, reject) {
			var existing = document.querySelector('script[src*="17track.net/externalcall.js"]');

			if (existing) {
				existing.addEventListener('load', function () {
					if (window.YQV5) resolve(window.YQV5);
					else reject(new Error('17TRACK widget did not load correctly.'));
				}, { once: true });
				existing.addEventListener('error', function () {
					reject(new Error('Could not load 17TRACK widget.'));
				}, { once: true });
				return;
			}

			var script = document.createElement('script');
			script.src = 'https://www.17track.net/externalcall.js';
			script.async = true;
			script.onload = function () {
				if (window.YQV5) resolve(window.YQV5);
				else reject(new Error('17TRACK widget did not load correctly.'));
			};
			script.onerror = function () {
				reject(new Error('Could not load 17TRACK widget.'));
			};
			document.body.appendChild(script);
		});

		return yqLoadingPromise;
	}

	function hide17TrackPromos(root) {
		if (!root) return;

		var selectors = [
			'[class*="ad" i]',
			'[id*="ad" i]',
			'[class*="banner" i]',
			'[id*="banner" i]',
			'[class*="promo" i]',
			'[id*="promo" i]',
			'[class*="recommend" i]',
			'[id*="recommend" i]',
			'[class*="download" i]',
			'[id*="download" i]',
			'[href*="apps.shopify.com" i]',
			'[href*="/en/api" i]',
			'[href*="17track.net/en/api" i]'
		];

		root.querySelectorAll(selectors.join(',')).forEach(function (node) {
			node.setAttribute('hidden', 'hidden');
			node.style.setProperty('display', 'none', 'important');
			node.style.setProperty('visibility', 'hidden', 'important');
			node.style.setProperty('height', '0', 'important');
			node.style.setProperty('min-height', '0', 'important');
			node.style.setProperty('margin', '0', 'important');
			node.style.setProperty('padding', '0', 'important');
			node.style.setProperty('overflow', 'hidden', 'important');
		});
	}

	function observe17TrackWidget() {
		if (!window.MutationObserver || !widgetContainer) return;

		hide17TrackPromos(widgetContainer);

		var observer = new MutationObserver(function () {
			hide17TrackPromos(widgetContainer);
		});

		observer.observe(widgetContainer, {
			childList: true,
			subtree: true,
			attributes: true,
			attributeFilter: ['class', 'id', 'href', 'style']
		});

		window.setTimeout(function () {
			observer.disconnect();
		}, 30000);
	}

	function render17TrackWidget(trackingNumber, sourceForm) {
		setLoading(true, sourceForm);
		resEl.hidden = true;
		errEl.hidden = true;
		widgetShell.hidden = false;
		scrollToTrackingOutput(widgetShell);
		widgetContainer.innerHTML = '';

		load17TrackWidget()
			.then(function (YQV5) {
				YQV5.trackSingle({
					YQ_ContainerId: widgetContainer.id,
					YQ_Height: 760,
					YQ_Fc: '0',
					YQ_Lang: 'en',
					YQ_Num: trackingNumber
				});
				observe17TrackWidget();
				window.setTimeout(function () {
					var iframe = widgetContainer.querySelector('iframe');
					if (iframe) {
						iframe.style.setProperty('height', '760px', 'important');
						iframe.style.setProperty('min-height', '760px', 'important');
					}
				}, 500);
			})
			.catch(function (error) {
				showError(error && error.message ? error.message : 'Could not load tracking widget. Please try again.');
			})
			.finally(function () {
				setLoading(false, sourceForm);
			});
	}

	function unwrapPayload(payload) {
		if (!payload) return null;
		if (payload.success === false || payload.ok === false) throw new Error(stripTags(messageFromPayload(payload)) || 'Tracking lookup failed.');
		if (payload.error || (payload.errors && payload.errors.length)) throw new Error(stripTags(messageFromPayload(payload)) || 'Tracking lookup failed.');
		if (Array.isArray(payload)) return payload[0] || null;
		if (payload.tracking) return unwrapPayload(payload.tracking);
		if (payload.track) return unwrapPayload(payload.track);
		if (payload.result) return unwrapPayload(payload.result);
		if (payload.results) return unwrapPayload(payload.results);
		if (payload.data) return unwrapPayload(payload.data);
		if (payload.TrackResults && payload.TrackResults.TrackInfo) return payload.TrackResults.TrackInfo;
		return payload;
	}

	function getTrackingNumber(item, fallback) {
		return stripTags(item.trackingNumber || item.tracking_number || item.associatedTrackingNumber || item.ID || item['@ID'] || fallback);
	}

	function getTrackingUrl(item) {
		return stripTags(item.trackingUrl || item.tracking_url || item.trackingLink || item.tracking_link || item.url || item.URL || '');
	}

	function getCarrierName(item) {
		return stripTags(
			item.carrierName ||
			item.courierName ||
			item.carrier ||
			item.slug ||
			item.courier_slug ||
			item.provider ||
			''
		);
	}

	function getService(item) {
		var services = item.services;
		if (Array.isArray(services)) return services.map(stripTags).filter(Boolean).join(', ');
		return stripTags(services || item.mailClass || item.MailClass || item.service || item.shipmentType || item.shipment_type || '');
	}

	function getDeliveryDate(item) {
		var delivery = item.deliveryDateExpectation || {};
		return delivery.predictedDeliveryDate ||
			delivery.expectedDeliveryDate ||
			delivery.guaranteedDeliveryDate ||
			item.expectedDelivery ||
			item.expectedDeliveryDate ||
			item.estimatedDelivery ||
			item.estimatedDeliveryDate ||
			item.expected_delivery ||
			item.expected_delivery_date ||
			item.estimated_delivery ||
			item.estimated_delivery_date ||
			item.estDeliveryDate ||
			item.eta ||
			item.ExpectedDeliveryDate ||
			item.GuaranteedDeliveryDate ||
			'';
	}

	function getRoute(item) {
		var origin = joinLocation([
			item.originCity,
			item.originState,
			item.originZIPCode || item.originZIP,
			item.originCountry || item.origin_country_region || item.origin_country
		]);
		var destination = joinLocation([
			item.destinationCity,
			item.destinationState,
			item.destinationZIPCode || item.destinationZIP,
			item.destinationCountry || item.destination_country_region || item.destination_country
		]);

		if (origin && destination) return origin + ' / ' + destination;
		return origin || destination || '';
	}

	function getSummary(item) {
		return stripTags(
			item.statusSummary ||
			item.subtagMessage ||
			item.subtag_message ||
			item.TrackSummary ||
			item.summary ||
			item.message ||
			''
		);
	}

	function getEvents(item) {
		var events = item.trackingEvents || item.checkpoints || item.events || item.TrackDetail || [];
		if (!Array.isArray(events)) events = [events];

		return events.map(function (event, index) {
			if (typeof event === 'string') {
				return {
					index: index,
					time: '',
					description: stripTags(event),
					location: '',
					sortTime: 0
				};
			}

			var time = event.GMTTimestamp ||
				event.eventTimestamp ||
				event.checkpoint_time ||
				compact([event.EventDate, event.EventTime]).join(' ') ||
				event.timestamp ||
				event.time ||
				event.date ||
				'';
			var location = event.location || joinLocation([
				event.eventCity || event.EventCity,
				event.city,
				event.eventState || event.EventState,
				event.state,
				event.eventZIPCode || event.EventZIPCode,
				event.postal_code,
				event.eventCountry || event.EventCountry || event.country_region || event.country_region_name
			]);
			var description = event.eventType ||
				event.Event ||
				event.message ||
				event.subtag_message ||
				event.desc ||
				event.description ||
				event.status ||
				event.tag ||
				event.summary ||
				'';
			var sortTime = time ? new Date(time).getTime() : 0;

			return {
				index: index,
				time: stripTags(time),
				description: stripTags(description),
				location: stripTags(location),
				sortTime: isNaN(sortTime) ? 0 : sortTime
			};
		}).filter(function (event) {
			return event.description || event.time || event.location;
		}).sort(function (a, b) {
			if (a.sortTime && b.sortTime && a.sortTime !== b.sortTime) return b.sortTime - a.sortTime;
			return a.index - b.index;
		});
	}

	function mapStatus(statusText) {
		var value = stripTags(statusText).toLowerCase();
		if (!value) return 'pending';
		if (value.indexOf('delivered') !== -1) return 'delivered';
		if (value.indexOf('exception') !== -1 || value.indexOf('alert') !== -1 || value.indexOf('return') !== -1 || value.indexOf('fail') !== -1) return 'exception';
		if (value.indexOf('pickup') !== -1 || value.indexOf('available') !== -1) return 'pickup';
		if (value.indexOf('pending') !== -1 || value.indexOf('info') !== -1 || value.indexOf('pre-shipment') !== -1 || value.indexOf('label') !== -1) return 'pending';
		return 'intransit';
	}

	function formatDate(raw, dateOnly) {
		var value = stripTags(raw);
		if (!value) return '';

		var date = new Date(value);
		if (isNaN(date.getTime())) return value;

		if (dateOnly && /^\d{4}-\d{2}-\d{2}$/.test(value)) {
			return date.toLocaleDateString(undefined, { year: 'numeric', month: 'short', day: '2-digit' });
		}

		return date.toLocaleString(undefined, {
			year: 'numeric',
			month: 'short',
			day: '2-digit',
			hour: '2-digit',
			minute: '2-digit'
		});
	}

	function titleCase(value) {
		return stripTags(value).toLowerCase().replace(/\b[a-z]/g, function (letter) {
			return letter.toUpperCase();
		});
	}

	function formatDeliveryTime(raw) {
		var value = stripTags(raw).replace(/\s+/g, ' ').trim();
		var match = value.match(/^(\d{1,2})(?::(\d{2}))?\s*([ap])\.?m\.?$/i);

		if (!match) {
			return value.replace(/\b(am|pm)\b/gi, function (period) {
				return period.toUpperCase();
			});
		}

		return parseInt(match[1], 10) + ':' + (match[2] || '00') + ' ' + match[3].toUpperCase() + 'M';
	}

	function formatDeliveryEstimate(raw) {
		var value = stripTags(raw).replace(/\s+/g, ' ').trim();
		if (!value) return '';

		var clean = value
			.replace(/^expected\s+delivery\s*(?:by)?\s*/i, '')
			.replace(/^estimated\s+delivery\s*(?:by)?\s*/i, '')
			.trim();
		var parsedDate = new Date(clean);

		if (!isNaN(parsedDate.getTime())) {
			return parsedDate.toLocaleString('en-US', {
				weekday: 'long',
				month: 'long',
				day: 'numeric',
				year: 'numeric',
				hour: 'numeric',
				minute: '2-digit'
			});
		}

		var months = {
			jan: 0,
			feb: 1,
			mar: 2,
			apr: 3,
			may: 4,
			jun: 5,
			jul: 6,
			aug: 7,
			sep: 8,
			oct: 9,
			nov: 10,
			dec: 11
		};
		var match = clean.match(/^(?:(monday|tuesday|wednesday|thursday|friday|saturday|sunday)\s+)?(\d{1,2})\s+([a-z]+)\s+(\d{4})(?:\s+by\s+(.+))?$/i);

		if (match) {
			var day = parseInt(match[2], 10);
			var month = months[match[3].slice(0, 3).toLowerCase()];
			var year = parseInt(match[4], 10);
			if (month === undefined) return clean;

			var date = new Date(year, month, day);
			var weekday = match[1] ? titleCase(match[1]) : date.toLocaleDateString('en-US', { weekday: 'long' });
			var dateText = weekday + ', ' + date.toLocaleDateString('en-US', {
				month: 'long',
				day: 'numeric',
				year: 'numeric'
			});
			var timeText = match[5] ? formatDeliveryTime(match[5]) : '';

			return dateText + (timeText ? ' by ' + timeText : '');
		}

		return clean.replace(/\b(am|pm)\b/gi, function (period) {
			return period.toUpperCase();
		});
	}

	function appendEvent(timeline, event, index) {
		var li = document.createElement('li');
		li.className = 'cs-event' + (index === 0 ? ' cs-event--first' : '');

		if (event.time) {
			var time = document.createElement('div');
			time.className = 'cs-event__time';
			time.textContent = formatDate(event.time, false);
			li.appendChild(time);
		}

		var description = document.createElement('div');
		description.className = 'cs-event__desc';
		description.textContent = event.description || 'Tracking update received.';
		li.appendChild(description);

		if (event.location) {
			var location = document.createElement('div');
			location.className = 'cs-event__loc';
			location.textContent = event.location;
			li.appendChild(location);
		}

		timeline.appendChild(li);
	}

	function render(payload, requestedNumber) {
		setOfficialLink(null);

		var item = unwrapPayload(payload);
		if (!item) {
			showError('No tracking record was found for this number yet.');
			return;
		}

		if (item.error || item.errors) {
			showError(stripTags(messageFromPayload(item)) || 'No tracking record was found for this number yet.');
			return;
		}

		var events = getEvents(item);
		var summary = getSummary(item);
		var rawStatus = stripTags(item.status || '');
		var statusLabel = /^\d+$/.test(rawStatus) ? '' : rawStatus;
		statusLabel = stripTags(statusLabel || item.statusCategory || item.tag || (events[0] && events[0].description) || 'Tracking received');
		var statusSub = summary || (events[0] && events[0].description) || 'Waiting for the latest carrier update.';
		var statusType = mapStatus([item.statusCategory, item.status, item.tag, summary].join(' '));
		var icon = resEl.querySelector('.cs-result__status-icon');
		var timeline = resEl.querySelector('[data-field="timeline"]');

		icon.setAttribute('data-status', statusType);
		resEl.querySelector('.cs-result__status-label').textContent = statusLabel;
		resEl.querySelector('.cs-result__status-sub').textContent = statusSub;

		var carrierName = getCarrierName(item);
		var trackingUrl = '';

		setField('[data-field="number"]', getTrackingNumber(item, requestedNumber));
		setField('[data-field="carrier"]', carrierName);
		setField('[data-field="service"]', getService(item));
		setField('[data-field="delivery"]', formatDeliveryEstimate(getDeliveryDate(item)));
		setField('[data-field="route"]', getRoute(item));
		setOfficialLink(trackingUrl ? {
			name: carrierName || 'carrier',
			url: trackingUrl,
			linkLabel: 'Open tracking page'
		} : null);

		timeline.innerHTML = '';
		if (events.length) {
			events.forEach(function (event, index) {
				appendEvent(timeline, event, index);
			});
		} else {
			appendEvent(timeline, {
				time: '',
				description: summary || 'Tracking has been received. Carrier scan events will appear here when available.',
				location: ''
			}, 0);
		}

		errEl.hidden = true;
		resEl.hidden = false;
		scrollToTrackingOutput(resEl);
	}

	function renderDirectLink(trackingNumber) {
		var carrier = detectCarrier(trackingNumber);

		var icon = resEl.querySelector('.cs-result__status-icon');
		var timeline = resEl.querySelector('[data-field="timeline"]');

		icon.setAttribute('data-status', 'pickup');
		resEl.querySelector('.cs-result__status-label').textContent = carrier.fallback ? 'Carrier not detected' : 'Ready to track';
		resEl.querySelector('.cs-result__status-sub').textContent = carrier.fallback ?
			'Open the multi-carrier page or use the link in your shipping email for the most accurate status.' :
			'Open the official carrier page for live updates.';

		setField('[data-field="number"]', trackingNumber);
		setField('[data-field="carrier"]', carrier.name);
		setField('[data-field="service"]', carrier.service);
		setField('[data-field="delivery"]', '');
		setField('[data-field="route"]', '');
		setOfficialLink(carrier);

		timeline.innerHTML = '';
		appendEvent(timeline, {
			time: '',
			description: carrier.fallback ? 'This number does not match a known carrier pattern yet.' : 'Official carrier tracking page is ready.',
			location: carrier.name
		}, 0);

		if (carrier.fallback) {
			appendEvent(timeline, {
				time: '',
				description: 'For full order details, sign in to your account or open the tracking link from your shipping confirmation email.',
				location: 'Camo Signal'
			}, 1);
		}

		errEl.hidden = true;
		resEl.hidden = false;
		scrollToTrackingOutput(resEl);
	}

	function track(rawValue, sourceForm) {
		var trackingNumber = normalizeTrackingNumber(rawValue);
		clearStates();

		if (!isValidTrackingNumber(trackingNumber)) {
			showError('Please enter a valid tracking number.');
			return;
		}

		if (mode === 'seventeen_track_widget') {
			render17TrackWidget(trackingNumber, sourceForm);
			return;
		}

		if (mode === 'direct_link') {
			renderDirectLink(trackingNumber);
			return;
		}

		setLoading(true, sourceForm);
		fetchTracking(trackingNumber, sourceForm)
			.then(function (payload) {
				render(payload, trackingNumber);
			})
			.catch(function (error) {
				showError(error && error.message ? error.message : 'Could not fetch tracking information. Please try again.');
			})
			.finally(function () {
				setLoading(false, sourceForm);
			});
	}

	function trackOrder(rawEmail, rawOrderNumber, sourceForm) {
		var email = normalizeEmail(rawEmail);
		var orderNumber = normalizeOrderNumber(rawOrderNumber);
		clearStates();

		if (!isValidEmail(email)) {
			showError('Please enter the email address used at checkout.');
			return;
		}

		if (!isValidOrderNumber(orderNumber)) {
			showError('Please enter a valid order number.');
			return;
		}

		setLoading(true, sourceForm);
		fetchOrderTracking(email, orderNumber, sourceForm)
			.then(function (payload) {
				render(payload, orderNumber);
			})
			.catch(function (error) {
				showError(error && error.message ? error.message : 'Could not fetch tracking information. Please try again.');
			})
			.finally(function () {
				setLoading(false, sourceForm);
			});
	}

	if (orderForm) {
		orderForm.addEventListener('submit', function (event) {
			event.preventDefault();
			trackOrder(emailInput ? emailInput.value : '', orderInput ? orderInput.value : '', orderForm);
		});
	}

	if (trackingForm) {
		trackingForm.addEventListener('submit', function (event) {
			event.preventDefault();
			track(trackingInput ? trackingInput.value : '', trackingForm);
		});
	}

	if (form) {
		form.addEventListener('submit', function (event) {
			event.preventDefault();

			if (lookupMode === 'order_lookup') {
				trackOrder(emailInput ? emailInput.value : '', orderInput ? orderInput.value : '', form);
				return;
			}

			track(trackingInput ? trackingInput.value : '', form);
		});
	}

	try {
		var params = new URLSearchParams(window.location.search);
		if (lookupMode === 'order_lookup' || lookupMode === 'split_lookup') {
			var emailPreset = params.get('email');
			var orderPreset = params.get('orderNumber') || params.get('order') || params.get('name');

			if (emailPreset && emailInput) emailInput.value = emailPreset;
			if (orderPreset && orderInput) orderInput.value = orderPreset;
			if (emailPreset && orderPreset) trackOrder(emailPreset, orderPreset, orderForm || form);
		}

		var preset = params.get('trackingNumber') || params.get('tracking') || params.get('nums') || params.get('tn');
		if (preset && trackingInput) {
			trackingInput.value = preset;
			track(preset, trackingForm || form);
		}
	} catch (error) {}
})();
