			color: #2c3d33 !important;
		}
		.product-filters .filter-clear-btn svg {
			display: none !important; /* Hide the X on Bottom Clear All to match screenshot */
		}

		/* Outline unselected size pills */
		.product-filters .custom-pill-list .checkbox__input:not(:checked) + .checkbox__label {
			background: transparent !important;
			color: #2c3d33 !important;
			border: 1px solid #2c3d33 !important;
		}
		/* Hide the pseudo checkboxes on the pills */
		.product-filters .custom-pill-list .checkbox__label::before,
		.product-filters .custom-pill-list .checkbox__label::after {
			display: none !important;
		}
		
