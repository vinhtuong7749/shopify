			text-transform: uppercase !important;
			color: #2c3d33 !important;
			font-weight: 800 !important;
			letter-spacing: 0.05em !important;
			font-size: 16px !important;
		}
		
		.product-filters .checkbox__label {
			font-family: Oswald, sans-serif !important;
			text-transform: uppercase !important;
			color: #2c3d33 !important;
			font-size: 14px !important;
			letter-spacing: 0.02em !important;
		}

		/* Square off checkboxes and make them thick #2c3d33 */
		.product-filters .checkbox__label::before {
			border-radius: 0 !important;
			border: 1px solid #2c3d33 !important;
			background-color: transparent !important;
			width: 18px !important;
			height: 18px !important;
			top: 3px !important;
		}
		
		/* Solid checkbox background when checked */
		.product-filters .checkbox__input:checked + .checkbox__label::before {
			background-color: #2c3d33 !important;
			border-color: #2c3d33 !important;
		}
		
		/* Make checkmark white and sharper */
		.product-filters .checkbox__input:checked + .checkbox__label::after {
			content: "" !important;
			position: absolute !important;
			border-color: white !important;
			border-width: 0 2px 2px 0 !important;
			border-style: solid !important;
			width: 6px !important;
			height: 10px !important;
			top: 5px !important;
			left: 7px !important;
			transform: rotate(45deg) !important;
			box-sizing: border-box !important;
			display: block !important;
		}

		/* Active Filter Pills at the top */
		.product-filters .product-filters-selected__list {
			display: flex !important;
			flex-wrap: wrap !important;
			gap: 8px !important;
			margin-bottom: 25px !important;
		}
		.product-filters .product-filters-selected__item {
			margin: 0 !important;
		}
		.product-filters .product-filters-selected__button,
		.product-filters .custom-pill-list .checkbox__label {
			display: inline-flex !important;
			align-items: center !important;
			background: #2c3d33 !important;
			color: white !important;
			border-radius: 99px !important;
			padding: 4px 16px !important;
			font-family: Oswald, sans-serif !important;
			font-weight: 800 !important;
			font-size: 12px !important;
			text-transform: uppercase !important;
			text-decoration: none !important;
			border: none !important;
			height: auto !important;
			line-height: normal !important;
			cursor: pointer !important;
			letter-spacing: 0.05em !important;
