		.product-filters .product-filters-selected__button svg {
			margin-left: 8px !important;
			width: 10px !important;
			height: 10px !important;
			fill: white !important;
			stroke: white !important;
		}

		/* Bottom Desktop Clear All Button */
		.product-filters .filter-clear-btn,
		.product-filters__form-footer-button.js-reset-filters {
			display: flex !important;
			justify-content: center !important;
			align-items: center !important;
			width: 100% !important;
			background-color: #2c3d33 !important;
			color: white !important;
			font-family: Oswald, sans-serif !important;
			font-weight: 800 !important;
			font-size: 16px !important;
			text-transform: uppercase !important;
			padding: 15px 15px !important;
			border: 2px solid #2c3d33 !important;
			border-radius: 0 !important;
			text-decoration: none !important;
