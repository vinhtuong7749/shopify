		.product-filters .checkbox__label--swatch::before,
		.product-filters .checkbox__label--swatch::after {
			display: none !important; 
		}
		/* Highlight selected color swatch */
		.product-filters .checkbox__input:checked + .checkbox__label--swatch::before {
			display: block !important;
			content: "" !important;
			position: absolute !important;
			top: -4px !important;
			left: -4px !important;
			right: -4px !important;
			bottom: -4px !important;
			border: 2px solid #2c3d33 !important;
			border-radius: 50% !important;
			background: transparent !important;
			width: auto !important;
			height: auto !important;
		}
		.product-filters .checkbox__input:checked + .checkbox__label--swatch::after {
			display: none !important;
		}

		/* Custom color swatches keep the selected ring inside the chip to avoid clipping. */
		.product-filters .checkbox__label--swatch.custom-color-swatch {
			display: inline-flex !important;
			align-items: center !important;
			justify-content: center !important;
			width: 32px !important;
			height: 32px !important;
			min-width: 32px !important;
			min-height: 32px !important;
			padding: 0 !important;
			border: 0 !important;
			box-shadow: none !important;
			overflow: visible !important;
			background: transparent !important;
		}
		.product-filters .checkbox__label--swatch.custom-color-swatch::before,
		.product-filters .checkbox__label--swatch.custom-color-swatch::after,
		.product-filters .checkbox__input:checked + .checkbox__label--swatch.custom-color-swatch::before,
		.product-filters .checkbox__input:checked + .checkbox__label--swatch.custom-color-swatch::after {
			display: none !important;
			content: none !important;
		}
		.product-filters .checkbox__label--swatch.custom-color-swatch .custom-color-swatch__fill {
			display: block !important;
			width: 28px !important;
			height: 28px !important;
			border-radius: 50% !important;
		}
		.product-filters .checkbox__input:checked + .checkbox__label--swatch.custom-color-swatch {
			border: 0 !important;
			box-shadow: none !important;
		}
		.product-filters .checkbox__input:checked + .checkbox__label--swatch.custom-color-swatch .custom-color-swatch__fill {
			box-shadow: inset 0 0 0 2px #2c3d33 !important;
		}
		.product-filters .checkbox__input:checked + .checkbox__label--swatch.custom-color-swatch .custom-color-swatch__fill::after {
			display: block !important;
		}
		
		/* Custom static checkboxes (e.g ALL, BRAND, CLOTHING) */
		.custom-checkbox-icon {
			display: flex !important;
			flex-shrink: 0 !important;
			border-radius: 0 !important;
			border: 1px solid #2c3d33 !important;
			background-color: transparent !important;
			width: 18px !important;
			height: 18px !important;
			min-width: 18px !important;
			position: relative !important;
			margin-right: 8px !important;
			box-sizing: border-box !important;
		}
		.custom-checkbox-icon.is-checked,
		.filter-list__collection-link.is-selected .custom-checkbox-icon,
		.filter-list__collection-link--active .custom-checkbox-icon {
			background-color: #2c3d33 !important;
			border-color: #2c3d33 !important;
		}
		.custom-checkbox-icon.is-checked::after,
		.filter-list__collection-link.is-selected .custom-checkbox-icon::after,
		.filter-list__collection-link--active .custom-checkbox-icon::after {
			content: "" !important;
			position: absolute !important;
			border-right: 2px solid white !important;
			border-bottom: 2px solid white !important;
			width: 6px !important;
			height: 10px !important;
			top: 1px !important;
			left: 5px !important;
			transform: rotate(45deg) !important;
			box-sizing: border-box !important;
		}
	</style>
</section>

