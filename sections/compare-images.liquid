{%- comment -%}
------------------------------------------------------------------------------
	Section: Image compare
------------------------------------------------------------------------------
{%- endcomment -%}

{%- render 'adastra' with '/src/styles/compare-images.scss' -%}

{%- style -%}
	#shopify-section-{{- section.id -}} {
		padding-top: {{- section.settings.offset_top_mobile -}}px;
		padding-bottom: {{- section.settings.offset_bottom_mobile -}}px;
	}

	@media screen and (min-width: 768px) {
		#shopify-section-{{- section.id -}} {
			padding-top: {{- section.settings.offset_top_desktop -}}px;
			padding-bottom: {{- section.settings.offset_bottom_desktop -}}px;
		}
	}
{%- endstyle -%}

{%- assign heading                  = section.settings.heading -%}
{%- assign text                     = section.settings.text -%}
{%- assign desktop_image_height     = section.settings.desktop_image_height -%}
{%- assign mobile_image_height      = section.settings.mobile_image_height -%}
{%- assign background_image         = section.settings.background_image -%}
{%- assign first_image              = section.settings.first_image -%}
{%- assign second_image             = section.settings.second_image -%}
{%- assign full_width               = section.settings.full_width -%}
{%- assign container                = section.settings.container_width -%}

{%- if container == 'inherit' -%}
	{%- assign container_width = settings.container_width -%}
{%- else -%}
	{%- assign container_width = container -%}
{%- endif -%}

{%- capture styles -%}
	--desktop-image-height: {{- desktop_image_height -}}; {{-  -}}
	--mobile-image-height: {{- mobile_image_height -}}; {{-  -}}
	--container-width: {{- container_width -}};
{%- endcapture -%}

{%- capture first_image_focal -%}
	--first-img-pos: {{- first_image.presentation.focal_point -}};
{%- endcapture -%}

{%- capture second_image_focal -%}
	--second-img-pos: {{- second_image.presentation.focal_point -}};
{%- endcapture -%}

<section
	class="image-compare section-animate js-animate {% if request.visual_preview_mode or section.index == 1 %}animated{% endif %}"
	data-section-id="{{- section.id -}}"
	data-section-type="image-compare"
	style="{{- styles -}}"
>
	{%- if heading != blank or text != blank -%}
		<div class="image-compare__header">
			{%- if heading != blank -%}
				<h2 class="image-compare__heading">
					{{- heading -}}
				</h2>
			{%- endif -%}

			{%- if text != blank -%}
				<div class="image-compare__text rte">
					{{- text -}}
				</div>
			{%- endif -%}
		</div>
	{%- endif -%}

	<div class="image-compare__container">
		<div class="image-compare__bg-images-wrapper">
			{%- if background_image != blank -%}
				<picture>
					<source
						srcset="{{ background_image | image_url: height: 384 }} 1x,
								{{ background_image | image_url: height: 768 }} 2x"
						media="(max-width: 375px)"
					/>
					<source
						srcset="{{ background_image | image_url: width: 420 }} 1x,
								{{ background_image | image_url: width: 840 }} 2x"
						media="(max-width: 420px)"
					/>
					<source
						srcset="{{ background_image | image_url: width: 575 }} 1x,
								{{ background_image | image_url: width: 1150 }} 2x"
						media="(max-width: 575px)"
					/>
					<source
						srcset="{{ background_image | image_url: width: 767 }} 1x,
								{{ background_image | image_url: width: 1534 }} 2x"
						media="(max-width: 767px)"
					/>
					<source
						srcset="{{ background_image | image_url: width: 991 }} 1x,
								{{ background_image | image_url: width: 1982 }} 2x"
						media="(max-width: 991px)"
					/>
					<source
						srcset="{{ background_image | image_url: width: 1440 }} 1x,
								{{ background_image | image_url: width: 2880 }} 2x"
						media="(max-width: 1440px)"
					/>
					<source
						 srcset="{{ background_image | image_url: width: 1600 }} 1x,
								 {{ background_image | image_url: width: 3200 }} 2x"
						 media="(max-width: 1600px)"
					/>

					<img
						srcset="{{ background_image | image_url: width: 1920 }} 1x,
								{{ background_image | image_url: width: 3840 }} 2x"
						src="{{ background_image | image_url: width: 1920 }}"
						alt="{{ background_image.alt | escape }}"
						class="image-compare__bg-images-image"
						style="{{ img_focal }}"
						loading="lazy"
						fetchpriority="low"
					/>
				</picture>
			{%- else -%}
				{{- 'lifestyle-2' | placeholder_svg_tag: "image-compare__bg-images-image image-compare__bg-images-image--placeholder" -}}
			{%- endif -%}
		</div>

		<div class="image-compare__wrapper">
			<img-comparison-slider tabindex="0">
				{%- if first_image != blank -%}
					<img slot="first"
						 srcset="{{ first_image | image_url: width: 1920 }} 1x , {{ first_image | image_url: width: 3840 }} 2x"
						 alt="{{- first_image.alt -}}"
						 style="{{- first_image_focal -}}"
						 class="image-compare__image image-compare__image--first"
						{%- if section.index > 1 -%}
							loading="lazy"
						{%- endif -%}

					>
				{%- else -%}
					<div slot="first" class="image-compare__placeholder">
						{{- 'lifestyle-2' | placeholder_svg_tag: 'image-compare__image image-compare__image--placeholder' -}}
					</div>
				{%- endif -%}

				{%- if second_image != blank -%}
					<img slot="second"
						 srcset="{{ second_image | image_url: width: 1920 }} 1x , {{ second_image | image_url: width: 3840 }} 2x"
						 alt="{{- first_image.alt -}}"
						 style="{{- second_image_focal -}}"
						 class="image-compare__image image-compare__image--second"
						{%- if section.index > 1 -%}
							loading="lazy"
						{%- endif -%}
					>
				{%- else -%}
					<div slot="second" class="image-compare__placeholder">
						{{- 'lifestyle-2' | placeholder_svg_tag: 'image-compare__image image-compare__image--placeholder image-compare__image--placeholder-compare' -}}
					</div>
				{%- endif -%}

				<div slot="handle" class="image-compare__handle">
					{%- render "icons", icon: "double-arrow" -%}
				</div>
			</img-comparison-slider>
		</div>
	</div>
</section>

{%- render 'adastra' with '/src/scripts/section-compare-images.js' -%}

