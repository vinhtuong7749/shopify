{%- comment -%}
------------------------------------------------------------------------------
	Section: Images row
------------------------------------------------------------------------------
{%- endcomment -%}

{%- assign enable_color_scheme_inheritance 	= section.settings.enable_color_scheme_inheritance -%}
{%- assign color_scheme      	           	= section.settings.color_scheme -%}

{%- assign heading 			   				= section.settings.heading -%}
{%- assign two_images_layout 			   	= section.settings.two_images_layout -%}
{%- assign image_1 			   				= section.settings.image_1 -%}
{%- assign image_2 			   				= section.settings.image_2 -%}
{%- assign image_3 			   				= section.settings.image_3 -%}

{%- assign container    				   	= section.settings.container_width -%}

{%- if enable_color_scheme_inheritance -%}
	{%- assign color_scheme = settings.main_color_scheme -%}
{%- endif -%}

{%- if container == 'inherit' -%}
	{%- assign container_width = settings.container_width -%}
{%- else -%}
	{%- assign container_width = container -%}
{%- endif -%}

{%- capture section_styles -%}
	--inner-offset-top-desktop: {{- section.settings.inner_offset_top_desktop -}}px; {{- -}}
	--inner-offset-bottom-desktop: {{- section.settings.inner_offset_bottom_desktop -}}px; {{- -}}
	--inner-offset-top-mobile: {{- section.settings.inner_offset_top_mobile -}}px; {{- -}}
	--inner-offset-bottom-mobile: {{- section.settings.inner_offset_bottom_mobile -}}px; {{- -}}
	--container-width: {{ container_width }}; {{-  -}}
{%- endcapture -%}

{%- render 'adastra' with '/src/styles/images-row.scss' -%}

{%- style -%}
	#shopify-section-{{- section.id -}} {
		padding-top: {{- section.settings.offset_top_mobile -}}px;
		padding-bottom: {{- section.settings.offset_bottom_mobile -}}px;
	}

	@media screen and (min-width: 768px) {
		#shopify-section-{{- section.id -}} {
			padding-top: {{- section.settings.offset_top_desktop -}}px;
			padding-bottom: {{- section.settings.offset_bottom_desktop -}}px;
		}
	}
{%- endstyle -%}

{%- assign is_two_images_layout = true -%}

{%- if image_1 != blank and image_2 != blank and image_3 != blank -%}
	{%- assign is_two_images_layout = false -%}
{%- endif -%}

{%- assign min  = 1 -%}
{%- assign max  = 4 -%}
{%- assign diff = max | minus: min -%}

<section
	class="images-row color-{{ color_scheme }} js-animate {% if request.visual_preview_mode or section.index == 1 %}animated{% endif %}"
	style="{{- section_styles -}}"
>
	<div class="images-row__container section-animate container">
		{%- if heading != blank -%}
			<h2 class="images-row__heading">
				{{- heading -}}
			</h2>
		{%- endif -%}

		{%- if is_two_images_layout -%}
			{%- if two_images_layout == 'equal' -%}
				<div class="images-row__row images-row__row--two-images-equal">
					{%- for i in (1..2) -%}
						{%- assign image_prefix = 'image_' | append: i -%}
						{%- assign image = section.settings[image_prefix] -%}
						{%- assign is_lazy = true -%}

						{% if section.index == 1 and i == 1 %}
							{%- assign is_lazy = false -%}
						{% endif %}

						<div class="images-row__col">
							{%- if image != blank -%}
								<picture class="images-row__image-wrapper">
									<source
										srcset="{{ image | image_url: width: 375 }} 1x, {{ image | image_url: width: 750 }} 2x"
										media="(max-width: 375px)"
										width="375"
										height="400"
									/>

									<source
										srcset="{{ image | image_url: width: 420 }} 1x, {{ image | image_url: width: 840 }} 2x"
										media="(max-width: 420px)"
										width="420"
										height="448"
									/>

									<source
										srcset="{{ image | image_url: width: 767 }} 1x, {{ image | image_url: width: 1534 }} 2x"
										media="(max-width: 767px)"
										width="767"
										height="818"
									/>

									<source
										srcset="{{ image | image_url: width: 494 }} 1x, {{ image | image_url: width: 988 }} 2x"
										media="(max-width: 991px)"
										width="494"
										height="510"
									/>

									<source
										srcset="{{ image | image_url: width: 654 }} 1x, {{ image | image_url: width: 1308 }} 2x"
										media="(max-width: 1440px)"
										width="654"
										height="676"
									/>

									<img
										class="images-row__image"
										srcset="{{ image | image_url: width: 838 }} 1x, {{ image | image_url: width: 1676 }} 2x"
										src="{{ image | image_url: width: 838 }}"
										alt="{{ image.alt }}"
										width="838"
										height="866"
										{% if is_lazy %}
											fetchpriority="low"
											loading="lazy"
										{% else %}
											fetchpriority="high"
											loading="eager"
										{% endif %}
										style="--img-pos: {{ image.presentation.focal_point }};"
									/>
								</picture>
							{%- else -%}
								{%- assign random_number        = "now" | date: "%N" | modulo: diff | plus: min -%}
								{%- assign placeholder_svg_name = 'collection-apparel-' | append: random_number -%}

								<div class="images-row__image-wrapper">
									{{- placeholder_svg_name | placeholder_svg_tag: 'images-row__image' -}}
								</div>
							{%- endif -%}
						</div>
					{%- endfor -%}
				</div>
			{%- elsif two_images_layout == 'big-left' -%}
				<div class="images-row__row images-row__row--two-images-big-left">
					{%- for i in (1..2) -%}
						{%- assign image_prefix = 'image_' | append: i -%}
						{%- assign image = section.settings[image_prefix] -%}
						{%- assign is_lazy = true -%}

						{%- if section.index == 1 and i == 1 -%}
							{%- assign is_lazy = false -%}
						{%- endif -%}

						{%- if i == 1 -%}
							{%- assign w_375 = 375 -%}
							{%- assign h_375 = 400 -%}
							{%- assign w_375_2x = 750 -%}
							{%- assign h_375_2x = 800 -%}

							{%- assign w_420 = 420 -%}
							{%- assign h_420 = 448 -%}
							{%- assign w_420_2x = 840 -%}
							{%- assign h_420_2x = 896 -%}

							{%- assign w_767 = 767 -%}
							{%- assign h_767 = 818 -%}
							{%- assign w_767_2x = 1534 -%}
							{%- assign h_767_2x = 1636 -%}

							{%- assign w_991 = 431 -%}
							{%- assign h_991 = 446 -%}
							{%- assign w_991_2x = 862 -%}
							{%- assign h_991_2x = 892 -%}

							{%- assign w_1440 = 656 -%}
							{%- assign h_1440 = 678 -%}
							{%- assign w_1440_2x = 1312 -%}
							{%- assign h_1440_2x = 1356 -%}

							{%- assign w_default = 840 -%}
							{%- assign h_default = 868 -%}
							{%- assign w_default_2x = 1680 -%}
							{%- assign h_default_2x = 1736 -%}
						{%- elsif i == 2 -%}
							{%- assign w_375 = 279 -%}
							{%- assign h_375 = 304 -%}
							{%- assign w_375_2x = 558 -%}
							{%- assign h_375_2x = 608 -%}

							{%- assign w_420 = 312 -%}
							{%- assign h_420 = 340 -%}
							{%- assign w_420_2x = 624 -%}
							{%- assign h_420_2x = 680 -%}

							{%- assign w_767 = 571 -%}
							{%- assign h_767 = 622 -%}
							{%- assign w_767_2x = 1142 -%}
							{%- assign h_767_2x = 1244 -%}

							{%- assign w_991 = 297 -%}
							{%- assign h_991 = 311 -%}
							{%- assign w_991_2x = 594 -%}
							{%- assign h_991_2x = 622 -%}

							{%- assign w_1440 = 451 -%}
							{%- assign h_1440 = 473 -%}
							{%- assign w_1440_2x = 902 -%}
							{%- assign h_1440_2x = 946 -%}

							{%- assign w_default = 578 -%}
							{%- assign h_default = 606 -%}
							{%- assign w_default_2x = 1156 -%}
							{%- assign h_default_2x = 1212 -%}
						{%- endif -%}

						<div class="images-row__col {% if i == 2 %}images-row__col--small{% endif %}">
							{%- if image != blank -%}
								<picture class="images-row__image-wrapper">
									<source
										srcset="{{ image | image_url: width: w_375 }} 1x, {{ image | image_url: width: w_375_2x }} 2x"
										media="(max-width: 375px)"
										width="{{- w_375 -}}"
										height="{{- h_375 -}}"
									/>

									<source
										srcset="{{ image | image_url: width: w_420 }} 1x, {{ image | image_url: width: w_420_2x }} 2x"
										media="(max-width: 420px)"
										width="{{- w_420 -}}"
										height="{{- h_420 -}}"
									/>

									<source
										srcset="{{ image | image_url: width: w_767 }} 1x, {{ image | image_url: width: w_767_2x }} 2x"
										media="(max-width: 767px)"
										width="{{- w_767 -}}"
										height="{{- h_767 -}}"
									/>

									<source
										srcset="{{ image | image_url: width: w_991 }} 1x, {{ image | image_url: width: w_991_2x }} 2x"
										media="(max-width: 991px)"
										width="{{- w_991 -}}"
										height="{{- h_991 -}}"
									/>

									<source
										srcset="{{ image | image_url: width: w_1440 }} 1x, {{ image | image_url: width: w_1440_2x }} 2x"
										media="(max-width: 1440px)"
										width="{{- w_1440 -}}"
										height="{{- h_1440 -}}"
									/>

									<img
										class="images-row__image"
										srcset="{{ image | image_url: width: w_default }} 1x, {{ image | image_url: width: w_default_2x }} 2x"
										src="{{ image | image_url: width: 838 }}"
										alt="{{ image.alt }}"
										width="{{- w_default -}}"
										height="{{- h_default -}}"
										{% if is_lazy %}
											fetchpriority="low"
											loading="lazy"
										{% else %}
											fetchpriority="high"
											loading="eager"
										{% endif %}
										style="--img-pos: {{ image.presentation.focal_point }};"
									/>
								</picture>
							{%- else -%}
								{%- assign random_number        = "now" | date: "%N" | modulo: diff | plus: min -%}
								{%- assign placeholder_svg_name = 'collection-apparel-' | append: random_number -%}

								<div class="images-row__image-wrapper">
									{{- placeholder_svg_name | placeholder_svg_tag: 'images-row__image' -}}
								</div>
							{%- endif -%}
						</div>
					{%- endfor -%}
				</div>
			{%- elsif two_images_layout == 'big-right' -%}
				{%- assign image_1 = section.settings.image_1 -%}
				{%- assign image_2 = section.settings.image_2 -%}
				{%- assign is_lazy = true -%}

				<div class="images-row__row images-row__row--two-images-big-right">
					{%- capture small_image -%}
						{%- if image_1 != blank -%}
							{%- assign w_375 = 279 -%}
							{%- assign h_375 = 304 -%}
							{%- assign w_375_2x = 558 -%}
							{%- assign h_375_2x = 608 -%}

							{%- assign w_420 = 312 -%}
							{%- assign h_420 = 340 -%}
							{%- assign w_420_2x = 624 -%}
							{%- assign h_420_2x = 680 -%}

							{%- assign w_767 = 571 -%}
							{%- assign h_767 = 622 -%}
							{%- assign w_767_2x = 1142 -%}
							{%- assign h_767_2x = 1244 -%}

							{%- assign w_991 = 297 -%}
							{%- assign h_991 = 311 -%}
							{%- assign w_991_2x = 594 -%}
							{%- assign h_991_2x = 622 -%}

							{%- assign w_1440 = 451 -%}
							{%- assign h_1440 = 473 -%}
							{%- assign w_1440_2x = 902 -%}
							{%- assign h_1440_2x = 946 -%}

							{%- assign w_default = 578 -%}
							{%- assign h_default = 606 -%}
							{%- assign w_default_2x = 1156 -%}
							{%- assign h_default_2x = 1212 -%}

							<picture class="images-row__image-wrapper">
								<source
									srcset="{{ image_1 | image_url: width: w_375 }} 1x, {{ image_1 | image_url: width: w_375_2x }} 2x"
									media="(max-width: 375px)"
									width="{{- w_375 -}}"
									height="{{- h_375 -}}"
								/>

								<source
									srcset="{{ image_1 | image_url: width: w_420 }} 1x, {{ image_1 | image_url: width: w_420_2x }} 2x"
									media="(max-width: 420px)"
									width="{{- w_420 -}}"
									height="{{- h_420 -}}"
								/>

								<source
									srcset="{{ image_1 | image_url: width: w_767 }} 1x, {{ image_1 | image_url: width: w_767_2x }} 2x"
									media="(max-width: 767px)"
									width="{{- w_767 -}}"
									height="{{- h_767 -}}"
								/>

								<source
									srcset="{{ image_1 | image_url: width: w_991 }} 1x, {{ image_1 | image_url: width: w_991_2x }} 2x"
									media="(max-width: 991px)"
									width="{{- w_991 -}}"
									height="{{- h_991 -}}"
								/>

								<source
									srcset="{{ image_1 | image_url: width: w_1440 }} 1x, {{ image_1 | image_url: width: w_1440_2x }} 2x"
									media="(max-width: 1440px)"
									width="{{- w_1440 -}}"
									height="{{- h_1440 -}}"
								/>

								<img
									class="images-row__image"
									srcset="{{ image_1 | image_url: width: w_default }} 1x, {{ image_1 | image_url: width: w_default_2x }} 2x"
									src="{{ image_1 | image_url: width: 838 }}"
									alt="{{ image_1.alt }}"
									width="{{- w_default -}}"
									height="{{- h_default -}}"
									{% if section.index == 1 and image_1 != blank %}
										fetchpriority="low"
										loading="lazy"
									{% else %}
										fetchpriority="high"
										loading="eager"
									{% endif %}
									style="--img-pos: {{ image_1.presentation.focal_point }};"
								/>
							</picture>
						{%- else -%}
							{%- assign random_number        = "now" | date: "%N" | modulo: diff | plus: min -%}
							{%- assign placeholder_svg_name = 'collection-apparel-' | append: random_number -%}

							<div class="images-row__image-wrapper">
								{{- placeholder_svg_name | placeholder_svg_tag: 'images-row__image' -}}
							</div>
						{%- endif -%}
					{%- endcapture -%}

					<div class="images-row__col images-row__col--desktop images-row__col--small">
						{{- small_image -}}
					</div>

					<div class="images-row__col">
						{%- if image_2 != blank -%}
							{%- assign w_375 = 375 -%}
							{%- assign h_375 = 400 -%}
							{%- assign w_375_2x = 750 -%}
							{%- assign h_375_2x = 800 -%}

							{%- assign w_420 = 420 -%}
							{%- assign h_420 = 448 -%}
							{%- assign w_420_2x = 840 -%}
							{%- assign h_420_2x = 896 -%}

							{%- assign w_767 = 767 -%}
							{%- assign h_767 = 818 -%}
							{%- assign w_767_2x = 1534 -%}
							{%- assign h_767_2x = 1636 -%}

							{%- assign w_991 = 431 -%}
							{%- assign h_991 = 446 -%}
							{%- assign w_991_2x = 862 -%}
							{%- assign h_991_2x = 892 -%}

							{%- assign w_1440 = 656 -%}
							{%- assign h_1440 = 678 -%}
							{%- assign w_1440_2x = 1312 -%}
							{%- assign h_1440_2x = 1356 -%}

							{%- assign w_default = 840 -%}
							{%- assign h_default = 868 -%}
							{%- assign w_default_2x = 1680 -%}
							{%- assign h_default_2x = 1736 -%}

							<picture class="images-row__image-wrapper">
								<source
									srcset="{{ image_2 | image_url: width: w_375 }} 1x, {{ image_2 | image_url: width: w_375_2x }} 2x"
									media="(max-width: 375px)"
									width="{{- w_375 -}}"
									height="{{- h_375 -}}"
								/>

								<source
									srcset="{{ image_2 | image_url: width: w_420 }} 1x, {{ image_2 | image_url: width: w_420_2x }} 2x"
									media="(max-width: 420px)"
									width="{{- w_420 -}}"
									height="{{- h_420 -}}"
								/>

								<source
									srcset="{{ image_2 | image_url: width: w_767 }} 1x, {{ image_2 | image_url: width: w_767_2x }} 2x"
									media="(max-width: 767px)"
									width="{{- w_767 -}}"
									height="{{- h_767 -}}"
								/>

								<source
									srcset="{{ image_2 | image_url: width: w_991 }} 1x, {{ image_2 | image_url: width: w_991_2x }} 2x"
									media="(max-width: 991px)"
									width="{{- w_991 -}}"
									height="{{- h_991 -}}"
								/>

								<source
									srcset="{{ image_2 | image_url: width: w_1440 }} 1x, {{ image_2 | image_url: width: w_1440_2x }} 2x"
									media="(max-width: 1440px)"
									width="{{- w_1440 -}}"
									height="{{- h_1440 -}}"
								/>

								<img
									class="images-row__image"
									srcset="{{ image_2 | image_url: width: w_default }} 1x, {{ image_2 | image_url: width: w_default_2x }} 2x"
									src="{{ image_2 | image_url: width: 838 }}"
									alt="{{ image_2.alt }}"
									width="{{- w_default -}}"
									height="{{- h_default -}}"
									fetchpriority="high"
									loading="eager"
									style="--img-pos: {{ image_2.presentation.focal_point }};"
								/>
							</picture>
						{%- else -%}
							{%- assign random_number        = "now" | date: "%N" | modulo: diff | plus: min -%}
							{%- assign placeholder_svg_name = 'collection-apparel-' | append: random_number -%}

							<div class="images-row__image-wrapper">
								{{- placeholder_svg_name | placeholder_svg_tag: 'images-row__image' -}}
							</div>
						{%- endif -%}
					</div>

					<div class="images-row__col images-row__col--mobile images-row__col--small">
						{{- small_image -}}
					</div>
				</div>
			{%- endif -%}
		{%- else -%}
			<div class="images-row__row images-row__row--three-images">
				{%- for i in (1..3) -%}
					{%- assign image_prefix = 'image_' | append: i -%}
					{%- assign image = section.settings[image_prefix] -%}
					{%- assign is_lazy = true -%}

					{% if section.index == 1 and i == 1 %}
						{%- assign is_lazy = false -%}
					{% endif %}

					<div class="images-row__col">
						{%- if image != blank -%}
							<picture class="images-row__image-wrapper">
								<source
									srcset="{{ image | image_url: width: 375 }} 1x, {{ image | image_url: width: 750 }} 2x"
									media="(max-width: 375px)"
									width="375"
									height="540"
								/>

								<source
									srcset="{{ image | image_url: width: 420 }} 1x, {{ image | image_url: width: 840 }} 2x"
									media="(max-width: 420px)"
									width="420"
									height="605"
								/>

								<source
									srcset="{{ image | image_url: width: 767 }} 1x, {{ image | image_url: width: 1534 }} 2x"
									media="(max-width: 767px)"
									width="767"
									height="1105"
								/>

								<source
									srcset="{{ image | image_url: width: 328 }} 1x, {{ image | image_url: width: 656 }} 2x"
									media="(max-width: 991px)"
									width="328"
									height="509"
								/>

								<source
									srcset="{{ image | image_url: width: 435 }} 1x, {{ image | image_url: width: 870 }} 2x"
									media="(max-width: 1440px)"
									width="435"
									height="675"
								/>

								<img
									class="images-row__image"
									srcset="{{ image | image_url: width: 557 }} 1x, {{ image | image_url: width: 1114 }} 2x"
									src="{{ image | image_url: width: 557 }}"
									alt="{{ image.alt }}"
									width="557"
									height="866"
									{% if is_lazy %}
										fetchpriority="low"
										loading="lazy"
									{% else %}
										fetchpriority="high"
										loading="eager"
									{% endif %}
									style="--img-pos: {{ image.presentation.focal_point }};"
								/>
							</picture>
						{%- else -%}
							{%- assign random_number        = "now" | date: "%N" | modulo: diff | plus: min -%}
							{%- assign placeholder_svg_name = 'collection-apparel-' | append: random_number -%}

							<div class="images-row__image-wrapper">
								{{- placeholder_svg_name | placeholder_svg_tag: 'images-row__image' -}}
							</div>
						{%- endif -%}
					</div>
				{%- endfor -%}
			</div>
		{%- endif -%}
	</div>
</section>

{%- schema -%}
{
	"name": "Images row",
	"disabled_on": {
		"groups": ["header", "footer", "custom.popup"]
	},
	"settings": [
		{
			"type": "checkbox",
			"id": "enable_color_scheme_inheritance",
			"label": "Enable color scheme inheritance",
			"default": true,
			"info": "When this setting is enabled, the color scheme is inherited from the theme settings."
		},
		{
			"type": "color_scheme",
			"id": "color_scheme",
			"label": "Color scheme",
			"default": "scheme-1"
		},
		{
			"type": "text",
			"id": "heading",
			"label": "Heading",
			"default": "Heading"
		},
		{
			"type": "select",
			"id": "two_images_layout",
			"label": "Two images layout",
			"options": [
				{
					"value": "equal",
					"label": "Equal"
				},
				{
					"value": "big-left",
					"label": "Big image left"
				},
				{
					"value": "big-right",
					"label": "Big image right"
				}
			],
			"default": "big-left"
		},
		{
			"type": "image_picker",
			"id": "image_1",
			"label": "Image"
		},
		{
			"type": "image_picker",
			"id": "image_2",
			"label": "Second image"
		},
		{
