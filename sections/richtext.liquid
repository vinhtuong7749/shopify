{%- comment -%}
------------------------------------------------------------------------------
	Section: Rich text
------------------------------------------------------------------------------
{%- endcomment -%}

{%- assign color_scheme      	           = section.settings.color_scheme -%}
{%- assign enable_color_scheme_inheritance = section.settings.enable_color_scheme_inheritance -%}
{%- assign heading      		           = section.settings.heading -%}
{%- assign label   		           		   = section.settings.label -%}
{%- assign text_content 		           = section.settings.text_content -%}
{%- assign text_alignment 		           = section.settings.text_alignment -%}

{%- assign enable_read_more 	           = section.settings.enable_read_more -%}
{%- assign read_more_text 		           = section.settings.read_more_text -%}
{%- assign show_less_text 		           = section.settings.show_less_text -%}
{%- assign container 			           = section.settings.container_width -%}
{%- assign link 			           	   = section.settings.link -%}
{%- assign link_text 			           = section.settings.link_text -%}

{%- if enable_color_scheme_inheritance -%}
	{%- assign color_scheme = settings.main_color_scheme -%}
{%- endif -%}

{%- if container == 'inherit' -%}
	{%- assign container_width = settings.container_width -%}
{%- else -%}
	{%- assign container_width = container -%}
{%- endif -%}

{%- if heading != blank or text_content != blank -%}
	{%- render 'adastra' with '/src/styles/text-section.scss' -%}

	{%- style -%}
		#shopify-section-{{- section.id -}} {
			padding-top: {{- section.settings.offset_top_mobile -}}px;
			padding-bottom: {{- section.settings.offset_bottom_mobile -}}px;
		}

		@media screen and (min-width: 768px) {
			#shopify-section-{{- section.id -}} {
				padding-top: {{- section.settings.offset_top_desktop -}}px;
				padding-bottom: {{- section.settings.offset_bottom_desktop -}}px;
			}
		}
	{%- endstyle -%}

	{%- capture styles -%}
		--text-align: {{ text_alignment | replace: 'left', 'start' | replace: 'right', 'end' }}; {{-  -}}
		--container-width: {{ container_width }}; {{-  -}}
		--inner-offset-top: {{- section.settings.inner_offset_top -}}px; {{-  -}}
		--inner-offset-bottom: {{- section.settings.inner_offset_bottom -}}px; {{-  -}}
		--inner-offset-top-mobile: {{- section.settings.inner_offset_top_mobile -}}px; {{-  -}}
		--inner-offset-bottom-mobile: {{- section.settings.inner_offset_bottom_mobile -}}px; {{-  -}}
	{%- endcapture -%}

	<section class="text-section js-richtext js-animate color-{{ color_scheme }} {% if request.visual_preview_mode or section.index == 1 %}animated{% endif %}" style="{{ styles }}">
		<div class="container text-section__container section-animate">
			{%- if label != blank -%}
				<p class="text-section__label">{{- label -}}</p>
			{%- endif -%}

			{%- if heading != blank -%}
				<h2 class="text-section__heading h2">
					{{- heading -}}
				</h2>
			{%- endif -%}

			{%- if text_content != blank -%}
				<div id="text-section-content-{{ section.id }}"
					 class="text-section__content {% if enable_read_more %}text-section__content--cut-off{% endif %}"
				>
					<div class="rte">
						{{- text_content -}}
					</div>

					{%- if link != blank and link_text != blank -%}
						<a href="{{ link }}" class="text-section__link button button--primary">
							{{- link_text -}}
						</a>
					{%- endif -%}
				</div>

				{%- if enable_read_more -%}
					<button class="text-section__read-more-button button-link focus-visible-outline js-rich-text-read-more"
							data-read-more-text="{{ read_more_text }}"
							data-show-less-text="{{ show_less_text }}"
							aria-expanded="false"
							aria-controls="text-section-content-{{ section.id }}"
					>
						{%- render 'icons', icon: 'plus' -%}
						<span data-text="{{ read_more_text }}">
							<span>
								{{- read_more_text -}}
							</span>
						</span>
					</button>
				{%- endif -%}
			{%- endif -%}
		</div>
	</section>

	{%- render 'adastra' with '/src/scripts/section-richtext.js' -%}
{%- endif -%}

{%- schema -%}
	{
		"name": "Rich text",
		"disabled_on": {
			"groups": ["header", "footer", "custom.popup"]
		},
		"settings": [
			{
				"type": "header",
				"content": "Colors"
			},
			{
				"type": "checkbox",
				"id": "enable_color_scheme_inheritance",
				"label": "Enable color scheme inheritance",
				"default": true,
				"info": "When this setting is enabled, the color scheme is inherited from the theme settings."
			},
			{
				"type": "color_scheme",
				"id": "color_scheme",
				"label": "Color scheme",
				"default": "scheme-1"
			},
			{
				"type": "header",
				"content": "General"
			},
			{
				"id": "heading",
				"type": "inline_richtext",
				"label": "Heading",
				"default": "Rich <i>text</i>"
			},
			{
				"id": "label",
				"type": "text",
				"label": "Label",
				"default": "Label"
			},
			{
				"id": "text_content",
				"type": "richtext",
				"label": "Text",
				"default": "<p>Add text to share customers about your store, products, brand.</p>"
			},
			{
				"type": "select",
				"id": "text_alignment",
				"label": "Text alignment",
				"options": [
					{
						"value": "left",
						"label": "Left"
					},
					{
						"value": "center",
						"label": "Center"
					},
					{
						"value": "right",
						"label": "Right"
					}
				],
				"default": "left"
			},
			{
				"type": "checkbox",
				"id": "enable_read_more",
				"label": "Enable read more button",
				"default": false,
				"info": "Enable this feature to truncate text and show read more button. Limits the display to 5 lines. Anything after the fifth line is truncated."
			},
			{
				"type": "text",
				"id": "read_more_text",
				"label": "Read more button label",
				"default": "Show more"
			},
			{
				"type": "text",
				"id": "show_less_text",
				"label": "Show less button label",
				"default": "Show less"
			},
			{
				"type": "text",
				"id": "link_text",
				"label": "Link text",
				"default": "Link name"
			},
			{
				"type": "url",
				"id": "link",
				"label": "Link"
			},
			{
				"type": "header",
				"content": "Layout"
			},
			{
				"type": "select",
				"id": "container_width",
				"label": "Container width",
				"options": [
					{
						"value": "1808px",
						"label": "Default - 1680px"
					},
					{
						"value": "2048px",
						"label": "Large - 1920px"
					},
					{
						"value": "100%",
						"label": "Full width"
					},
					{
						"value": "inherit",
						"label": "Inherit of general setting"
					}
				],
				"default": "inherit",
				"info": "if you select 'Inherit of general setting', then container width will be used from the Theme settings/Layout"
			},
			{
				"type": "paragraph",
				"content": "External offsets"
			},
			{
				"type": "range",
				"id": "offset_top_desktop",
				"min": 0,
				"max": 100,
				"step": 1,
				"unit": "px",
				"label": "Desktop external offset top",
				"default": 0
			},
			{
				"type": "range",
				"id": "offset_bottom_desktop",
				"min": 0,
				"max": 100,
				"step": 1,
				"unit": "px",
				"label": "Desktop external offset bottom",
				"default": 0
			},
			{
				"type": "range",
				"id": "offset_top_mobile",
				"min": 0,
				"max": 100,
				"step": 1,
				"unit": "px",
				"label": "Mobile external offset top",
				"default": 0
			},
			{
				"type": "range",
				"id": "offset_bottom_mobile",
				"min": 0,
				"max": 100,
				"step": 1,
				"unit": "px",
				"label": "Mobile external offset bottom",
				"default": 0
			},
			{
				"type": "paragraph",
				"content": "Internal offsets"
			},
			{
				"type": "range",
				"id": "inner_offset_top",
				"min": 0,
				"max": 100,
				"step": 1,
				"unit": "px",
				"label": "Desktop internal offset top",
				"default": 64
			},
			{
				"type": "range",
				"id": "inner_offset_bottom",
				"min": 0,
				"max": 100,
				"step": 1,
				"unit": "px",
				"label": "Desktop internal offset bottom",
				"default": 64
			},
			{
				"type": "range",
				"id": "inner_offset_top_mobile",
				"min": 0,
				"max": 100,
				"step": 1,
				"unit": "px",
				"label": "Mobile internal offset top",
				"default": 32
			},
			{
				"type": "range",
				"id": "inner_offset_bottom_mobile",
				"min": 0,
				"max": 100,
				"step": 1,
				"unit": "px",
				"label": "Mobile internal offset bottom",
				"default": 32
			}
		],
		"presets": [
			{
				"name": "Rich text"
			}
		]
	}
{%- endschema -%}
