{%- comment -%}
------------------------------------------------------------------------------
	Section: Product recommendations
------------------------------------------------------------------------------
{%- endcomment -%}

{%- render 'adastra' with '/src/styles/carousel.scss' -%}
{%- render 'adastra' with '/src/styles/featured-products.scss' -%}
{%- render 'adastra' with '/src/styles/product-card.scss' -%}

{%- assign desktop_limit = section.settings.products_to_show | default: 4 | plus: 0 -%}
{%- assign mobile_limit = section.settings.products_to_show_mobile | default: 6 | plus: 0 -%}
{%- assign limit = desktop_limit -%}
{%- if mobile_limit > limit -%}
	{%- assign limit = mobile_limit -%}
{%- endif -%}

{%- style -%}
	#shopify-section-{{- section.id -}} {
		container-type: inline-size;
		padding-top: {{- section.settings.offset_top_mobile -}}px;
		padding-bottom: {{- section.settings.offset_bottom_mobile -}}px;
	}

	@media screen and (min-width: 768px) {
		#shopify-section-{{- section.id -}} {
			padding-top: {{- section.settings.offset_top_desktop -}}px;
			padding-bottom: {{- section.settings.offset_bottom_desktop -}}px;
		}
	}

	#shopify-section-{{- section.id -}} .product-recommendations__mobile-pagination {
		display: none;
	}

	#shopify-section-{{- section.id -}} .featured-products__header.product-recommendations__header h2 {
		font-size: var(--product-recommendations-heading-size-desktop, {{- section.settings.heading_font_size_desktop | default: 36 -}}px) !important;
	}

	@media screen and (min-width: 768px) {
		#shopify-section-{{- section.id -}} .product-recommendations__slide--desktop-hidden {
			display: none !important;
		}
	}

	{%- if mobile_limit > desktop_limit -%}
		@media screen and (min-width: 768px) {
			#shopify-section-{{- section.id -}} .featured-products__buttons-wrapper {
				display: none !important;
			}

			#shopify-section-{{- section.id -}} .featured-products__slider {
				cursor: default !important;
			}
		}
	{%- endif -%}

	@media screen and (max-width: 767px) {
		#shopify-section-{{- section.id -}} {
			padding-top: max(0px, {{- section.settings.offset_top_mobile | minus: 10 -}}px);
		}

		#shopify-section-{{- section.id -}} .featured-products.product-recommendations {
			padding-top: max(0px, calc(var(--inner-offset-top-mobile) - 10px));
		}

		html body #shopify-section-{{- section.id -}} .featured-products__header.product-recommendations__header {
			position: relative !important;
			display: block !important;
			min-height: 40px !important;
			margin-bottom: 24px !important;
			width: 100%;
			padding-right: 72px !important;
		}

		html body #shopify-section-{{- section.id -}} .featured-products__header.product-recommendations__header h2 {
			margin: 0 !important;
			min-width: 0;
			max-width: 100%;
			min-height: 40px !important;
			display: flex !important;
			align-items: center !important;
			line-height: 1.05;
			font-size: var(--product-recommendations-heading-size-mobile, {{- section.settings.heading_font_size_mobile | default: 22 -}}px) !important;
			white-space: nowrap !important;
			overflow: hidden !important;
			text-overflow: clip !important;
			word-break: normal;
			overflow-wrap: normal;
		}

		html body #shopify-section-{{- section.id -}} .featured-products__header.product-recommendations__header .featured-products__buttons-wrapper {
			position: absolute !important;
			top: 0 !important;
			right: 0 !important;
			display: inline-flex !important;
			flex-direction: row !important;
			flex-wrap: nowrap !important;
			align-items: center;
			flex: 0 0 auto !important;
			margin: 0 !important;
			width: auto !important;
			min-width: 0 !important;
			white-space: nowrap !important;
			transform: none !important;
		}

		html body #shopify-section-{{- section.id -}} .featured-products__header.product-recommendations__header .swiper-button-prev-new,
		html body #shopify-section-{{- section.id -}} .featured-products__header.product-recommendations__header .swiper-button-next-new {
			flex: 0 0 32px !important;
			width: 32px !important;
			height: 40px !important;
		}

		html body #shopify-section-{{- section.id -}} .featured-products__header.product-recommendations__header .swiper-button-prev-new .icon,
		html body #shopify-section-{{- section.id -}} .featured-products__header.product-recommendations__header .swiper-button-next-new .icon {
			width: 14px !important;
			height: 14px !important;
		}

		#shopify-section-{{- section.id -}} .featured-products__slider {
			position: relative !important;
			overflow: hidden !important;
			cursor: grab !important;
			padding-bottom: 0 !important;
			margin-bottom: 0 !important;
		}

		#shopify-section-{{- section.id -}} .container {
			padding-left: 16px !important;
			padding-right: 16px !important;
		}

		#shopify-section-{{- section.id -}} .featured-products__row {
			display: flex !important;
			gap: 0 !important;
			flex-wrap: nowrap !important;
			overflow: visible !important;
			margin-bottom: 0 !important;
			padding-bottom: 0 !important;
		}

		#shopify-section-{{- section.id -}} .featured-products__col {
			display: block !important;
			margin: 0 !important;
			min-width: 0 !important;
			flex-shrink: 0 !important;
		}

		#shopify-section-{{- section.id -}} .product-recommendations__slide--desktop-hidden {
			display: block !important;
		}

		#shopify-section-{{- section.id -}} .product-recommendations__slide--mobile-hidden {
			display: none !important;
		}

		#shopify-section-{{- section.id -}} .featured-products__col:nth-child(n+{{ mobile_limit | plus: 1 }}) {
			display: none !important;
		}

		#shopify-section-{{- section.id -}} .featured-products__slider:not(.swiper-initialized) .featured-products__col {
			width: calc(50% - 6px) !important;
			margin-right: 12px !important;
		}

		#shopify-section-{{- section.id -}} .product-card .product-card__title {
			min-height: auto !important;
			line-height: 1.4 !important;
			display: block !important;
			white-space: nowrap !important;
			overflow: hidden !important;
			text-overflow: ellipsis !important;
			word-break: normal !important;
			overflow-wrap: normal !important;
			-webkit-line-clamp: unset !important;
			-webkit-box-orient: unset !important;
			font-weight: 500 !important;
			text-transform: capitalize !important;
			font-size: 13px !important;
		}

		#shopify-section-{{- section.id -}} .product-card__footer {
			padding: 0 !important;
			margin-top: 5px !important;
		}

		#shopify-section-{{- section.id -}} .product-card__custom-quick-add {
			display: none !important;
		}

		#shopify-section-{{- section.id -}} .product-card__image img {
			filter: brightness(1.03) contrast(0.95) saturate(0.92);
		}

		#shopify-section-{{- section.id -}} .product-card__image {
			border-radius: 10px;
			overflow: hidden;
		}

		#shopify-section-{{- section.id -}} .product-recommendations__mobile-pagination,
		#shopify-section-{{- section.id -}} .product-recommendations__mobile-pagination.swiper-pagination-bullets,
		#shopify-section-{{- section.id -}} .product-recommendations__mobile-pagination.swiper-pagination-horizontal,
		#shopify-section-{{- section.id -}} .product-recommendations .swiper-pagination {
			display: none !important;
			height: 0 !important;
			margin: 0 !important;
			padding: 0 !important;
			visibility: hidden !important;
			pointer-events: none !important;
		}

		#shopify-section-{{- section.id -}} .product-recommendations__mobile-pagination .swiper-pagination-bullet {
			display: block;
			width: 28px;
			height: 2px;
			margin: 0 !important;
			border-radius: 0;
			background: #2c3d33;
			opacity: 0.14;
			transition: opacity 0.25s ease;
		}

		#shopify-section-{{- section.id -}} .product-recommendations__mobile-pagination .swiper-pagination-bullet-active {
			opacity: 1;
		}

		@media screen and (max-width: 374px) {
			html body #shopify-section-{{- section.id -}} .featured-products__header.product-recommendations__header {
				padding-right: 64px !important;
			}

			html body #shopify-section-{{- section.id -}} .featured-products__header.product-recommendations__header .swiper-button-prev-new,
			html body #shopify-section-{{- section.id -}} .featured-products__header.product-recommendations__header .swiper-button-next-new {
				flex-basis: 28px !important;
				width: 28px !important;
				height: 38px !important;
			}
		}
	}

	@container (max-width: 767px) {
		html body #shopify-section-{{- section.id -}} .featured-products__header.product-recommendations__header {
			position: relative !important;
			display: block !important;
			min-height: 40px !important;
			margin-bottom: 24px !important;
			width: 100%;
			padding-right: 72px !important;
		}

		html body #shopify-section-{{- section.id -}} .featured-products__header.product-recommendations__header h2 {
			margin: 0 !important;
			min-width: 0;
			max-width: 100%;
			min-height: 40px !important;
			display: flex !important;
			align-items: center !important;
			line-height: 1.05;
			font-size: var(--product-recommendations-heading-size-mobile, {{- section.settings.heading_font_size_mobile | default: 22 -}}px) !important;
			white-space: nowrap !important;
			overflow: hidden !important;
			text-overflow: clip !important;
			word-break: normal;
			overflow-wrap: normal;
		}

		html body #shopify-section-{{- section.id -}} .featured-products__header.product-recommendations__header .featured-products__buttons-wrapper {
			position: absolute !important;
			top: 0 !important;
			right: 0 !important;
			display: inline-flex !important;
			flex-direction: row !important;
			flex-wrap: nowrap !important;
			align-items: center;
			flex: 0 0 auto !important;
			margin: 0 !important;
			width: auto !important;
			min-width: 0 !important;
			white-space: nowrap !important;
			transform: none !important;
		}

		html body #shopify-section-{{- section.id -}} .featured-products__header.product-recommendations__header .swiper-button-prev-new,
		html body #shopify-section-{{- section.id -}} .featured-products__header.product-recommendations__header .swiper-button-next-new {
			flex: 0 0 32px !important;
			width: 32px !important;
			height: 40px !important;
		}
	}

	html body #shopify-section-{{- section.id -}} .product-recommendations.is-mobile-layout .featured-products__header.product-recommendations__header {
		position: relative !important;
		display: block !important;
		min-height: 40px !important;
		margin-bottom: 24px !important;
		width: 100%;
		padding-right: 72px !important;
	}

	html body #shopify-section-{{- section.id -}} .product-recommendations.is-mobile-layout .featured-products__header.product-recommendations__header h2 {
		margin: 0 !important;
		min-width: 0;
		max-width: 100%;
		min-height: 40px !important;
		display: flex !important;
		align-items: center !important;
		line-height: 1.05;
		font-size: var(--product-recommendations-heading-size-mobile, {{- section.settings.heading_font_size_mobile | default: 22 -}}px) !important;
		white-space: nowrap !important;
		overflow: hidden !important;
		text-overflow: clip !important;
		word-break: normal;
		overflow-wrap: normal;
	}

	html body #shopify-section-{{- section.id -}} .product-recommendations.is-mobile-layout .featured-products__header.product-recommendations__header .featured-products__buttons-wrapper {
		position: absolute !important;
		top: 0 !important;
		right: 0 !important;
		display: inline-flex !important;
		flex-direction: row !important;
		flex-wrap: nowrap !important;
		align-items: center;
		flex: 0 0 auto !important;
		margin: 0 !important;
		width: auto !important;
		min-width: 0 !important;
		white-space: nowrap !important;
		transform: none !important;
	}

	html body #shopify-section-{{- section.id -}} .product-recommendations.is-mobile-layout .featured-products__header.product-recommendations__header .swiper-button-prev-new,
	html body #shopify-section-{{- section.id -}} .product-recommendations.is-mobile-layout .featured-products__header.product-recommendations__header .swiper-button-next-new {
		flex: 0 0 32px !important;
		width: 32px !important;
		height: 40px !important;
	}
{%- endstyle -%}

{%- assign enable_color_scheme_inheritance = section.settings.enable_color_scheme_inheritance -%}
{%- assign color_scheme 				   = section.settings.color_scheme -%}
{%- assign heading    					   = section.settings.heading -%}

{%- if enable_color_scheme_inheritance -%}
	{%- assign color_scheme = settings.main_color_scheme -%}
{%- endif -%}

{%- assign container = section.settings.container_width -%}

{%- if container == 'inherit' -%}
	{%- assign container_width = settings.container_width -%}
{%- else -%}
	{%- assign container_width = container -%}
{%- endif -%}

{%- assign collection = section.settings.collection -%}
{%- assign product_list = collection.products -%}

{%- assign enable_shopify_recommendations = section.settings.enable_shopify_recommendations -%}

{%- liquid
	assign slider_enabled = false

	if enable_shopify_recommendations or product_list.count > 1
		assign slider_enabled = true
	endif

	assign desktop_slider_enabled = slider_enabled

	if mobile_limit > desktop_limit
		assign desktop_slider_enabled = false
	endif
-%}

{%- capture styles -%}
	--container-width: {{- container_width -}};
	--inner-offset-top: {{ section.settings.inner_offset_top }}px;
	--inner-offset-bottom: {{ section.settings.inner_offset_bottom }}px;
	--inner-offset-top-mobile: {{ section.settings.inner_offset_top_mobile }}px;
	--inner-offset-bottom-mobile: {{ section.settings.inner_offset_bottom_mobile }}px;
	--product-recommendations-heading-size-desktop: {{ section.settings.heading_font_size_desktop | default: 36 }}px;
	--product-recommendations-heading-size-mobile: {{ section.settings.heading_font_size_mobile | default: 22 }}px;
{%- endcapture -%}

<section
	class="featured-products product-recommendations section-animate featured-products--layout-4 color-{{ color_scheme.id | default: color_scheme }} js-animate{% if desktop_slider_enabled %} js-featured-products{% endif %}{% if request.visual_preview_mode or section.index == 1 %} animated{% endif %}"
	id="{{- section.id -}}"
	style="{{- styles -}}"
	data-product-id="{{- product.id -}}"
	data-limit="{{- limit -}}"
	data-desktop-limit="{{- desktop_limit -}}"
	data-mobile-limit="{{- mobile_limit -}}"
>
	<div class="container">
		<div class="featured-products__header product-recommendations__header">
			{%- if heading != blank -%}
				<h2>{{- heading -}}</h2>
			{%- endif -%}

			{%- if slider_enabled -%}
				<div class="featured-products__buttons-wrapper product-recommendations__buttons-wrapper">
					<button
						class="focus-visible-outline swiper-button-prev-new js-featured-products-slider-button-prev">
						{%- render 'icons', icon: 'arrow-left' -%}
					</button>

					<button
						class="focus-visible-outline swiper-button-next-new js-featured-products-slider-button-next">
						{%- render 'icons', icon: 'arrow-right' -%}
					</button>
				</div>
			{%- endif -%}
		</div>

		<div class="js-product-recommendations-content">
			<div class="featured-products__slider swiper js-featured-products-slider" data-slides-in-row="4">
				<div class="featured-products__row swiper-wrapper">
					{%- capture slides -%}
						{%- assign image_size        = 439 -%}
						{%- assign image_size_tablet = 328 -%}
						{%- assign image_size_mobile = 308 -%}

						{%- if enable_shopify_recommendations and product != blank -%}
							{%- assign related_collections = product.collections | sort: 'all_products_count' -%}
							{%- assign selected_products = "," -%}
							{%- assign selected_count = 0 -%}

							{%- for related_collection in related_collections limit: 2 -%}
								{%- if selected_count >= limit -%}
									{%- break -%}
								{%- endif -%}

								{%- for related_product in related_collection.products -%}
									{%- if selected_count >= limit -%}
										{%- break -%}
									{%- endif -%}

									{%- if related_product.handle == product.handle -%}
										{%- continue -%}
									{%- endif -%}

									{%- unless related_product.available and related_product.selected_or_first_available_variant.requires_shipping -%}
										{%- continue -%}
									{%- endunless -%}

									{%- assign product_handle = related_product.handle -%}
									{%- assign check_handle = "," | append: product_handle | append: "," -%}
									{%- unless selected_products contains check_handle -%}
										{%- assign is_lazy = true -%}
										{%- if section.index == 1 and selected_count == 0 -%}
											{%- assign is_lazy = false -%}
										{%- endif -%}
										{%- assign selected_products = selected_products | append: product_handle | append: "," -%}
										{%- assign selected_count = selected_count | plus: 1 -%}
										<div class="featured-products__col swiper-slide js-featured-products-slide{% if selected_count > desktop_limit %} product-recommendations__slide--desktop-hidden{% endif %}{% if selected_count > mobile_limit %} product-recommendations__slide--mobile-hidden{% endif %}">
											{%- render
												'product-card',
												product: related_product,
												size: image_size,
												tablet_size: image_size_tablet,
												mobile_size: image_size_mobile,
												is_lazy: is_lazy
											-%}
										</div>
									{%- endunless -%}
								{%- endfor -%}
							{%- endfor -%}
						{%- elsif product_list != blank and product_list.count > 0 -%}
							{%- assign display_count = 0 -%}
							{%- for product in product_list -%}
								{%- if display_count >= limit -%}
									{%- break -%}
								{%- endif -%}

								{%- unless product.selected_or_first_available_variant.requires_shipping -%}{%- continue -%}{%- endunless -%}

								{%- assign is_lazy = true -%}
								{%- if section.index == 1 and display_count == 0 -%}
									{%- assign is_lazy = false -%}
								{%- endif -%}

								{%- assign display_count = display_count | plus: 1 -%}
								<div class="featured-products__col swiper-slide js-featured-products-slide{% if display_count > desktop_limit %} product-recommendations__slide--desktop-hidden{% endif %}{% if display_count > mobile_limit %} product-recommendations__slide--mobile-hidden{% endif %}">
									{%- render
										'product-card',
										product: product,
										size: image_size,
										tablet_size: image_size_tablet,
										mobile_size: image_size_mobile,
										is_lazy: is_lazy
									-%}
								</div>
							{%- endfor -%}
						{%- endif -%}
					{%- endcapture -%}

					{%- if slides != "" -%}
						{{- slides -}}
					{%- else -%}
						{%- for i in (1..limit) -%}
							<div class="featured-products__col swiper-slide js-featured-products-slide{% if i > desktop_limit %} product-recommendations__slide--desktop-hidden{% endif %}{% if i > mobile_limit %} product-recommendations__slide--mobile-hidden{% endif %}">
								{%- render 'product-card', product: nil -%}
							</div>
						{%- endfor -%}
					{%- endif -%}
				</div>
				<div class="product-recommendations__mobile-pagination js-product-recommendations-mobile-pagination"></div>
			</div>
		</div>
	</div>
</section>

<script>
	(function() {
		var mobileQuery = window.matchMedia('(max-width: 767px)');
		var retries = 0;

		function updateResponsiveHeadingLayout() {
			var section = document.getElementById('{{ section.id }}');
			if (!section) return;

			var sectionWidth = section.getBoundingClientRect().width || window.innerWidth;
			var shouldUseMobileLayout = mobileQuery.matches || sectionWidth <= 767;
			var heading = section.querySelector('.featured-products__header.product-recommendations__header h2');
			var desktopHeadingSize = section.style.getPropertyValue('--product-recommendations-heading-size-desktop').trim() || '{{ section.settings.heading_font_size_desktop | default: 36 }}px';
			var mobileHeadingSize = section.style.getPropertyValue('--product-recommendations-heading-size-mobile').trim() || '{{ section.settings.heading_font_size_mobile | default: 22 }}px';

			section.classList.toggle('is-mobile-layout', shouldUseMobileLayout);

			if (heading) {
				heading.style.setProperty('font-size', shouldUseMobileLayout ? mobileHeadingSize : desktopHeadingSize, 'important');
			}

			applyResponsiveProductLimit();
		}

		function applyResponsiveProductLimit() {
			var section = document.getElementById('{{ section.id }}');
			if (!section) return;

			var activeLimit = mobileQuery.matches
				? parseInt(section.getAttribute('data-mobile-limit'), 10)
				: parseInt(section.getAttribute('data-desktop-limit'), 10);
			var slides = section.querySelectorAll('.js-featured-products-slide');
			var slider = section.querySelector('.js-featured-products-slider');

			if (!activeLimit || !slides.length) return;

			slides.forEach(function(slide, index) {
				var shouldHide = index >= activeLimit;

				if (shouldHide) {
					slide.style.setProperty('display', 'none', 'important');
					slide.setAttribute('aria-hidden', 'true');
				} else {
					slide.style.removeProperty('display');
					slide.removeAttribute('aria-hidden');
				}
			});

			if (slider && slider.swiper && typeof slider.swiper.update === 'function') {
				slider.swiper.update();
			}
		}

		function initMobileRecommendationsSlider() {
			updateResponsiveHeadingLayout();
			applyResponsiveProductLimit();

			if (!mobileQuery.matches) return;

			var section = document.getElementById('{{ section.id }}');
			if (!section) return;

			section.classList.remove('js-featured-products');

			var slider = section.querySelector('.js-featured-products-slider');
			var prevButton = section.querySelector('.js-featured-products-slider-button-prev');
			var nextButton = section.querySelector('.js-featured-products-slider-button-next');
			var Swiper = window.themeCore && window.themeCore.utils && window.themeCore.utils.Swiper;

			if (!slider) return;
			if (slider.swiper) return;

			if (!Swiper) {
				retries += 1;

				if (retries < 60) {
					setTimeout(initMobileRecommendationsSlider, 150);
				}

				return;
			}

			new Swiper(slider, {
				grabCursor: true,
				slidesPerView: 2,
				slidesPerGroup: 2,
				spaceBetween: 12,
				navigation: {
					prevEl: prevButton,
					nextEl: nextButton
				},
				on: {
					init: function() {
						section.classList.add('is-initialized');
						applyResponsiveProductLimit();
					}
				}
			});
		}

		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', initMobileRecommendationsSlider);
			document.addEventListener('DOMContentLoaded', updateResponsiveHeadingLayout);
		} else {
			updateResponsiveHeadingLayout();
			initMobileRecommendationsSlider();
		}

		window.addEventListener('resize', updateResponsiveHeadingLayout);
		window.addEventListener('orientationchange', updateResponsiveHeadingLayout);
		document.addEventListener('theme:all:loaded', initMobileRecommendationsSlider);
		document.addEventListener('shopify:section:load', updateResponsiveHeadingLayout);
		document.addEventListener('shopify:section:select', updateResponsiveHeadingLayout);

		if (window.ResizeObserver) {
			var observedSection = document.getElementById('{{ section.id }}');

			if (observedSection) {
				new ResizeObserver(updateResponsiveHeadingLayout).observe(observedSection);
			}
		}

		if (window.MutationObserver) {
			var mutableSection = document.getElementById('{{ section.id }}');

			if (mutableSection) {
				new MutationObserver(updateResponsiveHeadingLayout).observe(mutableSection, {
					attributes: true,
					attributeFilter: ['style']
				});
			}
		}
	})();
</script>

