{%- comment -%}
------------------------------------------------------------------------------
	Section: Footer
------------------------------------------------------------------------------
{%- endcomment -%}

{%- render 'adastra' with '/src/styles/footer.scss' -%}

{%- assign logo_image		    	= section.settings.logo_image -%}
{%- assign logo_image_width	    	= section.settings.logo_image_width -%}

{%- assign copyright_text			= section.settings.copyright_text -%}
{%- assign default_success_text     = 'newsletter.success' | t -%}
{%- assign current_year				= 'now' | date: '%Y'  -%}

{%- assign is_show_country_selector  = section.settings.is_show_country_selector -%}
{%- assign is_show_language_selector = section.settings.is_show_language_selector -%}
{%- assign is_show_payment_methods   = section.settings.is_show_payment_methods -%}
{%- assign show_back_to_top_button	 = section.settings.show_back_to_top_button -%}
{%- assign show_store_policies_in_footer = section.settings.show_store_policies_in_footer -%}

{%- assign color_scheme                    = section.settings.color_scheme -%}
{%- assign enable_color_scheme_inheritance = section.settings.enable_color_scheme_inheritance -%}

{%- assign refund_policy 		= shop.refund_policy -%}
{%- assign privacy_policy 		= shop.privacy_policy -%}
{%- assign terms_of_service 	= shop.terms_of_service -%}
{%- assign shipping_policy 		= shop.shipping_policy -%}
{%- assign legal_notice 		= shop.legal_notice -%}

{%- if enable_color_scheme_inheritance -%}
	{%- assign color_scheme = settings.main_color_scheme -%}
{%- endif -%}

{%- capture section_styles -%}
	--logo-image-width: {{ logo_image_width }}px;
{%- endcapture -%}

{%- capture newsletter -%}
	{%- assign newsletter_block = section.blocks | where: 'type', 'newsletter' | first -%}

	{%- if newsletter_block != blank -%}
		{%- assign newsletter_heading = newsletter_block.settings.heading -%}
		{%- assign newsletter_text = newsletter_block.settings.text -%}
		{%- assign newsletter_input_placeholder = newsletter_block.settings.input_placeholder -%}
		{%- assign newsletter_button_label = newsletter_block.settings.button_label -%}
		{%- assign newsletter_success_message = newsletter_block.settings.success_message -%}

		{%- if newsletter_heading != blank -%}
			<h2 class="footer__newsletter-heading h4">
				{{- newsletter_heading -}}
			</h2>
		{%- endif -%}

		{%- if newsletter_text != blank -%}
			<p class="footer__newsletter-text">
				{{- newsletter_text -}}
			</p>
		{%- endif -%}

		{%- assign id = 'footerForm--' | append: section.id -%}

		{%- form 'customer', class: 'footer-form js-newsletter-form', id: id -%}
			<input type="hidden" name="contact[tags]" value="newsletter"/>

			<div class="footer-form__field">
				<label class="visually-hidden" for="NewsletterForm--{{- section.id -}}">
					{{- newsletter_input_placeholder -}}
				</label>

				<input
					id="NewsletterForm--{{- section.id -}}"
					type="email"
					name="contact[email]"
					class="footer-form__input input js-newsletter-input"
					value="{{- form.email -}}"
					aria-required="true"
					autocapitalize="off"
					autocomplete="email"
					{% if form.errors %}
						aria-invalid="true"
						aria-describedby="Newsletter-error--{{- section.id -}}"
					{% elsif form.posted_successfully? %}
						aria-describedby="Newsletter-success--{{- section.id -}}"
					{% endif %}
					placeholder="{{- newsletter_input_placeholder -}}"
					required
				/>

				<button type="submit" name="commit" class="button button--secondary button--block footer-form__button">
					<span data-text="{{- newsletter_button_label -}}">
						<span>{{- newsletter_button_label -}}</span>
					</span>
				</button>
			</div>

			{%- if form.errors -%}
				<small class="footer-form__message footer-form__message--error" id="Newsletter-error--{{- section.id -}}">
					{%- render 'icons', icon: 'menu-close' -%}

					{{- form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] -}}
				</small>
			{%- endif -%}

			{%- if form.posted_successfully? -%}
				<p
					class="footer-form__message footer-form__message--success"
					id="Newsletter-success--{{- section.id -}}"
					tabindex="-1"
				>
					{%- render 'icons', icon: 'check' -%}

					{{- newsletter_success_message -}}
				</p>
			{%- endif -%}
		{%- endform -%}
	{%- endif -%}
{%- endcapture -%}

{%- capture contact -%}
	{%- assign contact_block = section.blocks | where: 'type', 'contact' | first -%}

	{%- if contact_block != blank -%}
		{%- assign show_socials = contact_block.settings.show_socials -%}
		{%- assign heading = contact_block.settings.heading -%}
		{%- assign email_icon = contact_block.settings.email_icon -%}
		{%- assign email_text = contact_block.settings.email_text -%}
		{%- assign phone_icon = contact_block.settings.phone_icon -%}
		{%- assign phone_text = contact_block.settings.phone_text -%}
		{%- assign additional_icon = contact_block.settings.additional_icon -%}
		{%- assign additional_text = contact_block.settings.additional_text -%}

		{%- if heading != blank -%}
			<h2 class="footer__navigation-heading text">
				{{- heading -}}
			</h2>
		{%- endif -%}

		{%- if show_socials or email_text != blank or phone_text != blank or additional_text != blank -%}
			<ul class="footer__navigation-list">
				{%- if email_text != blank -%}
					<li class="footer__navigation-list-item">
						{%- capture img_focal -%}
							--img-desktop-pos: {{ email_icon.presentation.focal_point }};
						{%- endcapture -%}

						{%- if email_icon != blank -%}
							<img
								class="icon"
								src="{{ email_icon | image_url: width: 16 }}"
								srcset="{{ email_icon | image_url: width: 16 }} 1x,
										{{ email_icon | image_url: width: 32 }} 2x"
								alt="{{ email_icon.alt | escape }}"
								width="16"
								height="16"
								style="{{ img_focal }}"
								loading="lazy"
								fetchpriority="low"
								decoding="async"
							/>
						{%- endif -%}

						<div class="rte">{{ email_text }}</div>
					</li>
				{%- endif -%}

				{%- if phone_text != blank -%}
					<li class="footer__navigation-list-item">
						{%- capture img_focal -%}
							--img-desktop-pos: {{ phone_icon.presentation.focal_point }};
						{%- endcapture -%}

						{%- if phone_icon != blank -%}
							<img
								class="icon"
								src="{{ phone_icon | image_url: width: 16 }}"
								srcset="{{ phone_icon | image_url: width: 16 }} 1x,
										{{ phone_icon | image_url: width: 32 }} 2x"
								alt="{{ phone_icon.alt | escape }}"
								width="16"
								height="16"
								style="{{ img_focal }}"
								loading="lazy"
								fetchpriority="low"
								decoding="async"
							/>
						{%- endif -%}

						<div class="rte">{{ phone_text }}</div>
					</li>
				{%- endif -%}

				{%- if additional_text != blank -%}
					<li class="footer__navigation-list-item">
						{%- capture img_focal -%}
							--img-desktop-pos: {{ additional_icon.presentation.focal_point }};
						{%- endcapture -%}

						{%- if additional_icon != blank -%}
							<img
								class="icon"
								src="{{ additional_icon | image_url: width: 16 }}"
								srcset="{{ additional_icon | image_url: width: 16 }} 1x,
										{{ additional_icon | image_url: width: 32 }} 2x"
								alt="{{ additional_icon.alt | escape }}"
								width="16"
								height="16"
								style="{{ img_focal }}"
								loading="lazy"
								fetchpriority="low"
								decoding="async"
							/>
						{%- endif -%}

						<div class="rte">{{ additional_text }}</div>
					</li>
				{%- endif -%}

				{%- if show_socials -%}
					<li class="footer__navigation-list-item">
						{%- render 'social-links' -%}
					</li>
				{%- endif -%}
			</ul>
		{%- endif -%}
	{%- endif -%}
{%- endcapture -%}

{%- capture middle_content -%}
	{%- if is_show_country_selector == true and localization.available_countries.size > 1 -%}
		{%- assign country_selector = true -%}
	{%- endif -%}
	{%- if is_show_language_selector == true and localization.available_languages.size > 1 -%}
		{%- assign language_selector = true -%}
	{%- endif -%}

	{%- if country_selector or language_selector or shop.enabled_payment_types and is_show_payment_methods -%}
		<div class="footer__middle-container">
			{%- if country_selector or language_selector -%}
				<div class="footer__selectors">
					{%- if language_selector -%}
						{%- render 'language-localization-form', class: 'footer', id_prefix: 'footer', form_id: "FooterLocalizationForm" -%}
					{%- endif -%}

					{%- if country_selector -%}
						{%- render 'country-localization-form', class: 'footer', id_prefix: "footer", form_id: "FooterCountryForm" -%}
					{%- endif -%}
				</div>
			{%- endif -%}

			{%- if shop.enabled_payment_types and is_show_payment_methods -%}
				<ul class="footer__payments-container" aria-label="{{ 'general.payment.method' | t | escape }}">
					{%- for type in shop.enabled_payment_types -%}
						<li class="footer__payments-item">
							{{- type | payment_type_svg_tag: class: 'payment-icon' -}}
						</li>
					{% endfor %}
				</ul>
			{%- endif -%}
		</div>
	{%- endif -%}
{%- endcapture -%}

{%- capture logo_content -%}
	<div class="footer__logo-container">
		{%- if logo_image != blank -%}
			{%- assign logo_height = logo_image_width | divided_by: logo_image.aspect_ratio | round: 0 -%}
			{%- assign logo_width_x2 = logo_image_width | times: 2 -%}

			{%- capture img_focal -%}
				--img-desktop-pos: {{ logo_image.presentation.focal_point }};
			{%- endcapture -%}

			<a
				href="{{ routes.root_url }}"
				class="footer__logo-link focus-visible-outline"
				aria-label="{{ 'general.accessibility.link_messages.link_to_home_page' | t | escape }}"
			>
				<img
					class="footer__logo"
					src="{{ logo_image | image_url: width: logo_image_width }}"
					srcset="{{ logo_image | image_url: width: logo_image_width }} 1x,
						{{ logo_image | image_url: width: logo_width_x2 }} 2x"
					alt="{{ logo_image.alt | escape }}"
					width="{{ logo_image_width }}"
					height="{{ logo_height }}"
					style="{{ img_focal }}"
					loading="lazy"
					fetchpriority="low"
					decoding="async"
				/>
			</a>
		{%- endif -%}
	</div>
{% endcapture %}

<footer class="footer need-animate js-animate" style="{{ section_styles }}">
	<style>
		html, body {
			margin: 0;
			padding: 0;
			height: 100%;
		}
		body {
			display: flex;
			flex-direction: column;
			min-height: 100vh;
		}
		#MainContent {
			flex: 1 0 auto;
		}
		.shopify-section-footer-group {
			margin-bottom: 0 !important;
			padding-bottom: 0 !important;
		}
		.footer {
			margin-bottom: 0 !important;
			padding-bottom: 0 !important;
			border-bottom: none !important;
		}

		.footer-custom-top {
			background-color: #243029;
			color: #faf6ee;
			padding: 64px 20px 48px;
			width: 100%;
		}
		/* Desktop/Mobile visibility helpers */
		.mobile-only { display: none !important; }

		.footer-custom-top-inner {
			max-width: 1400px;
			margin: 0 auto;
			display: grid;
			grid-template-columns: repeat(3, 1fr);
			gap: 60px;
			text-align: left;
		}

		/* Grid Columns */
		.footer-col {
			display: flex;
			flex-direction: column;
		}
		
		/* Column 1: Logo & text */
		.footer-col-1 .footer-logo-img {
			width: 90px;
			height: auto;
			margin-bottom: 20px;
		}
		.footer-col-1 p {
			margin: 0 0 16px 0;
			font-family: var(--base-font-family), system-ui, sans-serif;
			font-weight: 400;
			letter-spacing: 0;
			font-size: 15px;
			line-height: 1.6;
			color: rgba(250, 246, 238, 0.85);
		}
		.footer-col-1 .footer-manifesto {
		}

		/* Column 2 & 3: Headings */
		.footer-heading {
			font-family: 'Oswald', sans-serif;
			font-size: 20px;
			font-weight: 600;
			text-transform: uppercase;
			margin: 0 0 30px 0;
			color: #faf6ee;
			letter-spacing: 0.05em;
		}

		/* Column 2: Info list */
		.footer-info-list {
			list-style: none;
			padding: 0;
			margin: 0;
		}
		.footer-info-list li {
			margin-bottom: 16px;
			font-family: var(--base-font-family), system-ui, sans-serif;
			font-weight: 400;
			letter-spacing: 0;
			font-size: 15px;
			line-height: 1.5;
			color: rgba(250, 246, 238, 0.85);
		}

		/* Column 3: Newsletter */
		.footer-col-3 p {
			margin: 0 0 24px 0;
			font-family: var(--base-font-family), system-ui, sans-serif;
			font-weight: 400;
			letter-spacing: 0;
			font-size: 15px;
			line-height: 1.5;
			color: rgba(250, 246, 238, 0.85);
		}

		/* Newsletter form */
		.footer-custom-top .footer-form {
			display: block;
			width: 100%;
			margin-bottom: 30px;
		}
		.footer-custom-top .footer-form__wrapper {
			display: flex;
			height: 44px;
			width: 100%;
			overflow: hidden;
		}
		.footer-custom-top .footer-form > input[type="hidden"] {
			display: none !important;
		}
		.footer-custom-top .footer-form__input {
			flex: 1;
			background: transparent;
			border: 1px solid rgba(250, 246, 238, 0.3);
			border-right: none;
			color: #faf6ee;
			padding: 0 16px;
			height: 100% !important;
			min-height: 44px !important;
			max-height: 44px !important;
			font-size: 12px;
			font-weight: 400;
			letter-spacing: 1px;
			margin: 0 !important;
			box-sizing: border-box !important;
			border-radius: 22px 0 0 22px !important;
			outline: none !important;
			-webkit-appearance: none;
		}
		.footer-custom-top .footer-form__input:focus {
			border-color: #faf6ee;
		}
		.footer-custom-top .footer-form__input::placeholder {
			color: rgba(250, 246, 238, 0.45);
		}
		.footer-custom-top .footer-form__button {
			background: #faf6ee;
			color: #243029;
			border: none;
			height: 100% !important;
			min-height: 44px !important;
			max-height: 44px !important;
			padding: 0 20px;
			font-family: 'Oswald', sans-serif;
			font-weight: 600;
			text-transform: uppercase;
			font-size: 14px;
			letter-spacing: 1px;
			cursor: pointer;
			transition: background 0.3s ease;
			margin: 0 !important;
			box-sizing: border-box !important;
			border-radius: 0 22px 22px 0 !important;
			display: flex !important;
			align-items: center !important;
			justify-content: center !important;
		}
		.footer-custom-top .footer-form__button:hover {
			background: #e8e4dc;
		}
		
		/* Socials */
		.footer-custom-socials {
			display: flex;
			gap: 24px;
			align-items: center;
		}
		.footer-custom-socials a {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			height: 24px;
		}

		.footer-custom-bottom {
			background-color: #243029;
			color: rgba(250, 246, 238, 0.6);
			padding: 24px 20px;
			width: 100%;
			border-top: 1px solid rgba(250, 246, 238, 0.15);
		}
		.footer-custom-bottom-inner {
			max-width: 1400px;
			margin: 0 auto;
			display: flex;
			justify-content: space-between;
			align-items: center;
		}
		.footer-custom-bottom-left {
			display: flex;
			gap: 20px;
			align-items: center;
			flex-wrap: wrap;
			font-size: 10px;
			font-weight: 700;
			letter-spacing: 1px;
		}
		.footer-custom-bottom-left a {
			color: rgba(250, 246, 238, 0.6);
			text-decoration: none;
			text-transform: uppercase;
			transition: color 0.3s ease;
		}
		.footer-custom-bottom-left a:hover {
			color: #faf6ee;
		}
		.footer-custom-bottom-right .footer__payments-container {
			display: flex;
			gap: 8px;
			list-style: none;
			padding: 0;
			margin: 0;
		}
		.footer-custom-bottom-right .payment-icon {
			width: 38px;
			height: 24px;
		}

		/* Mobile adjustments */
		@media screen and (max-width: 1024px) {
			.desktop-only { display: none !important; }
			.mobile-only { display: block !important; }
			.footer-custom-socials.mobile-only { display: flex !important; }

			.footer-custom-top { padding-top: 90px; padding-bottom: 0; }
			.footer-custom-top-inner {
				display: flex;
				flex-direction: column;
				gap: 0;
			}
			.footer-col {
				width: 100%;
				padding: 40px 0;
			}
			.footer-col-1 { display: none !important; }
			.footer-col-3 { 
				order: 1; 
				padding-top: 0;
				text-align: center; 
				border-bottom: none;
			}
			.footer-col-2 { 
				order: 2; 
				text-align: center; 
			}

			.footer-col-1-inner { justify-content: center !important; gap: 0 !important; }
			.footer-col-1-text { display: none !important; }

			.footer-col-3 .footer-heading, .footer-col-2 .footer-heading {
				width: 100%;
				text-align: center;
				margin-bottom: 20px;
			}
			
			.footer-col-3 p { margin: 0 auto 24px; max-width: 100%; }
			.footer-custom-top .footer-form { margin: 0 auto; max-width: 100%; }

			.footer-col-2 .footer-custom-socials {
				justify-content: center;
				margin-top: 32px;
			}

			.footer-info-list { text-align: center; }
			.footer-info-list li { margin-bottom: 12px; }

			.footer-custom-bottom-inner {
				flex-direction: column;
				gap: 20px;
				text-align: center;
			}
			.footer-custom-bottom-left {
				justify-content: center;
				gap: 15px;
			}
			.footer-custom-bottom-right .footer__payments-container {
				justify-content: center;
				flex-wrap: wrap;
			}
		}
	</style>

	<div class="footer-custom-top">
		<div class="footer-custom-top-inner">
			<!-- Column 1 -->
			<div class="footer-col footer-col-1">
				<div class="footer-col-1-inner" style="display: flex; gap: 20px; align-items: flex-start;">
					{%- assign display_logo = logo_image | default: settings.logo -%}
					{%- if display_logo != blank -%}
						<div class="desktop-only" style="flex-shrink: 0;">
							<img src="{{ display_logo | img_url: '300x' }}" alt="Camo Signal" class="footer-logo-img" loading="lazy" style="margin-bottom: 0;">
						</div>
					{%- endif -%}
					
					<div class="footer-col-1-text">
						{%- if display_logo == blank -%}
							<h2 class="footer-heading desktop-only" style="margin-bottom: 12px;">CAMO SIGNAL</h2>
						{%- endif -%}
						
						{%- if section.settings.brand_heading != blank -%}
							<h3 class="footer-heading" style="font-size: 20px;">{{ section.settings.brand_heading | escape }}</h3>
						{%- endif -%}
						{%- if section.settings.manifesto_subheading != blank -%}
							<p>{{ section.settings.manifesto_subheading }}</p>
						{%- endif -%}
						{%- if section.settings.manifesto_text != blank -%}
							<div class="footer-manifesto" style="margin-top: 12px; line-height: 1.6;">{{ section.settings.manifesto_text }}</div>
						{%- endif -%}
					</div>
				</div>
			</div>


			<!-- Column 2 -->
			<div class="footer-col footer-col-2">
				<h3 class="footer-heading">{{ section.settings.info_heading | default: 'CAMO SIGNAL INFO' | escape }}</h3>
				<ul class="footer-info-list">
					{%- if section.settings.info_phone != blank -%}<li>Phone: {{ section.settings.info_phone }}</li>{%- endif -%}
					{%- if section.settings.info_email != blank -%}<li>Email: {{ section.settings.info_email }}</li>{%- endif -%}
					{%- if section.settings.info_address != blank -%}<li>Address: {{ section.settings.info_address }}</li>{%- endif -%}
				</ul>
				
				<div class="footer-custom-socials mobile-only" style="margin-top: 32px;">
					<a href="{{ settings.social_facebook_link | default: 'https://www.facebook.com/profile.php?id=61575744733042' }}" target="_blank" style="color: #faf6ee;">
						{% render 'icons-social', icon: 'facebook' %}
					</a>
					<a href="{{ settings.social_instagram_link | default: 'https://www.instagram.com/camo.signal/' }}" target="_blank" style="color: #faf6ee;">
						{% render 'icons-social', icon: 'instagram' %}
					</a>
					<a href="#" target="_blank" style="color: #faf6ee;">
						{% render 'icons-social', icon: 'tiktok' %}
					</a>
				</div>
			</div>

			<!-- Column 3 -->
			<div class="footer-col footer-col-3">
				<h3 class="footer-heading">{{ section.settings.newsletter_heading | default: 'SUBSCRIBE TO OUR EMAIL' | escape }}</h3>
				{%- if section.settings.newsletter_text != blank -%}
					<div class="footer-newsletter-text">{{ section.settings.newsletter_text }}</div>
				{%- endif -%}
				
				{%- form 'customer', class: 'footer-form js-newsletter-form' -%}
					<input type="hidden" name="contact[tags]" value="newsletter"/>
					<div class="footer-form__wrapper">
						<input
							type="email"
							name="contact[email]"
							class="footer-form__input input js-newsletter-input"
							value="{{- form.email -}}"
							placeholder="Email address"
							required
						/>
						<button type="submit" name="commit" class="footer-form__button">
							SUBSCRIBE
						</button>
					</div>
				{%- endform -%}
				
				<div class="footer-custom-socials desktop-only" style="margin-top: 20px;">
					<a href="{{ settings.social_facebook_link | default: 'https://www.facebook.com/profile.php?id=61575744733042' }}" target="_blank" style="color: #faf6ee;">
						{% render 'icons-social', icon: 'facebook' %}
					</a>
					<a href="{{ settings.social_instagram_link | default: 'https://www.instagram.com/camo.signal/' }}" target="_blank" style="color: #faf6ee;">
						{% render 'icons-social', icon: 'instagram' %}
					</a>
					<a href="#" target="_blank" style="color: #faf6ee;">
						{% render 'icons-social', icon: 'tiktok' %}
					</a>
				</div>
			</div>
		</div>
	</div>

	<div class="footer-custom-bottom">
		<div class="footer-custom-bottom-inner">
			<div class="footer-custom-bottom-left">
				<span>&copy; {{ 'now' | date: "%Y" }} ORCAS ECOMMERCE LLC</span>

				{%- if section.settings.sub_footer_menu != blank -%}
					{%- for link in linklists[section.settings.sub_footer_menu].links -%}
						<a href="{{ link.url }}">{{ link.title | upcase }}</a>
					{%- endfor -%}
				{%- else -%}
					<a href="/pages/about-us1">ABOUT US</a>
					<a href="/pages/contact">CONTACT INFORMATION</a>
					<a href="/policies/shipping-policy">SHIPPING POLICY</a>
					<a href="/policies/refund-policy">REFUND POLICY</a>
					<a href="/policies/privacy-policy">PRIVACY POLICY</a>
					<a href="/policies/terms-of-service">TERMS OF SERVICE</a>
				{%- endif -%}
			</div>

			<div class="footer-custom-bottom-right">
				{%- if shop.enabled_payment_types != blank -%}
					<ul class="footer__payments-container">
						{%- for type in shop.enabled_payment_types -%}
							<li class="footer__payments-item">
								{{- type | payment_type_svg_tag: class: 'payment-icon' -}}
							</li>
						{% endfor %}
					</ul>
				{%- else -%}
					<ul class="footer__payments-container">
						<li class="footer__payments-item"><div class="payment-icon" style="background: #ccc; border-radius: 3px;"></div></li>
						<li class="footer__payments-item"><div class="payment-icon" style="background: #ccc; border-radius: 3px;"></div></li>
						<li class="footer__payments-item"><div class="payment-icon" style="background: #ccc; border-radius: 3px;"></div></li>
						<li class="footer__payments-item"><div class="payment-icon" style="background: #ccc; border-radius: 3px;"></div></li>
						<li class="footer__payments-item"><div class="payment-icon" style="background: #ccc; border-radius: 3px;"></div></li>
					</ul>
				{%- endif -%}
			</div>
		</div>
	</div>
</footer>

<style>
/* Reduce excessive spacing in the footer for mobile only */
@media screen and (max-width: 767px) {
  .footer-custom-top {
    padding-top: 10px !important; /* Cut top space */
  }
  .footer-custom-row {
    gap: 20px !important;
  }
  .footer-col {
    padding-top: 25px !important; /* Cut top space */
    padding-bottom: 10px !important;
    margin-bottom: 10px !important;
  }
  .footer-col-3 p {
    margin-bottom: 35px !important; /* Push form down a bit */
  }
  .footer-col-2 .footer-custom-socials.mobile-only {
    margin-top: 15px !important;
  }
  .footer-heading {
    margin-bottom: 10px !important;
  }
  .footer-info-list li {
    margin-bottom: 5px !important;
  }
  .footer-custom-bottom {
    padding-top: 15px !important;
    margin-top: 0 !important;
  }
}
</style>

