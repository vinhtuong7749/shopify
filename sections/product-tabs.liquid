{%- comment -%}
------------------------------------------------------------------------------
	Section: Product tabs
------------------------------------------------------------------------------
{%- endcomment -%}

{%- render 'adastra' with '/src/styles/carousel.scss' -%}
{%- render 'adastra' with '/src/styles/product-tabs.scss' -%}

{%- style -%}
	#shopify-section-{{- section.id -}} {
		padding-top: {{- section.settings.offset_top_mobile -}}px;
		padding-bottom: {{- section.settings.offset_bottom_mobile -}}px;
	}

	@media screen and (min-width: 768px) {
		#shopify-section-{{- section.id -}} {
			padding-top: {{- section.settings.offset_top_desktop -}}px;
			padding-bottom: {{- section.settings.offset_bottom_desktop -}}px;
		}
	}
{%- endstyle -%}

{%- assign heading                         = section.settings.heading -%}
{%- assign show_arrows                     = section.settings.show_arrows -%}
{%- assign container                       = section.settings.container_width -%}
{%- assign enable_color_scheme_inheritance = section.settings.enable_color_scheme_inheritance -%}
{%- assign color_scheme 				   = section.settings.color_scheme -%}
{%- assign blocks 	                       = section.blocks -%}
{%- assign tabs_count                      = 0 -%}

{%- if enable_color_scheme_inheritance -%}
	{%- assign color_scheme = settings.main_color_scheme -%}
{%- endif -%}

{%- assign container_width = container -%}
{%- if container == 'inherit' -%}
	{%- assign container_width = settings.container_width -%}
{%- endif -%}

{%- for block in blocks -%}
	{%- assign tab_heading = block.settings.heading -%}

	{%- if tab_heading != blank -%}
		{%- assign tabs_count = tabs_count | plus: 1 -%}
	{%- endif -%}
{%- endfor %}

{%- capture slider_arrows -%}
	{%- if show_arrows -%}
		{%- assign index = 0 -%}

		{%- for block in blocks -%}
			{%- assign tab_heading = block.settings.heading -%}

			{%- if tab_heading != blank -%}
				{%- assign index = index | plus: 1 -%}

				<div
					class="product-tabs__slider-buttons-wrapper js-product-tabs-slider-buttons-wrapper{% unless index == 1 %} is-hidden{% endunless %}"
					data-index="{{- index -}}"
				>
					<button
						class="swiper-button-prev-new js-product-tabs-slider-button-prev"
						data-index="{{- index -}}"
					>
						{%- render 'icons', icon: 'arrow-left' -%}
					</button>

					<button
						class="swiper-button-next-new js-product-tabs-slider-button-next"
						data-index="{{- index -}}"
					>
						{%- render 'icons', icon: 'arrow-right' -%}
					</button>
				</div>
			{%- endif -%}
		{%- endfor -%}
	{%- endif -%}
{%- endcapture -%}

{%- capture style -%}
	--container-width: {{- container_width -}}; {{-  -}}
	--inner-offset-top: {{- section.settings.inner_offset_top -}}px; {{-  -}}
	--inner-offset-bottom: {{- section.settings.inner_offset_bottom -}}px; {{-  -}}
	--inner-offset-top-mobile: {{- section.settings.inner_offset_top_mobile -}}px; {{-  -}}
	--inner-offset-bottom-mobile: {{- section.settings.inner_offset_bottom_mobile -}}px; {{-  -}}
{%- endcapture -%}

<section
	class="product-tabs color-{{ color_scheme.id }}{% if request.visual_preview_mode or section.index == 1 %} animated{% endif %} js-product-tabs-section js-animate"
	style="{{- style -}}"
>
	<div class="product-tabs__container section-animate container">
		{%- if heading != blank -%}
			<h2 class="product-tabs__heading">
				{{- heading -}}
			</h2>
		{%- endif -%}

		{%- if tabs_count > 0 -%}
			<div class="product-tabs__grid">
				<div class="product-tabs__collections">
					{%- assign index = 0 -%}

					{%- for block in blocks -%}
						{%- assign tab_heading      	= block.settings.heading -%}
						{%- assign collection 			= block.settings.collection -%}
						{%- assign image 				= block.settings.image | default: collection.featured_image -%}
						{%- assign link_label_default 	= 'sections.collection_list.see_all_products' | t -%}
						{%- assign link_label       	= block.settings.link_label | default: link_label_default -%}
						{%- assign link_url       		= collection.url | default: "#" -%}
						{%- assign title_default 	   	= 'sections.collection_list.card_title' | t -%}
						{%- assign title          		= collection.title | default: title_default -%}

						{%- if tab_heading != blank -%}
							{%- assign index = index | plus: 1 -%}

							{%- assign is_lazy = true -%}

							{%- if section.index == 1 and index == 1 -%}
								{%- assign is_lazy = false -%}
							{%- endif -%}

							<div
								class="product-tabs__collection{% unless index == 1 %} is-hidden{% endunless %} js-product-tabs-collection"
								data-index="{{- index -}}"
							>
								{%- render 'media-card-overlay',
									title: title,
									link_label: link_label,
									link_url: link_url,
									image: image,
									is_lazy: is_lazy,
									size_width_991: 314,
									size_height_991: 646,
									size_width_1199: 383,
									size_height_1199: 677,
									size_width_1500: 434,
									size_height_1500: 639,
									size_width: 574,
									size_height: 698
								-%}
							</div>
						{%- endif -%}
					{%- endfor -%}
				</div>

				<div class="product-tabs__main">
					{%- if tabs_count > 1 or slider_arrows != blank -%}
						<div class="product-tabs__buttons-wrapper{% if tabs_count < 2 %} product-tabs__buttons-wrapper--mobile-hidden{% endif %}">
							{%- if tabs_count > 1 -%}
								<ul class="product-tabs__buttons-list">
									{%- assign index = 0 -%}

									{%- for block in blocks -%}
										{%- assign tab_heading = block.settings.heading -%}

										{%- if tab_heading != blank -%}
											{%- assign index = index | plus: 1 -%}

											<li>
												<button
													class="button-link product-tabs__button{% if index == 1 %} is-active{% endif %} js-product-tabs-button"
													tabindex="{%- if index == 1 -%}-1{%- else -%}0{%- endif -%}"
													data-index="{{- index -}}"
												>
													<span data-text="{{- tab_heading -}}">
														<span>
															{{- tab_heading -}}
														</span>
													</span>

													<span class="visually-hidden">
														{{- 'sections.product_tabs.button_aria' | t: number: index | escape -}}
													</span>
												</button>
											</li>
										{%- endif -%}
									{%- endfor -%}
								</ul>
							{%- endif -%}

							{%- if slider_arrows != blank -%}
								{{- slider_arrows -}}
							{%- endif -%}
						</div>
					{%- endif -%}

					{%- assign index = 0 -%}

					{%- for block in blocks -%}
						{%- assign tab_heading 		  = block.settings.heading -%}
						{%- assign product_list       = block.settings.product_list -%}
						{%- assign collection         = block.settings.collection -%}
						{%- assign image 			  = block.settings.image | default: collection.featured_image-%}
						{%- assign link_label_default = 'sections.collection_list.see_all_products' | t -%}
						{%- assign link_label         = block.settings.link_label | default: link_label_default -%}
						{%- assign link_url       	  = collection.url | default: "#" -%}
						{%- assign title_default 	  = 'sections.collection_list.card_title' | t -%}
						{%- assign title          	  = collection.title | default: title_default -%}

						{%- if tab_heading != blank -%}
							{%- assign index = index | plus: 1 -%}

							{%- assign is_lazy = true -%}

							{%- if section.index == 1 and index == 1 -%}
								{% assign is_lazy = false -%}
							{%- endif -%}

							{%- if product_list.count == 1 -%}
								{%- assign collection_card_size_width  = 362 -%}
								{%- assign collection_card_size_height = 592 -%}
								{%- assign product_card_tablet_size    = 362 -%}
							{%- else -%}
								{%- assign collection_card_size_width  = 320 -%}
								{%- assign collection_card_size_height = 545 -%}
								{%- assign product_card_tablet_size    = 320 -%}
							{%- endif -%}

							<div
								class="product-tabs__slider-wrapper js-product-tabs-slider-wrapper{% unless index == 1 %} is-hidden{% endunless %}"
								data-index="{{- index -}}"
							>
								<div class="product-tabs__slider product-tabs__slider--count-{{ product_list.count }} swiper js-product-tabs-slider">
									<div class="product-tabs__slider-content swiper-wrapper">
										<div class="product-tabs__slide product-tabs__slide--mobile swiper-slide js-product-tabs-slide">
											{%- render 'media-card-overlay',
												title: title,
												link_label: link_label,
												link_url: link_url,
												image: image,
												is_lazy: is_lazy,
												size_width_375: 272,
												size_height_375: 537,
												size_width_420: 308,
												size_height_420: 500,
												size_width_575: 432,
												size_height_575: 673,
												size_width: collection_card_size_width,
												size_height: collection_card_size_height
											-%}
										</div>

										{%- if product_list != blank and product_list.count > 0 -%}
											{%- for product in product_list limit: limit -%}
												<div class="product-tabs__slide swiper-slide js-product-tabs-slide">
													{%- render
														'product-card',
														product: product,
														size: 383,
														tablet_size: product_card_tablet_size,
														mobile_size: 308
													-%}
												</div>
											{%- endfor -%}
										{%- else -%}
											{%- for i in (1..6) -%}
												<div class="product-tabs__slide swiper-slide js-product-tabs-slide">
													{%- render 'product-card' -%}
												</div>
											{%- endfor -%}
										{%- endif -%}
									</div>
								</div>
							</div>
						{%- endif -%}
					{%- endfor -%}
				</div>
			</div>
		{%- endif -%}
	</div>
</section>

{%- if tabs_count > 0 -%}
	{%- render 'adastra' with '/src/scripts/section-product-tabs.js' -%}
{%- endif -%}

{%- schema -%}
{
	"name": "Product tabs",
	"disabled_on": {
		"groups": ["header", "footer", "custom.popup"]
	},
	"settings": [
		{
			"type": "header",
			"content": "Colors"
		},
		{
			"type": "checkbox",
			"id": "enable_color_scheme_inheritance",
			"label": "Enable color scheme inheritance",
			"default": true,
			"info": "When this setting is enabled, the color scheme is inherited from the theme settings."
		},
		{
			"type": "color_scheme",
			"id": "color_scheme",
			"label": "Color scheme",
			"default": "scheme-1"
		},
		{
			"type": "header",
			"content": "General"
		},
		{
			"type": "inline_richtext",
			"id": "heading",
			"label": "Heading",
			"default": "Trending Products"
		},
		{
			"type": "checkbox",
			"id": "show_arrows",
			"label": "Show arrows",
			"default": true
		},
		{
			"type": "header",
			"content": "Layout"
		},
		{
			"type": "select",
			"id": "container_width",
			"label": "Container width",
			"options": [
				{
					"value": "1808px",
					"label": "Default - 1680px"
				},
				{
					"value": "2048px",
					"label": "Large - 1920px"
				},
				{
					"value": "100%",
					"label": "Full width"
				},
				{
					"value": "inherit",
					"label": "Inherit of general setting"
				}
			],
			"default": "inherit",
			"info": "if you select 'Inherit of general setting', then container width will be used from the Theme settings/Layout"
		},
		{
			"type": "paragraph",
			"content": "External offsets"
		},
		{
			"type": "range",
			"id": "offset_top_desktop",
			"min": 0,
			"max": 100,
			"step": 1,
			"unit": "px",
			"label": "Desktop external offset top",
			"default": 40
		},
		{
			"type": "range",
			"id": "offset_bottom_desktop",
			"min": 0,
			"max": 100,
			"step": 1,
			"unit": "px",
			"label": "Desktop external offset bottom",
			"default": 40
		},
		{
			"type": "range",
			"id": "offset_top_mobile",
			"min": 0,
			"max": 100,
			"step": 1,
			"unit": "px",
			"label": "Mobile external offset top",
			"default": 25
		},
		{
			"type": "range",
			"id": "offset_bottom_mobile",
			"min": 0,
			"max": 100,
			"step": 1,
			"unit": "px",
			"label": "Mobile external offset bottom",
			"default": 25
		},
		{
			"type": "paragraph",
			"content": "Internal offsets"
		},
		{
			"type": "range",
			"id": "inner_offset_top",
			"min": 0,
			"max": 100,
			"step": 1,
			"unit": "px",
			"label": "Desktop internal offset top",
			"default": 64
		},
		{
			"type": "range",
			"id": "inner_offset_bottom",
			"min": 0,
			"max": 100,
			"step": 1,
			"unit": "px",
			"label": "Desktop internal offset bottom",
			"default": 64
		},
		{
			"type": "range",
			"id": "inner_offset_top_mobile",
			"min": 0,
			"max": 100,
			"step": 1,
			"unit": "px",
			"label": "Mobile internal offset top",
			"default": 32
		},
		{
			"type": "range",
			"id": "inner_offset_bottom_mobile",
			"min": 0,
			"max": 100,
			"step": 1,
			"unit": "px",
			"label": "Mobile internal offset bottom",
			"default": 32
		}
	],
	"blocks": [
		{
			"type": "tab",
			"name": "Tab",
			"limit": 4,
			"settings": [
				{
					"type": "text",
					"id": "heading",
					"label": "Heading",
					"default": "Category"
				},
				{
					"type": "product_list",
					"id": "product_list",
					"label": "Products",
					"limit": 6
				},
				{
					"type": "collection",
					"id": "collection",
					"label": "Collection"
				},
				{
					"type": "image_picker",
					"id": "image",
					"label": "Image",
					"info": "Use instead of collection image"
				},
				{
					"type": "text",
					"id": "link_label",
					"label": "Link label",
					"default": "See all products"
				}
			]
		}
	],
	"presets": [
		{
			"name": "Product tabs",
			"blocks": [
				{
					"type": "tab",
					"settings": {
						"heading": "Best sellers"
					}
				},
				{
					"type": "tab",
					"settings": {
						"heading": "Arrivals"
					}
				},
				{
					"type": "tab",
					"settings": {
						"heading": "On Sale"
					}
				}
			]
		}
	]
}
{%- endschema -%}
