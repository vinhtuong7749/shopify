{% comment %}
  Section: Smart Newsletter Popup
  Features: Split Layout, Delay, Frequency Cap, Advanced Display Logic, Fully Customizable via Theme Customizer
{% endcomment %}

{%- assign show_popup = false -%}

{%- if section.settings.display_scope == 'all' -%}
  {%- assign show_popup = true -%}
{%- else -%}
  {%- if section.settings.show_on_home and template.name == 'index' -%}
    {%- assign show_popup = true -%}
  {%- endif -%}
  {%- if section.settings.show_on_collection and template.name == 'collection' -%}
    {%- assign show_popup = true -%}
  {%- endif -%}
  {%- if section.settings.show_on_product and template.name == 'product' -%}
    {%- assign show_popup = true -%}
  {%- endif -%}
  {%- if section.settings.show_on_blog and template.name == 'article' or template.name == 'blog' -%}
    {%- assign show_popup = true -%}
  {%- endif -%}
  {%- if section.settings.show_on_cart and template.name == 'cart' -%}
    {%- assign show_popup = true -%}
  {%- endif -%}

  {%- if section.settings.target_handles != blank -%}
    {%- assign handles = section.settings.target_handles | split: ',' -%}
    {%- for handle in handles -%}
      {%- assign clean_handle = handle | strip -%}
      {%- if clean_handle == collection.template_suffix
          or clean_handle == product.template_suffix
          or clean_handle == page.template_suffix -%}
        {%- assign show_popup = true -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}
  {%- endif -%}
{%- endif -%}

{%- if show_popup and section.settings.enable_popup -%}

  {%- comment -%} Assign customizable values {%- endcomment -%}
  {%- assign border_radius = section.settings.border_radius | append: 'px' -%}
  {%- assign input_radius = section.settings.input_radius | append: 'px' -%}
  {%- assign heading_size_mobile = section.settings.heading_size_mobile | divided_by: 100.0 | append: 'rem' -%}
  {%- assign heading_size_desktop = section.settings.heading_size_desktop | divided_by: 100.0 | append: 'rem' -%}

  <div id="newsletter-popup-{{ section.id }}" class="popup-overlay" style="display: none;">
    <div class="popup-container">
      
      <button class="popup-close" aria-label="Close" style="color: {{ section.settings.text_color }};">&times;</button>

      <div class="popup-image">
        {%- if section.settings.image != blank -%}
          <img 
            src="{{ section.settings.image | image_url: width: 800 }}" 
            alt="{{ section.settings.heading | escape }}"
            loading="lazy"
            width="400" height="400"
          >
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>

      <div class="popup-content" style="background-color: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }};">
        <div class="popup-text-wrapper">
          {%- if section.settings.subheading != blank -%}
            <p class="popup-subheading">{{ section.settings.subheading }}</p>
          {%- endif -%}
          
          {%- if section.settings.heading != blank -%}
            <h2 class="popup-heading">{{ section.settings.heading }}</h2>
          {%- endif -%}

          {%- if section.settings.description != blank -%}
            <div class="popup-desc">
              {{ section.settings.description }}
            </div>
          {%- endif -%}

          {% form 'customer', class: 'popup-form' %}
            <input type="hidden" name="contact[tags]" value="newsletter, popup, apparel">
            {%- if form.posted_successfully? -%}
              <div class="form-success-wrapper" style="text-align: center; margin: 15px 0;">
                <div class="form-success">
                  {{ section.settings.success_message | default: "Thank you! Use the promo code below at checkout:" | newline_to_br }}
                </div>
                {%- if section.settings.coupon_code != blank -%}
                  <div class="popup-coupon-code">
                    {{ section.settings.coupon_code }}
                  </div>
                {%- endif -%}
              </div>
              <script>
                window.camoPopupSuccess = true;
                localStorage.setItem('popupSubscribed', 'true');
              </script>
            {%- else -%}
              <div class="input-group">
                <input type="email" inputmode="email" name="contact[email]" class="popup-input" value="{{ form.email }}" placeholder="{{ section.settings.input_placeholder }}" autocomplete="email" autocorrect="off" autocapitalize="off" required>
                <button type="submit" class="popup-submit">
                  {{ section.settings.btn_label }}
                </button>
              </div>
              {%- if form.errors -%}
                <div class="form-error">{{ form.errors | default_errors }}</div>
              {%- endif -%}
            {%- endif -%}
          {% endform %}
          
          <p class="popup-disclaimer">
            {{ section.settings.disclaimer }}
          </p>
        </div>
      </div>
    </div>
  </div>

  <style>
    /* ═══════════════════════════════════════════════════ */
    /*  POPUP OVERLAY                                     */
    /* ═══════════════════════════════════════════════════ */
    .popup-overlay {
      position: fixed; top: 0; left: 0; width: 100%; height: 100%;
      background: rgba(0, 0, 0, {{ section.settings.overlay_opacity | divided_by: 100.0 }});
      z-index: 99999; display: flex; justify-content: center; align-items: center;
      opacity: 0; visibility: hidden; transition: opacity 0.4s ease, visibility 0.4s ease;
    }
    .popup-overlay.is-visible { opacity: 1; visibility: visible; }

    /* ═══════════════════════════════════════════════════ */
    /*  POPUP CONTAINER                                   */
    /* ═══════════════════════════════════════════════════ */
    .popup-container {
      background: #fff; width: 90%; max-width: {{ section.settings.popup_max_width }}px; display: flex;
      position: relative; border-radius: {{ border_radius }}; overflow: hidden;
      box-shadow: 0 20px 40px rgba(0,0,0,0.2);
      transform: translateY(20px); transition: transform 0.4s ease;
      min-height: 0px !important;
      font-family: '{{ section.settings.font_family }}', sans-serif !important;
    }
    .popup-overlay.is-visible .popup-container { transform: translateY(0); }

    /* ═══════════════════════════════════════════════════ */
    /*  CLOSE BUTTON                                      */
    /* ═══════════════════════════════════════════════════ */
    .popup-close {
      position: absolute; padding: 0; background: none; border: none;
      font-size: 30px; line-height: 1; cursor: pointer; z-index: 10; opacity: 0.7;
      width: 40px !important; height: 40px !important;
      min-width: 0px !important; min-height: 0px !important;
      right: 5px; top: 5px;
    }
    .popup-close:before { display: none; }
    .popup-close:hover { opacity: 1; }

    /* ═══════════════════════════════════════════════════ */
    /*  IMAGE HALF – square aspect ratio                  */
    /* ═══════════════════════════════════════════════════ */
    .popup-image { width: 50%; display: none; position: relative; }
    .popup-image::before { content: ''; display: block; padding-top: 100%; }
    .popup-image img, .popup-image svg { position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; display: block; }
    @media (min-width: 769px) { .popup-image { display: block; } }

    /* ═══════════════════════════════════════════════════ */
    /*  CONTENT HALF – square aspect ratio                */
    /* ═══════════════════════════════════════════════════ */
    .popup-content { width: 100%; padding: 20px; display: flex; flex-direction: column; justify-content: center; text-align: center; box-sizing: border-box; }
    @media (min-width: 769px) { .popup-content { width: 50%; padding: 30px 35px; text-align: {{ section.settings.text_alignment }}; aspect-ratio: 1 / 1; } }

    /* ═══════════════════════════════════════════════════ */
    /*  TYPOGRAPHY                                        */
    /* ═══════════════════════════════════════════════════ */
    .popup-subheading {
      color: inherit;
      font-family: '{{ section.settings.font_family }}', sans-serif !important;
      text-transform: none !important;
      letter-spacing: 1px;
      font-size: 0.95rem;
      font-weight: normal !important;
      margin-bottom: 10px;
    }
    .popup-heading {
      color: inherit;
      font-family: '{{ section.settings.font_family }}', sans-serif !important;
      font-size: {{ heading_size_mobile }};
      margin: 0 0 15px 0;
      line-height: 1.3;
      font-weight: {{ section.settings.heading_weight }};
      text-transform: {{ section.settings.heading_transform }} !important;
      letter-spacing: 0;
    }
    @media (min-width: 769px) { .popup-heading { font-size: {{ heading_size_desktop }}; } }
    .popup-desc {
      color: inherit;
      margin-bottom: 25px;
      font-size: 1.05rem;
      line-height: 1.5;
      font-family: '{{ section.settings.font_family }}', sans-serif !important;
      font-weight: normal !important;
      text-transform: none !important;
      opacity: 0.8;
    }

    /* ═══════════════════════════════════════════════════ */
    /*  FORM: INPUT & BUTTON                              */
    /* ═══════════════════════════════════════════════════ */
    .popup-form { width: 100%; }
    .input-group { display: flex; flex-direction: column; gap: 10px; }
    .popup-input {
      font-family: '{{ section.settings.font_family }}', sans-serif !important;
      background: {{ section.settings.input_bg }} !important;
      color: {{ section.settings.input_text }} !important;
      padding: 14px 24px !important;
      border: 1px solid transparent;
      border-radius: {{ input_radius }} !important;
      width: 100%;
      box-sizing: border-box;
      outline: none;
      font-size: 1rem;
    }
    .popup-submit {
      font-family: '{{ section.settings.font_family }}', sans-serif !important;
      padding: 14px 30px !important;
      border: none !important;
      font-weight: bold;
      cursor: pointer;
      text-transform: uppercase;
      border-radius: {{ input_radius }} !important;
      background-color: {{ section.settings.btn_bg }} !important;
      color: {{ section.settings.btn_text }} !important;
      transition: opacity 0.3s ease;
      width: 100%;
      font-size: 1rem;
    }
    .popup-submit:before { display: none; }
    .popup-submit:hover { opacity: 0.85; }

    /* ═══════════════════════════════════════════════════ */
    /*  DISCLAIMER                                        */
    /* ═══════════════════════════════════════════════════ */
    .popup-disclaimer {
      color: inherit;
      font-size: min(2.6vw, 0.75rem);
      margin-top: 15px;
      font-style: italic;
      opacity: 0.6;
      font-weight: normal !important;
      letter-spacing: -0.2px;
      white-space: nowrap;
    }
    @media (min-width: 769px) { .popup-disclaimer { font-size: 0.75rem; white-space: normal; } }

    /* ═══════════════════════════════════════════════════ */
    /*  SUCCESS STATE & COUPON                            */
    /* ═══════════════════════════════════════════════════ */
    .form-success { color: inherit; font-family: '{{ section.settings.font_family }}', sans-serif !important; font-size: 1.1rem; line-height: 1.4; }
    .popup-coupon-code {
      display: inline-block;
      margin-top: 15px;
      padding: 12px 25px;
      color: inherit;
      background-color: rgba(255,255,255,0.1);
      border: 2px dashed currentColor;
      font-family: '{{ section.settings.font_family }}', sans-serif !important;
      font-size: 1.5rem;
      font-weight: 900;
      letter-spacing: 2px;
      border-radius: {{ input_radius }};
    }
    
    .placeholder-svg { background: #eee; width: 100%; height: 100%; }
    .form-error { color: #ff4444; margin-top: 8px; font-size: 0.85rem; }
  </style>

  <script>
    // Skip popup entirely for bots, crawlers, and Lighthouse automated testing
    if (!navigator.webdriver) {
      window.addEventListener("load", function() {
        const sectionId = "{{ section.id }}";
        const popup = document.getElementById(`newsletter-popup-${sectionId}`);
        if(!popup) return;

        const closeBtn = popup.querySelector('.popup-close');
        const delay = {{ section.settings.delay }} * 1000;
        const hoursToExpire = {{ section.settings.frequency }};
        const storageKey = 'shopifyPopupClosed';

        function shouldShowPopup() {
          if (window.camoPopupSuccess) return true;
          if (localStorage.getItem('popupSubscribed') === 'true') return false;
          const lastClosed = localStorage.getItem(storageKey);
          if (lastClosed) {
            const now = new Date().getTime();
            const hoursSince = (now - lastClosed) / (1000 * 60 * 60);
            if (hoursSince < hoursToExpire) return false;
          }
          return true;
        }

        function showPopup() {
          if (shouldShowPopup()) {
            popup.style.display = 'flex';
            setTimeout(() => { popup.classList.add('is-visible'); }, 10);
          }
        }

        function closePopup() {
          popup.classList.remove('is-visible');
          setTimeout(() => { popup.style.display = 'none'; }, 400);
          localStorage.setItem(storageKey, new Date().getTime());
        }

        if (window.camoPopupSuccess) {
          showPopup();
        } else {
          setTimeout(showPopup, delay);
        }

        closeBtn.addEventListener('click', closePopup);
        popup.addEventListener('click', function(e) { if (e.target === popup) closePopup(); });
      });
    }
  </script>

{%- endif -%}

{% schema %}
{
  "name": "Popup with apparel tag",
  "settings": [
    { "type": "header", "content": "⚙️ Bật/Tắt & Cấu hình" },
    { "type": "checkbox", "id": "enable_popup", "label": "Bật Popup", "default": true },
    { "type": "range", "id": "delay", "min": 1, "max": 60, "step": 1, "label": "Delay (giây)", "default": 5 },
    { "type": "range", "id": "frequency", "min": 0, "max": 72, "step": 1, "label": "Hiện lại sau (giờ)", "default": 1, "info": "Đặt 0 để hiện mỗi lần truy cập" },
    
    { "type": "header", "content": "🎯 Nơi hiển thị (Display Logic)" },
    {
      "type": "select",
      "id": "display_scope",
      "label": "Phạm vi hiển thị",
      "options": [
        { "value": "all", "label": "Tất cả các trang" },
        { "value": "specific", "label": "Chỉ các trang được chọn bên dưới" }
      ],
      "default": "all"
    },
    { "type": "checkbox", "id": "show_on_home", "label": "Trang chủ (Home)", "default": true },
    { "type": "checkbox", "id": "show_on_collection", "label": "Tất cả Collection", "default": false },
    { "type": "checkbox", "id": "show_on_product", "label": "Tất cả Sản phẩm", "default": false },
    { "type": "checkbox", "id": "show_on_blog", "label": "Tất cả Blog/Bài viết", "default": false },
    { "type": "checkbox", "id": "show_on_cart", "label": "Giỏ hàng (Cart)", "default": false },
    {
      "type": "textarea",
      "id": "target_handles",
      "label": "Danh sách trang cụ thể (Handles)",
      "info": "Nhập template_suffix, cách nhau bằng dấu phẩy. VD: 'about-us, summer-sale'"
    },

    { "type": "header", "content": "🖼️ Hình ảnh" },
    { "type": "image_picker", "id": "image", "label": "Hình ảnh (bên trái)" },
    
    { "type": "header", "content": "✏️ Nội dung" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "join our community" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "GET 10% OFF FOR YOUR FIRST ORDER AND LOTS OF GOOD DEALS" },
    { "type": "textarea", "id": "description", "label": "Mô tả", "default": "join the ground:" },
    { "type": "text", "id": "input_placeholder", "label": "Placeholder ô nhập", "default": "Your email address" },
    { "type": "text", "id": "btn_label", "label": "Nút bấm", "default": "Subscribe" },
    { "type": "textarea", "id": "success_message", "label": "Câu báo thành công", "default": "Thank you! Use the promo code below at checkout:" },
    { "type": "text", "id": "coupon_code", "label": "Mã Giảm Giá", "default": "CAMO10" },
    { "type": "text", "id": "disclaimer", "label": "Ghi chú", "default": "No spam, unsubscribe anytime. Just early promotions and new releases." },

    { "type": "header", "content": "🎨 Màu sắc" },
    { "type": "color", "id": "bg_color", "label": "Màu nền nội dung", "default": "#2C3D33" },
    { "type": "color", "id": "text_color", "label": "Màu chữ", "default": "#faf6ee" },
    { "type": "color", "id": "input_bg", "label": "Màu nền ô nhập", "default": "#faf6ee" },
    { "type": "color", "id": "input_text", "label": "Màu chữ ô nhập", "default": "#000000" },
    { "type": "color", "id": "btn_bg", "label": "Màu nền nút", "default": "#faf6ee" },
    { "type": "color", "id": "btn_text", "label": "Màu chữ nút", "default": "#2C3D33" },
    { "type": "range", "id": "overlay_opacity", "min": 0, "max": 90, "step": 10, "unit": "%", "label": "Độ tối nền overlay", "default": 50 },

    { "type": "header", "content": "🔤 Kiểu chữ" },
    {
      "type": "select",
      "id": "font_family",
      "label": "Phông chữ",
      "options": [
        { "value": "Oswald", "label": "Oswald" },
        { "value": "Inter", "label": "Inter" },
        { "value": "Roboto", "label": "Roboto" },
        { "value": "Montserrat", "label": "Montserrat" },
        { "value": "Playfair Display", "label": "Playfair Display" },
        { "value": "Lato", "label": "Lato" },
        { "value": "Poppins", "label": "Poppins" },
        { "value": "Raleway", "label": "Raleway" }
      ],
      "default": "Oswald"
    },
    { "type": "range", "id": "heading_size_mobile", "min": 100, "max": 300, "step": 5, "label": "Cỡ heading (Mobile, x0.01rem)", "default": 115, "info": "115 = 1.15rem" },
    { "type": "range", "id": "heading_size_desktop", "min": 100, "max": 400, "step": 5, "label": "Cỡ heading (Desktop, x0.01rem)", "default": 130, "info": "130 = 1.3rem" },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Độ đậm Heading",
      "options": [
        { "value": "400", "label": "Normal (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-Bold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "900", "label": "Black (900)" }
      ],
      "default": "700"
    },
    {
      "type": "select",
      "id": "heading_transform",
      "label": "Kiểu chữ Heading",
      "options": [
        { "value": "uppercase", "label": "IN HOA (UPPERCASE)" },
        { "value": "capitalize", "label": "Viết Hoa Đầu Chữ (Capitalize)" },
        { "value": "lowercase", "label": "viết thường (lowercase)" },
        { "value": "none", "label": "Giữ nguyên (None)" }
      ],
      "default": "uppercase"
    },

    { "type": "header", "content": "📐 Hình dạng & Bố cục" },
    { "type": "range", "id": "popup_max_width", "min": 600, "max": 1200, "step": 50, "unit": "px", "label": "Chiều rộng tối đa Popup", "default": 850 },
    { "type": "range", "id": "border_radius", "min": 0, "max": 30, "step": 2, "unit": "px", "label": "Bo tròn Popup", "default": 8 },
    { "type": "range", "id": "input_radius", "min": 0, "max": 30, "step": 2, "unit": "px", "label": "Bo tròn ô nhập & nút", "default": 12 },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Canh chữ (Desktop)",
      "options": [
        { "value": "left", "label": "Trái" },
        { "value": "center", "label": "Giữa" },
        { "value": "right", "label": "Phải" }
      ],
      "default": "left"
    }
  ],
  "presets": [ { "name": "Popup with apparel tag" } ]
}
{% endschema %}
