      CamoSmartPopup.prototype.hideEmailSuggestion = function() {
        this.currentEmailSuggestion = null;
        if (this.emailSuggestion) this.emailSuggestion.hidden = true;
        if (this.emailSuggestionButton) this.emailSuggestionButton.textContent = '';
      };

      CamoSmartPopup.prototype.checkEmailSuggestion = function() {
        if (this.destroyed || !this.emailInput || !this.emailSuggestion || !this.emailSuggestionButton) return;

        var normalizedEmail = this.normalizeEmailValue(this.emailInput.value);
        var suggestedEmail = this.getEmailSuggestion(normalizedEmail);
        if (!suggestedEmail) {
          this.hideEmailSuggestion();
          return;
        }

        this.currentEmailSuggestion = suggestedEmail;
        this.emailSuggestionButton.textContent = suggestedEmail;
        this.emailSuggestion.hidden = false;
      };

      CamoSmartPopup.prototype.handleEmailInput = function() {
        if (this.destroyed) return;
        if (this.mailcheckTimer) clearTimeout(this.mailcheckTimer);
        this.mailcheckTimer = null;
        this.checkEmailSuggestion();
      };

      CamoSmartPopup.prototype.handleEmailBlur = function() {
        if (this.destroyed || !this.emailInput) return;
        var normalizedEmail = this.normalizeEmailValue(this.emailInput.value);
        if (this.emailInput.value !== normalizedEmail) this.emailInput.value = normalizedEmail;
        this.checkEmailSuggestion();
      };

      CamoSmartPopup.prototype.handleEmailSuggestionClick = function() {
        if (this.destroyed || !this.emailInput || !this.currentEmailSuggestion) return;
        this.emailInput.value = this.currentEmailSuggestion;
        this.hideEmailSuggestion();
        this.emailInput.focus();
        this.emailInput.dispatchEvent(new Event('input', { bubbles: true }));
        this.emailInput.dispatchEvent(new Event('change', { bubbles: true }));
      };

      CamoSmartPopup.prototype.showPopup = function(force) {
        if (this.destroyed) return;
        if (!force && !this.shouldShowPopup()) return;

        if (this.delayTimer) {
          clearTimeout(this.delayTimer);
          this.delayTimer = null;
        }

        // Load font and hydrate media only when popup actually displays
        this.loadPopupFont();
        this.hydratePopupMedia();

        var styleEl = document.getElementById('popup-css-' + this.sectionId);
        if (styleEl) styleEl.media = 'all';

        this.popup.style.display = 'flex';
        var self = this;
        if (this.transitionTimer) clearTimeout(this.transitionTimer);
        this.transitionTimer = setTimeout(function() {
          self.transitionTimer = null;
          if (self.destroyed) return;
          self.popup.classList.add('is-visible');
        }, 10);
      };

      CamoSmartPopup.prototype.closePopup = function(force) {
        if (this.destroyed) return;
        this.popup.classList.remove('is-visible');
        var self = this;
        if (this.delayTimer) {
          clearTimeout(this.delayTimer);
          this.delayTimer = null;
        }
        if (this.transitionTimer) clearTimeout(this.transitionTimer);
        this.transitionTimer = setTimeout(function() {
          self.transitionTimer = null;
          if (self.destroyed) return;
          self.popup.style.display = 'none';
        }, 400);

        if (!force && !isDesignMode) {
          safeStorageSet('shopifyPopupClosed', new Date().getTime());
        }
      };

      CamoSmartPopup.prototype.handleSubmit = function(e) {
        if (this.destroyed) return;
        if (this.emailInput) {
          this.emailInput.value = this.normalizeEmailValue(this.emailInput.value);
          var suggestedEmail = this.getEmailSuggestion(this.emailInput.value);
          if (suggestedEmail) {
            if (e) e.preventDefault();
            this.currentEmailSuggestion = suggestedEmail;
            if (this.emailSuggestionButton) this.emailSuggestionButton.textContent = suggestedEmail;
            if (this.emailSuggestion) this.emailSuggestion.hidden = false;
            if (this.submitButton) this.submitButton.removeAttribute('aria-busy');
            return;
          }
          this.hideEmailSuggestion();
        }
        if (this.submitError) this.submitError.hidden = true;
        if (this.submitButton) this.submitButton.setAttribute('aria-busy', 'true');
        if (this.submitTimer) clearTimeout(this.submitTimer);

        var self = this;
        this.submitTimer = setTimeout(function() {
          self.submitTimer = null;
          if (self.destroyed) return;
          if (!self.popup.isConnected || !self.popup.classList.contains('is-visible')) return;
          if (self.submitButton) self.submitButton.removeAttribute('aria-busy');
          if (self.submitError) self.submitError.hidden = false;
        }, 8000);
      };

      CamoSmartPopup.prototype.init = function() {
        if (this.destroyed) return;
        if (this.initialized) return;
        this.initialized = true;

        // Move popup to body to escape parent stacking context constraints
        document.body.appendChild(this.popup);

        // Prevent Cart Drawer (and others) from disabling popup via inert attributes
        var self = this;
        this.inertObserver = new MutationObserver(function(mutations) {
          mutations.forEach(function(mutation) {
            if (mutation.attributeName === 'inert' && self.popup.hasAttribute('inert')) {
              self.popup.removeAttribute('inert');
            }
          });
        });
        this.inertObserver.observe(this.popup, { attributes: true, attributeFilter: ['inert'] });

        if (this.closeBtn) this.closeBtn.addEventListener('click', this.handleCloseClick);
        this.popup.addEventListener('click', this.handleOverlayClick);
        if (this.emailInput) {
          this.emailInput.addEventListener('input', this.handleEmailInput);
          this.emailInput.addEventListener('blur', this.handleEmailBlur);
        }
        if (this.emailSuggestionButton) this.emailSuggestionButton.addEventListener('click', this.handleEmailSuggestionClick);
        if (this.form) this.form.addEventListener('submit', this.handleSubmit);

        // Attach customizer listeners
        document.addEventListener('shopify:section:select', this.handleSectionSelect);
        document.addEventListener('shopify:section:deselect', this.handleSectionDeselect);
        document.addEventListener('shopify:section:unload', this.handleSectionUnload);

        var desktopDelay = {{ section.settings.delay }} * 1000;
        var mobileDelay = {{ section.settings.mobile_delay | default: section.settings.delay }} * 1000;
        var delay = window.matchMedia('(max-width: 767px)').matches ? mobileDelay : desktopDelay;

        if (window.camoPopupSuccess) {
          this.showPopup(true);
        } else if (isDesignMode) {
          this.showPopup(true);
        } else {
          this.delayTimer = setTimeout(function() {
            self.delayTimer = null;
            if (self.destroyed) return;
            self.showPopup(false);
          }, delay);
        }
      };

      CamoSmartPopup.prototype.handleSectionSelect = function(e) {
        if (this.destroyed) return;
        if (!e.detail || e.detail.sectionId !== this.sectionId) return;
        this.showPopup(true);
      };

      CamoSmartPopup.prototype.handleSectionDeselect = function(e) {
        if (this.destroyed) return;
        if (!e.detail || e.detail.sectionId !== this.sectionId) return;
        this.closePopup(true);
      };

      CamoSmartPopup.prototype.handleSectionUnload = function(e) {
        if (this.destroyed) return;
        if (!e.detail || e.detail.sectionId !== this.sectionId) return;
        this.destroy();
      };

      CamoSmartPopup.prototype.destroy = function() {
        if (this.destroyed) return;
        this.destroyed = true;

        // Clear all timers
        if (this.initTimer) clearTimeout(this.initTimer);
        if (this.delayTimer) clearTimeout(this.delayTimer);
        if (this.transitionTimer) clearTimeout(this.transitionTimer);
        if (this.submitTimer) clearTimeout(this.submitTimer);
        if (this.mailcheckTimer) clearTimeout(this.mailcheckTimer);

        if (this.domReadyHandler) {
          document.removeEventListener('DOMContentLoaded', this.domReadyHandler);
          this.domReadyHandler = null;
        }

        // Cancel requestIdleCallback if scheduled
        if (this.idleHandle && 'cancelIdleCallback' in window) {
          window.cancelIdleCallback(this.idleHandle);
          this.idleHandle = null;
        }

        // Disconnect MutationObserver
        if (this.inertObserver) {
          this.inertObserver.disconnect();
          this.inertObserver = null;
        }

        // Clean up theme editor event listeners
        document.removeEventListener('shopify:section:select', this.handleSectionSelect);
        document.removeEventListener('shopify:section:deselect', this.handleSectionDeselect);
        document.removeEventListener('shopify:section:unload', this.handleSectionUnload);

        // Remove event listeners from elements
        if (this.closeBtn) this.closeBtn.removeEventListener('click', this.handleCloseClick);
        this.popup.removeEventListener('click', this.handleOverlayClick);
        if (this.emailInput) {
          this.emailInput.removeEventListener('input', this.handleEmailInput);
          this.emailInput.removeEventListener('blur', this.handleEmailBlur);
        }
        if (this.emailSuggestionButton) this.emailSuggestionButton.removeEventListener('click', this.handleEmailSuggestionClick);
        if (this.form) this.form.removeEventListener('submit', this.handleSubmit);

        // Remove node from DOM if it is present
        if (this.popup && this.popup.parentNode) {
          this.popup.parentNode.removeChild(this.popup);
        }

        // Remove from registry
        if (window.CamoSmartPopupInstances && window.CamoSmartPopupInstances[this.sectionId] === this) {
          delete window.CamoSmartPopupInstances[this.sectionId];
        }
      };

      // Create instance and register it
      var instance = new CamoSmartPopup(popupEl, sectionId);
      window.CamoSmartPopupInstances = window.CamoSmartPopupInstances || {};
      window.CamoSmartPopupInstances[sectionId] = instance;

      // Bootstrap logic
      if (isDesignMode) {
        instance.init();
      } else {
        var scheduled = false;
        var scheduleInit = function() {
          if (instance.destroyed || scheduled) return;
          scheduled = true;
          instance.initTimer = setTimeout(function() {
            instance.initTimer = null;
            if (instance.destroyed) return;
            instance.runWhenIdle(function() {
              instance.init();
            }, 2500);
          }, 1500);
        };

        if (document.readyState === 'loading') {
          instance.domReadyHandler = scheduleInit;
          document.addEventListener('DOMContentLoaded', instance.domReadyHandler, { once: true });
        } else {
          scheduleInit();
        }
      }
    })();
  </script>

