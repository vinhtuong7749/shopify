        var correctedDomain = domainCorrections[domain];
        if (!correctedDomain) {
          var domainPrefixParts = domain.split('.');
          var leadingPart = domainPrefixParts[0];
          var restDomain = domainPrefixParts.slice(1).join('.');
          if (
            ['mail', 'email', 'e-mail', 'webmail', 'smtp', 'imap', 'pop'].indexOf(leadingPart) !== -1 &&
            knownDomains.indexOf(restDomain) !== -1
          ) {
            correctedDomain = restDomain;
          }
        }
        if (!correctedDomain) {
          var extraSuffixes = ['com', 'net', 'org', 'co', 'cm', 'con', 'cmo', 'comm', 'om'];
          for (var suffixIndex = 0; suffixIndex < extraSuffixes.length; suffixIndex += 1) {
            var extraSuffix = '.' + extraSuffixes[suffixIndex];
            if (domain.slice(-extraSuffix.length) !== extraSuffix) continue;

            var trimmedExtraSuffix = domain.slice(0, -extraSuffix.length);
            if (knownDomains.indexOf(trimmedExtraSuffix) !== -1) {
              correctedDomain = trimmedExtraSuffix;
              break;
            }
          }
        }
        if (!correctedDomain) {
          var parts = domain.split('.');
          var tld = parts.length > 1 ? parts[parts.length - 1] : '';
          var correctedTld = tldCorrections[tld];

          if (correctedTld && parts.length > 1) {
            parts[parts.length - 1] = correctedTld;
            var tldCandidate = parts.join('.');
            if (knownDomains.indexOf(tldCandidate) !== -1) correctedDomain = tldCandidate;
          }
        }

        if (!correctedDomain) {
          var squashedDomain = domain.replace(/\./g, '');
          for (var i = 0; i < knownDomains.length; i += 1) {
            var squashedKnownDomain = knownDomains[i].replace(/\./g, '');
            var squashedKnownParts = splitDomain(knownDomains[i]);
            var safeFuzzySquashedMatch = !hasDot &&
              squashedKnownParts.root.length > 4 &&
              squashedDomain.slice(0, 2) === squashedKnownDomain.slice(0, 2) &&
              distance(squashedDomain, squashedKnownDomain) <= 2;

            if (squashedDomain === squashedKnownDomain || safeFuzzySquashedMatch) {
              correctedDomain = knownDomains[i];
              break;
            }
          }
        }

        if (!correctedDomain) {
          var bestMatch = null;
          var bestScore = 1000;

          for (var k = 0; k < knownDomains.length; k += 1) {
            var knownParts = splitDomain(knownDomains[k]);
            if (knownParts.root.length <= 4 && inputParts.root !== knownParts.root) continue;

            var comparableTld = tldCorrections[inputParts.tld] || inputParts.tld || knownParts.tld;
            var rootDistance = distance(inputParts.root, knownParts.root);
            var tldDistance = distance(comparableTld, knownParts.tld);
            var fullDistance = distance(domain, knownDomains[k]);
            var sameRootFamily = inputParts.root.charAt(0) === knownParts.root.charAt(0) ||
              inputParts.root === knownParts.root.slice(1) ||
              inputParts.root.slice(1) === knownParts.root ||
              inputParts.root.slice(0, 2) === knownParts.root.slice(0, 2);
            var tldLooksClose = comparableTld === knownParts.tld ||
              tldDistance <= 1 ||
              (inputParts.root === knownParts.root && tldDistance <= 2);
            var rootLimit = knownParts.root.length <= 4 ? 1 : knownParts.root.length <= 8 ? 2 : 3;
            var fullLimit = knownDomains[k].length <= 8 ? 1 : 2;
            var isCandidate = false;

            if (sameRootFamily && tldLooksClose && rootDistance <= rootLimit) {
              isCandidate = true;
            } else if (sameRootFamily && fullDistance > 0 && fullDistance <= fullLimit) {
              isCandidate = true;
            } else if (inputParts.root === knownParts.root && tldLooksClose) {
              isCandidate = true;
            }

            if (isCandidate) {
              var score = (rootDistance * 4) + (tldDistance * 2) + fullDistance;
              if (score < bestScore) {
                bestScore = score;
                bestMatch = knownDomains[k];
              }
            }
