{% comment %}
  Section: Smart Newsletter Popup
  Features: Split Layout, Delay, Frequency Cap, Advanced Display Logic, Fully Customizable via Theme Customizer
{% endcomment %}

{%- assign show_popup = false -%}

{%- if section.settings.display_scope == 'all' -%}
  {%- assign show_popup = true -%}
{%- else -%}
  {%- if section.settings.show_on_home and template.name == 'index' -%}
    {%- assign show_popup = true -%}
  {%- endif -%}
  {%- if section.settings.show_on_collection and template.name == 'collection' -%}
    {%- assign show_popup = true -%}
  {%- endif -%}
  {%- if section.settings.show_on_product and template.name == 'product' -%}
    {%- assign show_popup = true -%}
  {%- endif -%}
  {%- if section.settings.show_on_blog and template.name == 'article' or template.name == 'blog' -%}
    {%- assign show_popup = true -%}
  {%- endif -%}
  {%- if section.settings.show_on_cart and template.name == 'cart' -%}
    {%- assign show_popup = true -%}
  {%- endif -%}

  {%- if section.settings.target_handles != blank -%}
    {%- assign handles = section.settings.target_handles | split: ',' -%}
    {%- for handle in handles -%}
      {%- assign clean_handle = handle | strip -%}
      {%- if clean_handle == collection.template_suffix
          or clean_handle == product.template_suffix
          or clean_handle == page.template_suffix -%}
        {%- assign show_popup = true -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}
  {%- endif -%}
{%- endif -%}

{%- if show_popup and section.settings.enable_popup -%}

  {%- comment -%} Assign customizable values {%- endcomment -%}
  {%- assign border_radius = section.settings.border_radius | append: 'px' -%}
  {%- assign input_radius = section.settings.input_radius | append: 'px' -%}
  {%- assign heading_size_mobile = section.settings.heading_size_mobile | divided_by: 100.0 | append: 'rem' -%}
  {%- assign heading_size_desktop = section.settings.heading_size_desktop | divided_by: 100.0 | append: 'rem' -%}

  <div id="newsletter-popup-{{ section.id }}" class="popup-overlay" style="display: none;">
    <div class="popup-container">
      
      <button class="popup-close" aria-label="Close" style="color: {{ section.settings.text_color }};">&times;</button>

      <div class="popup-image">
        {%- if section.settings.image != blank -%}
          {%- # theme-check-disable RemoteAsset -%}
          <img
            src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///ywAAAAAAQABAAACAUwAOw=="
            data-popup-src="{{ section.settings.image | image_url: width: 800 }}"
            alt="{{ section.settings.heading | escape }}"
            loading="lazy"
            decoding="async"
            fetchpriority="low"
            width="400" height="400"
          >
          {%- # theme-check-enable RemoteAsset -%}
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>

      <div class="popup-content" style="background-color: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }};">
        <div class="popup-text-wrapper">
          {%- if section.settings.subheading != blank -%}
            <p class="popup-subheading">{{ section.settings.subheading }}</p>
          {%- endif -%}
          
          {%- if section.settings.heading != blank -%}
            <h2 class="popup-heading">{{ section.settings.heading }}</h2>
          {%- endif -%}

          {%- if section.settings.description != blank -%}
            <div class="popup-desc">
              {{ section.settings.description }}
            </div>
          {%- endif -%}

          {%- assign popup_form_id = 'camo-popup-contact-form-' | append: section.id -%}
          {% form 'customer', class: 'popup-form js-camo-popup-form', id: popup_form_id %}
            <input type="hidden" name="contact[tags]" value="newsletter, popup, apparel">
            <input type="hidden" name="contact[accepts_marketing]" value="true">
            {%- if form.posted_successfully? and request.design_mode == false -%}
              <div class="form-success-wrapper" style="text-align: center; margin: 15px 0;">
                <div class="form-success">
                  {{ section.settings.success_message | default: "Thank you! Use the promo code below at checkout:" | newline_to_br }}
                </div>
                {%- if section.settings.coupon_code != blank -%}
                  <div class="popup-coupon-code">
                    {{ section.settings.coupon_code }}
                  </div>
                {%- endif -%}
              </div>
              <script>
                window.camoPopupSuccess = true;
                try { localStorage.setItem('popupSubscribed', 'true'); } catch(e) {}
                {%- if section.settings.coupon_code != blank -%}
                try { localStorage.setItem('pending_discount', '{{ section.settings.coupon_code }}'); } catch(e) {}
                {%- endif -%}
              </script>
            {%- else -%}
              <div class="input-group">
                <label class="visually-hidden" for="camo-popup-email-{{ section.id }}">
                  {{ section.settings.input_placeholder }}
                </label>
                <input id="camo-popup-email-{{ section.id }}" type="email" inputmode="email" name="contact[email]" class="popup-input" value="{{ form.email }}" placeholder="{{ section.settings.input_placeholder }}" autocomplete="email" autocorrect="off" autocapitalize="off" required>
                <div class="popup-email-suggestion js-camo-email-suggestion" aria-live="polite" hidden>
                  Did you mean
                  <button type="button" class="popup-email-suggestion__button js-camo-email-suggestion-button"></button>?
                </div>
                <button type="submit" name="commit" class="popup-submit">
                  {{ section.settings.btn_label }}
                </button>
              </div>
              {%- if form.errors -%}
                <div class="form-error">{{ form.errors | default_errors }}</div>
              {%- endif -%}
              <div class="form-error js-camo-popup-submit-error" role="alert" hidden>
                We could not verify this signup. Please allow the verification check or try again in another browser.
              </div>
            {%- endif -%}
          {% endform %}
          
          <p class="popup-disclaimer">
            {{ section.settings.disclaimer }}
          </p>
        </div>
      </div>
    </div>
  </div>

  <style id="popup-css-{{- section.id -}}" media="print">
    .popup-overlay {
      position: fixed; top: 0; left: 0; width: 100%; height: 100%;
      background: rgba(0, 0, 0, {{ section.settings.overlay_opacity | divided_by: 100.0 }});
      z-index: 2147483647 !important; display: flex; justify-content: center; align-items: center;
      opacity: 0; visibility: hidden; transition: opacity 0.4s ease, visibility 0.4s ease;
      pointer-events: auto !important;
      touch-action: manipulation;
    }
    .popup-overlay.is-visible { opacity: 1; visibility: visible; }

    .popup-container {
      background: #fff; width: 90%; max-width: {{ section.settings.popup_max_width }}px; display: flex;
      position: relative; border-radius: {{ border_radius }}; overflow: hidden;
      box-shadow: 0 20px 40px rgba(0,0,0,0.2);
      transform: translateY(20px); transition: transform 0.4s ease;
      min-height: 0px !important;
      font-family: '{{ section.settings.font_family }}', sans-serif !important;
      pointer-events: auto !important;
    }
    .popup-overlay.is-visible .popup-container { transform: translateY(0); }

    .popup-close {
      position: absolute; padding: 0; background: none; border: none;
      font-size: 30px; line-height: 1; cursor: pointer; z-index: 10; opacity: 0.7;
      width: 40px !important; height: 40px !important;
      min-width: 0px !important; min-height: 0px !important;
      right: 5px; top: 5px;
      pointer-events: auto !important;
    }
    .popup-close:before { display: none; }
    .popup-close:hover { opacity: 1; }

    .popup-image { width: 50%; display: none; position: relative; }
    .popup-image::before { content: ''; display: block; padding-top: 100%; }
    .popup-image img, .popup-image svg { position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; display: block; }
    @media (min-width: 769px) { .popup-image { display: block; } }

    .popup-content { width: 100%; padding: 20px; display: flex; flex-direction: column; justify-content: center; text-align: center; box-sizing: border-box; }
    @media (min-width: 769px) { .popup-content { width: 50%; padding: 30px 35px; text-align: {{ section.settings.text_alignment }}; aspect-ratio: 1 / 1; } }

    .popup-subheading {
      color: inherit;
      font-family: '{{ section.settings.font_family }}', sans-serif !important;
      text-transform: none !important;
      letter-spacing: 1px;
      font-size: 0.95rem;
      font-weight: normal !important;
      margin-bottom: 10px;
    }
    .popup-heading {
      color: inherit;
      font-family: '{{ section.settings.font_family }}', sans-serif !important;
      font-size: {{ heading_size_mobile }};
      margin: 0 0 15px 0;
      line-height: 1.3;
      font-weight: {{ section.settings.heading_weight }};
      text-transform: {{ section.settings.heading_transform }} !important;
      letter-spacing: 0;
    }
    @media (min-width: 769px) { .popup-heading { font-size: {{ heading_size_desktop }}; } }
    .popup-desc {
      color: inherit;
      margin-bottom: 25px;
      font-size: 1.05rem;
      line-height: 1.5;
      font-family: '{{ section.settings.font_family }}', sans-serif !important;
      font-weight: normal !important;
      text-transform: none !important;
      opacity: 0.8;
    }

    .popup-form { width: 100%; }
    .input-group { display: flex; flex-direction: column; gap: 10px; }
    .popup-input {
      font-family: '{{ section.settings.font_family }}', sans-serif !important;
      background: {{ section.settings.input_bg }} !important;
      color: {{ section.settings.input_text }} !important;
      padding: 14px 24px !important;
      border: 1px solid transparent;
      border-radius: {{ input_radius }} !important;
      width: 100%;
      box-sizing: border-box;
      outline: none;
      font-size: 1rem;
      pointer-events: auto !important;
    }
    .popup-submit {
      font-family: '{{ section.settings.font_family }}', sans-serif !important;
      padding: 14px 30px !important;
      border: none !important;
      font-weight: bold;
      cursor: pointer;
      text-transform: uppercase;
      border-radius: {{ input_radius }} !important;
      background-color: {{ section.settings.btn_bg }} !important;
      color: {{ section.settings.btn_text }} !important;
      transition: opacity 0.3s ease;
      width: 100%;
      font-size: 1rem;
      pointer-events: auto !important;
    }
    .popup-submit:before { display: none; }
    .popup-submit:hover { opacity: 0.85; }

    .popup-email-suggestion {
      margin-top: -3px;
      margin-bottom: 2px;
      padding: 8px 10px;
      color: #ffffff !important;
      background: rgba(255, 255, 255, 0.16);
      border: 1px solid rgba(255, 255, 255, 0.38);
      border-radius: {{ input_radius }};
      font-family: '{{ section.settings.font_family }}', sans-serif !important;
      font-size: 0.84rem;
      line-height: 1.35;
      font-weight: 600;
      opacity: 1;
      text-align: {{ section.settings.text_alignment }};
      text-shadow: 0 1px 2px rgba(0, 0, 0, 0.35);
      box-shadow: 0 6px 18px rgba(0, 0, 0, 0.14);
    }
    .popup-email-suggestion,
    .popup-email-suggestion * {
      color: #ffffff !important;
    }
    .popup-email-suggestion__button {
      display: inline !important;
      width: auto !important;
      min-width: 0 !important;
      min-height: 0 !important;
      padding: 0 !important;
      border: 0 !important;
      border-radius: 0 !important;
      background: transparent !important;
      color: #ffffff !important;
      font: inherit !important;
      font-weight: 900 !important;
      line-height: inherit !important;
      text-transform: none !important;
      text-decoration: underline;
      text-decoration-thickness: 2px;
      text-underline-offset: 3px;
      cursor: pointer;
    }
    .popup-email-suggestion__button:before { display: none !important; }

    .popup-disclaimer {
      color: inherit;
      font-size: min(2.6vw, 0.75rem);
      margin-top: 15px;
      font-style: italic;
      opacity: 0.6;
      font-weight: normal !important;
      letter-spacing: -0.2px;
      white-space: nowrap;
    }
    @media (min-width: 769px) { .popup-disclaimer { font-size: 0.75rem; white-space: normal; } }

    .form-success { color: inherit; font-family: '{{ section.settings.font_family }}', sans-serif !important; font-size: 1.1rem; line-height: 1.4; }
    .popup-coupon-code {
      display: inline-block;
      margin-top: 15px;
      padding: 12px 25px;
      color: inherit;
      background-color: rgba(255,255,255,0.1);
      border: 2px dashed currentColor;
      font-family: '{{ section.settings.font_family }}', sans-serif !important;
      font-size: 1.5rem;
      font-weight: 900;
      letter-spacing: 2px;
      border-radius: {{ input_radius }};
    }
    
    .placeholder-svg { background: #eee; width: 100%; height: 100%; }
    .form-error { color: #ff4444; margin-top: 8px; font-size: 0.85rem; }
  </style>

  <script>
    (function() {
      var sectionId = '{{- section.id -}}';

      // 1. Dọn dẹp instance cũ và phần tử cũ khỏi body nếu đã tồn tại để tránh duplicate
      if (window.CamoSmartPopupInstances && window.CamoSmartPopupInstances[sectionId]) {
        try {
          window.CamoSmartPopupInstances[sectionId].destroy();
        } catch(e) {
          console.warn('[CamoSignal] Error destroying old popup instance:', e);
        }
      }

      var popupSelector = '[id="newsletter-popup-' + sectionId + '"]';
      var currentScript = document.currentScript;
      var popupEl = currentScript && currentScript.parentNode ? currentScript.parentNode.querySelector(popupSelector) : null;
      if (!popupEl) popupEl = document.querySelector(popupSelector);
      if (!popupEl) return;

      Array.prototype.slice.call(document.querySelectorAll(popupSelector)).forEach(function(node) {
        if (node !== popupEl && node.parentNode) {
          node.parentNode.removeChild(node);
        }
      });

      var isDesignMode = {% if request.design_mode %}true{% else %}false{% endif %};

      function safeStorageGet(key) {
        try {
          return window.localStorage ? localStorage.getItem(key) : null;
        } catch(e) {
          return null;
        }
      }

      function safeStorageSet(key, value) {
        try {
          if (window.localStorage) localStorage.setItem(key, value);
        } catch(e) {}
      }

      function CamoSmartPopup(el, id) {
        this.popup = el;
        this.sectionId = id;
        this.initialized = false;
        this.destroyed = false;

        this.initTimer = null;
        this.delayTimer = null;
        this.transitionTimer = null;
        this.submitTimer = null;
        this.mailcheckTimer = null;
        this.idleHandle = null;
        this.domReadyHandler = null;
        this.inertObserver = null;

        this.closeBtn = this.popup.querySelector('.popup-close');
        this.form = this.popup.querySelector('.js-camo-popup-form');
        this.emailInput = this.form ? this.form.querySelector('input[name="contact[email]"]') : null;
        this.emailSuggestion = this.popup.querySelector('.js-camo-email-suggestion');
        this.emailSuggestionButton = this.popup.querySelector('.js-camo-email-suggestion-button');
        this.submitButton = this.form ? this.form.querySelector('[type="submit"]') : null;
        this.submitError = this.popup.querySelector('.js-camo-popup-submit-error');
        this.currentEmailSuggestion = null;

        // Binds
        this.handleCloseClick = this.closePopup.bind(this, false);
        this.handleOverlayClick = this.handleOverlayClick.bind(this);
        this.handleEmailInput = this.handleEmailInput.bind(this);
        this.handleEmailBlur = this.handleEmailBlur.bind(this);
        this.handleEmailSuggestionClick = this.handleEmailSuggestionClick.bind(this);
        this.handleSubmit = this.handleSubmit.bind(this);
        this.handleSectionSelect = this.handleSectionSelect.bind(this);
        this.handleSectionDeselect = this.handleSectionDeselect.bind(this);
        this.handleSectionUnload = this.handleSectionUnload.bind(this);
      }

      CamoSmartPopup.prototype.handleOverlayClick = function(e) {
        if (this.destroyed) return;
        if (e.target === this.popup) {
          this.closePopup(false);
        }
      };

      CamoSmartPopup.prototype.runWhenIdle = function(callback, timeout) {
        if (this.destroyed) return;
        var self = this;
        var wrappedCallback = function() {
          self.idleHandle = null;
          self.initTimer = null;
          if (self.destroyed) return;
          callback();
        };

        if ('requestIdleCallback' in window) {
          this.idleHandle = window.requestIdleCallback(wrappedCallback, { timeout: timeout || 2500 });
          return;
        }
        this.initTimer = setTimeout(wrappedCallback, timeout || 2500);
      };

      CamoSmartPopup.prototype.loadPopupFont = function() {
        var fontFamily = '{{ section.settings.font_family }}';
        var whitelist = ['Oswald', 'Inter', 'Roboto', 'Montserrat', 'Playfair Display', 'Lato', 'Poppins', 'Raleway'];
        if (whitelist.indexOf(fontFamily) === -1) {
          console.log('[CamoSignal] Font family not in whitelist, using fallback:', fontFamily);
          return;
        }
        var fontId = 'camo-font-' + fontFamily.toLowerCase().replace(/[^a-z0-9]/g, '-');
        if (document.getElementById(fontId)) return;

        var link = document.createElement('link');
        link.id = fontId;
        link.rel = 'stylesheet';
        link.href = 'https://fonts.googleapis.com/css2?family=' + fontFamily.replace(/\s+/g, '+') + ':wght@300;400;500;700;900&display=swap';
        document.head.appendChild(link);
      };

      CamoSmartPopup.prototype.hydratePopupMedia = function() {
        this.popup.querySelectorAll('img[data-popup-src]').forEach(function(img) {
          if (!img.dataset.popupSrc) return;
          img.src = img.dataset.popupSrc;
          img.removeAttribute('data-popup-src');
        });
      };

      CamoSmartPopup.prototype.shouldShowPopup = function() {
        if (isDesignMode) return true;
        if (window.camoPopupSuccess) return true;
        if (safeStorageGet('popupSubscribed') === 'true') return false;
        var lastClosed = safeStorageGet('shopifyPopupClosed');
        if (lastClosed) {
          var hoursSince = (new Date().getTime() - lastClosed) / 3600000;
          var hoursToExpire = {{ section.settings.frequency }};
          if (hoursSince < hoursToExpire) return false;
        }
        return true;
      };

      CamoSmartPopup.prototype.normalizeEmailValue = function(value) {
        var email = (value || '').trim();
        var atIndex = email.lastIndexOf('@');
        if (atIndex === -1) return email;

        var localPart = email.slice(0, atIndex).trim();
        var domain = email.slice(atIndex + 1).trim().toLowerCase();
        return localPart + '@' + domain;
      };

      CamoSmartPopup.prototype.getEmailSuggestion = function(value) {
        var email = this.normalizeEmailValue(value);
        var atIndex = email.lastIndexOf('@');
        if (atIndex <= 0 || atIndex === email.length - 1) return null;

        var localPart = email.slice(0, atIndex);
        var rawDomain = email.slice(atIndex + 1).trim().toLowerCase();
        var domain = rawDomain
          .replace(/\s+/g, '')
          .replace(/[,\u3002\uff0e\uff61\/\\;:|_]+/g, '.')
          .replace(/\.{2,}/g, '.')
          .replace(/^\./, '')
          .replace(/\.$/, '')
          .toLowerCase();
        if (domain.indexOf('www.') === 0) domain = domain.slice(4);
        if (!domain || domain.length < 3) return null;
        var hasDot = domain.indexOf('.') !== -1;

        var knownDomains = [
          'gmail.com',
          'googlemail.com',
          'yahoo.com',
          'ymail.com',
          'rocketmail.com',
          'hotmail.com',
          'outlook.com',
          'live.com',
          'msn.com',
          'icloud.com',
          'me.com',
          'mac.com',
          'aol.com',
          'proton.me',
          'protonmail.com',
          'pm.me',
          'mail.com',
          'zoho.com',
          'hey.com',
          'fastmail.com',
          'gmx.com',
          'gmx.net',
          'tutanota.com',
          'comcast.net',
          'verizon.net',
          'att.net',
          'ameritech.net',
          'sbcglobal.net',
          'bellsouth.net',
          'earthlink.net',
          'cox.net',
          'charter.net',
          'roadrunner.com',
          'btinternet.com',
          'sky.com',
          'yahoo.co.uk',
          'hotmail.co.uk',
          'outlook.co.uk',
          'yandex.com',
          'yandex.ru',
          'mail.ru',
          'rambler.ru',
          'qq.com',
          '163.com',
          '126.com',
          'naver.com',
          'daum.net',
          'hanmail.net',
          'web.de',
          'gmx.de',
          't-online.de',
          'freenet.de',
          'orange.fr',
          'free.fr',
          'laposte.net',
          'wanadoo.fr',
          'libero.it',
          'tiscali.it',
          'virgilio.it',
          'seznam.cz',
          'wp.pl',
          'onet.pl',
          'interia.pl'
        ];
        if (knownDomains.indexOf(domain) !== -1) {
          return domain === rawDomain ? null : localPart + '@' + domain;
        }

        var splitDomain = function(candidate) {
          var lastDotIndex = candidate.lastIndexOf('.');
          if (lastDotIndex === -1) return { root: candidate, tld: '' };
          return {
            root: candidate.slice(0, lastDotIndex),
            tld: candidate.slice(lastDotIndex + 1)
          };
        };
        var distance = function(a, b) {
          var matrix = [];
          var i;
          var j;

          for (i = 0; i <= a.length; i += 1) {
            matrix[i] = [i];
          }
          for (j = 0; j <= b.length; j += 1) {
            matrix[0][j] = j;
          }

          for (i = 1; i <= a.length; i += 1) {
            for (j = 1; j <= b.length; j += 1) {
              var cost = a.charAt(i - 1) === b.charAt(j - 1) ? 0 : 1;
              matrix[i][j] = Math.min(
                matrix[i - 1][j] + 1,
                matrix[i][j - 1] + 1,
                matrix[i - 1][j - 1] + cost
              );

              if (
                i > 1 &&
                j > 1 &&
                a.charAt(i - 1) === b.charAt(j - 2) &&
                a.charAt(i - 2) === b.charAt(j - 1)
              ) {
                matrix[i][j] = Math.min(matrix[i][j], matrix[i - 2][j - 2] + cost);
              }
            }
          }

          return matrix[a.length][b.length];
        };
        var tldCorrections = {
          'co': 'com',
          'cm': 'com',
          'con': 'com',
          'cmo': 'com',
          'comm': 'com',
          'comn': 'com',
          'comj': 'com',
          'cim': 'com',
          'cpm': 'com',
          'ocm': 'com',
          'om': 'com',
          'ne': 'net',
          'nt': 'net',
          'nte': 'net',
          'nett': 'net',
          'or': 'org',
          'ogr': 'org',
          'orgg': 'org',
          'ed': 'edu',
          'eddu': 'edu',
          'mee': 'me',
          'rj': 'ru',
          'ri': 'ru',
          're': 'ru',
          'dr': 'de',
          'fe': 'de',
          'ft': 'fr',
          'gr': 'fr',
          'ot': 'it',
          'ut': 'it',
          'pk': 'pl',
          'po': 'pl',
          'cf': 'cz',
          'cy': 'cz',
          'uj': 'uk',
          'uo': 'uk'
        };
        var inputParts = splitDomain(domain);

        var domainCorrections = {
          'gmail': 'gmail.com',
          'gmailcom': 'gmail.com',
          'gamil.com': 'gmail.com',
          'gmial.com': 'gmail.com',
          'gmai.com': 'gmail.com',
          'gmal.com': 'gmail.com',
          'gnail.com': 'gmail.com',
          'gmaill.com': 'gmail.com',
