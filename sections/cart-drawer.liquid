	<script>
		(function() {
			function setCartDrawerChatState(isOpen) {
				document.body.classList.toggle('is-cart-drawer-open', isOpen);
			}

			function syncCartDrawerChatState() {
				var cartDrawer = document.getElementById('CartDrawer');
				setCartDrawerChatState(!!(cartDrawer && cartDrawer.classList.contains('is-active')));
			}

			function bindCartDrawerChatEvents() {
				if (!window.themeCore || !window.themeCore.EventBus) return;

				window.themeCore.EventBus.listen('Toggle:CartDrawer:open', function() {
					setCartDrawerChatState(true);
				});

				window.themeCore.EventBus.listen('Toggle:CartDrawer:close', function() {
					setCartDrawerChatState(false);
				});

				window.themeCore.EventBus.listen('cart:drawer:open', function() {
					setCartDrawerChatState(true);
				});

				window.themeCore.EventBus.listen('cart:drawer:close', function() {
					setCartDrawerChatState(false);
				});

				syncCartDrawerChatState();
			}

			if (window.themeCore && window.themeCore.EventBus) {
				bindCartDrawerChatEvents();
			} else {
				document.addEventListener('theme:all:loaded', bindCartDrawerChatEvents, { once: true });
			}
		})();
	</script>

	{%- if show_auto_open and cart.item_count > 0 -%}
		<script>
			(function() {
				function autoOpenCartDrawer() {
					if (window.themeCore && window.themeCore.EventBus) {
						window.themeCore.EventBus.emit('cart:drawer:open');
					}
				}
				if (window.themeCore && window.themeCore.loaded) {
					autoOpenCartDrawer();
				} else {
					document.addEventListener('theme:all:loaded', autoOpenCartDrawer, { once: true });
				}
			})();
		</script>
	{%- endif -%}
{%- endif -%}

