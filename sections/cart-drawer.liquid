					setCartDrawerChatState(false);
				});

				window.themeCore.EventBus.listen('cart:drawer:open', function() {
					setCartDrawerChatState(true);
				});

				window.themeCore.EventBus.listen('cart:drawer:close', function() {
					setCartDrawerChatState(false);
				});

				syncCartDrawerChatState();
