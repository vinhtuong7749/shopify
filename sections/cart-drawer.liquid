		#CartDrawer .cart-tier-offer__quantity {
			display: inline-block;
			min-width: 0;
			font-size: 1.16em;
			font-style: italic;
			line-height: 0.9;
			text-align: center;
		}

		#CartDrawer .cart-tier-offer__divider {
			position: absolute;
			top: 24px;
			left: -8px;
			right: -8px;
			z-index: 1;
			height: 1px;
			background-image: repeating-linear-gradient(
				90deg,
				rgba(255, 218, 105, 0.82) 0 4px,
				transparent 4px 7px
			);
			transform: scaleY(0.55);
			transform-origin: center;
		}

		#CartDrawer .cart-tier-offer__value {
			display: inline-flex;
			width: 100%;
			align-items: flex-end;
			justify-content: center;
			gap: 0;
			margin-top: 0;
			font-family: 'Urban Shadow', 'Oswald', sans-serif;
			font-size: clamp(30px, 5.8vw, 34px);
			font-style: normal;
			font-weight: 800;
			letter-spacing: 0;
			line-height: 0.86;
			transform: translateY(0);
		}

		#CartDrawer .cart-tier-offer__amount {
			display: inline-block;
			margin-right: 2px;
			letter-spacing: 1.25px;
			line-height: 0.86;
			transform: scaleX(1.08);
			transform-origin: center bottom;
		}

		#CartDrawer .cart-tier-offer__percent {
			padding-bottom: 0;
			font-family: inherit;
			font-size: 1em;
			font-weight: 800;
			line-height: 0.86;
			transform: scaleX(0.78);
			transform-origin: center bottom;
		}

		#CartDrawer .cart-tier-offer.is-active {
			border-color: #ffda69;
			background: #263d30;
			color: #ffdf74;
			box-shadow: none;
		}

		#CartDrawer .cart-tier-offer.is-active .cart-tier-offer__value {
			text-shadow: 0 1px 0 rgba(0, 0, 0, 0.2);
		}

		#CartDrawer .cart-tier-offer.is-muted {
			opacity: 0.38;
			filter: saturate(0.55);
			box-shadow: none;
		}

		@media screen and (max-width: 480px) {
			#CartDrawer .cart-drawer__tier-offers {
				gap: 5px;
			}

			#CartDrawer .cart-tier-offer {
				height: 56px;
				padding-left: 4px;
				padding-right: 4px;
			}

			#CartDrawer .cart-tier-offer::before,
			#CartDrawer .cart-tier-offer::after {
				top: 22px;
			}

			#CartDrawer .cart-tier-offer__label {
				font-size: 13.2px;
			}

			#CartDrawer .cart-tier-offer__divider {
				top: 22px;
			}

			#CartDrawer .cart-tier-offer__value {
				font-size: clamp(27px, 7.2vw, 30px);
			}
		}

		@media screen and (max-width: 767px) {
			body.is-cart-drawer-open #ShopifyChat,
			body.is-cart-drawer-open #shopify-chat,
			body.is-cart-drawer-open [id*="shopify-chat"],
			body.is-cart-drawer-open [class*="shopify-chat"],
			body.is-cart-drawer-open iframe#dummy-chat-button-iframe,
			body.is-cart-drawer-open iframe[title*="chat" i],
			body.is-cart-drawer-open iframe[src*="shopifychat" i],
			body.is-cart-drawer-open iframe[src*="inbox.shopify" i],
			body.is-cart-drawer-open iframe[src*="chat" i] {
				opacity: 0 !important;
				visibility: hidden !important;
				pointer-events: none !important;
				transform: translateY(120%) !important;
			}
		}
	</style>
