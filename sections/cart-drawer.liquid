	<script>
		(function() {
			var syncState = window.CamoCartDrawerTitleSync || {};
			if (syncState.abortController) {
				syncState.abortController.abort();
			}

			var abortController = window.AbortController ? new AbortController() : null;
			var listenerOptions = abortController ? { signal: abortController.signal } : false;
			var titleSelector = '.js-cart-drawer-title';
			var quantityInputSelector = '#CartDrawer [data-cart-item] [data-quantity-input]';

			function getCountValue(count) {
				var value = Number(count);
				return Number.isFinite(value) && value >= 0 ? value : 0;
			}

			function updateTitle(count) {
				var titles = document.querySelectorAll(titleSelector);
				var normalizedCount = getCountValue(count);

				titles.forEach(function(title) {
					var baseTitle = title.getAttribute('data-cart-drawer-title-base') || title.textContent.replace(/\s*\(\d+\)\s*$/, '').trim();
					var showCount = title.getAttribute('data-cart-drawer-show-count') === 'true';
					var label = title.querySelector('.cart-drawer__title-label');
					var countBadge = title.querySelector('.cart-drawer__title-count');

					title.setAttribute('data-cart-drawer-title-base', baseTitle);
					title.setAttribute('data-cart-drawer-count', normalizedCount);

					if (!showCount) {
						title.textContent = baseTitle;
						return;
					}

					if (!label) {
						title.textContent = '';
						label = document.createElement('span');
						label.className = 'cart-drawer__title-label';
						title.appendChild(label);
					}
					if (!countBadge) {
						countBadge = document.createElement('span');
						countBadge.className = 'cart-drawer__title-count';
						countBadge.setAttribute('aria-label', normalizedCount + ' items in cart');
						title.appendChild(countBadge);
					}

					label.textContent = baseTitle;
					countBadge.textContent = normalizedCount;
					countBadge.setAttribute('aria-label', normalizedCount + ' items in cart');
				});
			}

			/* Count items currently rendered in the drawer.
			   IMPORTANT: shipping-protection cards intentionally render WITHOUT a
			   [data-quantity-input], so summing only quantity inputs under-counts
			   the cart. Add the protection cards' quantity (always 1 per the
			   global enforcer) so optimistic updates stay in sync with the
			   server-side cart.item_count. */
			function getVisibleQuantityCount() {
				var drawer = document.querySelector('#CartDrawer');
				if (!drawer) return null;

				var inputs = drawer.querySelectorAll('[data-cart-item] [data-quantity-input]');
				var protectionCards = drawer.querySelectorAll('.cart-item-drawer--protection');

				if (!inputs.length && !protectionCards.length) return null;

				var inputSum = Array.prototype.reduce.call(inputs, function(total, input) {
					var value = Number(input.value || 0);
					return total + (Number.isFinite(value) && value > 0 ? value : 0);
				}, 0);

				return inputSum + protectionCards.length;
			}

			function getDisplayedCount() {
				var title = document.querySelector(titleSelector);
				if (!title) return null;
				var attrValue = title.getAttribute('data-cart-drawer-count');
				if (attrValue === null || attrValue === '') return null;
				var count = Number(attrValue);
				return Number.isFinite(count) && count >= 0 ? count : null;
			}

			function updateFromVisibleQuantities() {
				var count = getVisibleQuantityCount();
				if (count === null) return;
				updateTitle(count);
			}

			function updateFromCartPayload(cart) {
				if (!cart || !Object.prototype.hasOwnProperty.call(cart, 'item_count')) return;
				updateTitle(cart.item_count);
			}

			function handleQuantityEvent(event) {
				if (!event.target.closest(quantityInputSelector)) return;
				updateFromVisibleQuantities();
			}

			document.addEventListener('input', handleQuantityEvent, listenerOptions);
			document.addEventListener('change', handleQuantityEvent, listenerOptions);
			document.addEventListener('click', function(event) {
				var removeButton = event.target.closest('#CartDrawer .js-cart-item-remove');
				if (removeButton) {
					/* Prefer the badge's current value over recomputing from the
					   DOM — the badge already reflects the authoritative
					   server-side count, including shipping-protection items. */
					var currentCount = getDisplayedCount();
					if (currentCount === null) currentCount = getVisibleQuantityCount();

					var cartItem = removeButton.closest('[data-cart-item]');
					var quantityInput = cartItem ? cartItem.querySelector('[data-quantity-input]') : null;
					/* Items without an input (shipping protection) always have
					   quantity 1 per the global cart enforcer. */
					var itemQuantity = quantityInput ? getCountValue(quantityInput.value) : 1;
					if (currentCount !== null) updateTitle(Math.max(currentCount - itemQuantity, 0));
					return;
				}

				if (!event.target.closest('#CartDrawer [data-quantity-increase], #CartDrawer [data-quantity-decrease]')) return;
				window.setTimeout(updateFromVisibleQuantities, 0);
			}, listenerOptions);

			window.CamoCartDrawerTitleSync = {
				abortController: abortController,
				updateTitle: updateTitle,
				updateFromVisibleQuantities: updateFromVisibleQuantities,
				updateFromCartPayload: updateFromCartPayload
			};

			function bindCartEvents() {
				if (!window.themeCore || !window.themeCore.EventBus || window.CamoCartDrawerTitleSyncEventsBound) return;
				window.CamoCartDrawerTitleSyncEventsBound = true;

				window.themeCore.EventBus.listen('cart:updated', function(cart) {
					if (window.CamoCartDrawerTitleSync) {
						window.CamoCartDrawerTitleSync.updateFromCartPayload(cart);
					}
				});

				window.themeCore.EventBus.listen('header:update-item-count', function(cart) {
					if (window.CamoCartDrawerTitleSync) {
						window.CamoCartDrawerTitleSync.updateFromCartPayload(cart);
					}
				});
			}

			if (window.themeCore && window.themeCore.EventBus) {
				bindCartEvents();
			} else {
				document.addEventListener('theme:all:loaded', bindCartEvents, abortController ? { once: true, signal: abortController.signal } : { once: true });
			}
		})();
	</script>

