{%- comment -%}
------------------------------------------------------------------------------
	Section: Cart drawer
------------------------------------------------------------------------------
{%- endcomment -%}
{%- if settings.cart_type == "drawer" and template != "cart" -%}
	{%- render 'adastra' with '/src/styles/cart.scss' -%}

	{%- capture default_heading -%}
		{{- "cart.general.title" | t -}}
	{%- endcapture -%}

	{%- capture default_upsell_heading -%}
		{{- "cart.general.upsell" | t -}}
	{%- endcapture -%}

	{%- assign color_scheme      	           	= section.settings.color_scheme -%}
	{%- assign enable_color_scheme_inheritance 	= section.settings.enable_color_scheme_inheritance -%}
	{%- assign show_cart_items_count 			= section.settings.show_cart_items_count -%}
	{%- assign heading 							= section.settings.heading | default: default_heading -%}
	{%- assign cart_button_label 				= section.settings.cart_button_label -%}
	{%- assign upsell_heading 					= section.settings.upsell_heading | default: default_upsell_heading -%}
	{%- assign upsell_products 					= section.settings.upsell_products -%}

	{%- if enable_color_scheme_inheritance -%}
		{%- assign color_scheme = settings.main_color_scheme -%}
	{%- endif -%}

	{%- if show_cart_items_count -%}
		{%- capture heading -%}
			{{- heading }} ({{- cart.item_count -}})
		{%- endcapture -%}
	{%- endif -%}

	{%- assign shipping_included = false -%}

	{%- comment -%} Extract shipping bar to render at top {%- endcomment -%}
	{%- capture shipping_bar_content -%}
		{%- for block in section.blocks -%}
			{%- if block.type == 'shipping' -%}
				{%- assign amount = block.settings.amount -%}
				{%- assign message = block.settings.message -%}
				{%- assign congratulatory_message = block.settings.congratulatory_message -%}
				{%- assign congratulatory_image = block.settings.icon -%}
				{%- assign bar_color = block.settings.bar_color -%}
				{%- assign fill_color = block.settings.fill_color -%}
				{%- render 'cart-shipping',
					amount: amount,
					message: message,
					congratulatory_message: congratulatory_message,
					congratulatory_image: congratulatory_image,
					bar_color: bar_color,
					fill_color: fill_color
				-%}
				{%- assign shipping_included = true -%}
			{%- endif -%}
		{%- endfor -%}
	{%- endcapture -%}

	{%- capture content -%}
		{%- for block in section.blocks -%}
			{%- case block.type -%}
				{%- when '@app' -%}
					{%- render block -%}
				{%- when 'items' -%}
					<div class="cart-drawer__section cart-drawer__section--items" style="margin-top: 0; padding-top: 0;">
						<div class="cart-items">
							<form action="{{- routes.cart_url -}}" id="cart-{{- section.id -}}" class="cart-items__form" method="post">
								<div class="cart-items__body">
									{%- render 'cart-items', cart_drawer: true -%}
								</div>
							</form>
						</div>
					</div>
			{%- endcase -%}
		{%- endfor -%}
	{%- endcapture -%}

	{%- capture upsell -%}
		{%- assign upsell_content = '' -%}

		{%- assign title 	= upsell_heading -%}
		{%- assign products = upsell_products -%}

		{%- capture upsell_item -%}
			{%- render 'cart-upsell',
				products: products,
				heading: title
			-%}
		{%- endcapture -%}

		{%- if upsell_item != '' -%}
			{%- capture upsell_content -%}
				{{- upsell_content -}}

				{{- upsell_item -}}
			{%- endcapture -%}
		{%- endif -%}

		{%- if upsell_content != '' -%}
			<div
				id="CartUpsellDrawer"
				class="cart-drawer__upsell cart-drawer__tab-content js-cart-drawer-tab-content is-hidden"
			>
				{{- upsell_content -}}
			</div>
		{%- endif -%}
	{%- endcapture -%}

	{%- capture footer -%}
		{%- render 'cart-footer',
			section: section,
			cart_button_label: cart_button_label,
			cart_drawer: true
		-%}
	{%- endcapture -%}

<section
	id="CartDrawer"
	class="drawer cart-drawer color-{{ color_scheme }} {% if cart.empty? %} is-empty{% endif %} js-cart-drawer"
	data-section-type="cart-template"
	data-section-modification="drawer"
	data-section-id="{{- section.id -}}"
	data-shadow-root
	role="dialog"
	aria-labelledby="CartDrawer-{{- heading | handle -}}"
	style="background-color: #ffffff !important; --color-background: #ffffff !important; --color-background-popup-drawer: #ffffff !important;"
	data-cart-drawer-fix
>
	<div class="drawer__header js-cart-header" style="position: absolute; top: 12px; right: 12px; z-index: 50; border: none; padding: 0; margin: 0; background: transparent;">
			<button
				class="drawer__close focus-visible-outline js-cart-close-button"
				data-target="CartDrawer"
				data-js-toggle="CartDrawer"
				aria-label="{{- 'general.accessibility.close_modal' | t | escape -}}"
			>
				{% render 'icons', icon: 'menu-close' %}
			</button>
		</div>

	<div class="drawer__body cart-drawer__container js-cart-container" style="padding-top: 20px;">
		<h2 class="drawer__title cart-drawer__title-empty h4" id="CartDrawer-{{- heading | handle -}}" style="font-family: 'Oswald', sans-serif; color: #2c3d33; font-weight: 700; text-transform: uppercase; margin: 0 16px 8px; font-size: 20px; letter-spacing: 0.5px; padding-bottom: 0; padding-right: 40px;">
			{{- heading -}}
		</h2>
		<div class="cart-drawer__content js-cart-content js-scroll-lock-container" data-scrollable>
			{%- if cart.empty? -%}
				{%- render 'cart-empty' -%}
			{%- else -%}
				{%- if content != '' -%}
					<div id="cart-drawer-main-content">
						{%- comment -%} Shipping bar at top {%- endcomment -%}
						{%- if shipping_bar_content != '' -%}
							<div class="cart-drawer__section cart-drawer__section--shipping" style="padding: 10px 16px; margin: 8px 16px 8px; background: #2c3d33; border-radius: 6px; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
								{{- shipping_bar_content -}}
							</div>
						{%- endif -%}

						<div class="cart-drawer__custom-banner" style="margin: 0 16px 0;">
							<img src="https://cdn.shopify.com/s/files/1/0741/7987/0911/files/banner-gio-hang.jpg?v=1778237632" alt="Special Offer" style="width: 100%; height: auto; border-radius: 6px; display: block;" loading="lazy">
						</div>

						{{- content -}}

						{%- comment -%} Inline upsell after items {%- endcomment -%}
						{%- capture internal_upsell_html -%}
							{%- render 'cart-upsell', products: upsell_products, heading: '' -%}
						{%- endcapture -%}
						
						{%- assign clean_html = internal_upsell_html | strip -%}
						{%- if upsell_products != blank and clean_html != '' -%}
							<div class="cart-drawer__section cart-drawer__section--upsell" style="margin: 12px 16px 24px;">
								<h3 style="background: #0d1f6b; color: #fff; padding: 12px; margin: 0; font-family: 'Oswald', sans-serif; font-size: 16px; font-weight: 700; text-transform: none; text-align: center; letter-spacing: 0.5px;">{{ upsell_heading }}</h3>
								<div style="padding: 12px 0;">
									{{- internal_upsell_html -}}
								</div>
							</div>
						{%- endif -%}
					</div>
					{%- endif -%}
				{%- endif -%}
			</div>

			{%- if footer != '' -%}
				<div class="drawer__footer cart-drawer__footer js-cart-footer">
					{{- footer -}}
				</div>
			{%- endif -%}
		</div>

		{%- render 'preloader' -%}

	<style>
		#CartDrawer.cart-drawer .cart-drawer__container {
			display: flex !important;
			flex-direction: column !important;
			justify-content: flex-start !important;
			align-items: stretch !important;
			height: 100% !important;
			min-height: 0 !important;
			padding-bottom: 0 !important;
			overflow: hidden !important;
		}

		#CartDrawer .drawer__title {
			flex: 0 0 auto !important;
		}

		#CartDrawer .cart-drawer__content {
			display: flex !important;
			flex-direction: column !important;
			justify-content: flex-start !important;
			flex: 1 1 auto !important;
			min-height: 0 !important;
			margin-top: 0 !important;
			padding-top: 0 !important;
			overflow-x: hidden !important;
			overflow-y: auto !important;
			-webkit-overflow-scrolling: touch !important;
			overscroll-behavior: contain !important;
		}

		#CartDrawer .cart-drawer__footer {
			display: block !important;
			flex: 0 0 auto !important;
			position: relative !important;
			bottom: auto !important;
			z-index: 30 !important;
			margin-top: 0 !important;
			padding: 0 !important;
			background: #ffffff !important;
			border-top: 1px solid rgba(0, 0, 0, 0.06) !important;
			box-shadow: 0 -12px 24px rgba(255, 255, 255, 0.95) !important;
		}

		#CartDrawer .cart-drawer__footer .cart-footer,
		#CartDrawer .cart-drawer__footer .cart-footer__main {
			display: flex !important;
			flex-direction: column !important;
			padding: 0 !important;
			background: #ffffff !important;
		}

		#CartDrawer .cart-drawer__footer .cart-footer__ctas {
			margin-top: 0 !important;
			border-top: 0 !important;
		}

		#CartDrawer .cart-drawer__payment-icons {
			background: #ffffff !important;
			padding-bottom: max(16px, env(safe-area-inset-bottom)) !important;
		}

		#CartDrawer #cart-drawer-main-content {
			display: flex !important;
			flex-direction: column !important;
			justify-content: flex-start !important;
			margin-top: 0 !important;
			padding-top: 0 !important;
		}

		#CartDrawer .cart-drawer__section.cart-drawer__section--shipping {
			margin: 8px 16px 8px !important;
		}

		#CartDrawer .cart-drawer__custom-banner,
		#CartDrawer .cart-drawer__section.cart-drawer__section--items {
			margin-top: 0 !important;
		}
	</style>
	</section>

	{%- if upsell_products != blank -%}
		{%- render 'adastra' with '/src/scripts/component-product-card-with-form.js' -%}
	{%- endif -%}

	{%- render 'adastra' with '/src/scripts/cart-drawer.js' -%}

	{%- if cart.item_count > 0 -%}
		<script>
			(function() {
				function autoOpenCartDrawer() {
					if (window.themeCore && window.themeCore.EventBus) {
						window.themeCore.EventBus.emit('cart:drawer:open');
					}
				}
				if (window.themeCore && window.themeCore.loaded) {
					autoOpenCartDrawer();
				} else {
					document.addEventListener('theme:all:loaded', autoOpenCartDrawer, { once: true });
				}
			})();
		</script>
	{%- endif -%}
{%- endif -%}

{% schema %}
{
	"name": "Cart drawer",
	"class": "cart-drawer-section",
	"settings": [
		{
			"type": "header",
			"content": "Colors"
		},
		{
			"type": "checkbox",
			"id": "enable_color_scheme_inheritance",
			"label": "Enable color scheme inheritance",
			"default": true,
			"info": "When this setting is enabled, the color scheme is inherited from the theme settings."
		},
		{
			"type": "color_scheme",
			"id": "color_scheme",
			"label": "Color scheme",
			"default": "scheme-1"
		},
		{
			"type": "header",
			"content": "Cart drawer settings"
		},
		{
			"type": "text",
			"id": "heading",
			"label": "Heading",
			"default": "Cart"
		},
		{
			"type": "checkbox",
			"id": "show_cart_items_count",
			"label": "Show items count in the cart",
			"default": true
		},
		{
			"type": "text",
			"id": "cart_button_label",
			"label": "View cart label",
			"default": "View cart"
		},
		{
			"type": "header",
			"content": "Upsell settings"
		},
		{
			"type": "text",
			"id": "upsell_heading",
			"label": "Heading",
			"default": "Recommended products"
		},
		{
			"type": "product_list",
			"id": "upsell_products",
			"label": "Products",
			"limit": 14
		}
	],
	"blocks": [
		{
			"type": "@app"
		},
		{
			"name": "Items",
			"type": "items",
			"limit": 1,
			"settings": []
		},
		{
			"name": "Shipping bar",
			"type": "shipping",
			"limit": 1,
			"settings": [
				{
					"type": "number",
					"id": "amount",
					"label": "Free shipping amount",
					"default": 70
				},
				{
					"type": "textarea",
					"id": "message",
					"label": "Shipping message",
					"default": "You are only {amount} away from free shipping",
					"info": "The pattern {amount} will be replaced with the remaining amount"
				},
				{
					"type": "textarea",
					"id": "congratulatory_message",
					"label": "Shipping congratulatory message",
					"default": "You got free shipping"
				},
				{
					"type": "image_picker",
					"id": "icon",
					"label": "Congratulatory icon",
					"info": "40 x 40px recommended"
				},
				{
					"type": "header",
					"content": "Colors"
				},
				{
					"type": "color",
					"id": "bar_color",
					"label": "Progress bar background color",
					"default": "#E9E9E9"
				},
				{
					"type": "color",
					"id": "fill_color",
					"label": "Progress bar fill color",
					"default": "#FFD875"
				}
			]
		},
		{
			"name": "Benefit",
			"type": "benefit",
			"limit": 6,
			"settings": [
				{
					"type": "inline_richtext",
					"id": "text",
					"label": "Text",
					"default": "Short text content."
				},
				{
					"type": "image_picker",
					"id": "icon",
					"label": "Icon",
					"info": "20 x 20px .svg recommended"
				}
			]
		}
	],
	"default": {
		"blocks": [
			{
				"type": "items"
			},
			{
				"type": "shipping"
			}
		]
	}
}
{% endschema %}
