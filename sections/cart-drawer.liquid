{%- comment -%}
------------------------------------------------------------------------------
	Section: Cart drawer
------------------------------------------------------------------------------
{%- endcomment -%}
{%- if settings.cart_type == "drawer" and template != "cart" -%}
	{%- render 'adastra' with '/src/styles/cart.scss' -%}

	{%- capture default_heading -%}
		{{- "cart.general.title" | t -}}
	{%- endcapture -%}

	{%- capture default_upsell_heading -%}
		{{- "cart.general.upsell" | t -}}
	{%- endcapture -%}

	{%- assign color_scheme      	           	= section.settings.color_scheme -%}
	{%- assign enable_color_scheme_inheritance 	= section.settings.enable_color_scheme_inheritance -%}
	{%- assign show_cart_items_count 			= section.settings.show_cart_items_count -%}
	{%- assign heading 							= section.settings.heading | default: default_heading -%}
	{%- assign cart_drawer_heading_base			= heading -%}
	{%- assign cart_button_label 				= section.settings.cart_button_label -%}
	{%- assign upsell_heading 					= section.settings.upsell_heading | default: default_upsell_heading -%}
	{%- assign upsell_products 					= section.settings.upsell_products -%}
	{%- assign drawer_background_color			= section.settings.drawer_background_color | default: '#ffffff' -%}
	{%- assign footer_background_color			= section.settings.footer_background_color | default: '#ffffff' -%}
	{%- assign footer_border_color				= section.settings.footer_border_color | default: 'rgba(0, 0, 0, 0.06)' -%}
	{%- assign footer_shadow					= section.settings.footer_shadow | default: '0 -12px 24px rgba(255, 255, 255, 0.95)' -%}
	{%- assign title_color						= section.settings.title_color | default: '#2c3d33' -%}
	{%- assign title_font_size					= section.settings.title_font_size | default: 20 -%}
	{%- assign title_font_weight				= section.settings.title_font_weight | default: '700' -%}
	{%- assign title_text_transform				= section.settings.title_text_transform | default: 'uppercase' -%}
	{%- assign title_letter_spacing				= section.settings.title_letter_spacing | default: '0.5px' -%}
	{%- assign title_margin_horizontal			= section.settings.title_margin_horizontal | default: 16 -%}
	{%- assign title_margin_bottom				= section.settings.title_margin_bottom | default: 8 -%}
	{%- assign title_padding_right				= section.settings.title_padding_right | default: 40 -%}
	{%- assign drawer_top_padding				= section.settings.drawer_top_padding | default: 20 -%}
	{%- assign show_custom_banner				= section.settings.show_custom_banner -%}
	{%- assign custom_banner_margin_top			= section.settings.custom_banner_margin_top | default: 0 -%}
	{%- assign custom_banner_margin_horizontal	= section.settings.custom_banner_margin_horizontal | default: 16 -%}
	{%- assign custom_banner_margin_bottom		= section.settings.custom_banner_margin_bottom | default: 0 -%}
	{%- assign custom_banner_radius				= section.settings.custom_banner_radius | default: 6 -%}
	{%- assign show_upsell						= section.settings.show_upsell -%}
	{%- assign upsell_margin_top				= section.settings.upsell_margin_top | default: 12 -%}
	{%- assign upsell_margin_horizontal			= section.settings.upsell_margin_horizontal | default: 16 -%}
	{%- assign upsell_margin_bottom				= section.settings.upsell_margin_bottom | default: 24 -%}
	{%- assign upsell_heading_background		= section.settings.upsell_heading_background | default: '#0d1f6b' -%}
	{%- assign upsell_heading_color				= section.settings.upsell_heading_color | default: '#ffffff' -%}
	{%- assign upsell_heading_font_size			= section.settings.upsell_heading_font_size | default: 16 -%}
	{%- assign upsell_heading_font_weight		= section.settings.upsell_heading_font_weight | default: '700' -%}
	{%- assign upsell_heading_padding			= section.settings.upsell_heading_padding | default: 12 -%}
	{%- assign upsell_heading_radius			= section.settings.upsell_heading_radius | default: 0 -%}
	{%- assign upsell_content_padding_vertical	= section.settings.upsell_content_padding_vertical | default: 12 -%}
	{%- assign show_auto_open					= section.settings.show_auto_open -%}

	{%- capture cart_drawer_vars -%}
		--cart-drawer-bg: {{ drawer_background_color }};{{-  -}}
		--cart-drawer-footer-bg: {{ footer_background_color }};{{-  -}}
		--cart-drawer-footer-border-color: {{ footer_border_color }};{{-  -}}
		--cart-drawer-footer-shadow: {{ footer_shadow }};{{-  -}}
		--cart-drawer-footer-padding: {{ section.settings.footer_padding_top | default: 20 }}px {{ section.settings.footer_padding_horizontal | default: 24 }}px {{ section.settings.footer_padding_bottom | default: 16 }}px;{{-  -}}
		--cart-drawer-payment-padding-bottom: {{ section.settings.payment_icons_padding_bottom | default: 24 }}px;{{-  -}}
		--cart-drawer-title-color: {{ title_color }};{{-  -}}
		--cart-drawer-checkout-bg: {{ section.settings.checkout_button_background | default: '#0d1f6b' }};{{-  -}}
		--cart-drawer-checkout-color: {{ section.settings.checkout_button_color | default: '#ffffff' }};{{-  -}}
		--cart-drawer-checkout-border: {{ section.settings.checkout_button_border_color | default: '#0d1f6b' }};{{-  -}}
		--cart-drawer-checkout-radius: {{ section.settings.checkout_button_radius | default: 6 }}px;{{-  -}}
		--cart-drawer-checkout-font-size: {{ section.settings.checkout_button_font_size | default: 16 }}px;{{-  -}}
		--cart-drawer-checkout-padding: {{ section.settings.checkout_button_padding_vertical | default: 14 }}px {{ section.settings.checkout_button_padding_horizontal | default: 14 }}px;{{-  -}}
		--cart-drawer-subtotal-color: {{ section.settings.subtotal_text_color | default: '#000000' }};{{-  -}}
		--cart-drawer-subtotal-price-color: {{ section.settings.subtotal_price_color | default: '#c0392b' }};{{-  -}}
		--cart-drawer-compare-price-color: {{ section.settings.compare_price_color | default: '#999999' }};{{-  -}}
		--cart-drawer-discount-badge-bg: {{ section.settings.discount_badge_background | default: '#2c3d33' }};{{-  -}}
		--cart-drawer-discount-badge-color: {{ section.settings.discount_badge_color | default: '#ffffff' }};{{-  -}}
		--cart-upsell-card-bg: {{ section.settings.upsell_card_background | default: '#ffffff' }};{{-  -}}
		--cart-upsell-card-border: {{ section.settings.upsell_card_border_color | default: 'rgba(44,61,51,0.12)' }};{{-  -}}
		--cart-upsell-card-border-hover: {{ section.settings.upsell_card_border_hover_color | default: '#2c3d33' }};{{-  -}}
		--cart-upsell-title-color: {{ section.settings.upsell_card_title_color | default: '#2c3d33' }};{{-  -}}
		--cart-upsell-price-color: {{ section.settings.upsell_card_price_color | default: '#2c3d33' }};{{-  -}}
		--cart-upsell-sale-price-color: {{ section.settings.upsell_card_sale_price_color | default: '#b52a2a' }};{{-  -}}
		--cart-upsell-button-bg: {{ section.settings.upsell_button_background | default: '#0d1f6b' }};{{-  -}}
		--cart-upsell-button-color: {{ section.settings.upsell_button_color | default: '#ffffff' }};{{-  -}}
		--cart-upsell-button-hover-bg: {{ section.settings.upsell_button_hover_background | default: '#1e2d24' }};{{-  -}}
		--cart-protection-border-color: {{ section.settings.protection_border_color | default: '#3a7d6a' }};{{-  -}}
		--cart-protection-background: {{ section.settings.protection_background | default: 'rgba(58, 125, 106, 0.06)' }};{{-  -}}
		--cart-protection-title-color: {{ section.settings.protection_title_color | default: '#2c3d33' }};{{-  -}}
		--cart-protection-text-color: {{ section.settings.protection_text_color | default: '#6b7f75' }};{{-  -}}
	{%- endcapture -%}

	{%- if enable_color_scheme_inheritance -%}
		{%- assign color_scheme = settings.main_color_scheme -%}
	{%- endif -%}

	{%- assign discount_eligible_item_count = 0 -%}
	{%- for item in cart.items -%}
		{%- unless item.product.handle == 'shipping-protection-apparel' -%}
			{%- assign discount_eligible_item_count = discount_eligible_item_count | plus: item.quantity -%}
		{%- endunless -%}
	{%- endfor -%}

	{%- assign active_discount_tier = 0 -%}
	{%- if discount_eligible_item_count >= 4 -%}
		{%- assign active_discount_tier = 4 -%}
	{%- elsif discount_eligible_item_count >= 3 -%}
		{%- assign active_discount_tier = 3 -%}
	{%- elsif discount_eligible_item_count >= 2 -%}
		{%- assign active_discount_tier = 2 -%}
	{%- endif -%}

	{%- if show_cart_items_count -%}
		{%- capture heading -%}
			<span class="cart-drawer__title-label">{{- heading -}}</span>
			<span class="cart-drawer__title-count" aria-label="{{ cart.item_count }} items in cart">{{- cart.item_count -}}</span>
		{%- endcapture -%}
	{%- endif -%}

	{%- assign shipping_included = false -%}

	{%- comment -%} Extract shipping bar to render at top {%- endcomment -%}
	{%- capture shipping_bar_content -%}
		{%- for block in section.blocks -%}
			{%- if block.type == 'shipping' -%}
				{%- assign amount = block.settings.amount -%}
				{%- assign message = block.settings.message -%}
				{%- assign congratulatory_message = block.settings.congratulatory_message -%}
				{%- assign congratulatory_image = block.settings.icon -%}
				{%- assign bar_color = block.settings.bar_color -%}
				{%- assign fill_color = block.settings.fill_color -%}
				<div class="cart-drawer__section cart-drawer__section--shipping" style="padding: {{ block.settings.wrapper_padding_vertical | default: 10 }}px {{ block.settings.wrapper_padding_horizontal | default: 16 }}px; margin: {{ block.settings.wrapper_margin_top | default: 8 }}px {{ block.settings.wrapper_margin_horizontal | default: 16 }}px {{ block.settings.wrapper_margin_bottom | default: 8 }}px; background: {{ block.settings.wrapper_background | default: '#2c3d33' }}; border-radius: {{ block.settings.wrapper_border_radius | default: 6 }}px; box-shadow: {{ block.settings.wrapper_shadow | default: '0 4px 6px rgba(0,0,0,0.05)' }};">
					{%- render 'cart-shipping',
						amount: amount,
						message: message,
						congratulatory_message: congratulatory_message,
						congratulatory_image: congratulatory_image,
						bar_color: bar_color,
						fill_color: fill_color,
						label_color: block.settings.label_color,
						label_font_size: block.settings.label_font_size,
						label_letter_spacing: block.settings.label_letter_spacing,
						label_text_transform: block.settings.label_text_transform
					-%}
				</div>
				{%- assign shipping_included = true -%}
			{%- endif -%}
		{%- endfor -%}
	{%- endcapture -%}

	{%- capture content -%}
		{%- for block in section.blocks -%}
			{%- case block.type -%}
				{%- when '@app' -%}
					{%- render block -%}
				{%- when 'items' -%}
					<div class="cart-drawer__section cart-drawer__section--items" style="margin-top: 0; padding-top: 0;">
						<div class="cart-items">
							<form action="{{- routes.cart_url -}}" id="cart-{{- section.id -}}" class="cart-items__form" method="post">
								<div class="cart-items__body">
									{%- render 'cart-items', cart_drawer: true -%}
								</div>
							</form>
						</div>
					</div>
			{%- endcase -%}
		{%- endfor -%}
	{%- endcapture -%}

	{%- capture upsell -%}
		{%- assign upsell_content = '' -%}

		{%- assign title 	= upsell_heading -%}
		{%- assign products = upsell_products -%}

		{%- capture upsell_item -%}
			{%- render 'cart-upsell',
				products: products,
				heading: title
			-%}
		{%- endcapture -%}

		{%- if upsell_item != '' -%}
			{%- capture upsell_content -%}
				{{- upsell_content -}}

				{{- upsell_item -}}
			{%- endcapture -%}
		{%- endif -%}

		{%- if upsell_content != '' -%}
			<div
				id="CartUpsellDrawer"
				class="cart-drawer__upsell cart-drawer__tab-content js-cart-drawer-tab-content is-hidden"
			>
				{{- upsell_content -}}
			</div>
		{%- endif -%}
	{%- endcapture -%}

	{%- capture footer -%}
		{%- render 'cart-footer',
			section: section,
			cart_button_label: cart_button_label,
			cart_drawer: true
		-%}
	{%- endcapture -%}

<section
	id="CartDrawer"
	class="drawer cart-drawer color-{{ color_scheme }} {% if cart.empty? %} is-empty{% endif %} js-cart-drawer"
	data-section-type="cart-template"
	data-section-modification="drawer"
	data-section-id="{{- section.id -}}"
	data-shadow-root
	role="dialog"
	aria-labelledby="CartDrawer-{{- heading | handle -}}"
	style="{{ cart_drawer_vars }} background-color: var(--cart-drawer-bg) !important; --color-background: var(--cart-drawer-bg) !important; --color-background-popup-drawer: var(--cart-drawer-bg) !important;"
	data-cart-drawer-fix
>
	<div class="drawer__header js-cart-header" style="position: absolute; top: max(6px, calc({{ drawer_top_padding }}px - 9px)); right: {{ title_margin_horizontal }}px; z-index: 50; border: none; padding: 0; margin: 0; background: transparent; width: 44px; height: 44px; display: flex; align-items: center; justify-content: center;">
			<button
				class="drawer__close focus-visible-outline js-cart-close-button"
				data-target="CartDrawer"
				data-js-toggle="CartDrawer"
				aria-label="{{- 'general.accessibility.close_modal' | t | escape -}}"
			>
				{% render 'icons', icon: 'menu-close' %}
			</button>
		</div>

	<div class="drawer__body cart-drawer__container js-cart-container" style="padding-top: {{ drawer_top_padding }}px;">
		<h2 class="drawer__title cart-drawer__title-empty h4 js-cart-drawer-title" id="CartDrawer-{{- cart_drawer_heading_base | handle -}}" data-cart-drawer-title-base="{{ cart_drawer_heading_base | escape }}" data-cart-drawer-show-count="{% if show_cart_items_count %}true{% else %}false{% endif %}" data-cart-drawer-count="{{ cart.item_count }}" style="font-family: 'Oswald', sans-serif; color: {{ title_color }}; font-weight: {{ title_font_weight }}; text-transform: {{ title_text_transform }}; margin: 0 {{ title_margin_horizontal }}px {{ title_margin_bottom }}px; font-size: {{ title_font_size }}px; letter-spacing: {{ title_letter_spacing }}; padding-bottom: 0; padding-right: {{ title_padding_right }}px;">
			{{- heading -}}
		</h2>
		<div class="cart-drawer__content js-cart-content js-scroll-lock-container" data-scrollable>
			{%- if cart.empty? -%}
				{%- render 'cart-empty' -%}
			{%- else -%}
				{%- if content != '' -%}
					<div id="cart-drawer-main-content">
						{%- comment -%} Shipping bar at top {%- endcomment -%}
						{%- if shipping_bar_content != '' -%}
							{{- shipping_bar_content -}}
						{%- endif -%}

						{%- if show_custom_banner -%}
							<div
								class="cart-drawer__tier-offers"
								data-cart-tier="{{ active_discount_tier }}"
								data-cart-eligible-items="{{ discount_eligible_item_count }}"
								style="--tier-offers-radius: {{ custom_banner_radius }}px; margin: {{ custom_banner_margin_top }}px {{ custom_banner_margin_horizontal }}px {{ custom_banner_margin_bottom }}px;"
								aria-label="Cart discount milestones"
							>
								<div class="cart-tier-offer{% if active_discount_tier >= 2 %} is-active{% elsif active_discount_tier > 0 %} is-muted{% endif %}" data-tier="2">
									<span class="cart-tier-offer__label">
										<span class="cart-tier-offer__word">BUY</span>
										<span class="cart-tier-offer__quantity">2</span>
										<span class="cart-tier-offer__word">SAVE</span>
									</span>
									<span class="cart-tier-offer__divider" aria-hidden="true"></span>
									<span class="cart-tier-offer__value">
										<span class="cart-tier-offer__amount">10</span><span class="cart-tier-offer__percent">%</span>
									</span>
									<span class="cart-tier-offer__outline" aria-hidden="true"></span>
								</div>

								<div class="cart-tier-offer{% if active_discount_tier >= 3 %} is-active{% elsif active_discount_tier > 0 %} is-muted{% endif %}" data-tier="3">
									<span class="cart-tier-offer__label">
										<span class="cart-tier-offer__word">BUY</span>
										<span class="cart-tier-offer__quantity">3</span>
										<span class="cart-tier-offer__word">SAVE</span>
									</span>
									<span class="cart-tier-offer__divider" aria-hidden="true"></span>
									<span class="cart-tier-offer__value">
										<span class="cart-tier-offer__amount">15</span><span class="cart-tier-offer__percent">%</span>
									</span>
									<span class="cart-tier-offer__outline" aria-hidden="true"></span>
								</div>

								<div class="cart-tier-offer{% if active_discount_tier >= 4 %} is-active{% elsif active_discount_tier > 0 %} is-muted{% endif %}" data-tier="4">
									<span class="cart-tier-offer__label">
										<span class="cart-tier-offer__word">BUY</span>
										<span class="cart-tier-offer__quantity">4</span>
										<span class="cart-tier-offer__word">SAVE</span>
									</span>
									<span class="cart-tier-offer__divider" aria-hidden="true"></span>
									<span class="cart-tier-offer__value">
										<span class="cart-tier-offer__amount">20</span><span class="cart-tier-offer__percent">%</span>
									</span>
									<span class="cart-tier-offer__outline" aria-hidden="true"></span>
								</div>
							</div>
						{%- endif -%}

						{{- content -}}

						{%- comment -%} Inline upsell after items {%- endcomment -%}
						{%- capture internal_upsell_html -%}
							{%- render 'cart-upsell', products: upsell_products, heading: '' -%}
						{%- endcapture -%}
						
						{%- assign clean_html = internal_upsell_html | strip -%}
						{%- if show_upsell and upsell_products != blank and clean_html != '' -%}
							<div class="cart-drawer__section cart-drawer__section--upsell" style="margin: {{ upsell_margin_top }}px {{ upsell_margin_horizontal }}px {{ upsell_margin_bottom }}px;">
								<h3 style="background: {{ upsell_heading_background }}; color: {{ upsell_heading_color }}; padding: {{ upsell_heading_padding }}px; margin: 0; font-family: 'Oswald', sans-serif; font-size: {{ upsell_heading_font_size }}px; font-weight: {{ upsell_heading_font_weight }}; text-transform: none; text-align: center; letter-spacing: 0.5px; border-radius: {{ upsell_heading_radius }}px;">{{ upsell_heading }}</h3>
								<div style="padding: {{ upsell_content_padding_vertical }}px 0;">
									{{- internal_upsell_html -}}
								</div>
							</div>
						{%- endif -%}
					</div>
					{%- endif -%}
				{%- endif -%}
			</div>

			{%- if footer != '' -%}
				<div class="drawer__footer cart-drawer__footer js-cart-footer">
					{{- footer -}}
				</div>
			{%- endif -%}
		</div>

		{%- render 'preloader' -%}

	<style>
		#CartDrawer.cart-drawer .cart-drawer__container {
			display: flex !important;
			flex-direction: column !important;
			justify-content: flex-start !important;
			align-items: stretch !important;
			height: 100% !important;
			min-height: 0 !important;
			padding-bottom: 0 !important;
			overflow: hidden !important;
		}

		#CartDrawer .drawer__title {
			display: inline-flex !important;
			align-items: center !important;
			gap: 9px !important;
			flex: 0 0 auto !important;
		}

		#CartDrawer .drawer__close {
			display: inline-flex !important;
			align-items: center !important;
			justify-content: center !important;
			width: 44px !important;
			height: 44px !important;
			min-width: 44px !important;
			padding: 0 !important;
			color: #2c3d33 !important;
			border-radius: 999px;
			opacity: 0.95;
		}

		#CartDrawer .drawer__close svg {
			width: 34px !important;
			height: 34px !important;
		}

		#CartDrawer .drawer__close svg path {
			stroke-width: 2;
		}

		#CartDrawer .cart-drawer__title-label {
			display: inline-block;
			line-height: 1;
		}

		#CartDrawer .cart-drawer__title-count {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			min-width: 26px;
			height: 26px;
			padding: 0 8px;
			border-radius: 999px;
			background: #2c3d33;
			color: #ffffff;
			border: 1px solid rgba(44, 61, 51, 0.18);
			box-shadow: 0 5px 14px rgba(44, 61, 51, 0.16);
			font-family: 'Oswald', sans-serif;
			font-size: 14px;
			font-weight: 700;
			line-height: 1;
			letter-spacing: 0;
			text-align: center;
		}

		#CartDrawer .cart-drawer__content {
			display: flex !important;
			flex-direction: column !important;
			justify-content: flex-start !important;
			flex: 1 1 auto !important;
			min-height: 0 !important;
			margin-top: 0 !important;
			padding-top: 0 !important;
			overflow-x: hidden !important;
			overflow-y: auto !important;
			-webkit-overflow-scrolling: touch !important;
			overscroll-behavior: contain !important;
		}

		#CartDrawer .cart-drawer__footer {
			display: block !important;
			flex: 0 0 auto !important;
			position: relative !important;
			bottom: auto !important;
			z-index: 30 !important;
			margin-top: 0 !important;
			padding: 0 !important;
			background: var(--cart-drawer-footer-bg) !important;
			border-top: 1px solid var(--cart-drawer-footer-border-color) !important;
			box-shadow: var(--cart-drawer-footer-shadow) !important;
		}

		#CartDrawer .cart-drawer__footer .cart-footer,
		#CartDrawer .cart-drawer__footer .cart-footer__main {
			display: flex !important;
			flex-direction: column !important;
			padding: 0 !important;
			background: var(--cart-drawer-footer-bg) !important;
		}

		#CartDrawer .cart-drawer__footer .cart-footer__ctas {
			margin-top: 0 !important;
			border-top: 0 !important;
		}

		#CartDrawer .cart-drawer__payment-icons {
			background: var(--cart-drawer-footer-bg) !important;
			padding-bottom: max(16px, env(safe-area-inset-bottom)) !important;
		}

		@media screen and (max-width: 767px) {
			#CartDrawer .cart-drawer__payment-icons {
				flex-wrap: nowrap !important;
				gap: 5px !important;
				overflow: hidden !important;
				padding-left: 12px !important;
				padding-right: 12px !important;
				white-space: nowrap !important;
			}

			#CartDrawer .cart-drawer__payment-icons .icon {
				flex: 0 1 auto !important;
				width: min(36px, 8.2vw) !important;
				min-width: 0 !important;
				max-width: 36px !important;
				height: auto !important;
			}
		}

		#CartDrawer #cart-drawer-main-content {
			display: flex !important;
			flex-direction: column !important;
