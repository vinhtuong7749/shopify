{%- comment -%}
------------------------------------------------------------------------------
	Section: Header
------------------------------------------------------------------------------
{%- endcomment -%}

{%- assign logo			 			            = section.settings.logo -%}
{%- assign logo_transparent			            = section.settings.logo_transparent | default: logo -%}
{%- assign logo_width	 			            = section.settings.logo_width -%}
{%- assign logo_position 						= section.settings.logo_position -%}
{%- assign menu					                = section.settings.menu -%}
{%- assign scroll_images_direction				= section.settings.scroll_images_direction -%}
{%- assign enable_transparent_header_homepage	= section.settings.enable_transparent_header_homepage -%}
{%- assign enable_transparent_header_collection = section.settings.enable_transparent_header_collection -%}
{%- assign enable_transparent_header_mobile 	= section.settings.enable_transparent_header_mobile -%}
{%- assign is_language_selector	                = section.settings.is_language_selector -%}
{%- assign is_country_selector		            = section.settings.is_country_selector -%}
{%- assign header_type 					        = section.settings.header_type -%}
{%- assign open_menu_type			 	        = section.settings.open_menu_type -%}
{%- assign make_first_lvl_clickable				= section.settings.make_first_lvl_clickable -%}
{%- assign is_show_border			            = section.settings.is_show_border -%}
{%- assign burger_menu                          = section.settings.burger_menu -%}
{%- assign mobile_top_menu 						= section.settings.mobile_top_menu -%}

{%- assign color_scheme      	           = section.settings.color_scheme -%}
{%- assign enable_color_scheme_inheritance = section.settings.enable_color_scheme_inheritance -%}
{%- assign text_color_transparent	       = section.settings.text_color_transparent -%}
{%- assign count_text_color				   = section.settings.count_text_color -%}
{%- assign count_text_color_transparent	   = section.settings.count_text_color_transparent -%}
{%- assign count_text_bg			       = section.settings.count_text_bg -%}
{%- assign count_text_bg_transparent       = section.settings.count_text_bg_transparent -%}

{%- assign is_enable_search		  = settings.enable_search -%}
{%- assign cart_type			  = settings.cart_type -%}
{%- assign show_cart_notification = settings.show_cart_notification -%}

{%- assign enable_sticky_header		 	= true -%}
{%- assign is_transparent_header    	= false -%}
{%- assign is_transparent_header_mobile = false -%}
{%- assign is_language_selector_enabled	= false -%}
{%- assign is_country_selector_enabled	= false -%}

{%- if enable_color_scheme_inheritance -%}
	{%- assign color_scheme = settings.main_color_scheme -%}
{%- endif -%}

{%- if header_type == "static" -%}
	{%- assign enable_sticky_header = false -%}
{%- endif -%}

{%- if enable_transparent_header_homepage and template.name == "index" -%}
	{%- assign is_transparent_header = true -%}
{%- endif -%}

{%- if enable_transparent_header_mobile and template.name == "index" -%}
	{%- assign is_transparent_header_mobile = true -%}
{%- endif -%}

{%- if template.name == "page" and template.suffix == "about" -%}
	{%- assign is_transparent_header = true -%}
	{%- assign is_transparent_header_mobile = true -%}
{%- endif -%}

{%- if enable_transparent_header_collection and template.name == "collection" -%}
	{%- assign is_transparent_header = false -%}
{%- endif -%}

{%- if enable_transparent_header_mobile and template.name == "collection" -%}
	{%- assign is_transparent_header_mobile = false -%}
{%- endif -%}

{%- if is_language_selector and localization.available_languages.size > 1 -%}
	{%- assign is_language_selector_enabled = true -%}
{%- endif -%}

{%- if is_country_selector and localization.available_countries.size > 1 -%}
	{%- assign is_country_selector_enabled = true -%}
{%- endif -%}

{% assign display_link_on_first_lvl = false %}

{% if make_first_lvl_clickable and open_menu_type == 'mouseenter' %}
	{% assign display_link_on_first_lvl = true %}
{% endif %}

<style>
	:root {
		--header-position: {%- if enable_sticky_header -%}sticky{%- else -%}static{%- endif -%}; {{- -}}
		--header-transparent-text-color: {{- text_color_transparent -}}; {{- -}}
		--header-count-text-color: {{- count_text_color -}}; {{- -}}
		--header-transparent-count-text-color: {{- count_text_color_transparent -}}; {{- -}}
		--header-count-text-bg: {{- count_text_bg -}}; {{- -}}
		--header-transparent-count-text-bg: {{- count_text_bg_transparent -}}; {{- -}}
		--header-height-sticky: {%- if enable_sticky_header -%}var(--header-height){%- else -%} 0px{%- endif -%}; {{- -}}
		--header-border-width: {%- if is_show_border -%}1px{%- else -%} 0px{%- endif -%}; {{- -}}
		--header-animation-image-start: {%- if scroll_images_direction == 'top' -%}0%{%- else -%}-100%{%- endif -%};
		--header-animation-image-end: {%- if scroll_images_direction == 'top' -%}-100%{%- else -%}0%{%- endif -%};
	}

	/* Force transparent header to overlay banner */
	@media (min-width: 1200px) {
		.header[data-header-transparent] {
			position: absolute !important;
			top: 0 !important;
			left: 0 !important;
			width: 100% !important;
			z-index: 100 !important;
			background: transparent !important;
		}
	}

	/* User request: Green text color when header is transparent */
	.header[data-header-transparent] .header-menu__item,
	.header[data-header-transparent] .header__icon,
	.header[data-header-transparent] .header__heading-link,
	.header-section.header-section--transparent-mobile .header[data-header-transparent-mobile] .header__icon,
	.header-section.header-section--transparent-mobile .header[data-header-transparent-mobile] .header__burger-mobile-menu-button,
	.header-section.header-section--transparent-mobile .header[data-header-transparent-mobile] .header__heading-link {
		color: #2c3d33 !important;
	}

	{%- if template.name == "page" and template.suffix == "about" -%}
	/* About page: white header text + icons over banner — only at top (not scrolled) */
	.header-section--top-position .header[data-header-transparent] .header-menu__item,
	.header-section--top-position .header[data-header-transparent] .header__icon,
	.header-section--top-position .header[data-header-transparent] .header__heading-link,
	.header-section--top-position.header-section--transparent-mobile .header[data-header-transparent-mobile] .header__icon,
	.header-section--top-position.header-section--transparent-mobile .header[data-header-transparent-mobile] .header__burger-mobile-menu-button,
	.header-section--top-position.header-section--transparent-mobile .header[data-header-transparent-mobile] .header__heading-link {
		color: #ffffff !important;
	}
	{%- endif -%}

	/* Layout overrides to prevent overflow and force center align */
	@media (min-width: 1200px) {
		.header-container, .header__container {
			justify-content: space-between !important;
		}
		.header .header__logo {
			flex: 1 1 0% !important;
			padding-right: 24px !important;
			justify-content: flex-start !important;
		}
		.header .header__utils {
			flex: 1 1 0% !important;
			justify-content: flex-end !important;
		}
		.header .header-menu {
			flex: 0 0 auto !important;
			justify-content: center !important;
		}
	}

	/* Desktop nav: bigger text */
	.header-menu__list--main .header-menu__item {
		text-transform: uppercase !important;
		font-family: var(--font-heading-family) !important;
		font-weight: 700 !important;
		font-size: 14px !important;
		letter-spacing: 0.5px !important;
		padding-left: 0 !important;
		padding-right: 0 !important;
		flex-shrink: 0 !important;
	}
	.header-menu__list--main {
		column-gap: clamp(12px, 1.5vw, 25px) !important;
		row-gap: 10px !important;
		justify-content: center !important;
		flex-wrap: nowrap !important;
	}
	.header-menu__list--main .header-menu__item-wrapper,
	.header-menu__list--main .header-menu__item-wrapper-mega-menu {
		margin: 0 !important;
		display: flex !important;
		align-items: center !important;
		gap: 2px !important;
	}

	.header-menu__list--main .header-menu__item * {
		font-weight: 900 !important;
	}

	/* ============================================
	   DISABLE TEXT JUMP ANIMATION on hover
	   Theme uses [data-text]::after to slide text.
	   We kill it entirely for a clean, static hover.
	   ============================================ */

	/* Remove the ::after pseudo-element text slide */
	.header-menu [data-text]::after {
		display: none !important;
	}

	/* Prevent the inner span from sliding up on hover */
	.header-menu [data-text] > span {
		transform: none !important;
		transition: none !important;
	}

	/* Simple hover: just opacity, no jump/blur/shift */
	.header-menu .header-menu__list.header-menu__list--main > li > .header-menu__item {
		transition: opacity 0.15s ease !important;
	}
	.header-menu .header-menu__list.header-menu__list--main > li > .header-menu__item:hover {
		opacity: 0.6;
	}

	/* Kill blur on inactive items */
	.header-menu .header-menu__list.header-menu__list--main > li > .header-menu__item:not(.is-active) {
		filter: none !important;
	}

	/* ============================================
	   DESKTOP DROPDOWN: refined, rounded styling
	   ============================================ */
	.header-menu .header-menu__list.header-menu__list--nested {
		animation-duration: 0.15s !important;
		border-radius: 8px !important;
		border: 1px solid rgba(0,0,0,0.08) !important;
		box-shadow: 0 8px 24px rgba(0,0,0,0.10), 0 2px 8px rgba(0,0,0,0.04) !important;
		margin-top: 8px !important;
		overflow: hidden !important;
		padding: 12px 10px !important;
	}

	/* Support dropdown items: Oswald regular to match mega menu */
	.header-menu__list--nested .header-menu__item,
	.header-menu__list--nested .header-menu__item *,
	.header-menu__list--nested .header-menu__item [data-text] > span {
		font-family: 'Oswald', sans-serif !important;
		font-weight: 400 !important;
		font-size: 14px !important;
		text-transform: uppercase !important;
		letter-spacing: 0.04em !important;
	}

	/* Wrapper: small gap so dropdown floats below the nav bar */
	.header-menu .header-menu__list-nested-wrapper {
		padding-top: 4px !important;
	}

	/* Split menu: link text + separate arrow toggle */
	.header-menu__item-wrapper {
		position: relative;
	}

	.header-menu__item--arrow {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0 2px !important;
		margin-left: 0 !important;
		border: none;
		background: none;
		cursor: pointer;
		vertical-align: middle;
		min-width: auto !important;
		transition: transform 0.15s ease;
	}

	.header-menu__item--arrow svg {
		width: 10px;
		height: 10px;
	}

	.header-menu__item--arrow:hover {
		opacity: 0.7;
	}

	.header-menu__item--arrow[aria-expanded="true"] {
		transform: rotate(180deg);
	}

	/* When link is separate from arrow, keep tight */
	.header-menu__item--link {
		padding-right: 0 !important;
	}


	/* Mobile: shrink logo to avoid dominating the nav bar */
	@media (max-width: 1199px) {
		.header .header__heading-logo {
			width: auto !important;
			max-width: 70px;
			height: auto;
			max-height: 44px;
		}
	}
	/* Mobile: remove gap between announcement bar and banner when header is transparent */
	@media (max-width: 767px) {
		.header-section.header-section--transparent-mobile {
			height: 0 !important;
			min-height: 0 !important;
			overflow: visible;
		}
	}

	/* Mobile: move search icon to right side (next to cart) */
	@media (max-width: 1199px) {
		/* Hide the search icon from the LEFT side (hamburger area) */
		.header__mobile-menu-wrapper .header__icon--search-mobile,
		.header__mobile-menu-wrapper .no-js.header__icon--search-mobile {
			display: none !important;
		}
		/* Show the desktop search icon on mobile too */
		.header__utils .header__icons .header__icon--search:not(.no-js) {
			display: inline-flex !important;
		}
		/* Keep no-js search hidden on mobile */
		.header__utils .header__icons .header__icon--search.no-js {
			display: none !important;
		}
		/* Compact icon row: tight gap, flush to right edge */
		.header__utils .header__icons {
			display: flex !important;
			align-items: center;
			gap: 2px !important;
			margin-right: -6px;
		}
		.header__utils .header__icons .header__icon {
			padding: 6px 5px !important;
			min-width: 0 !important;
		}
		.header__utils .header__icons .header__icon--search {
			order: 1;
		}
		.header__utils .header__icons .header__icon--account {
			order: 0;
		}
		.header__utils .header__icons .header__icon--cart {
			order: 2;
		}
		.header__utils .header__icons .header__icon--search-close {
			order: 3;
		}
	}
</style>

{%- capture classes -%}
	{% if logo_position == 'middle' %} header--menu-left{% elsif logo_position == 'left' %} header--menu-center{% elsif logo_position == 'top' %} header--menu-bottom{% endif %}
{%- endcapture -%}

{%- capture logo_snippet -%}
	<div class="header__logo">
		<span class="visually-hidden">
			{{ "layout.header.labels.store_logo" | t }}
		</span>

		{%- if request.page_type == 'index' -%}
			<h1 class="header__heading">
		{%- endif -%}
			<a
				href="{{ routes.root_url }}"
				class="header__heading-link focus-visible-outline"
			>
				{%- if logo != blank -%}
					{%- assign logo_alt_transparent = logo_transparent.alt | default: shop.name | escape -%}

					{%- assign logo_height = logo_width | divided_by: logo.aspect_ratio | round: 0 -%}
					{%- assign logo_width_x2 = logo_width | times: 2 -%}

					{%- capture img_styles -%}
						--img-desktop-pos: {{ logo.presentation.focal_point }}; {{- -}}
						--base-logo-width: {{ logo_width -}}px;
						--base-logo-height: {{ logo_height -}}px;
					{%- endcapture -%}

					{%- capture img_styles_transparent -%}
						--img-desktop-pos-transparent: {{ logo_transparent.presentation.focal_point }};
						--base-logo-width: {{ logo_width -}}px;
						--base-logo-height: {{ logo_height -}}px;
					{%- endcapture -%}

					<img
						srcset="{{ logo | image_url: width: logo_width }} 1x, {{ logo | image_url: width: logo_width_x2 }} 2x"
						src="{{ logo | image_url: width: logo_width }}"
						alt="{{ logo.alt }}"
						class="header__heading-logo"
						height="{{ logo_height }}"
						width="{{ logo_width }}"
						loading="eager"
						style="{{ img_styles }}"
					/>

					{%- if is_transparent_header -%}
						<img
							srcset="{{ logo_transparent | image_url: width: logo_width }} 1x, {{ logo_transparent | image_url: width: logo_width_x2 }} 2x"
							src="{{ logo_transparent | image_url: width: logo_width }}"
							alt="{{ logo_alt_transparent }}"
							class="header__heading-logo header__heading-logo--transparent"
							height="{{ logo_height }}"
							width="{{ logo_width }}"
							loading="eager"
							style="{{ img_styles_transparent }}"
						/>
					{%- endif -%}
				{%- else -%}
					<span class="h3">
						{{ shop.name }}
					</span>
				{%- endif -%}
			</a>
		{%- if request.page_type == 'index' -%}
			</h1>
		{%- endif -%}
	</div>
{%- endcapture -%}

<header
	class="header {{ classes | strip_newlines }} color-{{ color_scheme }} js-header"
	data-open-menu-type="{{- open_menu_type -}}"
	{% if header_type == "sticky_hide" %}
		data-hide-on-scroll-down
	{% endif %}
	{% if header_type == "static" %}
		data-static-header
	{% endif %}
	{% if is_transparent_header %}
		data-header-transparent
	{% endif %}
	{% if is_transparent_header_mobile %}
		data-header-transparent-mobile
	{% endif %}
>
	<div
		class="header__container"
		data-header-container
		{% if enable_sticky_header %}
			data-header-sticky
		{% endif %}
	>
		{% if logo_position == "top" %}
			<div class="header__top-container">
				<div class="header__top-left-col">
					{%- if is_language_selector_enabled or is_country_selector_enabled -%}
						<div class="header__localization">
							{%- if is_language_selector_enabled -%}
								{%- render 'language-localization-form', class: 'header', id_prefix: 'header-top', form_id: 'header-top-localization-form' -%}
							{%- endif -%}

							{%- if is_country_selector_enabled -%}
								{%- render 'country-localization-form', class: 'header', id_prefix: 'header-top', form_id: 'header-top-country-form' -%}
							{%- endif -%}
						</div>
					{%- endif -%}
				</div>

				{{- logo_snippet -}}

				<div class="header__utils-top">
					<div class="header__icons">
						{%- if is_enable_search -%}
							<button
								type="button"
								class="header__icon header__icon--search focus-visible-outline js-header-drawer-toggler js-header-search-toggler"
								data-target="headerDrawerSearch"
								data-js-toggle="searchToggleDrawer"
								aria-expanded="false"
								aria-controls="headerDrawerSearch"
								aria-label="{{- "layout.navigation.search" | t | escape -}}"
							>
								{%- render 'icons', icon: 'search' -%}
							</button>

							<a
								href="{{- routes.search_url -}}"
								class="header__icon header__icon--search focus-visible-outline no-js"
								aria-label="{{- "layout.navigation.search" | t | escape -}}"
							>
								{%- render 'icons', icon: 'search' -%}
							</a>
						{%- endif -%}

						{%- if shop.customer_accounts_enabled -%}
							<a
								href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
								class="header__icon header__icon--account focus-visible-outline"
								{% if customer %}
									aria-label="{{- "layout.customer.account" | t | escape -}}"
								{% else %}
									aria-label="{{- "layout.customer.log_in" | t | escape -}}"
								{% endif %}
							>
								{%- render 'icons', icon: 'account' -%}
							</a>
						{%- endif -%}

						{%- if cart_type == "drawer" and template != "cart"  -%}
							<button
								type="button"
								class="header__icon header__icon--cart focus-visible-outline js-header-cart-toggler"
								data-target="CartDrawer"
								data-js-toggle="CartDrawer"
								aria-expanded="false"
								aria-controls="CartDrawer"
							>
								{%- render 'icons', icon: 'cart' -%}

								<span class="visually-hidden">
									{{- "layout.header.labels.cart_drawer" | t | escape -}}
								</span>

								<span
									class="header__cart-count js-header-cart-item-count-wrapper"
									data-cart-count="{{- cart.item_count -}}"
								>
									<span class="visually-hidden">
										{{ "layout.header.labels.cart_item_count" | t }}
									</span>

									<span class="js-header-cart-item-count">
										{%- if cart.item_count > 99 -%}
											99+
										{%- else -%}
											{{- cart.item_count -}}
										{%- endif -%}
									</span>
								</span>
							</button>

							<a href="{{- routes.cart_url -}}" class="header__icon header__icon--cart focus-visible-outline no-js">
								{%- render 'icons', icon: 'cart' -%}

								<span class="visually-hidden">
									{{- "layout.header.labels.cart_drawer" | t | escape -}}
								</span>

								<span
									class="header__cart-count"
									data-cart-count="{{- cart.item_count -}}"
								>
									<span class="visually-hidden">
										{{ "layout.header.labels.cart_item_count" | t }}
									</span>

									<span>
										{%- if cart.item_count > 99 -%}
											99+
										{%- else -%}
											{{- cart.item_count -}}
										{%- endif -%}
									</span>
								</span>
							</a>
						{%- else -%}
							<a href="{{- routes.cart_url -}}" class="header__icon header__icon--cart focus-visible-outline">
								{%- render 'icons', icon: 'cart' -%}

								<span class="visually-hidden">
									{{- "layout.header.labels.cart" | t | escape -}}
								</span>

								<span
									class="header__cart-count js-header-cart-item-count-wrapper"
									data-cart-count="{{- cart.item_count -}}"
								>
									<span class="visually-hidden">
										{{ "layout.header.labels.cart_item_count" | t }}
									</span>

									<span class="js-header-cart-item-count">
										{%- if cart.item_count > 99 -%}
											99+
										{%- else -%}
											{{- cart.item_count -}}
										{%- endif -%}
									</span>
								</span>
							</a>
						{%- endif -%}

						<button
							class="header__icon header__icon--search-close focus-visible-outline"
							type="button"
							aria-label="{{- 'general.predictive_search.close_aria_label' | t | escape -}}"
							aria-expanded="false"
							aria-controls="headerDrawerSearch"
							data-target="headerDrawerSearch"
							data-js-toggle="searchToggleDrawer"
							data-toggle-close-only=""
						>
							{%- render 'icons', icon: 'menu-close' -%}
						</button>
					</div>
				</div>
			</div>
		{% endif %}

		<div class="header__mobile-menu-wrapper">
			<button
				class="header__burger-mobile-menu-button focus-visible-outline js-header-drawer-toggler js-mobile-header-main-toggler"
				type="button"
				data-target="headerDrawerMenu"
				data-js-toggle="headerToggleMenuDrawer"
				aria-expanded="false"
				aria-controls="headerDrawerMenu"
				aria-label="{{ "layout.navigation.open_drawer_menu" | t | escape }}"
			>
				{%- render 'icons', icon: 'burger-menu' -%}
			</button>

			{%- if is_enable_search -%}
				<button
					type="button"
					class="header__icon header__icon--search-mobile focus-visible-outline js-header-search-toggler"
					aria-expanded="false"
					aria-controls="headerDrawerSearch"
					data-target="headerDrawerSearch"
					data-js-toggle="searchToggleDrawer"
					aria-label="{{- "layout.navigation.search" | t | escape -}}"
				>
					{%- render 'icons', icon: 'search' -%}
				</button>

				<a
					href="{{- routes.search_url -}}"
					class="header__icon header__icon--search-mobile focus-visible-outline no-js"
					aria-label="{{- "layout.navigation.search" | t | escape -}}"
				>
					{%- render 'icons', icon: 'search' -%}
				</a>
			{%- endif -%}
		</div>

		{%- if logo_position == 'left' -%}
			{{- logo_snippet -}}
		{%- endif -%}

		{%- if menu.links != blank or burger_menu.links != blank -%}
			{%- render 'header-menu',
				menu: menu,
				burger_menu: burger_menu,
				display_link_on_first_lvl: display_link_on_first_lvl
			-%}
		{%- endif -%}

		{%- if logo_position == 'middle' or logo_position == 'top' -%}
			{{- logo_snippet -}}
		{%- endif -%}

		<div class="header__utils">
			{%- if is_language_selector_enabled or is_country_selector_enabled -%}
				<div class="header__localization">
					{%- if is_language_selector_enabled -%}
						{%- render 'language-localization-form', class: 'header', id_prefix: 'header', form_id: 'header-localization-form' -%}
					{%- endif -%}

					{%- if is_country_selector_enabled -%}
						{%- render 'country-localization-form', class: 'header', id_prefix: 'header', form_id: 'header-country-form' -%}
					{%- endif -%}
				</div>
			{%- endif -%}

			<div class="header__icons">
				{%- if is_enable_search -%}
					<button
						type="button"
						class="header__icon header__icon--search focus-visible-outline js-header-drawer-toggler js-header-search-toggler"
						data-target="headerDrawerSearch"
						data-js-toggle="searchToggleDrawer"
						aria-expanded="false"
						aria-controls="headerDrawerSearch"
						aria-label="{{- "layout.navigation.search" | t | escape -}}"
					>
						{%- render 'icons', icon: 'search' -%}
					</button>

					<a
						href="{{- routes.search_url -}}"
						class="header__icon header__icon--search focus-visible-outline no-js"
						aria-label="{{- "layout.navigation.search" | t | escape -}}"
					>
						{%- render 'icons', icon: 'search' -%}
					</a>
				{%- endif -%}

				{%- if shop.customer_accounts_enabled -%}
					<a
						href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
						class="header__icon header__icon--account focus-visible-outline"
						{% if customer %}
							aria-label="{{- "layout.customer.account" | t | escape -}}"
						{% else %}
							aria-label="{{- "layout.customer.log_in" | t | escape -}}"
						{% endif %}
					>
						{%- render 'icons', icon: 'account' -%}
					</a>
				{%- endif -%}

				{%- if cart_type == "drawer" and template != "cart"  -%}
					<button
						type="button"
						class="header__icon header__icon--cart focus-visible-outline js-header-cart-toggler"
						data-target="CartDrawer"
						data-js-toggle="CartDrawer"
						aria-expanded="false"
						aria-controls="CartDrawer"
					>
						{%- render 'icons', icon: 'cart' -%}

						<span class="visually-hidden">
							{{- "layout.header.labels.cart_drawer" | t | escape -}}
						</span>

						<span
							class="header__cart-count js-header-cart-item-count-wrapper"
							data-cart-count="{{- cart.item_count -}}"
						>
							<span class="visually-hidden">
								{{ "layout.header.labels.cart_item_count" | t }}
							</span>

							<span class="js-header-cart-item-count">
								{%- if cart.item_count > 99 -%}
									99+
								{%- else -%}
									{{- cart.item_count -}}
								{%- endif -%}
							</span>
						</span>
					</button>

					<a href="{{- routes.cart_url -}}" class="header__icon header__icon--cart focus-visible-outline no-js">
						{%- render 'icons', icon: 'cart' -%}

						<span class="visually-hidden">
							{{- "layout.header.labels.cart_drawer" | t | escape -}}
						</span>

						<span
							class="header__cart-count"
							data-cart-count="{{- cart.item_count -}}"
						>
							<span class="visually-hidden">
								{{ "layout.header.labels.cart_item_count" | t }}
							</span>

							<span>
								{%- if cart.item_count > 99 -%}
									99+
								{%- else -%}
									{{- cart.item_count -}}
								{%- endif -%}
							</span>
						</span>
					</a>
				{%- else -%}
					<a href="{{- routes.cart_url -}}" class="header__icon header__icon--cart focus-visible-outline">
						{%- render 'icons', icon: 'cart' -%}

						<span class="visually-hidden">
							{{- "layout.header.labels.cart" | t | escape -}}
						</span>

						<span
							class="header__cart-count js-header-cart-item-count-wrapper"
							data-cart-count="{{- cart.item_count -}}"
						>
							<span class="visually-hidden">
								{{ "layout.header.labels.cart_item_count" | t }}
							</span>

							<span class="js-header-cart-item-count">
								{%- if cart.item_count > 99 -%}
									99+
								{%- else -%}
									{{- cart.item_count -}}
								{%- endif -%}
							</span>
						</span>
					</a>
				{%- endif -%}

				<button
					class="header__icon header__icon--search-close focus-visible-outline"
					type="button"
					aria-label="{{- 'general.predictive_search.close_aria_label' | t | escape -}}"
					aria-expanded="false"
					aria-controls="headerDrawerSearch"
					data-target="headerDrawerSearch"
					data-js-toggle="searchToggleDrawer"
					data-toggle-close-only=""
				>
					{%- render 'icons', icon: 'menu-close' -%}
				</button>
			</div>
		</div>
	</div>

	{%- if show_cart_notification -%}
		{%- render 'cart-notification' -%}
	{%- endif -%}

	{%- render 'cart-notification-error' -%}
</header>

{%- if burger_menu.links != blank -%}
	{%- render 'header-mega-menu',
		burger_menu: burger_menu,
		color_scheme: color_scheme
	-%}
{%- endif -%}

{%- render 'header-mobile',
	menu: menu,
	mobile_top_menu: mobile_top_menu,
