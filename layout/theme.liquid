				animation-duration: 0s !important;
			}

			@keyframes camo-cart-spin {
				to {
					transform: rotate(360deg);
				}
			}
		</style>

		{%- comment -%}
			Cart partial update for item-level changes.
			--------------------------------------------------------------------
			By default theme.refreshSections() blows away the entire
			.js-cart-content innerHTML on every cart:updated, which makes the
			+/- buttons in the drawer feel janky (flicker, lost focus, every
			widget re-bound).

			For action === 'changeQuantity' / 'removeItem' / add actions we:
			  1. Inject a `noRefresh` flag into the cart:updated params, which
			     makes theme.onCartUpdated bail out without touching the DOM.
			  2. Surgically update only what actually changes — the affected
			     line item's price/discount, the subtotal, the discount-tier
			     banner, and the free-shipping progress bar — leaving the
			     quantity input element (and its theme widget binding) intact.

			This also handles inserted/removed line items without replacing the
			entire cart drawer/page content.
		{%- endcomment -%}
		<script>
			(function() {
				if (window.__camoCartPartialUpdateInstalled) return;

				function partialCartUpdate(payload) {
					if (!payload || !payload.sections) return;
					var sectionIds = Object.keys(payload.sections);
					for (var i = 0; i < sectionIds.length; i++) {
						var sectionId = sectionIds[i];
						var html = payload.sections[sectionId];
						if (typeof html !== 'string' || !html) continue;

						var sectionEl = document.querySelector('[data-section-id="' + sectionId + '"]');
						if (!sectionEl) continue;

						var template = document.createElement('template');
						template.innerHTML = html;
						updateSectionPartially(sectionEl, template.content);
					}
				}

				function updateSectionPartially(sectionEl, newRoot) {
					/* 1. Morph the cart-items list:
					      - update items present in both
					      - remove items missing from the response
					      - insert items that are new (e.g. from an add action)
					        in the same order the server rendered them. */
					var oldItemsRoot = getCartItemsRoot(sectionEl);
					var newItemsRoot = getCartItemsRoot(newRoot);
					var newItemEls = getThemeCartItems(newItemsRoot);
					var oldItemEls = getThemeCartItems(oldItemsRoot);
					var newKeys = newItemEls.map(function(el) { return el.getAttribute('data-cart-item'); });

					/* Remove items that are no longer in the new list. */
					oldItemEls.forEach(function(oldItem) {
						var key = oldItem.getAttribute('data-cart-item');
						if (key && newKeys.indexOf(key) === -1) {
							oldItem.remove();
						}
					});

					/* Walk the new list in order; update existing rows or insert
					   missing ones before the next-existing sibling. */
					for (var i = 0; i < newItemEls.length; i++) {
						var newItem = newItemEls[i];
						var key = newItem.getAttribute('data-cart-item');
						var oldItem = findThemeCartItemByKey(oldItemsRoot, key);

						if (oldItem) {
							updateLineItemPartially(oldItem, newItem);
							continue;
						}

						/* New item — find the nearest existing successor and
						   insertBefore it. Falls back to appending into the
						   nearest valid items container. */
						var anchor = null;
						for (var j = i + 1; j < newItemEls.length; j++) {
							var nextKey = newItemEls[j].getAttribute('data-cart-item');
							var nextOld = findThemeCartItemByKey(oldItemsRoot, nextKey);
							if (nextOld) { anchor = nextOld; break; }
						}

						var clone = document.importNode(newItem, true);
						if (anchor && anchor.parentNode) {
							anchor.parentNode.insertBefore(clone, anchor);
						} else {
							/* Find the theme-owned cart items container. Keep this
							   deliberately scoped so third-party cart app widgets
							   are not mistaken for cart rows. */
							var container = oldItemsRoot;
							if (container) {
								var appWidget = getCartAppWidget(container);
								var appAnchor = appWidget;
								while (appAnchor && appAnchor.parentNode !== container) {
									appAnchor = appAnchor.parentNode;
								}
								if (appAnchor && appAnchor.parentNode === container) {
									container.insertBefore(clone, appAnchor);
								} else {
									container.appendChild(clone);
								}
							}
						}
						bindNewItemQuantityWidget(clone);
					}

					/* 2. Subtotal, discount, and footer button blocks. */
					replaceInnerHTMLIfDifferent(sectionEl, newRoot, '.js-cart-subtotal');
					replaceInnerHTMLIfDifferent(sectionEl, newRoot, '.js-cart-discount-block');
					replaceInnerHTMLIfDifferent(sectionEl, newRoot, '.js-cart-footer-button');
					replaceInnerHTMLIfDifferent(sectionEl, newRoot, '.js-cart-footer-additional-buttons');

					/* 3. Drop the is-empty flag if items reappeared, or set it
					      when the cart just became empty. */
					var newSection = newRoot.querySelector('[data-section-type="cart-template"]');
					if (newSection) {
						sectionEl.classList.toggle('is-empty', newSection.classList.contains('is-empty'));
					}

					/* 4. Discount-tier banner (BUY 2/3/4 …). */
