				border: 2px solid rgba(255, 255, 255, 0.7);
				border-top-color: #263e30;
				border-radius: 999px;
				animation: camo-cart-spin 0.7s linear infinite;
				box-shadow: 0 3px 10px rgba(38, 62, 48, 0.22);
