			html.is-cart-qty-changing lb-upsell-widget *,
			html.is-cart-qty-changing .lb-widget *,
			html.is-cart-qty-changing [id*="lb-upsell" i] *,
			html.is-cart-qty-changing [class*="lb-upsell" i] *,
			html.is-cart-qty-changing [id*="selleasy" i] *,
			html.is-cart-qty-changing [class*="selleasy" i] * {
