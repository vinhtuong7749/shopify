<!doctype html>
<html class="no-js" lang="{{- request.locale.iso_code -}}">
	<head>
		<meta charset="utf-8">
		<meta http-equiv="X-UA-Compatible" content="IE=edge">
		<meta name="viewport" content="width=device-width,initial-scale=1">
		<meta name="theme-color" content="{{- settings.color_button -}}">
		<meta name="format-detection" content="telephone=no">

		{%- if settings.hide_search_engine -%}
			<meta name="robots" content="noindex">
		{%- endif -%}

		<link rel="canonical" href="{{- canonical_url -}}">
		<link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
		<link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
		{%- if settings.favicon != blank -%}
			<link rel="icon" href="{{ settings.favicon | img_url: '32x32' }}" type="image/png">
		{%- endif -%}

		{%- capture seo_title -%}
			{%- if template == 'search' and search.performed == true -%}
				{{ 'general.search.heading' | t: count: search.results_count }}: {{ 'general.search.results_with_count' | t: terms: search.terms, count: search.results_count }}
			{%- else -%}
				{{ page_title }}
			{%- endif -%}

			{%- if current_tags -%}
				{%- assign meta_tags = current_tags | join: ', ' -%} &ndash; {{ 'general.meta.tags' | t: tags: meta_tags -}}
			{%- endif -%}

			{%- if current_page != 1 -%}
				&ndash; {{ 'general.meta.page' | t: page: current_page }}
			{%- endif -%}

			{%- assign escaped_page_title = page_title | escape -%}
			{%- unless escaped_page_title contains shop.name -%}
				&ndash; {{ shop.name }}
			{%- endunless -%}
		{%- endcapture -%}

		<title>
			{{- seo_title | strip -}}
		</title>

		{%- if page_description -%}
			<meta name="description" content="{{- page_description | escape -}}">
		{%- endif -%}

		{%- render 'head-theme-meta', layout: 'theme' -%}
		{%- render 'social-meta-tags' -%}

		{%- render 'custom-variables.css' -%}

		{%- render 'adastra' with '/src/styles/main.scss', preload: true -%}

		{%- if template.directory == 'customers' -%}
			<script src="{{- 'shopify_common.js' | shopify_asset_url -}}" defer="defer"></script>
		{%- endif -%}

		<script>
			window.themeCore = window.themeCore || {};
			window.themeCore.productPlaceholderImage = {%- if settings.product_default_image -%} {{- settings.product_default_image | img_url: "master" | replace: "//", "https://" | json -}} {%- else -%} null {%- endif -%};
			window.themeCore.productPlaceholderAspectRatio = {{ settings.product_default_image.aspect_ratio | json }};
			{% if settings.cart_reminder_enable %}
				window.themeCore.CartReminder = {
					config: {
						enableColorSchemeInheritance: {{- settings.enable_color_scheme_inheritance | json -}},
						colorSchemeLocal: "{{- settings.color_scheme -}}",
						colorSchemeGlobal: "{{- settings.main_color_scheme -}}",
						cookieTime: {{- settings.cart_reminder_cookie_time | json -}},
						displayFrequency: {{- settings.cart_reminder_display_frequency | json -}},
						text: {{- settings.cart_reminder_text | json -}},
						cartType: {{- settings.cart_type | json -}},
						cartRoute: {{- routes.cart_url | json -}},
						cartLinkA11y: {{- "cart.reminder.accessibility.cart" | t | escape | json -}},
						cartButtonA11y: {{- "cart.reminder.accessibility.cart_drawer" | t | escape | json -}},
						closeButtonA11y: {{- "cart.reminder.accessibility.close_button" | t | escape | json -}}
					}
				}
			{% endif %}
		</script>

		{%- render 'translations-methods' -%}
		{%- render 'translations' -%}

		{%- if template.name == 'index' -%}
			{%- assign desktop_banner = images['banner_camosignal_fix-dung-luong.jpg'] -%}
			{%- if desktop_banner != blank -%}
				<link rel="preload" as="image" href="{{ desktop_banner | image_url: width: 1920 }}" media="(min-width: 768px)" fetchpriority="high">
			{%- endif -%}
			{%- assign mobile_banner = images['mobile_banner_fix.jpg'] -%}
			{%- if mobile_banner != blank -%}
				<link rel="preload" as="image" href="{{ mobile_banner | image_url: width: 767 }}" media="(max-width: 767px)" fetchpriority="high">
			{%- endif -%}
		{%- endif -%}

		<style>
			/* Hide Judge.me Reviews tab on mobile */
			@media screen and (max-width: 767px) {
				.jdgm-revs-tab {
					display: none !important;
				}
			}

			/* Match Judge.me review text to the product short description typography */
			.jdgm-widget .jdgm-rev__author,
			.jdgm-widget .jdgm-rev__timestamp,
			.jdgm-widget .jdgm-rev__title,
			.jdgm-widget .jdgm-rev__body,
			.jdgm-widget .jdgm-rev__body p,
			.jdgm-widget .jdgm-rev__content,
			.jdgm-widget .jdgm-rev__content p,
			.jdgm-all-reviews-page .jdgm-rev__author,
			.jdgm-all-reviews-page .jdgm-rev__timestamp,
			.jdgm-all-reviews-page .jdgm-rev__title,
			.jdgm-all-reviews-page .jdgm-rev__body,
			.jdgm-all-reviews-page .jdgm-rev__body p,
			.jdgm-all-reviews-page .jdgm-rev__content,
			.jdgm-all-reviews-page .jdgm-rev__content p,
			.jdgm-carousel-wrapper .jdgm-carousel-item__reviewer-name,
			.jdgm-carousel-wrapper .jdgm-carousel-item__timestamp,
			.jdgm-carousel-wrapper .jdgm-carousel-item__review-title,
			.jdgm-carousel-wrapper .jdgm-carousel-item__review-body,
			.jdgm-carousel-wrapper .jdgm-carousel-item__review-body p {
				font-family: var(--base-font-family) !important;
				font-size: calc(var(--body-font-size) * 0.875) !important;
				font-weight: 400 !important;
				line-height: 1.65 !important;
				letter-spacing: 0 !important;
				text-transform: none !important;
				color: var(--color-text-thirdly) !important;
			}

			.jdgm-widget .jdgm-rev__body p,
			.jdgm-all-reviews-page .jdgm-rev__body p,
			.jdgm-carousel-wrapper .jdgm-carousel-item__review-body p {
				margin-bottom: 0.5em !important;
			}

			.jdgm-widget .jdgm-rev__body p:last-child,
			.jdgm-all-reviews-page .jdgm-rev__body p:last-child,
			.jdgm-carousel-wrapper .jdgm-carousel-item__review-body p:last-child {
				margin-bottom: 0 !important;
			}

			@media screen and (max-width: 767px) {
				.jdgm-widget .jdgm-rev__author,
				.jdgm-widget .jdgm-rev__timestamp,
				.jdgm-widget .jdgm-rev__title,
				.jdgm-widget .jdgm-rev__body,
				.jdgm-widget .jdgm-rev__body p,
				.jdgm-widget .jdgm-rev__content,
				.jdgm-widget .jdgm-rev__content p,
				.jdgm-all-reviews-page .jdgm-rev__author,
				.jdgm-all-reviews-page .jdgm-rev__timestamp,
				.jdgm-all-reviews-page .jdgm-rev__title,
				.jdgm-all-reviews-page .jdgm-rev__body,
				.jdgm-all-reviews-page .jdgm-rev__body p,
				.jdgm-all-reviews-page .jdgm-rev__content,
				.jdgm-all-reviews-page .jdgm-rev__content p,
				.jdgm-carousel-wrapper .jdgm-carousel-item__reviewer-name,
				.jdgm-carousel-wrapper .jdgm-carousel-item__timestamp,
				.jdgm-carousel-wrapper .jdgm-carousel-item__review-title,
				.jdgm-carousel-wrapper .jdgm-carousel-item__review-body,
				.jdgm-carousel-wrapper .jdgm-carousel-item__review-body p {
					font-size: 13px !important;
					line-height: 1.5 !important;
				}
			}
		</style>

		{{ content_for_header }}

		<script>
			// Delay non-critical third-party scripts (Judge.me widgets, chat, etc.)
			// by replacing their script src loading until page is idle
			(function() {
				var DEFER_DELAY = 12000; // keep third-party scripts out of the first interaction window
				var loaded = false;

				function loadDeferredScripts() {
					if (loaded) return;
					loaded = true;
					// Trigger Shopify's lazy-loaded app scripts if available
					document.querySelectorAll('script[data-src]').forEach(function(s) {
						s.src = s.getAttribute('data-src');
						s.removeAttribute('data-src');
					});
				}

				// Load on first user interaction (instant responsiveness for real users)
				['pointerdown','keydown','touchstart','scroll'].forEach(function(ev) {
					window.addEventListener(ev, loadDeferredScripts, { once: true, passive: true });
				});

				// Fallback: load after delay even if no interaction
				window.addEventListener('load', function() {
					setTimeout(loadDeferredScripts, DEFER_DELAY);
				});
			})();
		</script>

		<script>
			document.querySelector("html").classList.remove("no-js");
		</script>
		{% comment %} startClarity {% endcomment %}
		<script type="text/javascript">
		(function() {
			var loaded = false;
			var CLARITY_DELAY = 12000;

			function loadClarity() {
				if (loaded) return;
				loaded = true;
				(function(c,l,a,r,i,t,y){
					c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
					t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
					y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
				})(window, document, "clarity", "script", "wgkwr65k4s");
			}

			function scheduleClarity() {
				if ('requestIdleCallback' in window) {
					window.requestIdleCallback(loadClarity, { timeout: 3000 });
				} else {
					loadClarity();
				}
			}

			window.addEventListener('load', function() {
				setTimeout(scheduleClarity, CLARITY_DELAY);
			});
		})();
		</script>
		{% comment %} endClarity {% endcomment %}
		<style>
			/* Ensure third-party app dropdowns appear above cart drawer */
			.select2-container,
			.select2-container--open,
			.select2-dropdown,
			[class*="sll-dropdown"],
			[class*="selleasy"],
			.sll-popup,
			.choices__list--dropdown {
				z-index: 999999 !important;
			}

			/* Soft Blurred Shadow Effect for Product Cards on Desktop */
			@media (min-width: 990px) {
				.product-card {
					border: 1px solid #e5e7eb !important;
					border-radius: 8px !important;
					box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.08), 0 2px 4px -1px rgba(0, 0, 0, 0.04) !important;
					background-color: #ffffff !important;
					display: flex;
					flex-direction: column;
					height: 100%;
					transition: transform 0.3s ease, box-shadow 0.3s ease;
					overflow: hidden !important;
				}
				.product-card:hover {
					box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05) !important;
				}
				.product-card .product-card__main {
					border-bottom: 1px solid #e5e7eb !important;
				}
				.product-card .product-card__footer {
					padding: 16px !important;
				}
			}
		</style>
	</head>

