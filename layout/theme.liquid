<!doctype html>
<html class="no-js" lang="{{- request.locale.iso_code -}}">
	<head>
		<meta charset="utf-8">
		<meta http-equiv="X-UA-Compatible" content="IE=edge">
		<meta name="viewport" content="width=device-width,initial-scale=1">
		<meta name="theme-color" content="{{- settings.color_button -}}">
		<meta name="format-detection" content="telephone=no">

		{%- if settings.hide_search_engine -%}
			<meta name="robots" content="noindex">
		{%- endif -%}

		<link rel="canonical" href="{{- canonical_url -}}">
		<link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
		<link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
		<link rel="preconnect" href="https://monorail-edge.shopifysvc.com" crossorigin>

		{%- if settings.favicon != blank -%}
			<link rel="icon" href="{{ settings.favicon | img_url: '32x32' }}" type="image/png">
		{%- endif -%}

		{%- capture seo_title -%}
			{%- if template == 'search' and search.performed == true -%}
				{{ 'general.search.heading' | t: count: search.results_count }}: {{ 'general.search.results_with_count' | t: terms: search.terms, count: search.results_count }}
			{%- else -%}
				{{ page_title }}
			{%- endif -%}

			{%- if current_tags -%}
				{%- assign meta_tags = current_tags | join: ', ' -%} &ndash; {{ 'general.meta.tags' | t: tags: meta_tags -}}
			{%- endif -%}

			{%- if current_page != 1 -%}
				&ndash; {{ 'general.meta.page' | t: page: current_page }}
			{%- endif -%}

			{%- assign escaped_page_title = page_title | escape -%}
			{%- unless escaped_page_title contains shop.name -%}
				&ndash; {{ shop.name }}
			{%- endunless -%}
		{%- endcapture -%}

		<title>
			{{- seo_title | strip -}}
		</title>

		{%- if page_description -%}
			<meta name="description" content="{{- page_description | escape -}}">
		{%- endif -%}

		{%- render 'head-theme-meta', layout: 'theme' -%}
		{%- render 'social-meta-tags' -%}

		{%- render 'custom-variables.css' -%}

		{%- render 'adastra' with '/src/styles/main.scss', preload: true -%}

		{%- if template.directory == 'customers' -%}
			<script src="{{- 'shopify_common.js' | shopify_asset_url -}}" defer="defer"></script>
		{%- endif -%}

		<script>
			window.themeCore = window.themeCore || {};
			window.themeCore.productPlaceholderImage = {%- if settings.product_default_image -%} {{- settings.product_default_image | img_url: "master" | replace: "//", "https://" | json -}} {%- else -%} null {%- endif -%};
			window.themeCore.productPlaceholderAspectRatio = {{ settings.product_default_image.aspect_ratio | json }};
			{% if settings.cart_reminder_enable %}
				window.themeCore.CartReminder = {
					config: {
						enableColorSchemeInheritance: {{- settings.enable_color_scheme_inheritance | json -}},
						colorSchemeLocal: "{{- settings.color_scheme -}}",
						colorSchemeGlobal: "{{- settings.main_color_scheme -}}",
						cookieTime: {{- settings.cart_reminder_cookie_time | json -}},
						displayFrequency: {{- settings.cart_reminder_display_frequency | json -}},
						text: {{- settings.cart_reminder_text | json -}},
						cartType: {{- settings.cart_type | json -}},
						cartRoute: {{- routes.cart_url | json -}},
						cartLinkA11y: {{- "cart.reminder.accessibility.cart" | t | escape | json -}},
						cartButtonA11y: {{- "cart.reminder.accessibility.cart_drawer" | t | escape | json -}},
						closeButtonA11y: {{- "cart.reminder.accessibility.close_button" | t | escape | json -}}
					}
				}
			{% endif %}
		</script>

		{%- render 'translations-methods' -%}
		{%- render 'translations' -%}

		{%- if template.name == 'index' -%}
			{%- assign desktop_banner = images['banner_camosignal_fix-dung-luong.jpg'] -%}
			{%- if desktop_banner != blank -%}
				<link rel="preload" as="image" href="{{ desktop_banner | image_url: width: 1920 }}" media="(min-width: 768px)" fetchpriority="high">
			{%- endif -%}
			{%- assign mobile_banner = images['mobile_banner_fix.jpg'] -%}
			{%- if mobile_banner != blank -%}
				<link rel="preload" as="image" href="{{ mobile_banner | image_url: width: 767 }}" media="(max-width: 767px)" fetchpriority="high">
			{%- endif -%}
		{%- endif -%}

		<style>
			/* Hide Judge.me Reviews tab on mobile */
			@media screen and (max-width: 767px) {
				.jdgm-revs-tab {
					display: none !important;
				}
			}
		</style>

		{{ content_for_header }}

		<script>
			// Delay non-critical third-party scripts (Judge.me widgets, chat, etc.)
			// by replacing their script src loading until page is idle
			(function() {
				var DEFER_DELAY = 4000; // 4 seconds after load
				var loaded = false;

				function loadDeferredScripts() {
					if (loaded) return;
					loaded = true;
					// Trigger Shopify's lazy-loaded app scripts if available
					document.querySelectorAll('script[data-src]').forEach(function(s) {
						s.src = s.getAttribute('data-src');
						s.removeAttribute('data-src');
					});
				}

				// Load on first user interaction (instant responsiveness for real users)
				['pointerdown','mousemove','keydown','touchstart','scroll'].forEach(function(ev) {
					window.addEventListener(ev, loadDeferredScripts, { once: true, passive: true });
				});

				// Fallback: load after delay even if no interaction
				window.addEventListener('load', function() {
					setTimeout(loadDeferredScripts, DEFER_DELAY);
				});
			})();
		</script>

		<script>
			document.querySelector("html").classList.remove("no-js");
		</script>
		{% comment %} startClarity {% endcomment %}
		<script type="text/javascript">
		setTimeout(function() {
			(function(c,l,a,r,i,t,y){
				c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
				t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
				y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
			})(window, document, "clarity", "script", "wgkwr65k4s");
		}, 3000);
		</script>
		{% comment %} endClarity {% endcomment %}
		<style>
			/* Ensure third-party app dropdowns appear above cart drawer */
			.select2-container,
			.select2-container--open,
			.select2-dropdown,
			[class*="sll-dropdown"],
			[class*="selleasy"],
			.sll-popup,
			.choices__list--dropdown {
				z-index: 999999 !important;
			}

			/* Soft Blurred Shadow Effect for Product Cards on Desktop */
			@media (min-width: 990px) {
				.product-card {
					border: 1px solid #e5e7eb !important;
					border-radius: 8px !important;
					box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.08), 0 2px 4px -1px rgba(0, 0, 0, 0.04) !important;
					background-color: #ffffff !important;
					display: flex;
					flex-direction: column;
					height: 100%;
					transition: transform 0.3s ease, box-shadow 0.3s ease;
					overflow: hidden !important;
				}
				.product-card:hover {
					box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05) !important;
				}
				.product-card .product-card__main {
					border-bottom: 1px solid #e5e7eb !important;
				}
				.product-card .product-card__footer {
					padding: 16px !important;
				}
			}
		</style>
	</head>

	{%- assign rtl_langs = 'ar,arc,dv,fa,ha,he,khw,ks,ku,ps,ur,yi' | split: ',' -%}
	{%- assign current_langs = localization.language.iso_code | split: '-' | first -%}

	<body class="template-{{ template | split: '.' | first }}{% if rtl_langs contains current_langs %} rtl{% endif %}">
		<a href="#MainContent" class="skip-content-link visually-hidden">
			{{- "general.accessibility.skip_to_content" | t -}}
		</a>

		{%- sections 'header-group' -%}

		{%- sections 'popup-group' -%}

		{%- if settings.enable_search -%}
			{%- render 'predictive-search' -%}
		{%- endif -%}

		<main id="MainContent" class="content" role="main" tabindex="-1">
			{%- if settings.show_breadcrumbs -%}
				{%- render "breadcrumbs" -%}
			{%- endif -%}

			{{ content_for_layout }}
		</main>

		{%- sections 'footer-group' -%}

		{%- render 'page-preloader' -%}

		{%- render 'js-objects' -%}

		{%- render 'adastra' with '/src/styles/carousel.scss' -%}

		{%- render 'adastra' with '/src/styles/deferred-main.scss' -%}

		{% render 'js-animate-observer' %}

		{%- render 'adastra' with '/src/scripts/main.js' -%}

		{%- if settings.cart_reminder_enable -%}
			{%- render 'adastra' with '/src/styles/cart-reminder.scss' -%}
			{%- render 'adastra' with '/src/scripts/component-cart-reminder.js' -%}
		{%- endif -%}

		{%- render 'adastra' with '/src/scripts/component-ar-model.js' -%}

		{%- render 'mobile-floating-cart' -%}
		{%- section 'smart-popup' -%}

		{%- comment -%} Global Cart Enforcer (Shipping Protection Max 1 & Merge Split Variants) {%- endcomment -%}
		<style>
			html.is-cart-merging .cart-drawer__items,
			html.is-cart-merging .cart-item,
			html.is-cart-merging .cart-items {
				opacity: 0.2 !important;
				pointer-events: none !important;
			}
		</style>
		<script>
		window.addEventListener('load', function() {
			setTimeout(function() {
			(function() {
				var SP_HANDLE = 'shipping-protection-apparel';
				var isEnforcing = false;

				function enforceCartRules(callback) {
					if (isEnforcing) return;
					isEnforcing = true;
					var xhr = new XMLHttpRequest();
					xhr.open('GET', '/cart.js', true);
					xhr.setRequestHeader('Content-Type', 'application/json');
					xhr.onload = function() {
						if (xhr.status >= 200 && xhr.status < 300) {
							var cart = JSON.parse(xhr.responseText);
							var updates = {};
							var needsUpdate = false;
							var variants = {};

							for (var i = 0; i < cart.items.length; i++) {
								var item = cart.items[i];

								// 1. Shipping Protection rule:
								if (item.handle === SP_HANDLE) {
									if (item.quantity > 1) {
										needsUpdate = true;
										updates[item.key] = 1;
									}
									continue;
								}

								// 2. Merge identical variants rule:
								if (variants[item.variant_id]) {
									needsUpdate = true;
									variants[item.variant_id].qty += item.quantity;
									updates[item.key] = 0; // Remove the duplicate
									updates[variants[item.variant_id].key] = variants[item.variant_id].qty; // Apply sum to the first occurrence
								} else {
									variants[item.variant_id] = { key: item.key, qty: item.quantity };
								}
							}

							if (needsUpdate) {
								document.documentElement.classList.add('is-cart-merging');
								var fix = new XMLHttpRequest();
								fix.open('POST', '/cart/update.js', true);
								fix.setRequestHeader('Content-Type', 'application/json');
								fix.onload = function() {
									isEnforcing = false;
									if (callback && typeof callback === 'function') {
										callback();
									} else {
										/* Refresh the cart drawer/page via AJAX */
										if (window.themeCore && window.themeCore.EventBus) {
											window.themeCore.EventBus.emit("cart:refresh");
											setTimeout(function() { document.documentElement.classList.remove('is-cart-merging'); }, 600);
										} else {
											window.location.reload();
										}
									}
								};
								fix.onerror = function() { 
									isEnforcing = false; 
									document.documentElement.classList.remove('is-cart-merging');
									if (callback) callback(); 
								};
								fix.send(JSON.stringify({ updates: updates }));
								return;
							}
						}
						isEnforcing = false;
						document.documentElement.classList.remove('is-cart-merging');
						if (callback && typeof callback === 'function') callback();
					};
					xhr.onerror = function() { 
						isEnforcing = false; 
						document.documentElement.classList.remove('is-cart-merging');
						if (callback) callback(); 
					};
					xhr.send();
				}

				/* Check cart on init (now delayed until after load) */
				enforceCartRules();

				/* Intercept fetch for cart update/change requests to enforce after any modification */
				var origFetch = window.fetch;
				window.fetch = function() {
					var url = arguments[0];
					if (typeof url === 'string' && (url.indexOf('/cart/update') !== -1 || url.indexOf('/cart/change') !== -1 || url.indexOf('/cart/add') !== -1)) {
						document.documentElement.classList.add('is-cart-merging');
						return origFetch.apply(this, arguments).then(function(res) {
							var cloned = res.clone();
							setTimeout(function() { enforceCartRules(); }, 50); // fast trigger
							return res;
						}).catch(function(err) {
							document.documentElement.classList.remove('is-cart-merging');
							throw err;
						});
					}
					return origFetch.apply(this, arguments);
				};

				/* Intercept checkout form submission to guarantee rules before proceeding to checkout */
				document.addEventListener('submit', function(e) {
					var isCheckout = false;
					if (e.target && e.target.action && e.target.action.indexOf('/cart') !== -1) {
						if (e.submitter && (e.submitter.name === 'checkout' || e.submitter.value === 'Checkout' || e.submitter.innerText === 'Checkout')) {
							isCheckout = true;
						} else if (e.target.querySelector('[name="checkout"]')) {
							isCheckout = true; // Fallback
						}
					}

					if (isCheckout) {
						e.preventDefault();
						var form = e.target;
						document.documentElement.classList.add('is-cart-merging');
						enforceCartRules(function() {
							document.documentElement.classList.remove('is-cart-merging');
							/* Submit programmatically bypassing the event listener so it doesn't loop */
							HTMLFormElement.prototype.submit.call(form);
						});
					}
				});
			})();
			}, 2000); // 2s delay after load event — reduces TBT significantly
		});
		</script>
	</body>
</html>
