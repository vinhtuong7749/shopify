					document.addEventListener('theme:all:loaded', function() {
						if (tryInstall()) stopInstallRetry();
					}, { once: true });
					window.addEventListener('load', function() {
						if (tryInstall()) stopInstallRetry();
					}, { once: true });
				}
			})();
		</script>

