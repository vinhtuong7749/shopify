		<script>
			/* Lazy load third-party app images (Judge.me, etc.) via MutationObserver
			   Intercepts images as they're added to DOM before browser downloads them */
			(function() {
				function applyLazy(node) {
					if (node.nodeType !== 1) return;
					var imgs = node.tagName === 'IMG' ? [node] : node.querySelectorAll('img');
					for (var i = 0; i < imgs.length; i++) {
						var img = imgs[i];
						if (!img.dataset.lazyDone && !img.hasAttribute('fetchpriority')) {
							img.loading = 'lazy';
							img.decoding = 'async';
							img.dataset.lazyDone = '1';
						}
					}
				}

				var mo = new MutationObserver(function(mutations) {
					for (var i = 0; i < mutations.length; i++) {
						var added = mutations[i].addedNodes;
						for (var j = 0; j < added.length; j++) {
							applyLazy(added[j]);
						}
					}
				});

				mo.observe(document.body, { childList: true, subtree: true });
				/* Stop after 30s — all app widgets should be loaded by then */
				setTimeout(function() { mo.disconnect(); }, 30000);
			})();
		</script>

		{%- comment -%} Global Cart Enforcer (Shipping Protection Max 1 & Merge Split Variants) + Auto-apply Discount {%- endcomment -%}
		<style>
			html.is-cart-merging .cart-drawer__items,
			html.is-cart-merging .cart-item,
			html.is-cart-merging .cart-items {
				opacity: 0.5 !important;
				pointer-events: none !important;
				transition: opacity 0.15s ease;
			}
		</style>
		<script>
		window.addEventListener('load', function() {
			setTimeout(function() {
			(function() {
				var SP_HANDLE = 'shipping-protection-apparel';
				var COOLDOWN_MS = 1200;
				var DEBOUNCE_MS = 220;
				var BLUR_HIDE_MS = 200;
				var isEnforcing = false;
				var lastEnforceAt = 0;
				var debounceTimer = null;
				var pendingHint = null;

				function analyzeItems(items) {
					var updates = {};
					var needsUpdate = false;
					var variants = {};

					for (var i = 0; i < items.length; i++) {
						var item = items[i];

						if (item.handle === SP_HANDLE) {
							if (item.quantity > 1) {
								needsUpdate = true;
								updates[item.key] = 1;
							}
							continue;
						}

						if (variants[item.variant_id]) {
							needsUpdate = true;
							variants[item.variant_id].qty += item.quantity;
							updates[item.key] = 0;
							updates[variants[item.variant_id].key] = variants[item.variant_id].qty;
						} else {
							variants[item.variant_id] = { key: item.key, qty: item.quantity };
						}
					}

					return { updates: updates, needsUpdate: needsUpdate };
				}

				function postCartUpdate(updates, callback) {
					document.documentElement.classList.add('is-cart-merging');
					var fix = new XMLHttpRequest();
					fix.open('POST', '/cart/update.js', true);
					fix.setRequestHeader('Content-Type', 'application/json');
					fix.onload = function() {
						isEnforcing = false;
						lastEnforceAt = Date.now();
						if (callback && typeof callback === 'function') {
							callback();
						} else if (window.themeCore && window.themeCore.EventBus) {
							window.themeCore.EventBus.emit("cart:refresh");
							setTimeout(function() { document.documentElement.classList.remove('is-cart-merging'); }, BLUR_HIDE_MS);
						} else {
							window.location.reload();
						}
					};
					fix.onerror = function() {
						isEnforcing = false;
						lastEnforceAt = Date.now();
						document.documentElement.classList.remove('is-cart-merging');
						if (callback) callback();
					};
					fix.send(JSON.stringify({ updates: updates }));
				}

				function isFullCartPayload(cart) {
					if (!cart || !Array.isArray(cart.items) || typeof cart.item_count !== 'number') return false;

					var totalQuantity = 0;
					for (var i = 0; i < cart.items.length; i++) {
						var item = cart.items[i];
						if (!item || !item.key || !item.variant_id || typeof item.quantity !== 'number') return false;
						totalQuantity += item.quantity;
					}

					return totalQuantity === cart.item_count;
				}

				function hasShippingProtection(items) {
					if (!Array.isArray(items)) return false;
					for (var i = 0; i < items.length; i++) {
						if (items[i] && items[i].handle === SP_HANDLE) return true;
					}
					return false;
				}

				function enforceCartRules(callback, cartHint) {
					if (isEnforcing) {
						if (callback) callback();
						return;
					}

					/* Fast path: payload already contains the full cart — analyze without an extra /cart.js fetch. */
					if (isFullCartPayload(cartHint)) {
						var result = analyzeItems(cartHint.items);
						lastEnforceAt = Date.now();
						if (!result.needsUpdate) {
							if (callback) callback();
							return;
						}
						isEnforcing = true;
						postCartUpdate(result.updates, callback);
						return;
					}

					/* Skip silent checks during cooldown — checkout-callback path still runs */
					if (!callback && Date.now() - lastEnforceAt < COOLDOWN_MS) {
						return;
					}

					isEnforcing = true;
					var xhr = new XMLHttpRequest();
					xhr.open('GET', '/cart.js', true);
					xhr.setRequestHeader('Content-Type', 'application/json');
					xhr.onload = function() {
						if (xhr.status >= 200 && xhr.status < 300) {
							var cart = JSON.parse(xhr.responseText);
							var result = analyzeItems(cart.items);

							if (result.needsUpdate) {
								postCartUpdate(result.updates, callback);
								return;
							}
						}
						isEnforcing = false;
						lastEnforceAt = Date.now();
						document.documentElement.classList.remove('is-cart-merging');
						if (callback && typeof callback === 'function') callback();
					};
					xhr.onerror = function() {
						isEnforcing = false;
						lastEnforceAt = Date.now();
						document.documentElement.classList.remove('is-cart-merging');
						if (callback) callback();
					};
					xhr.send();
				}

				function scheduleEnforce(cartHint) {
					pendingHint = cartHint || pendingHint;
					if (debounceTimer) clearTimeout(debounceTimer);
					debounceTimer = setTimeout(function() {
						debounceTimer = null;
						var hint = pendingHint;
						pendingHint = null;
						enforceCartRules(null, hint);
					}, DEBOUNCE_MS);
				}

				function hasCartItemsHint() {
					var counters = document.querySelectorAll('[data-cart-count], .js-header-cart-item-count');
					if (!counters.length) return true;

					for (var i = 0; i < counters.length; i++) {
						var rawCount = counters[i].getAttribute('data-cart-count') || counters[i].textContent || '';
						var count = parseInt(rawCount, 10);

						if (!isNaN(count)) {
							if (count > 0) return true;
						} else if (rawCount.trim() !== '') {
							return true;
						}
					}

					return false;
				}

				function bindCartUpdates() {
					if (!window.themeCore || !window.themeCore.EventBus) return;
					window.themeCore.EventBus.listen('cart:updated', function(cart) {
						if (!cart || !cart.item_count) return;
						/* For ADD responses, payload.items only contains added line items.
						   Skip the silent enforce entirely when those added items contain no
						   shipping-protection — Shopify already merges duplicate variants. */
						var isAddAction = cart.action === 'addItem' || cart.action === 'addItems';
						if (isAddAction && Array.isArray(cart.items) && !hasShippingProtection(cart.items)) {
							lastEnforceAt = Date.now();
							return;
						}
						scheduleEnforce(cart);
					});
				}

				if (window.themeCore && window.themeCore.EventBus) {
					bindCartUpdates();
				} else {
					document.addEventListener('theme:all:loaded', bindCartUpdates, { once: true });
				}

				/* Check cart on init only when the header confirms a non-empty cart. */
				if (hasCartItemsHint()) {
					enforceCartRules();
				}

				/* Intercept checkout form submission */
				document.addEventListener('submit', function(e) {
					var isCheckout = false;
					if (e.target && e.target.action && e.target.action.indexOf('/cart') !== -1) {
						if (e.submitter && (e.submitter.name === 'checkout' || e.submitter.value === 'Checkout' || e.submitter.innerText === 'Checkout')) {
							isCheckout = true;
						} else if (e.target.querySelector('[name="checkout"]')) {
							isCheckout = true;
						}
					}

					if (isCheckout) {
						e.preventDefault();
						var form = e.target;
						if (debounceTimer) {
							clearTimeout(debounceTimer);
							debounceTimer = null;
							pendingHint = null;
						}
						document.documentElement.classList.add('is-cart-merging');
						enforceCartRules(function() {
							document.documentElement.classList.remove('is-cart-merging');
							HTMLFormElement.prototype.submit.call(form);
						});
					}
				});

			})();
			}, 5000);
		});
		</script>

		{%- comment -%} Auto-apply discount code từ Popup Newsletter — chạy độc lập, không chờ Enforcer {%- endcomment -%}
		<script>
		window.addEventListener('load', function() {
			var discountApplied = false;
			function tryApplyDiscount() {
				if (discountApplied) return;
				var code = localStorage.getItem('pending_discount');
				if (!code) return;
				discountApplied = true;
				/* Gọi /discount/CODE — Shopify lưu vào session ngay */
				fetch('/discount/' + encodeURIComponent(code))
					.then(function() {
						localStorage.removeItem('pending_discount');
						console.log('[CamoSignal] Discount applied:', code);
						/* Refresh cart drawer nếu đã sẵn sàng */
						if (window.themeCore && window.themeCore.EventBus) {
							window.themeCore.EventBus.emit('cart:refresh');
						}
					})
					.catch(function(err) {
						discountApplied = false;
						console.warn('[CamoSignal] Discount error:', err);
					});
			}
			/* Chạy sau 1 giây — đủ nhanh để áp dụng trước khi khách mở giỏ hàng */
			setTimeout(tryApplyDiscount, 1000);
		});
		</script>
	</body>
</html>
