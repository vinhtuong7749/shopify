{% doc %}
  @prompt
    Create two accordion/drawer sections on the product page: "Size Guide" and "Shipping".
    
    1. **Size Guide**: When clicked, opens a popup/modal displaying a size chart table with the following columns: International size, Ukrainian size, Europe size, Breast size (cm), Waist size (cm), Hips size (cm). Rows: XXS(40,34,80,60,84), XS(42,36,84,64,88), S(44,38,88,68,92), M(46,40,92,72,96), L(48,42,96,76,100), XL(50,44,100,80,104), onesize(42-46,36-40,84-92,64-72,88-96). The modal should have a close (×) button and clean table styling with dividers between rows.
    
    2. **Shipping**: When clicked, opens a popup/modal with shipping policy content including: intro paragraph, "Shipping Policy" heading, "Processing Time" section (1-3 business days, excluding weekends/holidays, confirmation email with tracking), "Shipping Rates & Delivery Estimates" section with Standard Shipping (5-7 business days, free over $100 or $7.99 flat rate) and Expedited Shipping (2-3 business days, $14.99). The modal should have a close (×) button and be scrollable.
    
    Both items should appear as clickable rows with a right arrow (>) on the product page, similar to accordion items. Style should be minimal and clean with a bottom border separator., Tôi muốn tôi có thể sửa nội dung trong size guild và shipping, Làm để tôi có thể sửa các thông số cũng như các thuộc tính trong size guild, hãy sửa sizeguild để tối ưu cho 7 dòng và 4 cột
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-info-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    font-family: 'Oswald', sans-serif !important;
  }

  .ai-product-info-item-{{ ai_gen_id }} {
    border-bottom: 1px solid {{ block.settings.border_color }};
    padding: {{ block.settings.item_padding }}px 0;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: opacity 0.2s ease;
  }

  .ai-product-info-item-{{ ai_gen_id }}:hover {
    opacity: 0.7;
  }

  .ai-product-info-item-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    color: {{ block.settings.text_color }};
    font-weight: 500;
  }

  .ai-product-info-item-arrow-{{ ai_gen_id }} {
    color: {{ block.settings.arrow_color }};
    font-size: 20px;
    transition: transform 0.2s ease;
  }

  .ai-product-info-modal-overlay-{{ ai_gen_id }} {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.5);
    z-index: 9998;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }

  .ai-product-info-modal-overlay-{{ ai_gen_id }}.active {
    opacity: 1;
    visibility: visible;
  }

  .ai-product-info-modal-{{ ai_gen_id }} {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0.9);
    background-color: {{ block.settings.modal_bg_color }};
    border-radius: {{ block.settings.modal_border_radius }}px;
    max-width: {{ block.settings.modal_max_width }}px;
    width: 90%;
    max-height: 80vh;
    z-index: 9999;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease, transform 0.3s ease;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
  }

  .ai-product-info-modal-{{ ai_gen_id }}.active {
    opacity: 1;
    visibility: visible;
    transform: translate(-50%, -50%) scale(1);
  }

  .ai-product-info-modal-header-{{ ai_gen_id }} {
    padding: 24px;
    border-bottom: 1px solid {{ block.settings.border_color }};
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .ai-product-info-modal-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.modal_title_font_size }}px;
    color: {{ block.settings.text_color }};
    font-weight: 600;
    margin: 0;
  }

  .ai-product-info-modal-close-{{ ai_gen_id }} {
    background: none;
    border: none;
    font-size: 28px;
    color: {{ block.settings.text_color }};
    cursor: pointer;
    padding: 0;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.2s ease;
  }

  .ai-product-info-modal-close-{{ ai_gen_id }}:hover {
    opacity: 0.7;
  }

  .ai-product-info-modal-body-{{ ai_gen_id }} {
    padding: 24px;
    overflow-y: auto;
    max-height: calc(80vh - 100px);
  }

  .ai-product-info-size-table-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: collapse;
    margin-top: 16px;
  }

  .ai-product-info-size-table-{{ ai_gen_id }} th,
  .ai-product-info-size-table-{{ ai_gen_id }} td {
    padding: 12px;
    text-align: left;
    border-bottom: 1px solid {{ block.settings.table_border_color }};
    color: {{ block.settings.text_color }};
  }

  .ai-product-info-size-table-{{ ai_gen_id }} th {
    font-weight: 600;
    background-color: {{ block.settings.table_header_bg }};
    font-size: {{ block.settings.table_font_size }}px;
  }

  .ai-product-info-size-table-{{ ai_gen_id }} td {
    font-size: {{ block.settings.table_font_size }}px;
  }

  .ai-product-info-size-table-{{ ai_gen_id }} tr:last-child td {
    border-bottom: none;
  }

  .ai-product-info-shipping-content-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    line-height: 1.6;
  }

  .ai-product-info-shipping-content-{{ ai_gen_id }} h3 {
    font-size: {{ block.settings.shipping_heading_size }}px;
    margin: 20px 0 12px;
    font-weight: 600;
  }

  .ai-product-info-shipping-content-{{ ai_gen_id }} h4 {
    font-size: {{ block.settings.shipping_subheading_size }}px;
    margin: 16px 0 8px;
    font-weight: 600;
  }

  .ai-product-info-shipping-content-{{ ai_gen_id }} p {
    margin: 8px 0;
    font-size: {{ block.settings.shipping_text_size }}px;
  }

  .ai-product-info-shipping-content-{{ ai_gen_id }} ul {
    margin: 8px 0;
    padding-left: 20px;
  }

  .ai-product-info-shipping-content-{{ ai_gen_id }} li {
    margin: 4px 0;
    font-size: {{ block.settings.shipping_text_size }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-product-info-modal-{{ ai_gen_id }} {
      max-width: 95%;
    }

    .ai-product-info-size-table-{{ ai_gen_id }} {
      font-size: 12px;
    }

    .ai-product-info-size-table-{{ ai_gen_id }} th,
    .ai-product-info-size-table-{{ ai_gen_id }} td {
      padding: 8px 4px;
    }
  }
{% endstyle %}

