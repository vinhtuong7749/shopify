<script>
  (function() {
    class ProductInfoAccordion{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.items = this.querySelectorAll('.ai-product-info-item-{{ ai_gen_id }}');
        this.overlay = this.querySelector('[data-overlay]');
        this.modals = this.querySelectorAll('[data-modal-content]');
        this.closeButtons = this.querySelectorAll('.ai-product-info-modal-close-{{ ai_gen_id }}');

        this.setupEventListeners();
      }

      setupEventListeners() {
        this.items.forEach((item) => {
          item.addEventListener('click', () => {
            const modalType = item.getAttribute('data-modal');
            this.openModal(modalType);
          });
        });

        this.closeButtons.forEach((button) => {
          button.addEventListener('click', () => {
            this.closeAllModals();
          });
        });

        this.overlay.addEventListener('click', () => {
          this.closeAllModals();
        });

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') {
            this.closeAllModals();
          }
        });
      }

      openModal(type) {
        const modal = this.querySelector(`[data-modal-content="${type}"]`);
        if (modal) {
          this.overlay.classList.add('active');
          modal.classList.add('active');
          document.body.style.overflow = 'hidden';
        }
      }

      closeAllModals() {
        this.overlay.classList.remove('active');
        this.modals.forEach((modal) => {
          modal.classList.remove('active');
        });
        document.body.style.overflow = '';
      }
    }

    customElements.define('product-info-accordion-{{ ai_gen_id }}', ProductInfoAccordion{{ ai_gen_id }});
  })();
</script>

