{% doc %}
  @prompt
    Hãy thêm cho tôi section Banner có thể up ảnh cho desktop và mobile
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-banner-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    display: block;
  }

  .ai-banner-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-banner-image-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.desktop_height }}px;
  }

  .ai-banner-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-banner-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-banner-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-banner-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-banner-mobile-{{ ai_gen_id }} {
    display: none;
  }

  .ai-banner-content-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    color: {{ block.settings.text_color }};
    width: 90%;
    max-width: 800px;
    z-index: 2;
  }

  .ai-banner-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 16px;
    font-weight: 700;
  }

  .ai-banner-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    margin: 0 0 24px;
  }

  .ai-banner-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 32px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    transition: all 0.3s ease;
  }

  .ai-banner-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_background_hover }};
    color: {{ block.settings.button_text_color_hover }};
  }

  .ai-banner-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};
    z-index: 1;
  }

  @media screen and (max-width: 749px) {
    .ai-banner-desktop-{{ ai_gen_id }} {
      display: none;
    }

    .ai-banner-mobile-{{ ai_gen_id }} {
      display: block;
    }

    .ai-banner-image-container-{{ ai_gen_id }} {
      height: {{ block.settings.mobile_height }}px;
    }

    .ai-banner-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.6 }}px;
      margin: 0 0 12px;
    }

    .ai-banner-subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.7 }}px;
      margin: 0 0 16px;
    }

    .ai-banner-button-{{ ai_gen_id }} {
      padding: 10px 24px;
      font-size: {{ block.settings.button_font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-banner-wrapper-{{ ai_gen_id }}">
    <div class="ai-banner-image-container-{{ ai_gen_id }}">
      <div class="ai-banner-desktop-{{ ai_gen_id }}">
        {% if block.settings.desktop_image %}
          <img
            src="{{ block.settings.desktop_image | image_url: width: 2000 }}"
            alt="{{ block.settings.desktop_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.desktop_image.width }}"
            height="{{ block.settings.desktop_image.height }}"
            class="ai-banner-image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-banner-image-placeholder-{{ ai_gen_id }}">
            {{ 'hero-apparel-1' | placeholder_svg_tag }}
            <div class="ai-banner-empty-state-{{ ai_gen_id }}">
              Thêm ảnh desktop cho banner
            </div>
          </div>
        {% endif %}
      </div>

      <div class="ai-banner-mobile-{{ ai_gen_id }}">
        {% if block.settings.mobile_image %}
          <img
            src="{{ block.settings.mobile_image | image_url: width: 1000 }}"
            alt="{{ block.settings.mobile_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.mobile_image.width }}"
            height="{{ block.settings.mobile_image.height }}"
            class="ai-banner-image-{{ ai_gen_id }}"
          >
        {% elsif block.settings.desktop_image %}
          <img
            src="{{ block.settings.desktop_image | image_url: width: 1000 }}"
            alt="{{ block.settings.desktop_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.desktop_image.width }}"
            height="{{ block.settings.desktop_image.height }}"
            class="ai-banner-image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-banner-image-placeholder-{{ ai_gen_id }}">
            {{ 'hero-apparel-1' | placeholder_svg_tag }}
            <div class="ai-banner-empty-state-{{ ai_gen_id }}">
              Thêm ảnh mobile cho banner
            </div>
          </div>
        {% endif %}
      </div>

      {% if block.settings.show_overlay %}
        <div class="ai-banner-overlay-{{ ai_gen_id }}"></div>
      {% endif %}

      {% if block.settings.show_content %}
        <div class="ai-banner-content-{{ ai_gen_id }}">
          {% if block.settings.heading != blank %}
            <h2 class="ai-banner-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
          {% endif %}

          {% if block.settings.subheading != blank %}
            <p class="ai-banner-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
          {% endif %}

          {% if block.settings.button_text != blank and block.settings.button_link != blank %}
            <a href="{{ block.settings.button_link }}" class="ai-banner-button-{{ ai_gen_id }}">
              {{ block.settings.button_text }}
            </a>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Banner",
  "settings": [
    {
      "type": "header",
      "content": "Ảnh desktop"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Ảnh desktop"
    },
    {
      "type": "range",
      "id": "desktop_height",
      "min": 200,
      "max": 800,
      "step": 50,
      "unit": "px",
      "label": "Chiều cao desktop",
      "default": 500
    },
    {
      "type": "header",
      "content": "Ảnh mobile"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Ảnh mobile"
    },
    {
      "type": "range",
      "id": "mobile_height",
      "min": 200,
      "max": 600,
      "step": 50,
      "unit": "px",
      "label": "Chiều cao mobile",
      "default": 400
    },
    {
      "type": "header",
      "content": "Nội dung"
    },
    {
      "type": "checkbox",
      "id": "show_content",
      "label": "Hiển thị nội dung",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Tiêu đề",
      "default": "Chào mừng đến với cửa hàng"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Kích thước tiêu đề",
      "default": 48
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Tiêu đề phụ",
      "default": "Khám phá bộ sưu tập mới nhất của chúng tôi"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "label": "Kích thước tiêu đề phụ",
      "default": 18
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Màu chữ",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Nút bấm"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Văn bản nút",
      "default": "Mua ngay"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Liên kết nút"
    },
    {
      "type": "range",
      "id": "button_font_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Kích thước chữ nút",
      "default": 16
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Màu nền nút",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Màu chữ nút",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_background_hover",
      "label": "Màu nền nút khi hover",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "button_text_color_hover",
      "label": "Màu chữ nút khi hover",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Bo góc nút",
      "default": 4
    },
    {
      "type": "header",
      "content": "Lớp phủ"
    },
    {
      "type": "checkbox",
      "id": "show_overlay",
      "label": "Hiển thị lớp phủ",
      "default": true
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Màu lớp phủ",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "Độ mờ lớp phủ",
      "default": 30
    },
    {
      "type": "header",
      "content": "Cài đặt"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Chiều rộng desktop",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Bo góc banner",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Banner"
    }
  ]
}
{% endschema %}
